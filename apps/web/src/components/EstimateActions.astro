---
interface Props {
  defineOnly?: boolean;
}

const { defineOnly = false } = Astro.props;
---

{defineOnly && (
  <script is:inline>
    (() => {
      function escapeHtml(value = '') {
        return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
      }

      function money(value) {
        return window.PaintFlowFormat?.money(value) || new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
      }

      function netPaid(payments = []) {
        return payments.reduce((sum, payment) => {
          const status = String(payment.status || '');
          if (!['succeeded', 'paid', 'partially_refunded', 'refunded'].includes(status)) return sum;
          return sum + Number(payment.amount || 0) - Number(payment.refundedAmount || 0);
        }, 0);
      }

      function estimateContractTotal(estimate = {}) {
        const packages = Array.isArray(estimate.packages) ? estimate.packages : [];
        const selected = packages.find((pkg) => /better|recommended/i.test(String(pkg?.name || ''))) || packages[0];
        return Number(selected?.total ?? estimate.total ?? 0);
      }

      function estimateBalance(estimate = {}) {
        return Math.max(estimateContractTotal(estimate) - netPaid(Array.isArray(estimate.payments) ? estimate.payments : []), 0);
      }

      function estimateActions({
        estimate = {},
        previewHref = '',
        editHref = '',
        className = '',
        cancelLabel = 'Cancel',
      } = {}) {
        const status = String(estimate.status || '').toLowerCase();
        const estimateId = String(estimate.id || '');
        const canCancel = ['draft', 'sent', 'declined'].includes(status) && !estimate.signedAt;
        const canEdit = status === 'draft' || (status === 'sent' && !estimate.signedAt);
        const isSignedAgreement = Boolean(estimate.signedAt) || status === 'accepted';
        const canReviseAgreement = isSignedAgreement && status === 'accepted';
        const canVoidAgreement = isSignedAgreement && status === 'accepted';
        const isInactiveAgreement = ['voided', 'superseded'].includes(status);
        const balance = estimateBalance(estimate);
        const canRecordPayment = estimateId && !['draft', 'canceled', 'voided', 'superseded'].includes(status) && balance > 0.005;
        const actions = [];

        if (isInactiveAgreement) {
          actions.push({ priority: true, html: `<a href="/estimates/${escapeHtml(estimateId)}/details" class="btn-text btn-sm justify-center">View details</a>` });
        }

        if (canEdit) {
          actions.push({ priority: true, html: `<a href="${escapeHtml(editHref || `/estimates/production?estimateId=${estimateId}`)}" class="btn-text btn-sm justify-center">${status === 'sent' ? 'Edit sent' : 'Edit draft'}</a>` });
        }

        if (status !== 'draft') {
          actions.push({ priority: !canEdit, html: `<a href="${escapeHtml(previewHref || `/estimates/${estimateId}`)}" class="btn-text btn-sm justify-center">Preview link</a>` });
        }

        if (canCancel) {
          actions.push({ destructive: true, html: `<button type="button" class="btn-text btn-sm text-red-700 justify-center" data-cancel-estimate="${escapeHtml(estimateId)}">${escapeHtml(cancelLabel)}</button>` });
        }

        if (canRecordPayment) {
          actions.push({ html: `<button type="button" class="btn-text btn-sm justify-center" data-record-estimate-payment="${escapeHtml(estimateId)}" data-estimate-total="${escapeHtml(String(Number(estimate.total || 0)))}">Record payment</button>` });
        }

        if (canReviseAgreement) {
          actions.push({ html: `<button type="button" class="btn-text btn-sm justify-center" data-revise-estimate="${escapeHtml(estimateId)}">Create revision</button>` });
        }

        if (canVoidAgreement) {
          actions.push({ destructive: true, html: `<button type="button" class="btn-text btn-sm text-red-700 justify-center" data-void-estimate="${escapeHtml(estimateId)}">Void agreement</button>` });
        }

        const primary = actions.find((action) => action.priority) || actions[0];
        const overflow = actions
          .filter((action) => action !== primary)
          .sort((a, b) => Number(Boolean(a.destructive)) - Number(Boolean(b.destructive)));
        const overflowId = `estimate-actions-${escapeHtml(estimateId || crypto.randomUUID())}`;
        return `
          <div class="estimate-actions flex items-center gap-1 ${escapeHtml(className)}" data-estimate-actions>
            ${primary?.html || ''}
            ${overflow.length ? `
              <button type="button" class="btn-icon btn-icon-tonal pf-estimate-menu-button" aria-label="More estimate actions" aria-expanded="false" data-estimate-actions-trigger="${overflowId}">
                <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
                  <circle cx="5" cy="12" r="1.8"></circle>
                  <circle cx="12" cy="12" r="1.8"></circle>
                  <circle cx="19" cy="12" r="1.8"></circle>
                </svg>
              </button>
              <template id="${overflowId}">${overflow.map((action) => action.html).join('')}</template>
            ` : ''}
          </div>
        `;
      }

      function closeEstimateActionsMenu() {
        document.querySelectorAll('[data-estimate-actions-trigger][aria-expanded="true"]').forEach((button) => {
          button.setAttribute('aria-expanded', 'false');
        });
        document.getElementById('estimate-actions-menu')?.remove();
      }

      function openEstimateActionsMenu(button) {
        const template = document.getElementById(button.dataset.estimateActionsTrigger);
        if (!template) return;
        const wasOpen = button.getAttribute('aria-expanded') === 'true';
        closeEstimateActionsMenu();
        if (wasOpen) return;
        button.setAttribute('aria-expanded', 'true');
        const menu = document.createElement('div');
        menu.id = 'estimate-actions-menu';
        menu.className = 'fixed z-[80] min-w-44 rounded-lg border bg-white p-1 shadow-lg';
        menu.innerHTML = `<div class="grid gap-1">${template.innerHTML}</div>`;
        document.body.appendChild(menu);
        menu.querySelectorAll('a, button').forEach((item) => {
          item.classList.add('w-full', 'justify-start');
        });
        const rect = button.getBoundingClientRect();
        const menuRect = menu.getBoundingClientRect();
        const left = Math.min(Math.max(8, rect.right - menuRect.width), window.innerWidth - menuRect.width - 8);
        const top = Math.min(rect.bottom + 6, window.innerHeight - menuRect.height - 8);
        menu.style.left = `${left}px`;
        menu.style.top = `${top}px`;
      }

      function ensureAgreementActionModal() {
        let modal = document.getElementById('agreement-action-modal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.id = 'agreement-action-modal';
        modal.className = 'mobile-sheet hidden fixed inset-0 z-50 bg-black/50 flex items-end sm:items-center justify-center p-0 sm:p-4';
        modal.innerHTML = `
          <div class="bg-white rounded-t-lg sm:rounded-lg p-5 sm:p-6 w-full max-w-lg max-h-[92vh] overflow-y-auto">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 id="agreement-action-title" class="text-lg font-semibold text-gray-950"></h3>
                <p id="agreement-action-copy" class="mt-1 text-sm text-gray-600"></p>
              </div>
              <button type="button" class="btn-icon" data-close-agreement-action aria-label="Close">&times;</button>
            </div>
            <form id="agreement-action-form" class="mt-4 space-y-4">
              <input type="hidden" name="estimateId">
              <input type="hidden" name="action">
              <label class="block text-sm font-medium text-gray-700">Reason
                <textarea name="reason" rows="3" maxlength="500" required class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Customer requested a different scope, job postponed, agreement rescinded..."></textarea>
              </label>
              <div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-950">
                Signed agreements remain in the customer record for audit history. Use revisions for changed scope; use void only when the agreement should not proceed.
              </div>
              <div class="flex justify-end gap-2">
                <button type="button" class="btn-secondary btn-sm" data-close-agreement-action>Cancel</button>
                <button id="save-agreement-action" type="submit" class="btn-primary btn-sm">Continue</button>
              </div>
            </form>
          </div>
        `;
        document.body.appendChild(modal);
        modal.addEventListener('click', (event) => {
          if (event.target.closest('[data-close-agreement-action]') || event.target === modal) closeAgreementActionModal();
        });
        modal.querySelector('#agreement-action-form').addEventListener('submit', submitAgreementAction);
        return modal;
      }

      function closeAgreementActionModal() {
        document.getElementById('agreement-action-modal')?.classList.add('hidden');
      }

      function openAgreementActionModal(action, estimateId) {
        const modal = ensureAgreementActionModal();
        const form = modal.querySelector('#agreement-action-form');
        form.reset();
        form.elements.estimateId.value = estimateId;
        form.elements.action.value = action;
        const isRevision = action === 'revise';
        modal.querySelector('#agreement-action-title').textContent = isRevision ? 'Create revised agreement' : 'Void signed agreement';
        modal.querySelector('#agreement-action-copy').textContent = isRevision
          ? 'This creates a new draft estimate from the signed agreement and marks the signed agreement as superseded.'
          : 'This marks the signed agreement as voided while preserving the signed copy and payment history.';
        modal.querySelector('#save-agreement-action').textContent = isRevision ? 'Create revision' : 'Void agreement';
        modal.classList.remove('hidden');
        form.elements.reason.focus();
      }

      async function submitAgreementAction(event) {
        event.preventDefault();
        const form = event.currentTarget;
        const action = form.elements.action.value;
        const estimateId = form.elements.estimateId.value;
        const button = form.querySelector('#save-agreement-action');
        button.disabled = true;
        try {
          const { data } = await apiJson(`/v1/estimates/${estimateId}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({ reason: form.elements.reason.value }),
          });
          closeAgreementActionModal();
          if (action === 'revise') {
            window.showToast?.('Revision draft created', 'success');
            window.location.href = data?.editUrl || `/estimates/production?estimateId=${data?.id}`;
            return;
          }
          window.showToast?.('Agreement voided', 'success');
          window.dispatchEvent(new CustomEvent('paintflow:estimate-updated', { detail: { estimateId } }));
        } catch (err) {
          window.showToast?.(err.message || 'Agreement action failed', 'error');
        } finally {
          button.disabled = false;
        }
      }

      function apiBaseUrl() {
        return window.__PAINTFLOW_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
      }

      async function apiJson(path, options = {}) {
        const res = await fetch(`${apiBaseUrl()}${path}`, { credentials: 'include', ...options });
        if (res.status === 401) {
          window.location.href = '/login';
          throw new Error('Unauthorized');
        }
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          const message = typeof payload.error === 'string'
            ? payload.error
            : payload.error?.message || payload.message || 'Request failed';
          throw new Error(message);
        }
        return payload;
      }

      function ensureManualPaymentModal() {
        let modal = document.getElementById('manual-payment-modal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.id = 'manual-payment-modal';
        modal.className = 'mobile-sheet hidden fixed inset-0 z-50 bg-black/50 flex items-end sm:items-center justify-center p-0 sm:p-4';
        modal.innerHTML = `
          <div class="bg-white rounded-t-lg sm:rounded-lg p-5 sm:p-6 w-full max-w-lg max-h-[92vh] overflow-y-auto">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-gray-950">Record manual payment</h3>
                <p id="manual-payment-summary" class="mt-1 text-sm text-gray-600"></p>
              </div>
              <button type="button" class="btn-icon" data-close-manual-payment aria-label="Close payment form">&times;</button>
            </div>
            <form id="manual-payment-form" class="mt-4 space-y-4">
              <input type="hidden" name="estimateId">
              <div class="rounded-lg border border-amber-200 bg-amber-50 p-3 text-sm text-amber-950">
                This records money received outside Stripe. It will reduce the remaining balance, but it does not charge the customer.
              </div>
              <label id="manual-payment-confirm-wrap" class="hidden rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-950">
                <span class="flex items-start gap-3">
                  <input name="confirmAdditionalPayment" type="checkbox" class="mt-1 rounded border-red-300">
                  <span>This estimate already has a payment recorded. I confirm this is an additional payment and not a duplicate entry.</span>
                </span>
              </label>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label class="block text-sm font-medium text-gray-700">Payment type
                  <select name="source" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
                    <option value="check">Check</option>
                    <option value="cash">Cash</option>
                    <option value="ach">ACH / bank transfer</option>
                    <option value="other">Other</option>
                  </select>
                </label>
                <label class="block text-sm font-medium text-gray-700">Amount
                  <input name="amount" type="number" min="0.01" step="0.01" inputmode="decimal" required class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
                </label>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label class="block text-sm font-medium text-gray-700">Received date
                  <input name="receivedAt" type="date" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
                </label>
                <label class="block text-sm font-medium text-gray-700">Check / reference #
                  <input name="reference" maxlength="120" autocomplete="off" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Optional">
                </label>
              </div>
              <label class="block text-sm font-medium text-gray-700">Description
                <input name="description" maxlength="255" autocomplete="off" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Deposit, progress payment, final payment">
              </label>
              <div class="flex justify-end gap-2">
                <button type="button" class="btn-secondary btn-sm" data-close-manual-payment>Cancel</button>
                <button id="save-manual-payment" type="submit" class="btn-primary btn-sm">Record payment</button>
              </div>
            </form>
          </div>
        `;
        document.body.appendChild(modal);
        modal.addEventListener('click', (event) => {
          if (event.target.closest('[data-close-manual-payment]') || event.target === modal) closeManualPaymentModal();
        });
        modal.querySelector('#manual-payment-form').addEventListener('submit', submitManualPayment);
        return modal;
      }

      function closeManualPaymentModal() {
        document.getElementById('manual-payment-modal')?.classList.add('hidden');
      }

      async function openManualPaymentModal(estimateId) {
        const modal = ensureManualPaymentModal();
        const form = modal.querySelector('#manual-payment-form');
        const summary = modal.querySelector('#manual-payment-summary');
        form.reset();
        form.elements.estimateId.value = estimateId;
        form.elements.receivedAt.value = new Date().toISOString().slice(0, 10);
        summary.textContent = 'Loading balance...';
        modal.classList.remove('hidden');
        form.elements.amount.disabled = true;
        try {
          const { data } = await apiJson(`/v1/estimates/${estimateId}`);
          const payments = Array.isArray(data.payments) ? data.payments : [];
          const paid = netPaid(payments);
          const balance = Math.max(estimateContractTotal(data) - paid, 0);
          form.dataset.remaining = String(balance);
          form.dataset.hasRecordedPayment = paid > 0.005 ? 'true' : 'false';
          form.elements.amount.max = balance.toFixed(2);
          form.elements.amount.value = balance > 0 ? balance.toFixed(2) : '';
          summary.textContent = `${money(paid)} recorded · ${money(balance)} remaining`;
          modal.querySelector('#manual-payment-confirm-wrap')?.classList.toggle('hidden', paid <= 0.005);
          if (balance <= 0.005) {
            summary.textContent = 'This estimate is already paid in full.';
            form.elements.amount.value = '';
          }
        } catch (err) {
          summary.textContent = err.message || 'Unable to load payment balance.';
        } finally {
          form.elements.amount.disabled = false;
          form.elements.amount.focus();
        }
      }

      async function submitManualPayment(event) {
        event.preventDefault();
        const form = event.currentTarget;
        const button = form.querySelector('#save-manual-payment');
        const amount = Number(form.elements.amount.value);
        const remaining = Number(form.dataset.remaining || 0);
        if (!Number.isFinite(amount) || amount <= 0) {
          window.showToast?.('Enter a positive payment amount.', 'error');
          return;
        }
        if (amount > remaining + 0.005) {
          window.showToast?.(`Payment cannot exceed the remaining balance of ${money(remaining)}.`, 'error');
          return;
        }
        const hasRecordedPayment = form.dataset.hasRecordedPayment === 'true';
        if (hasRecordedPayment && !form.elements.confirmAdditionalPayment.checked) {
          window.showToast?.('Confirm this is not a duplicate payment before saving.', 'error');
          form.elements.confirmAdditionalPayment.focus();
          return;
        }
        button.disabled = true;
        try {
          const receivedAt = form.elements.receivedAt.value
            ? new Date(`${form.elements.receivedAt.value}T12:00:00`).toISOString()
            : null;
          await apiJson('/v1/payments/manual', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({
              estimateId: form.elements.estimateId.value,
              amount,
              source: form.elements.source.value,
              reference: form.elements.reference.value || null,
              description: form.elements.description.value || null,
              receivedAt,
              confirmAdditionalPayment: hasRecordedPayment && form.elements.confirmAdditionalPayment.checked,
            }),
          });
          closeManualPaymentModal();
          window.showToast?.('Payment recorded', 'success');
          window.dispatchEvent(new CustomEvent('paintflow:payment-recorded', { detail: { estimateId: form.elements.estimateId.value } }));
        } catch (err) {
          window.showToast?.(err.message || 'Failed to record payment', 'error');
        } finally {
          button.disabled = false;
        }
      }

      document.addEventListener('click', (event) => {
        const menuButton = event.target.closest('[data-estimate-actions-trigger]');
        if (menuButton) {
          event.preventDefault();
          event.stopPropagation();
          openEstimateActionsMenu(menuButton);
          return;
        }

        const menu = document.getElementById('estimate-actions-menu');
        if (menu && !menu.contains(event.target)) {
          closeEstimateActionsMenu();
        }
      });

      document.addEventListener('click', (event) => {
        const button = event.target.closest('[data-record-estimate-payment]');
        if (!button) return;
        closeEstimateActionsMenu();
        openManualPaymentModal(button.dataset.recordEstimatePayment);
      });

      document.addEventListener('click', (event) => {
        const reviseButton = event.target.closest('[data-revise-estimate]');
        if (reviseButton) {
          closeEstimateActionsMenu();
          openAgreementActionModal('revise', reviseButton.dataset.reviseEstimate);
          return;
        }
        const voidButton = event.target.closest('[data-void-estimate]');
        if (voidButton) {
          closeEstimateActionsMenu();
          openAgreementActionModal('void', voidButton.dataset.voidEstimate);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeEstimateActionsMenu();
      });

      window.PaintFlowUI = window.PaintFlowUI || {};
      window.PaintFlowUI.estimateActions = estimateActions;
      window.PaintFlowUI.openManualPaymentModal = openManualPaymentModal;
    })();
  </script>
)}
