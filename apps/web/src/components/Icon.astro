---
interface Props {
  name: 'bell' | 'chevron-left' | 'chevron-right' | 'close' | 'edit' | 'menu' | 'plus' | 'trash';
  class?: string;
}

const { name, class: className = 'pf-icon' } = Astro.props;

const icons = {
  bell: '<path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 0 1-6 0m6 0H9" />',
  'chevron-left': '<path d="m15 18-6-6 6-6" />',
  'chevron-right': '<path d="m9 18 6-6-6-6" />',
  close: '<path d="M18 6 6 18M6 6l12 12" />',
  edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
  menu: '<path d="M4 6h16M4 12h16M4 18h16" />',
  plus: '<path d="M12 5v14M5 12h14" />',
  trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
};
---

<svg
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="2"
  viewBox="0 0 24 24"
  aria-hidden="true"
  set:html={icons[name]}
/>
