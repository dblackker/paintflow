---
const { icon = '📭', title, description, actionText, actionHref } = Astro.props;
---
<div class="text-center py-12 px-4">
  <div class="text-6xl mb-4">{icon}</div>
  <h3 class="text-lg font-semibold text-gray-900 mb-2">{title}</h3>
  <p class="text-gray-600 mb-6 max-w-sm mx-auto">{description}</p>
  {actionText && actionHref && (
    <a href={actionHref} class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 touch-feedback">
      {actionText}
    </a>
  )}
</div>
