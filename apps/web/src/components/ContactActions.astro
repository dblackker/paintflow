---
import Icon from './Icon.astro';

interface Props {
  phone?: string | null;
  email?: string | null;
  leadId?: string | null;
  defineOnly?: boolean;
  class?: string;
}

const {
  phone = '',
  email = '',
  leadId = '',
  defineOnly = false,
  class: className = '',
} = Astro.props;

const sanitizedPhone = phone ? String(phone).replace(/[^+\d]/g, '') : '';
---

{!defineOnly && (
  <div class={`contact-action-group ${className}`.trim()} aria-label="Contact actions">
    {sanitizedPhone ? (
      <a class="btn-icon btn-icon-outlined" href={`tel:${sanitizedPhone}`} aria-label="Call customer" title="Call">
        <Icon name="phone" />
      </a>
    ) : (
      <span class="btn-icon btn-icon-outlined contact-action-disabled" aria-label="Call unavailable" title="No phone number">
        <Icon name="phone" />
      </span>
    )}
    {sanitizedPhone && leadId ? (
      <a class="btn-icon btn-icon-outlined" href={`/sms?leadId=${leadId}`} aria-label="Text customer" title="Text">
        <Icon name="message" />
      </a>
    ) : (
      <span class="btn-icon btn-icon-outlined contact-action-disabled" aria-label="Text unavailable" title="No textable number">
        <Icon name="message" />
      </span>
    )}
    {email ? (
      <a class="btn-icon btn-icon-outlined" href={`mailto:${email}`} aria-label="Email customer" title="Email">
        <Icon name="mail" />
      </a>
    ) : (
      <span class="btn-icon btn-icon-outlined contact-action-disabled" aria-label="Email unavailable" title="No email address">
        <Icon name="mail" />
      </span>
    )}
  </div>
)}

<script is:inline>
  (() => {
    const escapeHtml = (value = '') => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[char]));

    const icons = {
      phone: '<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.7 2.6a2 2 0 0 1-.5 2.1L8.1 9.6a16 16 0 0 0 6.3 6.3l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.6 2.6.7a2 2 0 0 1 1.7 2Z" />',
      message: '<path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4Z" />',
      mail: '<rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" />',
    };

    const svg = (name) => `
      <svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        ${icons[name] || ''}
      </svg>
    `;

    const action = ({ href, icon, label, disabledTitle }) => {
      if (!href) {
        return `<span class="btn-icon btn-icon-outlined contact-action-disabled" aria-label="${escapeHtml(label)} unavailable" title="${escapeHtml(disabledTitle)}">${svg(icon)}</span>`;
      }
      return `<a class="btn-icon btn-icon-outlined" href="${escapeHtml(href)}" aria-label="${escapeHtml(label)}" title="${escapeHtml(label)}">${svg(icon)}</a>`;
    };

    window.CrewmodoUI = window.CrewmodoUI || {};
    window.CrewmodoUI.contactActions = ({ phone = '', email = '', leadId = '', className = '' } = {}) => {
      const rawPhone = String(phone || '').trim();
      const phoneHref = rawPhone ? `tel:${rawPhone.replace(/[^+\d]/g, '')}` : '';
      const smsHref = rawPhone && leadId ? `/sms?leadId=${encodeURIComponent(leadId)}` : '';
      const emailHref = email ? `mailto:${String(email).trim()}` : '';
      return `
        <div class="contact-action-group ${escapeHtml(className)}" aria-label="Contact actions">
          ${action({ href: phoneHref, icon: 'phone', label: 'Call customer', disabledTitle: 'No phone number' })}
          ${action({ href: smsHref, icon: 'message', label: 'Text customer', disabledTitle: 'No textable number' })}
          ${action({ href: emailHref, icon: 'mail', label: 'Email customer', disabledTitle: 'No email address' })}
        </div>
      `;
    };
  })();
</script>
