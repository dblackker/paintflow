---
import Toast from '../components/Toast.astro';
import '../styles/design-system.css';

interface Props {
  title?: string;
}

const { title = 'PaintFlow' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <script is:inline>
    window.PaintFlowFormat = {
      money(value, options = {}) {
        const amount = Number(value || 0);
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: options.cents === false ? 0 : 2,
          maximumFractionDigits: options.cents === false ? 0 : 2,
        }).format(amount);
      },
      number(value, options = {}) {
        return new Intl.NumberFormat('en-US', options).format(Number(value || 0));
      },
      phone(value) {
        const raw = String(value || '').trim();
        const digits = raw.replace(/\D/g, '');
        const ten = digits.length === 11 && digits.startsWith('1') ? digits.slice(1) : digits;
        if (ten.length === 10) return `(${ten.slice(0, 3)}) ${ten.slice(3, 6)}-${ten.slice(6)}`;
        return raw;
      },
      label(value) {
        const text = String(value || '').trim();
        if (!text) return '';
        const known = {
          sqft: 'sq ft',
          sq_ft: 'sq ft',
          linear_ft: 'linear ft',
          brush_roll: 'Brush & roll',
          spray_backroll: 'Spray & back-roll',
          spray_only: 'Spray only',
          estimate_sent: 'Estimate sent',
          in_progress: 'In progress',
          past_due: 'Past due',
        };
        const key = text.toLowerCase();
        if (known[key]) return known[key];
        return text
          .replace(/[_-]+/g, ' ')
          .replace(/\s+/g, ' ')
          .replace(/\b\w/g, (char) => char.toUpperCase())
          .replace(/\b(And|Or|Of|The)\b/g, (word) => word.toLowerCase());
      },
    };
  </script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="pf-app-nav shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <div class="flex items-center space-x-8">
          <a href="/dashboard" class="flex items-center gap-3">
            <span class="pf-brand-mark">P</span>
            <span class="text-xl font-semibold text-gray-950">PaintFlow</span>
          </a>
          <div class="hidden md:flex space-x-4">
            <a href="/dashboard" class="pf-nav-link text-sm">Dashboard</a>
            <a href="/leads" class="pf-nav-link text-sm">Leads</a>
            <a href="/estimates" class="pf-nav-link text-sm">Estimates</a>
            <a href="/jobs" class="pf-nav-link text-sm">Jobs</a>
            <a href="/reports" class="pf-nav-link text-sm">Reports</a>
            <a href="/team" class="pf-nav-link text-sm">Team</a>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative">
            <button id="notifications-button" type="button" class="btn-icon relative" aria-label="Open notifications" aria-expanded="false">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 0 1-6 0m6 0H9"></path>
              </svg>
              <span id="notifications-badge" class="hidden absolute -right-1 -top-1 min-w-5 rounded-full bg-red-600 px-1.5 py-0.5 text-center text-[11px] font-bold leading-none text-white"></span>
            </button>
            <div id="notifications-menu" class="hidden absolute right-0 mt-2 w-[min(92vw,380px)] overflow-hidden rounded-lg border bg-white shadow-lg">
              <div class="flex items-center justify-between gap-3 border-b p-3">
                <div>
                  <p class="font-semibold text-gray-950">Notifications</p>
                  <p class="text-xs text-gray-500">Messages and customer events</p>
                </div>
                <a href="/notifications" class="text-sm font-medium text-blue-700">View all</a>
              </div>
              <div id="notifications-preview" class="max-h-96 overflow-y-auto">
                <div class="p-4 text-sm text-gray-500">Loading...</div>
              </div>
              <div class="border-t p-2">
                <button id="notifications-enable" type="button" class="w-full rounded-md px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Enable browser alerts</button>
              </div>
            </div>
          </div>
          <button type="button" data-logout class="pf-logout-button hidden md:inline-flex">Log out</button>
          <button id="mobile-menu" class="pf-mobile-menu-button md:hidden" aria-label="Open navigation" aria-expanded="false">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
    <div id="mobile-nav" class="pf-mobile-nav hidden md:hidden border-t">
      <div class="px-4 py-2 space-y-1">
        <a href="/dashboard" class="block py-2 text-sm">Dashboard</a>
        <a href="/leads" class="block py-2 text-sm">Leads</a>
        <a href="/estimates" class="block py-2 text-sm">Estimates</a>
        <a href="/jobs" class="block py-2 text-sm">Jobs</a>
        <a href="/reports" class="block py-2 text-sm">Reports</a>
        <a href="/team" class="block py-2 text-sm">Team</a>
        <a href="/notifications" class="block py-2 text-sm">Notifications</a>
        <button type="button" data-logout class="pf-mobile-logout-button">Log out</button>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <Toast />
  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const notificationState = {
      items: [],
      lastSeenKey: 'paintflow.lastSeenNotificationId',
      auditReadKey: 'paintflow.readAuditNotifications',
      browserKey: 'paintflow.browserNotifications',
    };

    function escapeNotificationHtml(value = '') {
      return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }

    function readAuditNotifications() {
      try {
        return new Set(JSON.parse(localStorage.getItem(notificationState.auditReadKey) || '[]'));
      } catch {
        return new Set();
      }
    }

    function notificationTime(value) {
      return value ? new Date(value).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '';
    }

    function applyLocalNotificationReadState(items) {
      const auditRead = readAuditNotifications();
      return items.map((item) => item.source === 'audit' && auditRead.has(item.id) ? { ...item, read: true } : item);
    }

    function renderNotificationsPreview() {
      const preview = document.getElementById('notifications-preview');
      const badge = document.getElementById('notifications-badge');
      if (!preview || !badge) return;

      const unread = notificationState.items.filter((item) => !item.read).length;
      badge.textContent = unread > 99 ? '99+' : String(unread);
      badge.classList.toggle('hidden', unread === 0);

      const items = notificationState.items.slice(0, 6);
      if (!items.length) {
        preview.innerHTML = '<div class="p-4 text-sm text-gray-500">No notifications yet.</div>';
        return;
      }

      preview.innerHTML = items.map((item) => `
        <a href="${escapeNotificationHtml(item.href || '/notifications')}" class="block border-b p-3 last:border-b-0 hover:bg-gray-50 ${item.read ? '' : 'bg-blue-50'}">
          <div class="flex items-start gap-2">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full ${item.read ? 'bg-gray-300' : 'bg-blue-600'}"></span>
            <span class="min-w-0">
              <span class="block truncate text-sm font-medium text-gray-950">${escapeNotificationHtml(item.title)}</span>
              <span class="mt-0.5 block truncate text-xs text-gray-600">${escapeNotificationHtml(item.body)}</span>
              <span class="mt-1 block text-xs text-gray-500">${notificationTime(item.createdAt)}</span>
            </span>
          </div>
        </a>
      `).join('');
    }

    async function loadNotificationsForNav({ notify = false } = {}) {
      try {
        const response = await fetch(`${API_URL}/v1/notifications`, { credentials: 'include' });
        if (!response.ok) return;
        const payload = await response.json();
        const incoming = applyLocalNotificationReadState(payload.data || []);
        const previousTopId = localStorage.getItem(notificationState.lastSeenKey);
        const newestUnread = incoming.find((item) => !item.read);
        notificationState.items = incoming;
        renderNotificationsPreview();

        if (newestUnread && previousTopId && newestUnread.id !== previousTopId) {
          window.showToast?.(newestUnread.title, 'info');
          if (notify && localStorage.getItem(notificationState.browserKey) === 'enabled' && 'Notification' in window && Notification.permission === 'granted') {
            const registration = 'serviceWorker' in navigator ? await navigator.serviceWorker.ready.catch(() => null) : null;
            if (registration?.showNotification) {
              registration.showNotification(newestUnread.title, {
                body: newestUnread.body,
                tag: newestUnread.id,
                data: { url: newestUnread.href || '/notifications' },
              });
            } else {
              new Notification(newestUnread.title, {
                body: newestUnread.body,
                tag: newestUnread.id,
              });
            }
          }
        }
        if (incoming[0]?.id) {
          localStorage.setItem(notificationState.lastSeenKey, incoming[0].id);
        }
      } catch (error) {
        console.warn('Notifications unavailable', error);
      }
    }

    async function enableBrowserNotifications() {
      if (!('Notification' in window)) {
        window.showToast?.('This browser does not support notifications', 'error');
        return;
      }
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        localStorage.setItem(notificationState.browserKey, 'disabled');
        window.showToast?.('Browser alerts not enabled', 'error');
        return;
      }
      const subscribed = await subscribeToPush();
      localStorage.setItem(notificationState.browserKey, subscribed ? 'enabled' : 'disabled');
      window.showToast?.(subscribed ? 'Browser alerts enabled' : 'Push is not configured yet', subscribed ? 'success' : 'error');
    }

    function urlBase64ToUint8Array(value) {
      const padding = '='.repeat((4 - value.length % 4) % 4);
      const base64 = (value + padding).replace(/-/g, '+').replace(/_/g, '/');
      const rawData = atob(base64);
      return Uint8Array.from([...rawData].map((char) => char.charCodeAt(0)));
    }

    async function subscribeToPush() {
      if (!('serviceWorker' in navigator) || !('PushManager' in window)) return false;
      const keyResponse = await fetch(`${API_URL}/v1/push/vapid-public-key`, { credentials: 'include' });
      if (!keyResponse.ok) return false;
      const keyPayload = await keyResponse.json();
      const publicKey = keyPayload?.data?.publicKey;
      if (!publicKey) return false;
      const registration = await navigator.serviceWorker.ready;
      const subscription = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(publicKey),
      });
      const saveResponse = await fetch(`${API_URL}/v1/push/subscriptions`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
        body: JSON.stringify(subscription.toJSON()),
      });
      return saveResponse.ok;
    }

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch((error) => console.warn('Service worker registration failed', error));
    }

    document.getElementById('mobile-menu')?.addEventListener('click', () => {
      document.getElementById('mobile-nav')?.classList.toggle('hidden');
      const button = document.getElementById('mobile-menu');
      button?.setAttribute('aria-expanded', String(document.getElementById('mobile-nav') && !document.getElementById('mobile-nav')?.classList.contains('hidden')));
    });

    document.getElementById('notifications-button')?.addEventListener('click', () => {
      const menu = document.getElementById('notifications-menu');
      const button = document.getElementById('notifications-button');
      menu?.classList.toggle('hidden');
      button?.setAttribute('aria-expanded', String(menu && !menu.classList.contains('hidden')));
    });

    document.addEventListener('click', (event) => {
      const menu = document.getElementById('notifications-menu');
      const button = document.getElementById('notifications-button');
      if (!menu || !button || menu.classList.contains('hidden')) return;
      if (menu.contains(event.target) || button.contains(event.target)) return;
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
    });

    document.getElementById('notifications-enable')?.addEventListener('click', enableBrowserNotifications);

    document.querySelectorAll('[data-logout]').forEach((button) => {
      button.addEventListener('click', async () => {
        button.disabled = true;
        button.textContent = 'Logging out...';

        try {
          const response = await fetch(`${API_URL}/v1/auth/logout`, {
            method: 'POST',
            credentials: 'include',
          });

          if (!response.ok) throw new Error('Logout failed');
          window.location.href = '/login';
        } catch (error) {
          button.disabled = false;
          button.textContent = 'Log out';
          window.showToast?.('Could not log out. Check that the API server is running.', 'error');
        }
      });
    });

    loadNotificationsForNav();
    setInterval(() => loadNotificationsForNav({ notify: true }), 30000);
  </script>
</body>
</html>
