---
import Toast from '../components/Toast.astro';
import ContactSummary from '../components/ContactSummary.astro';
import ContactActions from '../components/ContactActions.astro';
import StatusBadge from '../components/StatusBadge.astro';
import EstimateActions from '../components/EstimateActions.astro';
import Icon from '../components/Icon.astro';
import AuthBridge from '../components/AuthBridge.astro';
import '../styles/design-system.css';

interface Props {
  title?: string;
}

const { title = 'PaintFlow' } = Astro.props;
const shellTitle = title.replace(/\s+-\s+PaintFlow$/i, '');

const navSections = [
  {
    label: 'Sales',
    links: [
      { href: '/leads', label: 'Leads' },
      { href: '/pipeline', label: 'Pipeline' },
      { href: '/estimates', label: 'Estimates' },
    ],
  },
  {
    label: 'Operations',
    links: [
      { href: '/jobs', label: 'Jobs' },
      { href: '/calendar', label: 'Calendar' },
      { href: '/time', label: 'Time Tracking' },
    ],
  },
  {
    label: 'Admin',
    links: [
      { href: '/reports', label: 'Reports' },
      { href: '/activity', label: 'Activity' },
      { href: '/team', label: 'Team' },
      { href: '/email-templates', label: 'Email Templates' },
      { href: '/settings', label: 'Settings' },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <script is:inline>
    if (window.location.hostname === '127.0.0.1' && Number(window.location.port || 0) >= 4321 && Number(window.location.port || 0) <= 4399) {
      const url = new URL(window.location.href);
      url.hostname = 'localhost';
      window.location.replace(url.toString());
    }
  </script>
  <AuthBridge />
  <script is:inline>
    window.PaintFlowFormat = {
      money(value, options = {}) {
        const amount = Number(value || 0);
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: options.cents === false ? 0 : 2,
          maximumFractionDigits: options.cents === false ? 0 : 2,
        }).format(amount);
      },
      number(value, options = {}) {
        return new Intl.NumberFormat('en-US', options).format(Number(value || 0));
      },
      phone(value) {
        const raw = String(value || '').trim();
        const digits = raw.replace(/\D/g, '');
        const ten = digits.length === 11 && digits.startsWith('1') ? digits.slice(1) : digits;
        if (ten.length === 10) return `(${ten.slice(0, 3)}) ${ten.slice(3, 6)}-${ten.slice(6)}`;
        return raw;
      },
      address(record = {}, prefix = '') {
        const street = record[`${prefix}StreetAddress`] ?? record.streetAddress ?? record.street;
        const city = record[`${prefix}City`] ?? record.city;
        const state = record[`${prefix}State`] ?? record.state;
        const postalCode = record[`${prefix}PostalCode`] ?? record.postalCode;
        return [street, [city, state].filter(Boolean).join(', '), postalCode].filter(Boolean).join(' ');
      },
      mapsUrl(address) {
        return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address || '')}`;
      },
      addressLink(address, options = {}) {
        const text = String(address || '').trim();
        if (!text) return options.emptyText || 'No jobsite address';
        const escaped = text.replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
        const classes = options.className || 'block truncate text-sm text-gray-700 hover:text-blue-700 hover:underline';
        return `<a class="${classes}" href="${this.mapsUrl(text)}" target="_blank" rel="noreferrer">${escaped}</a>`;
      },
      label(value) {
        const text = String(value || '').trim();
        if (!text) return '';
        const known = {
          sqft: 'sq ft',
          sq_ft: 'sq ft',
          linear_ft: 'linear ft',
          brush_roll: 'Brush & roll',
          spray_backroll: 'Spray & back-roll',
          spray_only: 'Spray only',
          estimate_sent: 'Estimate sent',
          in_progress: 'In progress',
          past_due: 'Past due',
        };
        const key = text.toLowerCase();
        if (known[key]) return known[key];
        return text
          .replace(/[_-]+/g, ' ')
          .replace(/\s+/g, ' ')
          .replace(/\b\w/g, (char) => char.toUpperCase())
          .replace(/\b(And|Or|Of|The)\b/g, (word) => word.toLowerCase());
      },
    };
  </script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="pf-app-nav shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid h-16 grid-cols-[auto_minmax(0,1fr)_auto] items-center gap-3">
        <div class="flex items-center">
          <button id="mobile-menu" type="button" class="pf-mobile-menu-button" aria-label="Open navigation" aria-controls="mobile-nav" aria-expanded="false" data-owner-nav>
            <Icon name="menu" />
          </button>
        </div>
        <div class="min-w-0">
          <p id="app-bar-title" class="truncate text-lg font-semibold text-gray-950 sm:text-xl">{shellTitle}</p>
        </div>
        <div class="flex items-center gap-2">
          <div class="relative" data-owner-nav>
            <button id="notifications-button" type="button" class="btn-icon pf-notification-button relative" aria-label="Open notifications" aria-expanded="false">
              <Icon name="bell" />
              <span id="notifications-badge" class="hidden pf-notification-badge"></span>
            </button>
            <div id="notifications-menu" class="pf-notifications-menu hidden absolute right-0 mt-2 w-[min(92vw,380px)] overflow-hidden rounded-lg border bg-white shadow-lg">
              <div class="flex items-center justify-between gap-3 border-b p-3">
                <div>
                  <p class="font-semibold text-gray-950">Notifications</p>
                  <p class="text-xs text-gray-500">Messages and customer events</p>
                </div>
                <a href="/notifications" class="text-sm font-medium text-blue-700">View all</a>
              </div>
              <div id="notifications-preview" class="max-h-96 overflow-y-auto">
                <div class="p-4 text-sm text-gray-500">Loading...</div>
              </div>
              <div class="border-t p-2">
                <button id="notifications-enable" type="button" class="btn-secondary btn-sm w-full justify-center">Enable browser alerts</button>
              </div>
            </div>
          </div>
          <button type="button" data-logout class="pf-logout-button hidden lg:inline-flex">Log out</button>
          <a href="/dashboard" class="pf-app-brand-link" aria-label="PaintFlow dashboard">
            <span class="pf-brand-mark">P</span>
          </a>
        </div>
      </div>
    </div>
    <div id="mobile-nav-scrim" class="pf-mobile-nav-scrim hidden" data-owner-nav></div>
    <div id="mobile-nav" class="pf-mobile-nav hidden border-r" data-owner-nav>
      <div class="flex items-center justify-between gap-3 border-b px-4 py-4">
        <a href="/dashboard" class="flex items-center gap-3">
          <span class="pf-brand-mark">P</span>
          <span class="text-lg font-semibold text-gray-950">PaintFlow</span>
        </a>
        <button id="mobile-nav-close" type="button" class="btn-icon" aria-label="Close navigation">x</button>
      </div>
      <div class="px-4 py-3 space-y-4">
        <a href="/dashboard" class="block py-2 text-sm">Dashboard</a>
        {navSections.map((section) => (
          <section class="pf-mobile-nav-section">
            <p>{section.label}</p>
            <div class="grid grid-cols-1 gap-1">
              {section.links.map((link) => (
                <a href={link.href} class="block py-2 text-sm">{link.label}</a>
              ))}
            </div>
          </section>
        ))}
        <button type="button" data-logout class="pf-mobile-logout-button">Log out</button>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <ContactSummary defineOnly />
  <ContactActions defineOnly />
  <StatusBadge defineOnly />
  <EstimateActions defineOnly />
  <Toast />
  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const notificationState = {
      items: [],
      lastSeenKey: 'paintflow.lastSeenNotificationId',
      notifiedKey: 'paintflow.notifiedNotificationIds',
      auditReadKey: 'paintflow.readAuditNotifications',
      browserKey: 'paintflow.browserNotifications',
    };

    function escapeNotificationHtml(value = '') {
      return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }

    function readAuditNotifications() {
      try {
        return new Set(JSON.parse(localStorage.getItem(notificationState.auditReadKey) || '[]'));
      } catch {
        return new Set();
      }
    }

    function readNotifiedNotifications() {
      try {
        return new Set(JSON.parse(localStorage.getItem(notificationState.notifiedKey) || '[]'));
      } catch {
        return new Set();
      }
    }

    function rememberNotifiedNotifications(items) {
      const notified = readNotifiedNotifications();
      items.forEach((item) => notified.add(item.id));
      const recent = Array.from(notified).slice(-250);
      localStorage.setItem(notificationState.notifiedKey, JSON.stringify(recent));
    }

    async function applyCrewShellScope() {
      try {
        const response = await fetch(`${API_URL}/v1/team/punch/status`, { credentials: 'include' });
        if (!response.ok) return;
        const payload = await response.json();
        const isCrewOnly = Boolean(payload?.data?.member && !payload?.data?.canManage);
        document.body.classList.toggle('pf-crew-mode', isCrewOnly);
        if (!isCrewOnly) return;

        document.querySelectorAll('a[href="/dashboard"]').forEach((link) => link.setAttribute('href', '/time'));
        const path = window.location.pathname;
        const allowed = path === '/time' || path === '/login' || path.startsWith('/assets/');
        if (!allowed) window.location.replace('/time');
      } catch {
        // Navigation scope should never block the page from loading.
      }
    }

    function notificationTime(value) {
      return value ? new Date(value).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '';
    }

    function applyLocalNotificationReadState(items) {
      const auditRead = readAuditNotifications();
      return items.map((item) => item.source === 'audit' && auditRead.has(item.id) ? { ...item, read: true } : item);
    }

    function renderNotificationsPreview() {
      const preview = document.getElementById('notifications-preview');
      const badge = document.getElementById('notifications-badge');
      if (!preview || !badge) return;

      const unread = notificationState.items.filter((item) => !item.read).length;
      badge.textContent = unread > 99 ? '99+' : String(unread);
      badge.classList.toggle('hidden', unread === 0);

      const items = notificationState.items.slice(0, 6);
      if (!items.length) {
        preview.innerHTML = '<div class="p-4 text-sm text-gray-500">No notifications yet.</div>';
        return;
      }

      preview.innerHTML = items.map((item) => `
        <a href="${escapeNotificationHtml(item.href || '/notifications')}" class="block border-b p-3 last:border-b-0 hover:bg-gray-50 ${item.read ? '' : 'bg-blue-50'}">
          <div class="flex items-start gap-2">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full ${item.read ? 'bg-gray-300' : 'bg-blue-600'}"></span>
            <span class="min-w-0">
              <span class="block truncate text-sm font-medium text-gray-950">${escapeNotificationHtml(item.title)}</span>
              <span class="mt-0.5 block truncate text-xs text-gray-600">${escapeNotificationHtml(item.body)}</span>
              <span class="mt-1 block text-xs text-gray-500">${notificationTime(item.createdAt)}</span>
            </span>
          </div>
        </a>
      `).join('');
    }

    async function loadNotificationsForNav({ notify = false } = {}) {
      try {
        const response = await fetch(`${API_URL}/v1/notifications`, { credentials: 'include' });
        if (!response.ok) return;
        const payload = await response.json();
        const incoming = applyLocalNotificationReadState(payload.data || []);
        const previousTopId = localStorage.getItem(notificationState.lastSeenKey);
        const existingNotified = localStorage.getItem(notificationState.notifiedKey);
        const notified = readNotifiedNotifications();
        const unreadItems = incoming.filter((item) => !item.read);
        const newestUnread = unreadItems.find((item) => !notified.has(item.id));
        notificationState.items = incoming;
        renderNotificationsPreview();

        if (newestUnread && previousTopId && existingNotified) {
          window.showToast?.(newestUnread.title, 'info');
          if (notify && localStorage.getItem(notificationState.browserKey) === 'enabled' && 'Notification' in window && Notification.permission === 'granted') {
            const registration = 'serviceWorker' in navigator ? await navigator.serviceWorker.ready.catch(() => null) : null;
            if (registration?.showNotification) {
              registration.showNotification(newestUnread.title, {
                body: newestUnread.body,
                tag: newestUnread.id,
                data: { url: newestUnread.href || '/notifications' },
              });
            } else {
              new Notification(newestUnread.title, {
                body: newestUnread.body,
                tag: newestUnread.id,
              });
            }
          }
        }
        rememberNotifiedNotifications(unreadItems);
        if (incoming[0]?.id) {
          localStorage.setItem(notificationState.lastSeenKey, incoming[0].id);
        }
      } catch (error) {
        console.warn('Notifications unavailable', error);
      }
    }

    async function enableBrowserNotifications() {
      if (!('Notification' in window)) {
        window.showToast?.('This browser does not support notifications', 'error');
        return;
      }
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        localStorage.setItem(notificationState.browserKey, 'disabled');
        window.showToast?.('Browser alerts not enabled', 'error');
        return;
      }
      const subscribed = await subscribeToPush();
      localStorage.setItem(notificationState.browserKey, subscribed ? 'enabled' : 'disabled');
      window.showToast?.(subscribed ? 'Browser alerts enabled' : 'Push is not configured yet', subscribed ? 'success' : 'error');
    }

    function urlBase64ToUint8Array(value) {
      const padding = '='.repeat((4 - value.length % 4) % 4);
      const base64 = (value + padding).replace(/-/g, '+').replace(/_/g, '/');
      const rawData = atob(base64);
      return Uint8Array.from([...rawData].map((char) => char.charCodeAt(0)));
    }

    async function subscribeToPush() {
      if (!('serviceWorker' in navigator) || !('PushManager' in window)) return false;
      const keyResponse = await fetch(`${API_URL}/v1/push/vapid-public-key`, { credentials: 'include' });
      if (!keyResponse.ok) return false;
      const keyPayload = await keyResponse.json();
      const publicKey = keyPayload?.data?.publicKey;
      if (!publicKey) return false;
      const registration = await navigator.serviceWorker.ready;
      const subscription = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(publicKey),
      });
      const saveResponse = await fetch(`${API_URL}/v1/push/subscriptions`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
        body: JSON.stringify(subscription.toJSON()),
      });
      return saveResponse.ok;
    }

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch((error) => console.warn('Service worker registration failed', error));
    }

    document.querySelectorAll('.pf-nav-group').forEach((group) => {
      group.addEventListener('toggle', () => {
        if (!group.open) return;
        document.querySelectorAll('.pf-nav-group[open]').forEach((other) => {
          if (other !== group) other.removeAttribute('open');
        });
      });
    });

    function setMobileNavOpen(open) {
      const nav = document.getElementById('mobile-nav');
      const scrim = document.getElementById('mobile-nav-scrim');
      const button = document.getElementById('mobile-menu');
      if (!nav || !button) return;
      nav.classList.toggle('hidden', !open);
      nav.classList.toggle('is-open', open);
      scrim?.classList.toggle('hidden', !open);
      scrim?.classList.toggle('is-open', open);
      button.setAttribute('aria-expanded', String(open));
      document.body.classList.toggle('pf-nav-drawer-open', open);
    }

    function toggleMobileNav(event) {
      event?.preventDefault?.();
      const nav = document.getElementById('mobile-nav');
      const isOpen = Boolean(nav && !nav.classList.contains('hidden'));
      setMobileNavOpen(!isOpen);
      if (!isOpen) {
        const notificationMenu = document.getElementById('notifications-menu');
        const notificationButton = document.getElementById('notifications-button');
        notificationMenu?.classList.add('hidden');
        notificationButton?.setAttribute('aria-expanded', 'false');
      }
    }

    function hideDuplicatePageTitle() {
      const shellTitle = document.getElementById('app-bar-title')?.textContent?.trim().toLowerCase();
      if (!shellTitle) return;
      const heading = document.querySelector('main h1, main h2');
      if (!heading || heading.closest('[data-keep-page-title]')) return;
      const headingText = heading.textContent?.trim().toLowerCase();
      if (headingText === shellTitle) {
        heading.classList.add('sr-only');
        heading.setAttribute('data-shell-title-hidden', 'true');
      }
    }

    document.addEventListener('click', (event) => {
      const menuButton = event.target?.closest?.('#mobile-menu');
      if (menuButton) {
        toggleMobileNav(event);
        return;
      }

      const navGroup = event.target?.closest?.('.pf-nav-group');
      if (!navGroup) {
        document.querySelectorAll('.pf-nav-group[open]').forEach((group) => group.removeAttribute('open'));
      }

      const nav = document.getElementById('mobile-nav');
      const scrim = event.target?.closest?.('#mobile-nav-scrim');
      if (scrim) {
        setMobileNavOpen(false);
        return;
      }
      if (!nav || nav.classList.contains('hidden')) return;
      if (nav.contains(event.target)) return;
      setMobileNavOpen(false);
    });

    document.getElementById('mobile-nav-close')?.addEventListener('click', () => setMobileNavOpen(false));
    hideDuplicatePageTitle();

    document.getElementById('notifications-button')?.addEventListener('click', () => {
      const menu = document.getElementById('notifications-menu');
      const button = document.getElementById('notifications-button');
      menu?.classList.toggle('hidden');
      button?.setAttribute('aria-expanded', String(menu && !menu.classList.contains('hidden')));
    });

    document.addEventListener('click', (event) => {
      const menu = document.getElementById('notifications-menu');
      const button = document.getElementById('notifications-button');
      if (!menu || !button || menu.classList.contains('hidden')) return;
      if (menu.contains(event.target) || button.contains(event.target)) return;
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
    });

    document.getElementById('notifications-enable')?.addEventListener('click', enableBrowserNotifications);

    document.querySelectorAll('[data-logout]').forEach((button) => {
      button.addEventListener('click', async () => {
        button.disabled = true;
        button.textContent = 'Logging out...';

        try {
          const response = await fetch(`${API_URL}/v1/auth/logout`, {
            method: 'POST',
            credentials: 'include',
          });

          if (!response.ok) throw new Error('Logout failed');
          window.PaintFlowAuth?.clearSessionFallback?.();
          window.location.href = '/login';
        } catch (error) {
          button.disabled = false;
          button.textContent = 'Log out';
          window.showToast?.('Could not log out. Check that the API server is running.', 'error');
        }
      });
    });

    applyCrewShellScope().then(() => {
      if (!document.body.classList.contains('pf-crew-mode')) {
        loadNotificationsForNav();
        setInterval(() => loadNotificationsForNav({ notify: true }), 30000);
      }
    });
  </script>
</body>
</html>
