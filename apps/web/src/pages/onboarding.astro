---
import Base from '../layouts/Base.astro';
---

<Base title="Onboarding">
  <div class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-sm border p-8 w-full max-w-2xl">
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h1 class="text-2xl font-bold">Welcome to PaintFlow</h1>
          <span class="text-sm text-gray-600" id="step-counter">Step 1 of 5</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full transition-all" id="progress-bar" style="width: 20%"></div>
        </div>
      </div>

      <div id="step-content">
        <!-- Step content injected by JS -->
      </div>

      <div class="flex justify-between mt-8">
        <button id="prev-btn" class="px-4 py-2 text-gray-600 hover:text-gray-900 hidden">Back</button>
        <button id="next-btn" class="ml-auto px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Next</button>
      </div>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
    let currentStep = 1;
    const totalSteps = 5;
    let formData = {};

    const steps = [
      {
        title: 'Business Basics',
        fields: [
          { name: 'companyName', label: 'Company Name', type: 'text', required: true },
          { name: 'phone', label: 'Phone Number', type: 'tel', required: true },
          { name: 'email', label: 'Email', type: 'email', required: true },
          { name: 'address', label: 'Business Address', type: 'text', required: true },
        ]
      },
      {
        title: 'Pricing & Tax',
        fields: [
          { name: 'defaultLaborRate', label: 'Default Labor Rate ($/hour)', type: 'number', value: '65' },
          { name: 'materialMarkupPercent', label: 'Material Markup (%)', type: 'number', value: '30' },
          { name: 'salesTaxRate', label: 'Sales Tax Rate (%)', type: 'number', value: '9.2', step: '0.1' },
          { name: 'depositPercent', label: 'Deposit Required (%)', type: 'number', value: '50' },
        ]
      },
      {
        title: 'Service Areas',
        custom: true,
      },
      {
        title: 'Connect Your Tools',
        custom: true,
      },
      {
        title: 'You\'re All Set!',
        custom: true,
      }
    ];

    function renderStep() {
      document.getElementById('step-counter').textContent = `Step ${currentStep} of ${totalSteps}`;
      document.getElementById('progress-bar').style.width = `${(currentStep / totalSteps) * 100}%`;
      document.getElementById('prev-btn').classList.toggle('hidden', currentStep === 1);

      const step = steps[currentStep - 1];
      const content = document.getElementById('step-content');

      if (step.custom) {
        content.innerHTML = renderCustomStep(currentStep);
      } else {
        content.innerHTML = `
          <h2 class="text-xl font-semibold mb-6">${step.title}</h2>
          <div class="space-y-4">
            ${step.fields.map(f => `
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">${f.label}${f.required ? ' *' : ''}</label>
                <input type="${f.type}" name="${f.name}" value="${formData[f.name] || f.value || ''}" step="${f.step || ''}" required="${f.required || false}"
                  class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
              </div>
            `).join('')}
          </div>
        `;
      }
    }

    function renderCustomStep(step) {
      if (step === 3) {
        return `
          <h2 class="text-xl font-semibold mb-2">Where do you work?</h2>
          <p class="text-gray-600 mb-6">Enter ZIP codes you serve (comma separated)</p>
          <input type="text" id="zip-codes" placeholder="98383, 98366, 98370" class="w-full px-3 py-2 border rounded-lg">
          <p class="text-sm text-gray-500 mt-2">We'll use this to qualify leads</p>
        `;
      }
      if (step === 4) {
        return `
          <h2 class="text-xl font-semibold mb-6">Connect Your Tools</h2>
          <div class="space-y-3">
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div>
                <p class="font-medium">Stripe</p>
                <p class="text-sm text-gray-600">Accept payments</p>
              </div>
              <a href="${API_URL}/v1/auth/stripe/connect" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">Connect</a>
            </div>
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div>
                <p class="font-medium">QuickBooks</p>
                <p class="text-sm text-gray-600">Sync invoices</p>
              </div>
              <a href="${API_URL}/v1/quickbooks/connect" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">Connect</a>
            </div>
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div>
                <p class="font-medium">Google Calendar</p>
                <p class="text-sm text-gray-600">Schedule jobs</p>
              </div>
              <a href="${API_URL}/v1/calendar/connect" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">Connect</a>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-4">You can connect these later in Settings</p>
        `;
      }
      if (step === 5) {
        return `
          <div class="text-center py-8">
            <div class="text-6xl mb-4">🎉</div>
            <h2 class="text-2xl font-bold mb-2">You're all set!</h2>
            <p class="text-gray-600 mb-6">PaintFlow is ready to help you close more painting jobs.</p>
            <a href="/dashboard" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg">Go to Dashboard</a>
          </div>
        `;
      }
    }

    document.getElementById('next-btn').addEventListener('click', async () => {
      // Collect form data
      document.querySelectorAll('input[name]').forEach(input => {
        formData[input.name] = input.value;
      });

      if (currentStep === 3) {
        const zips = document.getElementById('zip-codes')?.value;
        if (zips) {
          await fetch(`${API_URL}/v1/settings/service-areas`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ zipCodes: zips.split(',').map(z => z.trim()) }),
          });
        }
      }

      if (currentStep === 1 || currentStep === 2) {
        await fetch(`${API_URL}/v1/settings/org`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(formData),
        });
      }

      if (currentStep < totalSteps) {
        currentStep++;
        if (currentStep === totalSteps) {
          document.getElementById('next-btn').classList.add('hidden');
        }
        renderStep();
      }
    });

    document.getElementById('prev-btn').addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        document.getElementById('next-btn').classList.remove('hidden');
        renderStep();
      }
    });

    renderStep();
  </script>
</Base>
