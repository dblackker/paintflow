---
import Base from '../layouts/Base.astro';

const isWelcome = Astro.url.searchParams.get('welcome') === '1';
---

<Base title="Onboarding">
  <style>
    @media (max-width: 640px) {
      .onboarding-shell {
        padding: 0.75rem;
      }
      .onboarding-card {
        padding: 1rem;
      }
      .onboarding-card h1 {
        font-size: 1.35rem;
      }
      .onboarding-aside {
        display: grid;
        gap: 0.75rem;
      }
      .onboarding-aside > div {
        padding: 0.85rem;
      }
      .onboarding-actions {
        background: var(--pf-surface);
        border-top: 1px solid var(--pf-border);
        bottom: 0;
        margin-inline: -1rem;
        padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom));
        position: sticky;
      }
      .onboarding-actions > div {
        display: grid;
        flex: 1;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .onboarding-actions button {
        justify-content: center;
      }
    }
  </style>
  <div class="onboarding-shell min-h-screen bg-gray-50 p-4 sm:p-6">
    {isWelcome && (
      <div class="max-w-5xl mx-auto mb-4 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-950">
        <p class="font-semibold">Workspace created</p>
        <p class="mt-1">We loaded starter settings for lead intake, estimating, job costing, roles, and follow-up. Review the defaults here before your first estimate.</p>
      </div>
    )}

    <div class="max-w-5xl mx-auto grid lg:grid-cols-[1fr_320px] gap-6">
      <section class="onboarding-card bg-white rounded-lg shadow-sm border p-6 sm:p-8">
        <div class="mb-8">
          <div class="flex items-center justify-between gap-4 mb-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Setup</p>
              <h1 class="text-2xl font-bold">Get PaintFlow ready for your painting business</h1>
            </div>
            <span class="text-sm text-gray-600" id="step-counter">Step 1 of 5</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div class="bg-blue-600 h-2 rounded-full transition-all" id="progress-bar" style="width: 20%"></div>
          </div>
        </div>

        <div id="alert" class="hidden rounded-lg border p-3 mb-5 text-sm"></div>
        <div id="step-content"></div>

        <div class="onboarding-actions flex justify-between mt-8">
          <button id="prev-btn" class="btn-text hidden">Back</button>
          <div class="ml-auto flex gap-3">
            <button id="skip-btn" class="btn-text">Finish later</button>
            <button id="next-btn" class="btn-primary">Save and continue</button>
          </div>
        </div>
      </section>

      <aside class="onboarding-aside space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <p class="text-sm font-semibold text-gray-900 mb-3">Setup checklist</p>
          <div id="checklist" class="space-y-2 text-sm text-gray-700"></div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <p class="text-sm font-semibold text-gray-900">Estimator setup</p>
          <p class="mt-2 text-sm text-gray-600">Keep pricing accurate by entering paint products and production rates before live estimates.</p>
          <div class="mt-4 grid gap-2">
            <a href="/materials" class="btn-secondary btn-sm justify-center">Paint products and costs</a>
            <a href="/production-rates" class="btn-secondary btn-sm justify-center">Production rates</a>
          </div>
        </div>
        <div id="upsell-card" class="hidden bg-blue-50 border border-blue-200 rounded-lg p-5">
          <p class="text-sm font-semibold text-blue-950" id="upsell-title">Keep your trial moving</p>
          <p class="text-sm text-blue-900 mt-2" id="upsell-message"></p>
          <a id="upsell-link" href="/billing" class="btn-primary btn-sm mt-4">Compare plans</a>
        </div>
      </aside>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let currentStep = 1;
    const totalSteps = 5;
    let formData = {};
    let serviceAreas = [];
    let progress = null;

    const steps = [
      { title: 'Business Basics', fields: [
        { name: 'companyName', label: 'Company Name', type: 'text', required: true, autocomplete: 'organization', placeholder: 'Acme Painting Co.' },
        { name: 'phone', label: 'Phone Number', type: 'tel', required: true, autocomplete: 'tel', inputmode: 'numeric', placeholder: '(555) 123-4567', maxlength: '14', pattern: '[0-9() -]{10,14}', format: 'phone' },
        { name: 'email', label: 'Email', type: 'email', required: true, autocomplete: 'email', inputmode: 'email', placeholder: 'owner@example.com' },
        { name: 'address', label: 'Business Address', type: 'text', required: true, autocomplete: 'street-address', placeholder: '123 Main St, Tacoma, WA 98402' },
      ]},
      { title: 'Pricing and Deposit Defaults', fields: [
        { name: 'defaultLaborRate', label: 'Default Labor Rate ($/hour)', type: 'number', value: '65', min: '0', step: '0.01', inputmode: 'decimal', autocomplete: 'off', placeholder: '65.00' },
        { name: 'materialMarkupPercent', label: 'Material Markup (%)', type: 'number', value: '30', min: '0', step: '0.01', inputmode: 'decimal', autocomplete: 'off', placeholder: '30' },
        { name: 'salesTaxRate', label: 'Sales Tax Rate (%)', type: 'number', value: '9.2', min: '0', step: '0.01', inputmode: 'decimal', autocomplete: 'off', placeholder: '9.2' },
        { name: 'depositPercent', label: 'Deposit Required (%)', type: 'number', value: '50', min: '0', max: '100', step: '0.01', inputmode: 'decimal', autocomplete: 'off', placeholder: '50' },
      ]},
      { title: 'Service Areas', custom: true },
      { title: 'Connect Your Tools', custom: true },
      { title: 'Ready to Work', custom: true },
    ];

    function showAlert(message, type = 'error') {
      const alert = document.getElementById('alert');
      alert.textContent = message;
      alert.className = `rounded-lg border p-3 mb-5 text-sm ${type === 'error' ? 'bg-red-50 border-red-200 text-red-800' : 'bg-green-50 border-green-200 text-green-800'}`;
    }

    function clearAlert() {
      const alert = document.getElementById('alert');
      alert.textContent = '';
      alert.className = 'hidden rounded-lg border p-3 mb-5 text-sm';
    }

    async function apiJson(url, options = {}) {
      const res = await fetch(url, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(payload.error || 'Request failed');
      }
      return payload;
    }

    function collectInputs() {
      document.querySelectorAll('input[name]').forEach(input => {
        formData[input.name] = input.value;
      });
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('"', '&quot;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;');
    }

    function fieldAttributes(field) {
      const attrs = {
        type: field.type,
        name: field.name,
        id: field.name,
        value: formData[field.name] ?? field.value ?? '',
        min: field.min,
        max: field.max,
        step: field.step,
        autocomplete: field.autocomplete,
        inputmode: field.inputmode,
        placeholder: field.placeholder,
        maxlength: field.maxlength,
        pattern: field.pattern,
        'data-format': field.format,
        enterkeyhint: field.name === 'address' ? 'done' : 'next',
      };

      return Object.entries(attrs)
        .filter(([, value]) => value !== undefined && value !== null && value !== '')
        .map(([key, value]) => `${key}="${escapeHtml(value)}"`)
        .concat(field.required ? ['required'] : [])
        .join(' ');
    }

    function renderField(field) {
      return `
        <div>
          <label for="${field.name}" class="block text-sm font-medium text-gray-700 mb-1">${field.label}${field.required ? ' *' : ''}</label>
          <input ${fieldAttributes(field)} class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
        </div>
      `;
    }

    function phoneDigits(value) {
      return String(value || '').replace(/\D/g, '').slice(0, 10);
    }

    function formatPhone(value) {
      const digits = phoneDigits(value);
      if (digits.length <= 3) return digits;
      if (digits.length <= 6) return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
      return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
    }

    function attachInputEnhancements() {
      document.querySelectorAll('[data-format="phone"]').forEach((input) => {
        input.value = formatPhone(input.value);
        input.addEventListener('input', () => {
          input.value = formatPhone(input.value);
        });
      });

      const zipInput = document.getElementById('zip-codes');
      if (zipInput) {
        zipInput.addEventListener('input', () => {
          zipInput.value = zipInput.value.replace(/[^\d,\s-]/g, '');
        });
      }
    }

    function renderChecklist() {
      const checklist = document.getElementById('checklist');
      const steps = progress?.steps || [];
      checklist.innerHTML = steps.map(step => `
        <div class="flex items-center gap-2">
          <span class="inline-flex h-5 w-5 items-center justify-center rounded-full text-xs ${step.complete ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">${step.complete ? '&#10003;' : ''}</span>
          <span>${step.label}</span>
        </div>
      `).join('');

      const upsell = document.getElementById('upsell-card');
      if (progress?.shouldShowUpsell) {
        document.getElementById('upsell-title').textContent = progress.upsell.title;
        document.getElementById('upsell-message').textContent = progress.upsell.message;
        document.getElementById('upsell-link').textContent = progress.upsell.cta;
        document.getElementById('upsell-link').href = progress.upsell.href;
        upsell.classList.remove('hidden');
      } else {
        upsell.classList.add('hidden');
      }
    }

    function renderStep() {
      clearAlert();
      document.getElementById('step-counter').textContent = `Step ${currentStep} of ${totalSteps}`;
      document.getElementById('progress-bar').style.width = `${(currentStep / totalSteps) * 100}%`;
      document.getElementById('prev-btn').classList.toggle('hidden', currentStep === 1);
      document.getElementById('skip-btn').classList.toggle('hidden', currentStep === totalSteps);
      document.getElementById('next-btn').textContent = currentStep === totalSteps ? 'Go to dashboard' : 'Save and continue';

      const step = steps[currentStep - 1];
      const content = document.getElementById('step-content');
      if (step.custom) {
        content.innerHTML = renderCustomStep(currentStep);
      } else {
        const setupLinks = currentStep === 2 ? `
          <div class="mt-6 rounded-lg border border-blue-100 bg-blue-50 p-4">
            <p class="font-semibold text-blue-950">Estimator setup</p>
            <p class="mt-1 text-sm text-blue-900">Production rates price labor. Paint products price your material cost, coverage, suppliers, and markup.</p>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <a href="/materials" class="btn-secondary btn-sm justify-center">Add paint products and costs</a>
              <a href="/production-rates" class="btn-secondary btn-sm justify-center">Tune production rates</a>
            </div>
          </div>
        ` : '';
        content.innerHTML = `<h2 class="text-xl font-semibold mb-2">${step.title}</h2><p class="text-gray-600 mb-6">These defaults make estimates, deposits, and job costing usable immediately.</p><div class="space-y-4">${step.fields.map(renderField).join('')}</div>${setupLinks}`;
      }
      attachInputEnhancements();
      renderChecklist();
    }

    function renderCustomStep(step) {
      if (step === 3) {
        return `<h2 class="text-xl font-semibold mb-2">Where do you work?</h2><p class="text-gray-600 mb-6">Enter the ZIP codes your crew serves. This helps qualify leads and keep routing clean.</p><input type="text" id="zip-codes" value="${escapeHtml(serviceAreas.map(area => area.zipCode).join(', '))}" inputmode="numeric" autocomplete="postal-code" enterkeyhint="done" placeholder="98383, 98366, 98370" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500"><p class="text-sm text-gray-500 mt-2">Use commas between ZIP codes.</p>`;
      }
      if (step === 4) {
        return `<h2 class="text-xl font-semibold mb-6">Connect your tools</h2><div class="space-y-3"><div class="flex items-center justify-between p-4 border rounded-lg"><div><p class="font-medium">Stripe Payments</p><p class="text-sm text-gray-600">Create or connect a Stripe account for customer deposits and payouts</p></div><a href="/payments/stripe" class="btn-primary btn-sm">Set up</a></div><div class="flex items-center justify-between p-4 border rounded-lg"><div><p class="font-medium">QuickBooks</p><p class="text-sm text-gray-600">Sync invoices and payments</p></div><a href="${API_URL}/v1/quickbooks/connect" class="btn-primary btn-sm">Connect</a></div><div class="flex items-center justify-between p-4 border rounded-lg"><div><p class="font-medium">Google Calendar</p><p class="text-sm text-gray-600">Schedule jobs and crews</p></div><a href="${API_URL}/v1/calendar/connect" class="btn-primary btn-sm">Connect</a></div></div><p class="text-sm text-gray-500 mt-4">You can connect these later, but payments and accounting are what make the CRM operational instead of just a contact list.</p>`;
      }
      return `<div class="text-center py-8"><div class="text-sm font-semibold uppercase tracking-wide text-blue-600 mb-4">Complete</div><h2 class="text-2xl font-bold mb-2">Your workspace is ready</h2><p class="text-gray-600 mb-6">Start with a lead, build a production estimate, then convert it into a scheduled job with costs tracked from day one.</p><a href="/dashboard" class="btn-primary justify-center">Go to Dashboard</a></div>`;
    }

    async function saveCurrentStep() {
      collectInputs();

      if (currentStep === 1) {
        const required = ['companyName', 'phone', 'email', 'address'];
        const missing = required.filter(name => !String(formData[name] || '').trim());
        if (missing.length) throw new Error('Complete the required business fields before continuing.');
        const normalizedPhone = formatPhone(formData.phone);
        if (phoneDigits(normalizedPhone).length !== 10) {
          throw new Error('Enter a 10-digit phone number before continuing.');
        }
        await apiJson(`${API_URL}/v1/settings/org`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            companyName: formData.companyName,
            phone: normalizedPhone,
            email: formData.email,
            address: formData.address,
          }),
        });
      }

      if (currentStep === 2) {
        await apiJson(`${API_URL}/v1/settings/org`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            defaultLaborRate: formData.defaultLaborRate,
            materialMarkupPercent: formData.materialMarkupPercent,
            salesTaxRate: formData.salesTaxRate,
            depositPercent: formData.depositPercent,
          }),
        });
      }

      if (currentStep === 3) {
        const raw = document.getElementById('zip-codes')?.value || '';
        const zipCodes = raw.split(',').map(zip => zip.trim()).filter(Boolean);
        await apiJson(`${API_URL}/v1/settings/service-areas`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ zipCodes }),
        });
      }

      if (currentStep === 4) {
        await apiJson(`${API_URL}/v1/settings/org`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ onboardingCompletedAt: new Date().toISOString() }),
        });
      }

      await loadOnboardingState();
    }

    async function loadOnboardingState() {
      const { data } = await apiJson(`${API_URL}/v1/settings/onboarding`);
      formData = {
        ...data.settings,
        salesTaxRate: data.settings.salesTaxRate ? (Number(data.settings.salesTaxRate) * 100).toString() : '',
      };
      serviceAreas = data.serviceAreas || [];
      progress = data.progress;
      renderChecklist();
    }

    document.getElementById('next-btn').addEventListener('click', async () => {
      try {
        await saveCurrentStep();
        if (currentStep < totalSteps) {
          currentStep++;
          renderStep();
        } else {
          window.location.href = '/dashboard';
        }
      } catch (err) {
        showAlert(err.message || 'Failed to save setup');
      }
    });

    document.getElementById('skip-btn').addEventListener('click', async () => {
      try {
        await loadOnboardingState();
      } catch (_) {}
      window.location.href = '/dashboard?setup=paused';
    });

    document.getElementById('prev-btn').addEventListener('click', () => {
      if (currentStep > 1) {
        collectInputs();
        currentStep--;
        renderStep();
      }
    });

    loadOnboardingState().then(() => {
      if (progress?.completed) {
        currentStep = totalSteps;
      } else if (progress?.completedSteps) {
        currentStep = Math.min(progress.completedSteps + 1, totalSteps - 1);
      }
      renderStep();
    }).catch((err) => {
      showAlert(err.message || 'Failed to load onboarding');
      renderStep();
    });
  </script>
</Base>
