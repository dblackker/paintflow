---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Settings - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/settings" class="text-blue-600 font-medium">Settings</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Settings</h2>

      <div class="space-y-6">
        <!-- Company Profile -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Company Profile</h3>
          <form id="company-form" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Company Name</label>
                <input name="name" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" value="Your Painting Co" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input name="phone" type="tel" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="(555) 123-4567" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input name="email" type="email" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="hello@paintingco.com" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
              <input name="address" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="123 Main St, City, ST 12345" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
              <input name="website" type="url" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" placeholder="https://paintingco.com" />
            </div>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Company Info</button>
          </form>
        </div>

        <!-- Pricing Defaults -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Pricing Defaults</h3>
          <form id="pricing-form" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Hourly Rate ($)</label>
                <input name="hourlyRate" type="number" step="0.01" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" value="65.00" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Markup %</label>
                <input name="markup" type="number" step="0.1" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" value="20" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Default Deposit %</label>
              <input name="deposit" type="number" step="1" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" value="50" />
              <p class="text-xs text-gray-500 mt-1">Percentage required to start work</p>
            </div>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Pricing</button>
          </form>
        </div>

        <!-- Email Templates -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Email Templates</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Estimate Email Subject</label>
              <input class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" value="Your painting estimate is ready" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Estimate Email Body</label>
              <textarea rows="6" class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">Hi {{customer_name}},

We've prepared a detailed estimate for your painting project.

View your estimate here: {{estimate_url}}

This estimate is valid for 30 days.

Questions? Just reply to this email.

Best regards,
{{company_name}}</textarea>
              <p class="text-xs text-gray-500 mt-1">Use variables: {{customer_name}}, {{estimate_url}}, {{company_name}}</p>
            </div>
            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Templates</button>
          </div>
        </div>

        <!-- Integrations -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Integrations</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-600 rounded flex items-center justify-center text-white font-bold">Q</div>
                <div>
                  <p class="font-medium">QuickBooks Online</p>
                  <p class="text-sm text-gray-600" id="qb-status">Sync customers and invoices</p>
                </div>
              </div>
              <button id="qb-connect-btn" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Connect</button>
            </div>
            
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-red-500 rounded flex items-center justify-center text-white font-bold">G</div>
                <div>
                  <p class="font-medium">Google Calendar</p>
                  <p class="text-sm text-gray-600">Sync jobs to your calendar</p>
                </div>
              </div>
              <button class="px-4 py-2 border rounded-lg hover:bg-gray-50">Connect</button>
            </div>
            
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-purple-600 rounded flex items-center justify-center text-white font-bold">S</div>
                <div>
                  <p class="font-medium">Stripe</p>
                  <p class="text-sm text-gray-600">Accept payments online</p>
                </div>
              </div>
              <button class="px-4 py-2 border rounded-lg hover:bg-gray-50">Connect</button>
            </div>
            
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-500 rounded flex items-center justify-center text-white font-bold">T</div>
                <div>
                  <p class="font-medium">Twilio</p>
                  <p class="text-sm text-gray-600">Send and receive SMS</p>
                </div>
              </div>
              <button class="px-4 py-2 border rounded-lg hover:bg-gray-50">Connect</button>
            </div>
          </div>
        </div>

        <!-- Team Members -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold">Team Members</h3>
            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm">Invite Member</button>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between p-3 border rounded">
              <div>
                <p class="font-medium">You</p>
                <p class="text-sm text-gray-600">owner@paintingco.com</p>
              </div>
              <span class="text-sm px-2 py-1 bg-blue-100 text-blue-800 rounded">Owner</span>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
      
      document.getElementById('company-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Company info saved! (API integration pending)');
      });
      
      document.getElementById('pricing-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Pricing defaults saved! (API integration pending)');
      });
      
      // QuickBooks connection
      async function checkQBStatus() {
        try {
          const res = await fetch(`${API_URL}/v1/quickbooks/status`, { credentials: 'include' });
          const data = await res.json();
          const btn = document.getElementById('qb-connect-btn');
          const status = document.getElementById('qb-status');
          
          if (data.connected) {
            btn.textContent = 'Disconnect';
            btn.onclick = disconnectQB;
            status.textContent = 'Connected to ' + data.companyName;
            status.className = 'text-sm text-green-600';
          } else {
            btn.textContent = 'Connect';
            btn.onclick = () => window.location.href = `${API_URL}/v1/quickbooks/connect`;
          }
        } catch (err) {
          console.error('QB status check failed', err);
        }
      }
      
      async function disconnectQB() {
        if (!confirm('Disconnect QuickBooks?')) return;
        await fetch(`${API_URL}/v1/quickbooks/disconnect`, { method: 'POST', credentials: 'include' });
        checkQBStatus();
      }
      
      checkQBStatus();
    </script>
  </body>
</html>
