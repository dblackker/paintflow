---
import Base from '../layouts/Base.astro';
---

<Base title="Team">
  <div class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/team" class="text-blue-600 font-medium">Team</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex justify-between items-center mb-6">
        <div>
          <h2 class="text-2xl font-bold">Team Members</h2>
          <p class="text-gray-600">Manage roles and permissions</p>
        </div>
        <button id="add-member-btn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">+ Add Member</button>
      </div>

      <div id="members-list" class="space-y-3">
        <div class="p-8 text-center text-gray-500">Loading...</div>
      </div>

      <!-- Add Member Modal -->
      <div id="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-lg p-6 w-full max-w-md">
          <h3 class="text-lg font-semibold mb-4">Add Team Member</h3>
          <form id="add-member-form" class="space-y-4">
            <input name="name" placeholder="Full Name" required class="w-full px-3 py-2 border rounded-lg">
            <input name="email" type="email" placeholder="Email" required class="w-full px-3 py-2 border rounded-lg">
            <select name="role" class="w-full px-3 py-2 border rounded-lg">
              <option value="crew">Crew Member</option>
              <option value="estimator">Estimator</option>
              <option value="admin">Admin</option>
            </select>
            <input name="hourlyRate" type="number" step="0.01" min="0" placeholder="Hourly Rate" class="w-full px-3 py-2 border rounded-lg">
            <div class="flex gap-3 pt-4">
              <button type="button" id="cancel-btn" class="flex-1 px-4 py-2 border rounded-lg">Cancel</button>
              <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg">Add Member</button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';

    async function loadMembers() {
      const res = await fetch(`${API_URL}/v1/settings/team`, { credentials: 'include' });
      const { data } = await res.json();
      const container = document.getElementById('members-list');
      
      if (data.length === 0) {
        container.innerHTML = '<div class="bg-white rounded-lg border p-8 text-center text-gray-500">No team members yet. Add your first crew member!</div>';
        return;
      }

      const roleColors = {
        owner: 'bg-purple-100 text-purple-800',
        admin: 'bg-blue-100 text-blue-800',
        estimator: 'bg-green-100 text-green-800',
        crew: 'bg-gray-100 text-gray-800',
      };

      container.innerHTML = data.map(member => `
        <div class="bg-white rounded-lg border p-4 flex justify-between items-center">
          <div>
            <p class="font-medium">${member.name || 'Unnamed'}</p>
            <p class="text-sm text-gray-600">${member.email}</p>
          </div>
          <div class="flex items-center gap-3">
            ${member.hourlyRate ? `<span class="text-sm text-gray-600">$${member.hourlyRate}/hr</span>` : ''}
            <span class="px-2 py-1 text-xs rounded ${roleColors[member.role] || 'bg-gray-100'}">${member.role}</span>
            <button onclick="removeMember('${member.id}')" class="text-red-600 hover:text-red-700 text-sm">Remove</button>
          </div>
        </div>
      `).join('');
    }

    document.getElementById('add-member-btn').addEventListener('click', () => {
      document.getElementById('modal').classList.remove('hidden');
    });

    document.getElementById('cancel-btn').addEventListener('click', () => {
      document.getElementById('modal').classList.add('hidden');
    });

    document.getElementById('add-member-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = Object.fromEntries(new FormData(e.target));
      
      await fetch(`${API_URL}/v1/settings/team`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(formData),
      });
      
      document.getElementById('modal').classList.add('hidden');
      e.target.reset();
      window.showToast('Team member added', 'success');
      loadMembers();
    });

    window.removeMember = async (id) => {
      if (!confirm('Remove this team member?')) return;
      await fetch(`${API_URL}/v1/settings/team/${id}`, { method: 'DELETE', credentials: 'include' });
      window.showToast('Team member removed', 'success');
      loadMembers();
    };

    loadMembers();
  </script>
</Base>
