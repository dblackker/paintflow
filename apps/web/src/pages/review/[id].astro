---
import '../../styles/design-system.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rate Your Experience - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-sm border p-8 w-full max-w-md text-center">
      <div id="loading" class="py-8">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
        <p class="mt-4 text-gray-600">Loading...</p>
      </div>

      <div id="rating-step" class="hidden">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">How did we do?</h1>
        <p class="text-gray-600 mb-6" id="company-name">We'd love your feedback</p>

        <div class="flex justify-center gap-2 mb-6" id="stars">
          <button data-rating="1" class="text-4xl hover:scale-110 transition">&#9733;</button>
          <button data-rating="2" class="text-4xl hover:scale-110 transition">&#9733;</button>
          <button data-rating="3" class="text-4xl hover:scale-110 transition">&#9733;</button>
          <button data-rating="4" class="text-4xl hover:scale-110 transition">&#9733;</button>
          <button data-rating="5" class="text-4xl hover:scale-110 transition">&#9733;</button>
        </div>

        <p class="text-sm text-gray-500">Tap a star to rate</p>
      </div>

      <div id="thankyou-step" class="hidden">
        <div class="text-sm font-semibold uppercase tracking-wide text-blue-600 mb-4">Thanks</div>
        <h2 class="text-xl font-bold mb-2">Thank you!</h2>
        <p class="text-gray-600 mb-6" id="thankyou-message"></p>
        <a id="review-link" href="#" target="_blank" class="btn-primary justify-center">Leave Review</a>
      </div>

      <div id="feedback-step" class="hidden">
        <h2 class="text-xl font-bold mb-4">We're sorry to hear that</h2>
        <p class="text-gray-600 mb-4">Please tell us what went wrong so we can make it right:</p>
        <textarea id="feedback-text" class="w-full px-3 py-2 border rounded-lg mb-4" rows="4" placeholder="Your feedback..."></textarea>
        <button id="submit-feedback" class="btn-primary w-full justify-center">Submit Feedback</button>
      </div>
    </div>

    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
      const requestId = window.location.pathname.split('/').pop();
      let selectedRating = 0;

      async function init() {
        document.getElementById('loading').classList.add('hidden');
        document.getElementById('rating-step').classList.remove('hidden');
      }

      document.querySelectorAll('#stars button').forEach(btn => {
        btn.addEventListener('click', async () => {
          selectedRating = parseInt(btn.dataset.rating);

          document.querySelectorAll('#stars button').forEach((b, i) => {
            b.style.opacity = i < selectedRating ? '1' : '0.3';
          });

          setTimeout(async () => {
            try {
              await fetch(`${API_URL}/v1/reviews/${requestId}/rate`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating: selectedRating }),
              });
            } catch (err) {
              console.error('Failed to submit rating:', err);
            }

            if (selectedRating >= 4) {
              document.getElementById('rating-step').classList.add('hidden');
              document.getElementById('thankyou-step').classList.remove('hidden');
              document.getElementById('thankyou-message').textContent = "We're thrilled you had a great experience! Would you mind sharing your feedback publicly?";
              document.getElementById('review-link').href = 'https://g.page/r/YOUR_GOOGLE_BUSINESS_ID/review';
            } else {
              document.getElementById('rating-step').classList.add('hidden');
              document.getElementById('feedback-step').classList.remove('hidden');
            }
          }, 300);
        });
      });

      document.getElementById('submit-feedback')?.addEventListener('click', async () => {
        const feedback = document.getElementById('feedback-text').value;

        try {
          await fetch(`${API_URL}/v1/reviews/${requestId}/rate`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rating: selectedRating, feedback }),
          });
        } catch (err) {
          console.error('Failed to submit feedback:', err);
        }

        document.getElementById('feedback-step').innerHTML = `
          <div class="text-sm font-semibold uppercase tracking-wide text-blue-600 mb-4">Done</div>
          <h2 class="text-xl font-bold mb-2">Thank you for your feedback</h2>
          <p class="text-gray-600">We'll reach out soon to make this right.</p>
        `;
      });

      init();
    </script>
  </body>
</html>
