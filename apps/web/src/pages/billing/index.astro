---
import Layout from '../../components/Layout.astro';
---

<Layout title="Billing & Subscription">
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="pf-page-title">Billing & Subscription</h1>
      <p class="pf-page-copy mt-1">Manage your PaintFlow plan</p>
    </div>

    <div id="current-plan" class="bg-white rounded-lg shadow-sm border p-6 mb-8"></div>

    <h2 class="pf-section-title mb-6">Upgrade Your Plan</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="bg-white rounded-lg shadow-sm border p-6">
        <h3 class="pf-section-title">Starter</h3>
        <div class="mt-4 mb-6">
          <span class="pf-page-title">$49</span>
          <span class="pf-copy">/month</span>
        </div>
        <ul class="pf-copy space-y-2 mb-6">
          <li>Up to 3 team members</li>
          <li>100 leads/month</li>
          <li>E-signatures</li>
          <li>Basic reports</li>
        </ul>
        <button onclick="subscribe('starter')" class="btn-primary w-full justify-center">Choose Starter</button>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border-2 border-blue-600 p-6 relative">
        <span class="pf-table-heading absolute top-0 right-0 bg-blue-600 text-white px-3 py-1 rounded-bl-lg">Popular</span>
        <h3 class="pf-section-title">Pro</h3>
        <div class="mt-4 mb-6">
          <span class="pf-page-title">$149</span>
          <span class="pf-copy">/month</span>
        </div>
        <ul class="pf-copy space-y-2 mb-6">
          <li>Unlimited team</li>
          <li>Unlimited leads</li>
          <li>QuickBooks sync</li>
          <li>Advanced reporting</li>
          <li>Priority support</li>
        </ul>
        <button onclick="subscribe('pro')" class="btn-primary w-full justify-center">Choose Pro</button>
      </div>
      
      <div class="bg-white rounded-lg shadow-sm border p-6">
        <h3 class="pf-section-title">Enterprise</h3>
        <div class="mt-4 mb-6">
          <span class="pf-page-title">$399</span>
          <span class="pf-copy">/month</span>
        </div>
        <ul class="pf-copy space-y-2 mb-6">
          <li>Everything in Pro</li>
          <li>White-label</li>
          <li>API access</li>
          <li>Dedicated CSM</li>
        </ul>
        <button onclick="subscribe('enterprise')" class="btn-primary w-full justify-center">Contact Sales</button>
      </div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const money = (value, options = {}) => new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: options.cents === false ? 0 : 2,
      maximumFractionDigits: options.cents === false ? 0 : 2,
    }).format(Number(value || 0));
    const label = (value) => String(value || '').replace(/[_-]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
    
    async function loadSubscription() {
      try {
        const res = await fetch(`${API_URL}/v1/billing/subscription`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById('current-plan');
        
        if (!data) {
          container.innerHTML = '<p class="pf-copy">No active subscription. You are on a 14-day free trial.</p>';
          return;
        }
        
        container.innerHTML = `
          <div class="flex justify-between items-center">
            <div>
              <h3 class="pf-section-title">${data.plan.name}</h3>
              <p class="pf-copy">$${data.plan.price}/month &middot; ${data.status}</p>
              <p class="pf-meta mt-1">Renews ${new Date(data.currentPeriodEnd).toLocaleDateString()}</p>
            </div>
            <button onclick="manageBilling()" class="btn-secondary">Manage Billing</button>
          </div>
        `;
      } catch (err) {
        console.error(err);
      }
    }
    
    window.subscribe = async (plan) => {
      if (plan === 'enterprise') {
        window.location.href = 'mailto:sales@paintflow.app';
        return;
      }
      
      try {
        const res = await fetch(`${API_URL}/v1/billing/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ plan }),
        });
        const { url } = await res.json();
        window.location.href = url;
      } catch (err) {
        alert('Failed to start checkout');
      }
    };
    
    window.manageBilling = async () => {
      const res = await fetch(`${API_URL}/v1/billing/portal`, {
        method: 'POST',
        credentials: 'include',
      });
      const { url } = await res.json();
      window.location.href = url;
    };
    
    loadSubscription();
  </script>
</Layout>
