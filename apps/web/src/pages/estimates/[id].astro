---
import '../../styles/design-system.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Estimate - PaintFlow</title>
    <style>
      @media (max-width: 640px) {
        .proposal-shell {
          padding-inline: 0.75rem;
          padding-top: 0.75rem;
        }
        .proposal-card {
          padding: 1rem;
        }
        .proposal-card h1 {
          font-size: 1.6rem;
        }
        #accept-panel {
          padding: 1rem;
        }
        #accept-buttons {
          display: grid;
          gap: 0.5rem;
        }
        #accept-buttons > * {
          justify-content: center;
          width: 100%;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-50">
    <main class="proposal-shell max-w-5xl mx-auto px-4 py-6 sm:py-10">
      <div id="loading" class="text-center py-12">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
        <p class="mt-4 text-gray-600">Loading estimate...</p>
      </div>

      <section id="estimate-content" class="hidden space-y-5">
        <div class="proposal-card bg-white rounded-lg shadow-sm border p-5 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">
            <div>
              <div id="brand-block" class="mb-5"></div>
              <h1 class="text-3xl font-bold text-gray-900">Painting Proposal</h1>
              <p class="text-gray-600 mt-2">Review the project scope, selected products, and total investment.</p>
            </div>
            <div class="sm:text-right">
              <p class="text-sm text-gray-600">Estimate #</p>
              <p class="font-mono" id="estimate-id"></p>
            </div>
          </div>
          <div id="proposal-container"></div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-5" id="accept-panel">
          <h3 class="font-semibold text-gray-900 mb-2">Ready to proceed?</h3>
          <p class="text-gray-700 mb-4">Approve the proposal to review terms and sign. Any payment due will be shown separately.</p>
          <div id="accept-buttons"></div>
        </div>

        <section id="estimate-photo-panel" class="hidden bg-white rounded-lg shadow-sm border">
          <div class="p-5 border-b">
            <h2 class="font-semibold text-gray-900">Project Photos</h2>
            <p class="text-sm text-gray-600 mt-1">Photos included by your contractor for proposal context.</p>
          </div>
          <div id="estimate-photo-list" class="border-t"></div>
        </section>

        <div class="text-center text-sm text-gray-600">
          <p>Questions? Reply to the estimate email or call your contractor.</p>
        </div>
      </section>

      <section id="error" class="hidden text-center py-12 bg-white rounded-lg border">
        <p class="text-red-600 font-medium">Estimate not found or expired.</p>
      </section>
    </main>

    <div id="terms-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-end sm:items-center justify-center p-0 sm:p-4 z-50">
      <div class="bg-white rounded-t-lg sm:rounded-lg p-5 sm:p-6 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <h3 class="text-xl font-semibold mb-4">Terms and Conditions</h3>
        <div class="text-sm text-gray-700 space-y-4 mb-6">
          <div><h4 class="font-semibold text-gray-900">Scope of Work</h4><p>Contractor agrees to perform painting services described in the selected package using professional practices and quality materials.</p></div>
          <div><h4 class="font-semibold text-gray-900">Payment Terms</h4><p>The payment schedule shown on this proposal controls when deposits, progress payments, and final balances are due.</p></div>
          <div><h4 class="font-semibold text-gray-900">Change Orders</h4><p>Changes to scope must be approved in writing and may affect price and schedule.</p></div>
          <div><h4 class="font-semibold text-gray-900">Warranty</h4><p>Workmanship warranty and material manufacturer warranties apply according to contractor policy and product terms.</p></div>
          <div><h4 class="font-semibold text-gray-900">Access</h4><p>Customer agrees to provide reasonable access to the property and work areas during scheduled business hours.</p></div>
        </div>
        <div class="flex gap-3">
          <button id="decline-terms" class="btn-secondary flex-1 justify-center">Cancel</button>
          <button id="accept-terms" class="btn-primary flex-1 justify-center">I Agree</button>
        </div>
      </div>
    </div>

    <div id="signature-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-end sm:items-center justify-center p-0 sm:p-4 z-50">
      <div class="bg-white rounded-t-lg sm:rounded-lg p-5 sm:p-6 w-full max-w-md">
        <h3 class="text-lg font-semibold mb-4">Sign Estimate</h3>
        <p class="text-sm text-gray-600 mb-4">By signing, you agree to the terms and selected package.</p>
        <label class="block mb-4">
          <span class="block text-sm font-medium mb-1">Full Name</span>
          <input id="signer-name" type="text" autocomplete="name" enterkeyhint="done" class="w-full px-3 py-3 border rounded-lg" placeholder="Your full name" required />
        </label>
        <div class="mb-4">
          <label class="block text-sm font-medium mb-1">Signature</label>
          <canvas id="signature-pad" class="w-full h-36 border rounded-lg bg-gray-50 cursor-crosshair touch-none"></canvas>
          <button id="clear-sig" type="button" class="btn-text btn-sm mt-2">Clear signature</button>
        </div>
        <div class="flex gap-3">
          <button id="cancel-sign" class="btn-secondary flex-1 justify-center">Back</button>
          <button id="submit-sign" class="btn-primary flex-1 justify-center">Sign Proposal</button>
        </div>
      </div>
    </div>

    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
      const estimateId = window.location.pathname.split('/').pop();
      const labels = { good: 'Good', better: 'Better', best: 'Best', proposal: 'Proposal' };
      let selectedPackage = null;
      let primaryColor = '#2563eb';
      let canvas;
      let ctx;
      let isDrawing = false;
      let hasSignature = false;
      let selectedPackageData = null;
      let estimatePhotos = [];
      let currentEstimateData = null;

      function money(value) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
      }

      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      }

      function packageItems(pkg) {
        return Array.isArray(pkg.items) ? pkg.items : Array.isArray(pkg.lineItems) ? pkg.lineItems : [];
      }

      async function loadEstimate() {
        try {
          const res = await fetch(`${API_URL}/v1/estimates/${estimateId}/public`);
          if (!res.ok) {
            showError();
            return;
          }
          const { data } = await res.json();
          currentEstimateData = data;

          if (data.branding?.companyName) {
            document.title = `${data.branding.companyName} - Estimate`;
            document.getElementById('brand-block').innerHTML = `<p class="text-sm font-semibold text-gray-700">${escapeHtml(data.branding.companyName)}</p>`;
          }
          if (data.branding?.primaryColor) {
            primaryColor = data.branding.primaryColor;
            document.getElementById('accept-panel').style.borderColor = primaryColor;
          }
          if (data.branding?.logoUrl) {
            document.getElementById('brand-block').innerHTML = `<img src="${escapeHtml(data.branding.logoUrl)}" class="h-12 mb-3" alt="Logo" />` + document.getElementById('brand-block').innerHTML;
          }

          if (data.status === 'canceled') {
            document.getElementById('loading').innerHTML = `<div class="bg-white border rounded-lg p-8"><p class="text-red-700 font-medium">This estimate has been canceled.</p><p class="text-sm text-gray-600 mt-2">Please contact your contractor if you have questions or need a revised proposal.</p></div>`;
            return;
          }

          document.getElementById('estimate-id').textContent = data.id.slice(0, 8);
          renderProposal(data.packages || []);
          estimatePhotos = Array.isArray(data.photos) ? data.photos : [];
          renderEstimatePhotos();
          if (data.signedAt) {
            renderSignedState(data);
          } else {
            setupSignaturePad();
          }
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('estimate-content').classList.remove('hidden');
        } catch (err) {
          console.error('Failed to load estimate', err);
          showError();
        }
      }

      function renderSignedState(data) {
        const paidAmount = Number(data.paymentSummary?.paidAmount || 0);
        const nextPayment = nextDuePayment(data.paymentSchedule || []);
        document.getElementById('accept-panel').className = 'bg-green-50 border border-green-200 rounded-lg p-5';
        document.getElementById('accept-panel').innerHTML = `
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h3 class="font-semibold text-green-950">Final signed copy</h3>
              <p class="mt-1 text-sm text-green-800">Signed by ${escapeHtml(data.signedName || 'Customer')} on ${new Date(data.signedAt).toLocaleDateString()}.</p>
              <p class="mt-2 text-sm text-gray-700">${paidAmount > 0 ? `${money(paidAmount)} payment recorded.` : 'No online payment is recorded on this copy yet.'}</p>
              ${nextPayment ? `<p class="mt-1 text-sm text-gray-700">Next payment: <strong>${escapeHtml(nextPayment.label)}</strong> ${money(nextPayment.amount - nextPayment.paidAmount)}.</p>` : '<p class="mt-1 text-sm text-gray-700">No online payment is due right now.</p>'}
            </div>
            <div class="flex flex-col gap-2 sm:min-w-40">
              ${nextPayment ? `<button type="button" class="btn-primary btn-sm justify-center" data-pay-milestone="${escapeHtml(nextPayment.key)}">Pay ${escapeHtml(nextPayment.label)}</button>` : ''}
              <button type="button" class="btn-secondary btn-sm justify-center" onclick="window.print()">Print / save copy</button>
            </div>
          </div>
        `;
        document.querySelector('[data-pay-milestone]')?.addEventListener('click', (event) => {
          startCheckout(event.currentTarget.dataset.payMilestone, event.currentTarget);
        });
      }

      function itemMaterial(item) {
        if (!item.material?.name) return 'Paint: TBD';
        const name = [item.material.brand, item.material.name].filter(Boolean).join(' ');
        const color = [item.material.colorName, item.material.colorCode].filter(Boolean).join(' ');
        return `Paint: ${escapeHtml(name)}${color ? `, ${escapeHtml(color)}` : ''}`;
      }

      function applicationLabel(value) {
        return ({
          brush_roll: 'Brush & roll',
          spray_backroll: 'Spray & back-roll',
          spray_only: 'Spray only',
        })[value] || String(value || '').replace(/_/g, ' ');
      }

      function titleCaseScope(value) {
        return String(value || '')
          .replace(/\s+/g, ' ')
          .trim()
          .split(/(\s+|,|\/|-)/)
          .map(part => /^[a-z]/.test(part) ? part.charAt(0).toUpperCase() + part.slice(1) : part)
          .join('')
          .replace(/\bAnd\b/g, 'and');
      }

      function cleanScopeLabel(value) {
        return String(value || '')
          .replace(/\s*,?\s*(spray\s*(and|&|-|\/)\s*back-?roll|spray\/back-?roll|brush\s*(and|&)\s*roll|spray only)\s*$/i, '')
          .replace(/\s+/g, ' ')
          .trim();
      }

      function scopeParts(item) {
        const [area = 'Project', rawLabel = item.desc || 'Scope item'] = String(item.desc || '').split(/:\s(.+)/);
        const label = cleanScopeLabel(rawLabel || area);
        const surfaceMatch = label.match(/^(.*)\s+(walls?|ceilings?|trim|doors?|cabinets?|siding|soffits?|fascia|corner boards?)$/i);
        const surface = item.surfaceName || (surfaceMatch ? surfaceMatch[2].trim() : label.trim());
        return {
          area: area.trim() || 'Project',
          space: area.trim() || surfaceMatch?.[1]?.trim() || 'Project',
          surface: titleCaseScope(surface).replace(/^(Interior|Exterior)\s+/i, ''),
          label: titleCaseScope(label).replace(/^(Interior|Exterior)\s+/i, ''),
        };
      }

      function groupScopeBySpace(items) {
        const groups = new Map();
        items.forEach((item) => {
          const parts = scopeParts(item);
          const key = parts.space || parts.area;
          if (!groups.has(key)) groups.set(key, { name: key, area: parts.area, items: [] });
          groups.get(key).items.push({ item, parts });
        });
        return Array.from(groups.values());
      }

      function productSummary(items) {
        const products = new Map();
        items.forEach((item) => {
          if (!item.material?.name) return;
          const product = [item.material.brand, item.material.name].filter(Boolean).join(' ');
          const color = [item.material.colorName, item.material.colorCode].filter(Boolean).join(' ') || 'Color TBD';
          const key = `${product}|${color}`;
          if (!products.has(key)) products.set(key, { product, color, spaces: new Set() });
          products.get(key).spaces.add(scopeParts(item).space);
        });
        return Array.from(products.values()).map(product => ({
          ...product,
          spaces: Array.from(product.spaces).filter(Boolean),
        }));
      }

      function renderEstimatePhotos() {
        const container = document.getElementById('estimate-photo-list');
        if (!estimatePhotos.length) {
          return;
        }
        document.getElementById('estimate-photo-panel').classList.remove('hidden');

        container.innerHTML = `
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 p-5">
            ${estimatePhotos.map((photo) => `
              <a href="${escapeHtml(photo.url)}" target="_blank" rel="noreferrer" class="block border rounded-lg overflow-hidden bg-gray-50">
                <div class="aspect-[4/3] bg-gray-100 flex items-center justify-center text-xs text-gray-500">Photo</div>
                <div class="p-2">
                  <p class="text-xs text-gray-500">${escapeHtml(new Date(photo.createdAt).toLocaleDateString())}</p>
                  ${Array.isArray(photo.annotations) && photo.annotations[0]?.text ? `<p class="text-xs text-gray-700 mt-1 truncate">${escapeHtml(photo.annotations[0].text)}</p>` : ''}
                </div>
              </a>
            `).join('')}
          </div>
        `;
      }

      function customerScopeDetail(item) {
        if (item.kind === 'line_item') return escapeHtml(item.notes || 'Additional project item');
        const labor = item.labor || {};
        const parts = [
          labor.coats ? `${Number(labor.coats)} coat${Number(labor.coats) === 1 ? '' : 's'}` : '',
          labor.prepLevel ? `${String(labor.prepLevel).replace(/^\w/, c => c.toUpperCase())} prep` : '',
          labor.applicationMethod ? applicationLabel(labor.applicationMethod) : '',
        ].filter(Boolean);
        return escapeHtml(parts.join(' · ') || 'Included in project scope');
      }

      function selectedOptionalItems() {
        return Array.from(document.querySelectorAll('[data-option-index]:checked')).map((input) => {
          const option = JSON.parse(input.dataset.option || '{}');
          return {
            desc: option.desc,
            qty: Number(option.qty || 1),
            rate: Number(option.rate || 0),
            category: option.category || 'option',
          };
        });
      }

      function optionTotal() {
        return selectedOptionalItems().reduce((sum, item) => sum + Number(item.qty || 1) * Number(item.rate || 0), 0);
      }

      function hasProposalOptions() {
        return Boolean(document.querySelector('[data-option-index]'));
      }

      function pricingBreakdown(pkg) {
        const baseTotal = Number(pkg.total ?? 0);
        const discount = Number(pkg.discount ?? 0);
        const baseTax = Number(pkg.tax ?? 0);
        const rawSubtotal = Number(pkg.subtotal ?? 0);
        const baseSubtotal = rawSubtotal > 0 && Math.abs((rawSubtotal - discount + baseTax) - baseTotal) < 0.02
          ? rawSubtotal
          : Math.max(baseTotal - baseTax + discount, 0);
        const taxableBase = Math.max(baseSubtotal - discount, 0);
        const taxRate = taxableBase > 0 ? baseTax / taxableBase : 0;
        const options = optionTotal();
        const optionTax = Math.round(options * taxRate * 100) / 100;
        const totalTax = baseTax + optionTax;
        const total = baseTotal + options + optionTax;

        return {
          baseSubtotal,
          discount,
          baseTax,
          taxRate,
          options,
          optionTax,
          totalTax,
          baseTotal,
          total,
        };
      }

      function nextDuePayment(schedule) {
        return schedule.find(item => item.payable && item.status !== 'paid' && Number(item.amount || 0) > Number(item.paidAmount || 0)) || null;
      }

      function adjustedPaymentSchedule(total) {
        const schedule = Array.isArray(currentEstimateData?.paymentSchedule) ? currentEstimateData.paymentSchedule : [];
        const paidAmount = Number(currentEstimateData?.paymentSummary?.paidAmount || 0);
        let remainingPaid = paidAmount;
        return schedule.map((item, index) => {
          const amount = Math.round(total * (Number(item.percent || 0) / 100) * 100) / 100;
          const paid = Math.min(remainingPaid, amount);
          remainingPaid = Math.max(remainingPaid - paid, 0);
          return {
            ...item,
            amount,
            paidAmount: paid,
            status: paid >= amount - 0.01 ? 'paid' : index === 0 || item.payable ? 'due' : 'upcoming',
          };
        });
      }

      function renderPaymentSchedule(total) {
        const schedule = adjustedPaymentSchedule(total).filter(item => Number(item.percent || 0) > 0);
        if (!schedule.length) return '';
        return `
          <div class="mt-5 border-t pt-4">
            <p class="text-sm font-semibold text-gray-900">Payment schedule</p>
            <div class="mt-3 space-y-2" data-payment-schedule>
              ${schedule.map(item => `
                <div class="rounded-md bg-white border px-3 py-2">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-medium text-gray-900">${escapeHtml(item.label)}</p>
                      <p class="text-xs text-gray-500">${escapeHtml(item.due)}</p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-semibold text-gray-900">${money(item.amount)}</p>
                      <p class="text-xs text-gray-500">${Number(item.percent || 0).toFixed(Number(item.percent || 0) % 1 ? 1 : 0)}%</p>
                    </div>
                  </div>
                </div>
              `).join('')}
            </div>
            <p class="mt-2 text-xs text-gray-500">${escapeHtml(currentEstimateData?.paymentTerms || '')}</p>
          </div>
        `;
      }

      function updateSelectedTotal() {
        if (!selectedPackageData) return;
        const breakdown = pricingBreakdown(selectedPackageData);
        document.querySelectorAll('[data-selected-total]').forEach(node => {
          node.textContent = money(breakdown.total);
        });
        const optionNode = document.querySelector('[data-selected-options-total]');
        if (optionNode) optionNode.textContent = money(breakdown.options);
        const optionTaxNode = document.querySelector('[data-selected-options-tax]');
        if (optionTaxNode) optionTaxNode.textContent = money(breakdown.optionTax);
        const taxNode = document.querySelector('[data-selected-tax-total]');
        if (taxNode) taxNode.textContent = money(breakdown.totalTax);
        const scheduleNode = document.querySelector('[data-payment-schedule-shell]');
        if (scheduleNode) scheduleNode.innerHTML = renderPaymentSchedule(breakdown.total);
      }

      function priceSummary(pkg) {
        const breakdown = pricingBreakdown(pkg);
        const showOptions = packageItems(pkg).some(item => item.optional && item.customerVisible !== false);
        return `
          <div class="space-y-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Project investment</p>
              <p class="mt-1 text-3xl font-semibold text-gray-950" data-selected-total>${money(breakdown.total)}</p>
            </div>
            <div class="space-y-2 border-y py-3 text-sm">
              <div class="flex justify-between gap-4"><span class="text-gray-600">Base scope subtotal</span><span class="font-medium text-gray-900">${money(breakdown.baseSubtotal)}</span></div>
              ${breakdown.discount ? `<div class="flex justify-between gap-4 text-green-700"><span>Discount</span><span class="font-medium">-${money(breakdown.discount)}</span></div>` : ''}
              ${showOptions ? `<div class="flex justify-between gap-4"><span class="text-gray-600">Selected options</span><span class="font-medium text-gray-900" data-selected-options-total>$0.00</span></div>` : ''}
              ${showOptions ? `<div class="flex justify-between gap-4"><span class="text-gray-600">Tax on selected options</span><span class="font-medium text-gray-900" data-selected-options-tax>$0.00</span></div>` : ''}
              <div class="flex justify-between gap-4"><span class="text-gray-600">Estimated tax total</span><span class="font-medium text-gray-900" data-selected-tax-total>${money(breakdown.totalTax)}</span></div>
            </div>
            <div class="flex justify-between gap-4 text-base">
              <span class="font-semibold text-gray-900">Estimated total</span>
              <span class="font-bold" style="color: ${primaryColor}" data-selected-total>${money(breakdown.total)}</span>
            </div>
            <div data-payment-schedule-shell>${renderPaymentSchedule(breakdown.total)}</div>
          </div>
        `;
      }

      function renderProposal(packages) {
        const pkg = packages.find(item => item.name === 'proposal') || packages.find(item => /better|recommended/i.test(item.name)) || packages[0];
        const items = packageItems(pkg || {}).filter(item => item.customerVisible !== false);
        if (!pkg || items.length === 0) {
          showError();
          return;
        }
        selectedPackageData = pkg;
        const baseItems = items.filter(item => !item.optional);
        const optionalItems = items.filter(item => item.optional);
        const scopeGroups = groupScopeBySpace(baseItems);
        const products = productSummary(baseItems);

        document.getElementById('proposal-container').innerHTML = `
          <div class="grid lg:grid-cols-[1fr_280px] gap-6">
            <section class="space-y-5">
              <div>
                <h2 class="text-lg font-semibold text-gray-900">Included Scope</h2>
                <p class="mt-1 text-sm text-gray-600">Organized by space. Pricing is shown as one project total.</p>
              </div>
              <div class="space-y-2">
                ${scopeGroups.length ? scopeGroups.map(group => `
                  <div class="rounded-lg border bg-white overflow-hidden">
                    <div class="flex items-center justify-between gap-3 border-b bg-gray-50 px-3 py-2">
                      <h3 class="font-semibold text-gray-950">${escapeHtml(group.name)}</h3>
                      <span class="text-xs text-gray-500">${group.items.length} substrate${group.items.length === 1 ? '' : 's'}</span>
                    </div>
                    <div class="divide-y">
                      ${group.items.map(({ item, parts }) => `
                        <div class="grid gap-1 px-3 py-2 text-sm sm:grid-cols-[8rem_1fr] sm:items-start">
                          <p class="font-medium text-gray-900">${escapeHtml(parts.surface)}</p>
                          <p class="text-gray-600">
                            ${customerScopeDetail(item)}
                            ${itemMaterial(item) ? `<span class="mx-1 text-gray-300">·</span> ${itemMaterial(item)}` : ''}
                          </p>
                        </div>
                      `).join('')}
                    </div>
                  </div>
                `).join('') : '<p class="rounded-lg border border-dashed border-gray-300 p-4 text-sm text-gray-600">No included scope lines are visible on this proposal.</p>'}
              </div>
              ${optionalItems.length ? `
                <section class="rounded-lg border bg-white p-4">
                  <h2 class="text-lg font-semibold text-gray-900">Optional Add-ons</h2>
                  <p class="mt-1 text-sm text-gray-600">Select any optional scope you want included before approval. These options update the accepted total and deposit.</p>
                  <div class="mt-3 space-y-2">
                    ${optionalItems.map((item, index) => {
                      const option = escapeHtml(JSON.stringify({
                        desc: item.desc,
                        qty: item.qty,
                        rate: item.rate,
                        category: item.category,
                      }));
                      return `
                        <label class="flex flex-col gap-3 rounded-lg border p-3 sm:flex-row sm:items-start sm:justify-between">
                          <span class="flex min-w-0 gap-3">
                            <input type="checkbox" class="mt-1 rounded border-gray-300" data-option-index="${index}" data-option="${option}">
                            <span class="min-w-0">
                              <span class="block font-medium text-gray-900">${escapeHtml(scopeParts(item).label || item.desc)}</span>
                              <span class="mt-1 block text-sm text-gray-600">${customerScopeDetail(item)}${itemMaterial(item) ? ` · ${itemMaterial(item)}` : ''}</span>
                            </span>
                          </span>
                          <span class="font-semibold text-gray-900">${money(Number(item.qty || 1) * Number(item.rate || 0))}</span>
                        </label>
                      `;
                    }).join('')}
                  </div>
                </section>
              ` : ''}
              <section class="rounded-lg border bg-white p-4">
                <h2 class="text-lg font-semibold text-gray-900">Paint Products & Colors</h2>
                <div class="mt-3 space-y-3">
                  ${products.length ? products.map(product => `
                    <div class="rounded-md bg-gray-50 p-3">
                      <p class="font-medium text-gray-900">${escapeHtml(product.product)}</p>
                      <p class="text-sm text-gray-600">${escapeHtml(product.color)}</p>
                      ${product.spaces.length ? `<p class="mt-1 text-xs text-gray-500">Used in: ${escapeHtml(product.spaces.join(', '))}</p>` : ''}
                    </div>
                  `).join('') : '<p class="rounded-md bg-gray-50 p-3 text-sm text-gray-600">Paint product and color selections will be confirmed before ordering and production.</p>'}
                </div>
              </section>
            </section>
            <aside class="rounded-lg border p-5 bg-gray-50 self-start">
              <div class="mt-4">${priceSummary(pkg)}</div>
              <p class="text-sm text-gray-600 mt-4">Includes labor, selected paint products, prep, listed materials${optionalItems.length ? ', selected options,' : ''} and applicable estimated tax.</p>
            </aside>
          </div>
        `;

        document.getElementById('accept-buttons').innerHTML = `
          <button onclick="selectPackage('${escapeHtml(pkg.name)}')" class="w-full sm:w-auto px-5 py-3 text-white rounded-lg font-medium hover:opacity-90" style="background-color: ${primaryColor}">
            Approve and sign - <span data-selected-total>${money(pkg.total)}</span>
          </button>
        `;
        document.querySelectorAll('[data-option-index]').forEach(input => {
          input.addEventListener('change', updateSelectedTotal);
        });
        updateSelectedTotal();
      }

      function showError() {
        document.getElementById('loading').classList.add('hidden');
        document.getElementById('error').classList.remove('hidden');
      }

      function setupSignaturePad() {
        canvas = document.getElementById('signature-pad');
        ctx = canvas.getContext('2d');
        resizeCanvas();
        ctx.strokeStyle = '#111827';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseleave', stopDrawing);
        canvas.addEventListener('touchstart', (event) => { event.preventDefault(); startDrawing(event.touches[0]); });
        canvas.addEventListener('touchmove', (event) => { event.preventDefault(); draw(event.touches[0]); });
        canvas.addEventListener('touchend', stopDrawing);
        document.getElementById('clear-sig').onclick = () => {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          hasSignature = false;
        };
      }

      function resizeCanvas() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = 144;
      }

      function startDrawing(event) {
        isDrawing = true;
        const rect = canvas.getBoundingClientRect();
        ctx.beginPath();
        ctx.moveTo(event.clientX - rect.left, event.clientY - rect.top);
      }

      function draw(event) {
        if (!isDrawing) return;
        const rect = canvas.getBoundingClientRect();
        ctx.lineTo(event.clientX - rect.left, event.clientY - rect.top);
        ctx.stroke();
        hasSignature = true;
      }

      function stopDrawing() {
        isDrawing = false;
      }

      window.selectPackage = function(pkgName) {
        selectedPackage = pkgName;
        document.getElementById('terms-modal').classList.remove('hidden');
      };

      document.getElementById('decline-terms').onclick = () => {
        document.getElementById('terms-modal').classList.add('hidden');
        selectedPackage = null;
      };
      document.getElementById('accept-terms').onclick = () => {
        document.getElementById('terms-modal').classList.add('hidden');
        document.getElementById('signature-modal').classList.remove('hidden');
        setTimeout(resizeCanvas, 0);
      };
      document.getElementById('cancel-sign').onclick = () => {
        document.getElementById('signature-modal').classList.add('hidden');
        document.getElementById('terms-modal').classList.remove('hidden');
      };
      document.getElementById('submit-sign').onclick = async () => {
        const button = document.getElementById('submit-sign');
        const name = document.getElementById('signer-name').value.trim();
        if (!name) return alert('Please enter your name');
        if (!hasSignature) return alert('Please add your signature');
        const selectedOptions = selectedOptionalItems();

        try {
          button.disabled = true;
          button.textContent = 'Signing...';
          const signRes = await fetch(`${API_URL}/v1/estimates/${estimateId}/sign`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({ name, signatureData: canvas.toDataURL(), packageName: selectedPackage, selectedOptions }),
          });
          if (!signRes.ok) {
            const payload = await signRes.json().catch(() => ({}));
            throw new Error(payload.error || 'Failed to sign estimate');
          }
          document.getElementById('signature-modal').classList.add('hidden');
          await loadEstimate();
        } catch (err) {
          alert(err.message || 'Failed to process signature');
          button.disabled = false;
          button.textContent = 'Sign Proposal';
        }
      };

      async function startCheckout(milestoneKey, button) {
        try {
          if (button) {
            button.disabled = true;
            button.textContent = 'Preparing payment...';
          }
          const checkoutRes = await fetch(`${API_URL}/v1/payments/checkout`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({ estimateId, packageName: selectedPackageData?.name || 'proposal', selectedOptions: selectedOptionalItems(), milestoneKey }),
          });
          const checkoutPayload = await checkoutRes.json().catch(() => ({}));
          if (checkoutRes.status === 409) {
            throw new Error(checkoutPayload.error || 'Online payments are not available yet. Please contact your contractor to arrange payment.');
          }
          if (!checkoutRes.ok || !checkoutPayload.checkoutUrl) throw new Error(checkoutPayload.error || 'Failed to create payment checkout');
          window.location.href = checkoutPayload.checkoutUrl;
        } catch (err) {
          alert(err.message || 'Failed to start payment');
          if (button) {
            button.disabled = false;
            button.textContent = 'Pay deposit';
          }
        }
      }

      loadEstimate();
    </script>
  </body>
</html>
