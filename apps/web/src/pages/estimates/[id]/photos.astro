---
import '../../../styles/design-system.css';
import PhotoAnnotator from '../../../components/PhotoAnnotator.astro';
import DetailBackButton from '../../../components/DetailBackButton.astro';
import AuthBridge from '../../../components/AuthBridge.astro';

const { id } = Astro.params;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estimate Photos - PaintFlow</title>
  <AuthBridge />
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-[2.5rem_1fr_2.5rem] h-16 items-center gap-3">
        <DetailBackButton href={`/estimates/${id}`} label="Back to estimate" />
        <h1 class="text-xl font-semibold text-center">Estimate Photos</h1>
        <span aria-hidden="true"></span>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-blue-800">📸 Upload photos and add annotations</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6" id="photos-grid"></div>
    <label class="w-full py-4 border-2 border-dashed border-gray-300 rounded-lg text-center block cursor-pointer">
      <input type="file" accept="image/*" multiple class="hidden" id="photo-input">
      <span class="text-gray-600">+ Add Photos</span>
    </label>
  </main>
  <PhotoAnnotator />
  <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const estimateId = window.location.pathname.split('/')[2];
    let photos = [];
    async function loadPhotos() {
      const res = await fetch(`${API_URL}/v1/estimate-photos/${estimateId}`, { credentials: 'include' });
      const { data } = await res.json();
      photos = data;
      renderPhotos();
    }
    function renderPhotos() {
      const grid = document.getElementById('photos-grid');
      grid.innerHTML = photos.map(p => `<div><img src="${p.url}" class="w-full h-48 rounded-lg border"></div>`).join('');
    }
    loadPhotos();
  </script>
</body>
</html>
