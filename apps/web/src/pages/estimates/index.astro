---
import Base from '../../layouts/Base.astro';
---

<Base title="Estimates">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="pf-page-title">Estimates</h2>
      </div>
      <a href="/estimates/production" class="btn-primary justify-center w-full sm:w-auto">Start estimate</a>
    </div>

    <section class="estimate-mode-grid grid md:grid-cols-2 gap-3 mb-4">
      <a href="/estimates/production" class="block bg-white border rounded-lg shadow-sm p-4 hover:border-blue-300 hover:shadow-md">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="pf-section-title">Production estimate</h3>
            <p class="mobile-hide-copy pf-copy mt-1 sm:block">Use measured surfaces, prep levels, production rates, labor, paint products, and templates.</p>
          </div>
          <span class="shrink-0 rounded-full bg-blue-50 text-blue-700 px-3 py-1 text-xs font-medium">Default</span>
        </div>
      </a>
      <a href="/estimates/new" class="block bg-white border rounded-lg shadow-sm p-4 hover:border-blue-300 hover:shadow-md">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="pf-section-title">Quick line-item estimate</h3>
            <p class="mobile-hide-copy pf-copy mt-1 sm:block">Build a simple estimate from manually entered scope items when takeoff detail is not needed.</p>
          </div>
          <span class="shrink-0 rounded-full bg-gray-100 text-gray-700 px-3 py-1 text-xs font-medium">Simple</span>
        </div>
      </a>
    </section>

    <section class="mobile-filter-panel bg-white border rounded-lg shadow-sm p-3 sm:p-4 mb-4">
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_180px] gap-3">
        <input id="search" type="search" autocomplete="off" enterkeyhint="search" placeholder="Search customer, phone, or email" class="w-full px-3 py-2 border rounded-lg" />
        <select id="status-filter" class="w-full px-3 py-2 border rounded-lg">
          <option value="all">All statuses</option>
          <option value="sent">Sent</option>
          <option value="accepted">Accepted</option>
          <option value="declined">Declined</option>
          <option value="canceled">Canceled</option>
          <option value="superseded">Superseded</option>
          <option value="voided">Voided</option>
          <option value="draft">Draft</option>
        </select>
      </div>
      <div id="summary" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-4"></div>
    </section>

    <div id="estimates-list" class="grid gap-3">
      <div class="bg-white border rounded-lg p-8 text-center text-gray-500">Loading estimates...</div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let estimates = [];

    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: options.cents === false ? 0 : 2, maximumFractionDigits: options.cents === false ? 0 : 2 })}`;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const statusBadge = (value) => window.PaintFlowUI?.statusBadge({ value }) || `<span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">${escapeHtml(label(value))}</span>`;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function customerProfileLink(customer) {
      if (!customer?.leadId) {
        return `<div class="pf-row-title truncate">${escapeHtml(customer?.name || 'Customer')}</div>`;
      }
      const address = customer.address || 'No jobsite address';
      const contact = customer.contact || '';
      return `
        <div class="min-w-0 rounded-lg pr-2">
          <a href="/leads/${customer.leadId}" class="pf-row-title block truncate hover:text-blue-700">${escapeHtml(customer.name || 'Customer')}</a>
          ${window.PaintFlowFormat?.addressLink(address) || `<span class="pf-copy block truncate">${escapeHtml(address)}</span>`}
          ${contact ? `<span class="pf-meta block truncate">${escapeHtml(contact)}</span>` : ''}
        </div>
      `;
    }

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead', { includePostalCode: false }) || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', ')].filter(Boolean).join(' ');
    }

    function customerPreviewHref(estimate) {
      return new URL(estimate.customerPreviewUrl || estimate.publicUrl || `/estimates/${estimate.id}`, window.location.origin).pathname;
    }

    function estimateActions(estimate) {
      return window.PaintFlowUI?.estimateActions({
        estimate,
        previewHref: customerPreviewHref(estimate),
        editHref: `/estimates/production?estimateId=${estimate.id}`,
        className: 'justify-end',
      }) || '';
    }

    function paymentSummary(payments = []) {
      const paid = payments.reduce((sum, payment) => sum + Number(payment.amount || 0), 0);
      const refunded = payments.reduce((sum, payment) => sum + Number(payment.refundedAmount || 0), 0);
      const net = Math.max(paid - refunded, 0);
      if (!payments.length) return '<p class="pf-meta">No payments recorded</p>';
      return `<p class="pf-meta">${money(net)} paid${refunded > 0 ? ` · ${money(refunded)} refunded` : ''}</p>`;
    }

    async function apiJson(url, options = {}) {
      const res = await fetch(url, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    async function loadEstimates() {
      try {
        const { data } = await apiJson(`${API_URL}/v1/estimates?limit=100`);
        estimates = data;
        render();
      } catch (err) {
        console.error('Failed to load estimates', err);
        document.getElementById('summary').innerHTML = '';
        document.getElementById('estimates-list').innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-lg p-6 text-red-800">
            <p class="pf-row-title">Estimates could not be loaded</p>
            <p class="pf-copy mt-1">${escapeHtml(err.message || 'Check that the API server is running and try again.')}</p>
            <button id="retry-estimates" type="button" class="btn-primary btn-sm mt-4">Retry</button>
          </div>
        `;
        document.getElementById('retry-estimates')?.addEventListener('click', loadEstimates);
        window.showToast('Failed to load estimates', 'error');
      }
    }

    function filteredEstimates() {
      const q = document.getElementById('search').value.trim().toLowerCase();
      const status = document.getElementById('status-filter').value;
      return estimates.filter((estimate) => {
        const haystack = `${estimate.leadName || ''} ${estimate.leadPhone || ''} ${estimate.leadEmail || ''}`.toLowerCase();
        return (!q || haystack.includes(q)) && (status === 'all' || estimate.status === status);
      });
    }

    function renderSummary(list) {
      const counts = list.reduce((acc, estimate) => {
        acc[estimate.status] = (acc[estimate.status] || 0) + 1;
        return acc;
      }, {});
      const totalValue = list.reduce((sum, estimate) => sum + Number(estimate.total || 0), 0);
      document.getElementById('summary').innerHTML = `
        <div class="rounded-lg bg-gray-50 border px-3 py-2"><p class="pf-meta">Sent</p><p class="pf-section-title">${counts.sent || 0}</p></div>
        <div class="rounded-lg bg-gray-50 border px-3 py-2"><p class="pf-meta">Accepted</p><p class="pf-section-title">${counts.accepted || 0}</p></div>
        <div class="rounded-lg bg-gray-50 border px-3 py-2"><p class="pf-meta">Total Value</p><p class="pf-section-title">${money(totalValue)}</p></div>
        <div class="rounded-lg bg-gray-50 border px-3 py-2"><p class="pf-meta">Win Rate</p><p class="pf-section-title">${list.length ? Math.round(((counts.accepted || 0) / list.length) * 100) : 0}%</p></div>
      `;
    }

    function render() {
      const list = filteredEstimates();
      renderSummary(list);
      const container = document.getElementById('estimates-list');
      if (list.length === 0) {
        const filtered = document.getElementById('search').value.trim() || document.getElementById('status-filter').value !== 'all';
        container.innerHTML = filtered
          ? '<div class="pf-copy bg-white border rounded-lg p-8 text-center">No estimates match this view.</div>'
          : `
            <div class="bg-white border rounded-lg p-5 sm:p-8">
              <div class="mx-auto max-w-2xl text-center">
                <p class="pf-section-title">Create your first painting proposal</p>
                <p class="pf-copy mt-2">Track sent, accepted, and declined painting proposals once you have a customer ready for pricing.</p>
              </div>
              <div class="mt-5 grid gap-3 sm:grid-cols-3">
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">1. Select a customer</p>
                  <p class="pf-copy mt-1">Start from an existing lead or create one first.</p>
                </div>
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">2. Build scope</p>
                  <p class="pf-copy mt-1">Use production rates and paint products for accurate pricing.</p>
                </div>
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">3. Send and follow up</p>
                  <p class="pf-copy mt-1">The customer preview stays linked to the estimate activity.</p>
                </div>
              </div>
              <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                <a class="btn-primary justify-center" href="/estimates/production">Start estimate</a>
                <a class="btn-secondary justify-center" href="/leads?new=1">Add customer</a>
              </div>
            </div>
          `;
        return;
      }

      container.innerHTML = list.map((estimate) => `
        <article class="mobile-card-row bg-white rounded-lg shadow-sm border p-4">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
            <div class="min-w-0">
              ${customerProfileLink({ leadId: estimate.leadId, name: estimate.leadName, address: formatAddress(estimate), contact: estimate.leadPhone ? phone(estimate.leadPhone) : estimate.leadEmail || 'No contact' })}
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="pf-meta">${new Date(estimate.createdAt).toLocaleDateString()}</span>
                ${statusBadge(estimate.status)}
              </div>
            </div>
            <div class="sm:text-right flex items-center justify-between gap-3 sm:block">
              <div>
                <p class="pf-section-title text-blue-700">${money(estimate.total)}</p>
                ${paymentSummary(estimate.payments || [])}
              </div>
              <div class="mt-2">${estimateActions(estimate)}</div>
            </div>
          </div>
        </article>
      `).join('');
    }

    document.getElementById('search').addEventListener('input', render);
    document.getElementById('status-filter').addEventListener('change', render);
    const initialStatus = new URLSearchParams(window.location.search).get('status');
    if (initialStatus && ['all', 'sent', 'accepted', 'declined', 'canceled', 'superseded', 'voided', 'draft'].includes(initialStatus)) {
      document.getElementById('status-filter').value = initialStatus;
    }

    async function cancelEstimate(id) {
      const estimate = estimates.find((item) => item.id === id);
      if (!estimate || estimate.status === 'accepted' || estimate.signedAt) return;
      const shouldCancel = window.confirm('Cancel this estimate? The customer preview will no longer be approvable.');
      if (!shouldCancel) return;
      try {
        await apiJson(`${API_URL}/v1/estimates/${id}/cancel`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({ reason: 'Canceled from estimates list' }),
        });
        window.showToast?.('Estimate canceled', 'success');
        await loadEstimates();
      } catch (err) {
        window.showToast?.(err.message || 'Failed to cancel estimate', 'error');
      }
    }

    document.addEventListener('click', (event) => {
      const cancelButton = event.target.closest('[data-cancel-estimate]');
      if (!cancelButton) return;
      cancelEstimate(cancelButton.dataset.cancelEstimate);
    });
    window.addEventListener('paintflow:payment-recorded', loadEstimates);
    window.addEventListener('paintflow:estimate-updated', loadEstimates);
    loadEstimates();
  </script>
</Base>
