---
import Base from '../../layouts/Base.astro';
---

<Base title="Quick Estimate">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Quick Estimate</h2>
        <p class="text-sm text-gray-600 mt-1">Build one simple proposal from a few priced scope rows.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <a href="/estimates/production" class="btn-secondary btn-sm justify-center">Use production estimator</a>
        <a href="/estimates" class="btn-secondary btn-sm justify-center">Back to estimates</a>
      </div>
    </div>

    <form id="estimate-form" class="grid lg:grid-cols-[1fr_340px] gap-5">
      <section class="space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-4 sm:p-5">
          <label class="block text-sm font-medium text-gray-700 mb-2">Customer</label>
          <select name="leadId" id="lead-select" required class="w-full px-3 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Loading leads...</option>
          </select>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4 sm:p-5">
          <div class="flex items-start justify-between gap-3 mb-4">
            <div>
              <h3 class="font-semibold text-gray-900">Scope Items</h3>
              <p class="text-sm text-gray-600">Each row calculates: Qty x ((labor hours x labor rate) + materials with markup).</p>
            </div>
            <button type="button" id="add-item" class="btn-primary btn-sm">Add Item</button>
          </div>
          <div id="items" class="space-y-3"></div>
          <div class="mt-3 rounded-lg bg-gray-50 p-3 text-xs text-gray-600">
            Qty is the multiplier for the row. Scope type is descriptive only and helps the customer understand the scope.
          </div>
        </div>
      </section>

      <aside class="space-y-4 lg:sticky lg:top-20 self-start">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h3 class="font-semibold text-gray-900 mb-3">Owner Defaults</h3>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <label>
              <span class="text-gray-600">Labor rate</span>
              <input id="labor-rate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" class="mt-1 w-full px-3 py-2 border rounded-lg">
            </label>
            <label>
              <span class="text-gray-600">Material markup %</span>
              <input id="markup" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" class="mt-1 w-full px-3 py-2 border rounded-lg">
            </label>
            <label>
              <span class="text-gray-600">Sales tax %</span>
              <input id="tax-rate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" class="mt-1 w-full px-3 py-2 border rounded-lg">
            </label>
            <label>
              <span class="text-gray-600">Deposit %</span>
              <input id="deposit-percent" type="number" min="0" max="100" step="0.01" inputmode="decimal" autocomplete="off" class="mt-1 w-full px-3 py-2 border rounded-lg">
            </label>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h3 class="font-semibold text-gray-900 mb-3">Proposal Preview</h3>
          <div id="package-preview" class="space-y-3"></div>
          <button id="create-estimate-btn" type="submit" class="btn-primary w-full justify-center mt-4">Create Estimate</button>
          <p id="create-estimate-status" class="hidden mt-3 text-sm text-gray-600" aria-live="polite"></p>
        </div>
      </aside>
    </form>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const defaultItems = [
      { desc: 'Prep, patching, masking, and setup', qty: 1, unit: 'project', laborHours: 4, materialCost: 1 },
      { desc: 'Paint walls and ceilings', qty: 1, unit: 'area', laborHours: 8, materialCost: 1 },
    ];

    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function apiErrorMessage(payload) {
      const issues = payload?.issues || payload?.details?.formErrors || [];
      const fieldErrors = payload?.details?.fieldErrors || {};
      const issueMessage = Array.isArray(issues) && issues.length
        ? issues.map(issue => `${Array.isArray(issue.path) ? issue.path.join('.') : ''} ${issue.message || issue}`.trim()).join('; ')
        : '';
      const fieldMessage = Object.entries(fieldErrors)
        .flatMap(([field, messages]) => (messages || []).map(message => `${field}: ${message}`))
        .join('; ');
      return fieldMessage || issueMessage || payload?.error || 'Request failed';
    }

    async function apiJson(url, options = {}) {
      const res = await fetch(url, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(apiErrorMessage(payload));
      return payload;
    }

    async function loadSetup() {
      const [{ data: leads }, { data: settings }] = await Promise.all([
        apiJson(`${API_URL}/v1/leads?status=all&limit=200`),
        apiJson(`${API_URL}/v1/settings/org`),
      ]);
      const select = document.getElementById('lead-select');
      select.innerHTML = leads.length
        ? '<option value="">Select customer...</option>' + leads.map(lead => `<option value="${lead.id}">${escapeHtml(lead.name)} ${lead.phone ? `(${escapeHtml(phone(lead.phone))})` : ''}</option>`).join('')
        : '<option value="">No customers found - add a lead first</option>';
      document.getElementById('labor-rate').value = Number(settings.defaultLaborRate || 65).toFixed(2);
      document.getElementById('markup').value = Number(settings.materialMarkupPercent || 30).toFixed(2);
      document.getElementById('tax-rate').value = (Number(settings.salesTaxRate || 0.092) * 100).toFixed(2);
      document.getElementById('deposit-percent').value = Number(settings.depositPercent || 50).toFixed(2);
    }

    function addItem(item = {}) {
      const div = document.createElement('div');
      div.className = 'grid gap-2 sm:grid-cols-[1fr_90px_110px_120px_120px_auto] items-end border rounded-lg p-3';
      div.innerHTML = `
        <label class="block sm:col-span-1">
          <span class="text-xs text-gray-600">Description</span>
          <input data-field="desc" autocomplete="off" value="${escapeHtml(item.desc || '')}" placeholder="Scope item" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Qty</span>
          <input data-field="qty" type="number" min="0" step="0.25" inputmode="decimal" autocomplete="off" value="${item.qty ?? 1}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Scope type</span>
          <input data-field="unit" autocomplete="off" value="${escapeHtml(item.unit || 'item')}" placeholder="room, wall, door" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Labor hours</span>
          <input data-field="laborHours" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${item.laborHours || 0}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Materials cost</span>
          <input data-field="materialCost" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${item.materialCost ?? 1}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <button type="button" class="remove-item btn-secondary btn-sm">Remove</button>
      `;
      document.getElementById('items').appendChild(div);
      calculate();
    }

    function collectBaseItems() {
      const laborRate = Number(document.getElementById('labor-rate').value || 0);
      const markup = Number(document.getElementById('markup').value || 0);
      return Array.from(document.querySelectorAll('#items > div')).map(row => {
        const desc = row.querySelector('[data-field="desc"]').value.trim();
        const qty = Number(row.querySelector('[data-field="qty"]').value || 0);
        const unit = row.querySelector('[data-field="unit"]').value.trim() || 'each';
        const laborHours = Number(row.querySelector('[data-field="laborHours"]').value || 0);
        const materialCost = Number(row.querySelector('[data-field="materialCost"]').value || 0);
        const laborPrice = laborHours * laborRate;
        const materialPrice = materialCost * (1 + markup / 100);
        const rate = laborPrice + materialPrice;
        return { desc, qty, unit, laborHours, materialCost, rate };
      }).filter(item => item.desc && item.qty > 0 && item.rate > 0);
    }

    function buildPackages() {
      const baseItems = collectBaseItems();
      const taxRate = Number(document.getElementById('tax-rate').value || 0) / 100;
      const items = baseItems.map(item => ({
        desc: item.desc,
        qty: item.qty,
        rate: Number(item.rate.toFixed(2)),
        category: item.unit,
        notes: `${item.qty} ${item.unit}; ${item.laborHours} labor hours and ${money(item.materialCost)} materials before markup`,
      }));
      const subtotal = items.reduce((sum, item) => sum + item.qty * item.rate, 0);
      const tax = subtotal * taxRate;
      const total = subtotal + tax;
      return items.length ? [{ name: 'proposal', subtotal, tax, total, items, lineItems: items }] : [];
    }

    function calculate() {
      const packages = buildPackages();
      const depositPercent = Number(document.getElementById('deposit-percent').value || 0) / 100;
      const pkg = packages[0];
      const subtotal = pkg?.subtotal || 0;
      const tax = pkg?.tax || 0;
      const total = pkg?.total || 0;
      document.getElementById('package-preview').innerHTML = `
        <div class="border rounded-lg p-3">
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-between"><span class="text-gray-600">Scope rows</span><span class="font-medium">${pkg?.items.length || 0}</span></div>
            <div class="flex items-center justify-between"><span class="text-gray-600">Subtotal</span><span class="font-medium">${money(subtotal)}</span></div>
            <div class="flex items-center justify-between"><span class="text-gray-600">Estimated tax</span><span class="font-medium">${money(tax)}</span></div>
            <div class="flex items-center justify-between border-t pt-2 text-base"><span class="font-semibold">Proposal total</span><span class="font-bold text-blue-700">${money(total)}</span></div>
            <div class="flex items-center justify-between"><span class="text-gray-600">Deposit</span><span class="font-medium">${money(total * depositPercent)}</span></div>
          </div>
        </div>
      `;
    }

    document.getElementById('add-item').addEventListener('click', () => addItem());
    document.getElementById('items').addEventListener('click', (event) => {
      if (!event.target.classList.contains('remove-item')) return;
      event.target.closest('#items > div').remove();
      calculate();
    });
    document.addEventListener('input', (event) => {
      if (event.target.closest('#estimate-form')) calculate();
    });

    document.getElementById('estimate-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = document.getElementById('create-estimate-btn');
      const status = document.getElementById('create-estimate-status');
      const leadId = new FormData(event.target).get('leadId');
      const packages = buildPackages();

      if (!leadId) {
        window.showToast('Select a customer first', 'error');
        return;
      }
      if (packages.length === 0) {
        window.showToast('Add at least one priced scope item', 'error');
        return;
      }

      try {
        button.disabled = true;
        button.textContent = 'Creating estimate...';
        status.textContent = 'Creating estimate and opening the customer proposal...';
        status.classList.remove('hidden');
        const { data } = await apiJson(`${API_URL}/v1/estimates`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ leadId, packages }),
        });
        window.showToast('Estimate created. Opening it now.');
        window.location.href = `/estimates/${data.id}`;
      } catch (err) {
        window.showToast(err.message || 'Failed to create estimate', 'error');
        status.textContent = err.message || 'Failed to create estimate';
        button.disabled = false;
        button.textContent = 'Create Estimate';
      }
    });

    defaultItems.forEach(addItem);
    loadSetup().then(calculate).catch((err) => {
      console.error('Failed to load estimate setup', err);
      window.showToast('Failed to load estimate setup', 'error');
    });
  </script>
</Base>
