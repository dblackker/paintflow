---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>New Estimate - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/leads" class="text-gray-600 hover:text-gray-900">Leads</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Create Estimate</h2>
        <p class="text-gray-600">Build Good / Better / Best packages</p>
      </div>

      <form id="estimate-form" class="space-y-6">
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">Customer</label>
          <select name="leadId" required class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Select lead...</option>
          </select>
        </div>

        <!-- Good Package -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Good Package</h3>
            <span class="text-2xl font-bold" id="good-total">$0</span>
          </div>
          <div id="good-items" class="space-y-3">
            <div class="flex gap-3">
              <input placeholder="Description" class="flex-1 px-3 py-2 border rounded-lg" data-field="desc" />
              <input placeholder="Qty" type="number" class="w-20 px-3 py-2 border rounded-lg" data-field="qty" />
              <input placeholder="Rate" type="number" class="w-24 px-3 py-2 border rounded-lg" data-field="rate" />
            </div>
          </div>
          <button type="button" data-add="good" class="mt-3 text-sm text-blue-600 hover:text-blue-700">+ Add line item</button>
        </div>

        <!-- Better Package -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Better Package ⭐ Recommended</h3>
            <span class="text-2xl font-bold" id="better-total">$0</span>
          </div>
          <div id="better-items" class="space-y-3">
            <div class="flex gap-3">
              <input placeholder="Description" class="flex-1 px-3 py-2 border rounded-lg" data-field="desc" />
              <input placeholder="Qty" type="number" class="w-20 px-3 py-2 border rounded-lg" data-field="qty" />
              <input placeholder="Rate" type="number" class="w-24 px-3 py-2 border rounded-lg" data-field="rate" />
            </div>
          </div>
          <button type="button" data-add="better" class="mt-3 text-sm text-blue-600 hover:text-blue-700">+ Add line item</button>
        </div>

        <!-- Best Package -->
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Best Package</h3>
            <span class="text-2xl font-bold" id="best-total">$0</span>
          </div>
          <div id="best-items" class="space-y-3">
            <div class="flex gap-3">
              <input placeholder="Description" class="flex-1 px-3 py-2 border rounded-lg" data-field="desc" />
              <input placeholder="Qty" type="number" class="w-20 px-3 py-2 border rounded-lg" data-field="qty" />
              <input placeholder="Rate" type="number" class="w-24 px-3 py-2 border rounded-lg" data-field="rate" />
            </div>
          </div>
          <button type="button" data-add="best" class="mt-3 text-sm text-blue-600 hover:text-blue-700">+ Add line item</button>
        </div>

        <div class="flex gap-3">
          <button type="button" id="save-draft" class="flex-1 px-4 py-3 border rounded-lg hover:bg-gray-50">Save Draft</button>
          <button type="submit" class="flex-1 px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Send Estimate</button>
        </div>
      </form>
    </main>

    <script>
      // Add line items
      document.querySelectorAll('[data-add]').forEach(btn => {
        btn.addEventListener('click', () => {
          const pkg = btn.getAttribute('data-add');
          const container = document.getElementById(`${pkg}-items`);
          const div = document.createElement('div');
          div.className = 'flex gap-3';
          div.innerHTML = `
            <input placeholder="Description" class="flex-1 px-3 py-2 border rounded-lg" data-field="desc" />
            <input placeholder="Qty" type="number" class="w-20 px-3 py-2 border rounded-lg" data-field="qty" />
            <input placeholder="Rate" type="number" class="w-24 px-3 py-2 border rounded-lg" data-field="rate" />
            <button type="button" class="text-red-600 hover:text-red-700" onclick="this.parentElement.remove(); calculateTotals()">×</button>
          `;
          container.appendChild(div);
        });
      });

      // Calculate totals
      function calculateTotals() {
        ['good', 'better', 'best'].forEach(pkg => {
          const container = document.getElementById(`${pkg}-items`);
          let total = 0;
          container.querySelectorAll('div').forEach(row => {
            const qty = parseFloat(row.querySelector('[data-field="qty"]')?.value || '0');
            const rate = parseFloat(row.querySelector('[data-field="rate"]')?.value || '0');
            total += qty * rate;
          });
          document.getElementById(`${pkg}-total`).textContent = `$${total.toFixed(2)}`;
        });
      }

      document.addEventListener('input', calculateTotals);

      // Form submit
      document.getElementById('estimate-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        // TODO: Collect packages data and POST to /v1/estimates
        alert('Estimate builder ready! API integration pending.');
      });
    </script>
  </body>
</html>
