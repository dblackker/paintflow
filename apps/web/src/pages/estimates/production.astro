---
import Base from '../../layouts/Base.astro';
---

<Base title="Production Estimate">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Production Estimate</h2>
        <p class="text-sm text-gray-600 mt-1">Build pricing from measured surfaces, prep level, production rates, labor, and materials.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <a href="/templates" class="w-full sm:w-auto text-center px-4 py-2 border rounded-lg bg-white hover:bg-gray-50">Templates</a>
        <a href="/estimates/new" class="w-full sm:w-auto text-center px-4 py-2 border rounded-lg bg-white hover:bg-gray-50">Quick estimate</a>
      </div>
    </div>

    <div id="setup-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-5">
      <p class="font-medium">Estimator setup could not load</p>
      <p class="text-sm mt-1" id="setup-error-message"></p>
      <div class="flex flex-wrap gap-3 mt-3">
        <button id="retry-setup" type="button" class="px-3 py-2 bg-red-700 text-white rounded-lg text-sm">Retry</button>
        <a href="/settings" class="px-3 py-2 border border-red-300 rounded-lg text-sm">Check settings</a>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_340px] gap-5">
      <section class="space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Customer</label>
          <select id="lead-select" class="w-full px-3 py-3 border rounded-lg text-base">
            <option>Loading...</option>
          </select>
        </div>

        <div id="rooms-container" class="space-y-4"></div>
        <button id="add-room" class="w-full py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-blue-500 hover:text-blue-600">
          Add Room or Area
        </button>
      </section>

      <aside class="space-y-4 lg:sticky lg:top-20 self-start">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Estimate Summary</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-600">Labor hours</span><span id="total-hours" class="font-medium">0.0</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Labor</span><span id="labor-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Materials</span><span id="materials-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Tax</span><span id="tax-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between border-t pt-2 text-base"><span class="font-semibold">Proposal total</span><span id="total-cost" class="font-bold text-blue-600">$0.00</span></div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Paint Products</h2>
          <div class="space-y-3 text-sm">
            <label class="block">
              <span class="text-gray-600">Wall/finish paint</span>
              <select id="paint-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <label class="block">
              <span class="text-gray-600">Primer</span>
              <select id="primer-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <p id="material-note" class="text-xs text-gray-500"></p>
          </div>
          <button id="save-estimate" class="w-full mt-4 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60">
            Create Estimate
          </button>
          <p id="save-status" class="hidden mt-3 text-sm text-gray-600" aria-live="polite"></p>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const prepMultipliers = { none: 0.8, light: 1, standard: 1.2, heavy: 1.5 };
    let rates = [];
    let materialsCatalog = [];
    let settings = {};
    let roomCounter = 0;

    function money(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function apiJson(url, options = {}) {
      let res;
      try {
        res = await fetch(url, { credentials: 'include', ...options });
      } catch (err) {
        throw new Error(`Cannot reach the PaintFlow API at ${API_URL}. Start the API dev server or set PUBLIC_API_URL to the running API.`);
      }
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function showSetupError(message) {
      document.getElementById('setup-error-message').textContent = message;
      document.getElementById('setup-error').classList.remove('hidden');
    }

    function clearSetupError() {
      document.getElementById('setup-error-message').textContent = '';
      document.getElementById('setup-error').classList.add('hidden');
    }

    async function loadSetup() {
      clearSetupError();
      const [ratesRes, leadsRes, settingsRes, materialsRes] = await Promise.all([
        apiJson(`${API_URL}/v1/production-rates`),
        apiJson(`${API_URL}/v1/leads?limit=200`),
        apiJson(`${API_URL}/v1/settings/org`),
        apiJson(`${API_URL}/v1/materials`),
      ]);
      rates = ratesRes.data;
      settings = settingsRes.data;
      materialsCatalog = materialsRes.data || [];
      document.getElementById('lead-select').innerHTML =
        '<option value="">Select customer...</option>' +
        leadsRes.data.map(lead => `<option value="${lead.id}">${escapeHtml(lead.name)}</option>`).join('');
      renderMaterialSelectors();
      const templateRooms = consumeTemplateRooms();
      if (templateRooms.length) {
        templateRooms.forEach(room => addRoom(room.name || 'Template room', room.items || []));
        window.showToast('Template loaded into the production estimator.');
      } else {
        addRoom('Interior');
      }
      calculateTotal();
    }

    function rateOptions() {
      return rates.map(rate => `<option value="${rate.id}">${escapeHtml(rate.description || `${rate.category} ${rate.surfaceType}`)} (${rate.ratePerHour} ${rate.unit}/hr)</option>`).join('');
    }

    function renderMaterialSelectors() {
      const paintOptions = materialsCatalog
        .filter(material => ['paint', 'primer'].includes(String(material.category || '').toLowerCase()))
        .map(material => `<option value="${material.id}">${escapeHtml([material.brand, material.name].filter(Boolean).join(' - '))} (${money(material.costPerUnit)}/${escapeHtml(material.unit)})</option>`)
        .join('');
      const noMaterial = '<option value="">Use pricing default</option>';
      document.getElementById('paint-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('primer-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('material-note').textContent = paintOptions
        ? 'Coverage, unit cost, and markup are pulled from Materials.'
        : 'Add paint and primer products in Materials to calculate product-specific costs.';
    }

    function selectedMaterial(id) {
      return materialsCatalog.find(material => material.id === id);
    }

    function materialCostForQuantity(quantity, material) {
      if (!material || !material.coverageSqFt || !material.costPerUnit) return null;
      const coverage = Number(material.coverageSqFt || 0);
      if (coverage <= 0) return null;
      const units = Math.max(1, Math.ceil(quantity / coverage));
      const cost = units * Number(material.costPerUnit || 0);
      const markup = Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0);
      const price = cost * (1 + markup / 100);
      return { units, cost, markup, price };
    }

    function consumeTemplateRooms() {
      const raw = sessionStorage.getItem('templateRooms');
      if (!raw) return [];
      sessionStorage.removeItem('templateRooms');
      try {
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch (err) {
        window.showToast('Template data could not be loaded', 'error');
        return [];
      }
    }

    function addRoom(name = '', templateItems = []) {
      roomCounter++;
      const roomId = `room-${roomCounter}`;
      const div = document.createElement('div');
      div.className = 'bg-white rounded-lg shadow-sm border p-4';
      div.id = roomId;
      div.innerHTML = `
        <div class="flex gap-3 items-center mb-3">
          <input value="${escapeHtml(name)}" autocomplete="off" placeholder="Room or area name" class="text-lg font-semibold bg-transparent border-b flex-1 min-w-0" data-room-name>
          <button type="button" class="remove-room text-sm text-red-600">Remove</button>
        </div>
        <div class="space-y-3" data-items></div>
        <button type="button" class="add-surface mt-3 text-sm text-blue-600">Add surface</button>
      `;
      document.getElementById('rooms-container').appendChild(div);
      if (templateItems.length) {
        templateItems.forEach(item => addSurface(roomId, item));
      } else {
        addSurface(roomId);
      }
    }

    function findRateForTemplateItem(item = {}) {
      if (item.productionRateId && rates.some(rate => rate.id === item.productionRateId)) return item.productionRateId;
      const category = String(item.category || '').toLowerCase().replace(/[^a-z0-9]/g, '');
      const singularCategory = category.endsWith('s') ? category.slice(0, -1) : category;
      const match = rates.find(rate => {
        const rateCategory = String(rate.category || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        const singularRateCategory = rateCategory.endsWith('s') ? rateCategory.slice(0, -1) : rateCategory;
        const rateSurface = String(rate.surfaceType || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        const rateDescription = String(rate.description || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        return rateCategory === category ||
          rateCategory === singularCategory ||
          singularRateCategory === category ||
          singularRateCategory === singularCategory ||
          rateSurface === category ||
          rateDescription.includes(category) ||
          rateDescription.includes(singularCategory);
      });
      return match?.id || '';
    }

    function addSurface(roomId, item = {}) {
      const container = document.querySelector(`#${roomId} [data-items]`);
      const div = document.createElement('div');
      div.className = 'border rounded-lg p-3 bg-gray-50';
      const rateId = findRateForTemplateItem(item);
      const prepLevel = item.prepLevel || 'standard';
      const quantity = item.quantity || '';
      div.innerHTML = `
        <div class="grid sm:grid-cols-2 gap-2 mb-2">
          <select class="px-2 py-2 border rounded text-sm" data-field="rateId">
            <option value="">Select surface...</option>
            ${rateOptions()}
          </select>
          <select class="px-2 py-2 border rounded text-sm" data-field="prepLevel">
            <option value="none" ${prepLevel === 'none' ? 'selected' : ''}>No prep</option>
            <option value="light" ${prepLevel === 'light' ? 'selected' : ''}>Light prep</option>
            <option value="standard" ${prepLevel === 'standard' ? 'selected' : ''}>Standard prep</option>
            <option value="heavy" ${prepLevel === 'heavy' ? 'selected' : ''}>Heavy prep</option>
          </select>
        </div>
        <div class="grid grid-cols-3 gap-2 mb-2">
          <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Width" class="px-2 py-2 border rounded text-sm" data-field="width">
          <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Height" class="px-2 py-2 border rounded text-sm" data-field="height">
          <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Qty" value="${escapeHtml(quantity)}" class="px-2 py-2 border rounded text-sm" data-field="quantity">
        </div>
        <div class="flex justify-between items-center text-sm">
          <span class="text-gray-600" data-line-total>$0.00</span>
          <button type="button" class="remove-surface text-red-600">Remove</button>
        </div>
      `;
      container.appendChild(div);
      div.querySelector('[data-field="rateId"]').value = rateId;
    }

    function collectItems() {
      const taxRate = Number(settings.salesTaxRate || 0);
      const materialMarkup = Number(settings.materialMarkupPercent || 0) / 100;
      const paint = selectedMaterial(document.getElementById('paint-material').value);
      const primer = selectedMaterial(document.getElementById('primer-material').value);
      const items = [];
      let labor = 0;
      let materials = 0;
      let hours = 0;

      document.querySelectorAll('#rooms-container > div').forEach(room => {
        const roomName = room.querySelector('[data-room-name]').value.trim() || 'Area';
        room.querySelectorAll('[data-items] > div').forEach(surface => {
          const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
          if (!rate) return;
          const width = Number(surface.querySelector('[data-field="width"]').value || 0);
          const height = Number(surface.querySelector('[data-field="height"]').value || 0);
          const manualQty = Number(surface.querySelector('[data-field="quantity"]').value || 0);
          const quantity = manualQty || (width && height ? width * height : 0);
          if (quantity <= 0) return;
          if (!manualQty && width && height) surface.querySelector('[data-field="quantity"]').value = quantity.toFixed(1);

          const prep = surface.querySelector('[data-field="prepLevel"]').value;
          const itemHours = (quantity / Number(rate.ratePerHour || 1)) * Number(rate.coats || 2) * (prepMultipliers[prep] || 1.2);
          const itemLabor = itemHours * Number(rate.hourlyRate || settings.defaultLaborRate || 65);
          const isPrimerHeavy = prep === 'heavy' || /primer|prep|cabinet/i.test(`${rate.category} ${rate.description}`);
          const material = isPrimerHeavy && primer ? primer : paint;
          const productCost = materialCostForQuantity(quantity, material);
          const fallbackMaterialUnit = Number(rate.hourlyRate || settings.defaultLaborRate || 65) * 0.12;
          const itemMaterials = productCost ? productCost.price : quantity * fallbackMaterialUnit * (1 + materialMarkup);
          const itemTotal = itemLabor + itemMaterials;

          hours += itemHours;
          labor += itemLabor;
          materials += itemMaterials;
          items.push({
            desc: `${roomName}: ${rate.description || `${rate.category} ${rate.surfaceType}`}`,
            qty: 1,
            rate: Number(itemTotal.toFixed(2)),
            category: rate.unit,
            notes: `${quantity.toFixed(1)} ${rate.unit}, ${itemHours.toFixed(1)} labor hours, ${prep} prep${material ? `, ${material.brand || ''} ${material.name}` : ''}`,
            material: material ? {
              id: material.id,
              name: material.name,
              brand: material.brand,
              supplier: material.supplier,
              unit: material.unit,
              quantity: productCost?.units,
              costPerUnit: Number(material.costPerUnit || 0),
              markupPercent: Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0),
              price: productCost ? Number(productCost.price.toFixed(2)) : Number(itemMaterials.toFixed(2)),
            } : undefined,
          });
          surface.querySelector('[data-line-total]').textContent = money(itemTotal);
        });
      });

      const subtotal = labor + materials;
      const tax = subtotal * taxRate;
      return { items, hours, labor, materials, tax, total: subtotal + tax };
    }

    function buildPackages() {
      const result = collectItems();
      if (result.items.length === 0) return [];
      return [{
        name: 'proposal',
        subtotal: Number((result.labor + result.materials).toFixed(2)),
        tax: Number(result.tax.toFixed(2)),
        total: Number(result.total.toFixed(2)),
        items: result.items,
        lineItems: result.items,
      }];
    }

    function calculateTotal() {
      const result = collectItems();
      document.getElementById('total-hours').textContent = result.hours.toFixed(1);
      document.getElementById('labor-total').textContent = money(result.labor);
      document.getElementById('materials-total').textContent = money(result.materials);
      document.getElementById('tax-total').textContent = money(result.tax);
      document.getElementById('total-cost').textContent = money(result.total);
    }

    document.getElementById('add-room').addEventListener('click', () => addRoom());
    document.getElementById('retry-setup').addEventListener('click', () => {
      loadSetup().catch((err) => {
        console.error('Failed to load production estimator', err);
        showSetupError(err.message || 'Failed to load estimator setup');
      });
    });
    document.getElementById('rooms-container').addEventListener('click', (event) => {
      if (event.target.classList.contains('remove-room')) event.target.closest('#rooms-container > div').remove();
      if (event.target.classList.contains('add-surface')) addSurface(event.target.closest('#rooms-container > div').id);
      if (event.target.classList.contains('remove-surface')) event.target.closest('[data-items] > div').remove();
      calculateTotal();
    });
    document.addEventListener('input', (event) => {
      if (event.target.closest('main')) calculateTotal();
    });
    document.addEventListener('change', (event) => {
      if (event.target.closest('main')) calculateTotal();
    });

    document.getElementById('save-estimate').addEventListener('click', async () => {
      const button = document.getElementById('save-estimate');
      const status = document.getElementById('save-status');
      const leadId = document.getElementById('lead-select').value;
      const packages = buildPackages();
      if (!leadId) {
        window.showToast('Select a customer first', 'error');
        return;
      }
      if (packages.length === 0) {
        window.showToast('Add at least one measured surface', 'error');
        return;
      }

      try {
        button.disabled = true;
        button.textContent = 'Creating estimate...';
        status.textContent = 'Creating estimate and opening the customer proposal...';
        status.classList.remove('hidden');
        const { data } = await apiJson(`${API_URL}/v1/estimates`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ leadId, packages }),
        });
        window.showToast('Estimate created. Opening it now.');
        window.location.href = `/estimates/${data.id}`;
      } catch (err) {
        window.showToast(err.message || 'Failed to create estimate', 'error');
        status.textContent = err.message || 'Failed to create estimate';
        button.disabled = false;
        button.textContent = 'Create Estimate';
      }
    });

    loadSetup().catch((err) => {
      console.error('Failed to load production estimator', err);
      showSetupError(err.message || 'Failed to load estimator setup');
    });
  </script>
</Base>
