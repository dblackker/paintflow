---
import Base from '../../layouts/Base.astro';
---

<Base title="Production Estimate">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Production Estimate</h2>
        <p class="text-sm text-gray-600 mt-1">Build pricing from measured surfaces, prep level, production rates, labor, and materials.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <a href="/templates" class="w-full sm:w-auto text-center px-4 py-2 border rounded-lg bg-white hover:bg-gray-50">Templates</a>
        <a href="/estimates/new" class="w-full sm:w-auto text-center px-4 py-2 border rounded-lg bg-white hover:bg-gray-50">Quick estimate</a>
      </div>
    </div>

    <div id="setup-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-5">
      <p class="font-medium">Estimator setup could not load</p>
      <p class="text-sm mt-1" id="setup-error-message"></p>
      <div class="flex flex-wrap gap-3 mt-3">
        <button id="retry-setup" type="button" class="px-3 py-2 bg-red-700 text-white rounded-lg text-sm">Retry</button>
        <a href="/settings" class="px-3 py-2 border border-red-300 rounded-lg text-sm">Check settings</a>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_340px] gap-5">
      <section class="space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">Customer</label>
          <select id="lead-select" class="w-full px-3 py-3 border rounded-lg text-base">
            <option>Loading...</option>
          </select>
        </div>

        <div id="rooms-container" class="space-y-4"></div>
        <button id="add-room" class="w-full py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-blue-500 hover:text-blue-600">
          Add Room or Area
        </button>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <h2 class="font-semibold text-gray-900">Add-ons & Adjustments</h2>
              <p class="text-sm text-gray-600">Add trip charges, prep allowances, repairs, discounts, or other estimate-specific line items.</p>
            </div>
            <button id="add-line-item" type="button" class="px-3 py-2 bg-blue-600 text-white rounded-lg text-sm">Add Line</button>
          </div>
          <div id="line-items-container" class="space-y-3"></div>
        </div>
      </section>

      <aside class="space-y-4 lg:sticky lg:top-20 self-start">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Estimate Summary</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-600">Labor hours</span><span id="total-hours" class="font-medium">0.0</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Labor</span><span id="labor-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Materials</span><span id="materials-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Adjustments</span><span id="adjustments-total" class="font-medium">$0.00</span></div>
            <label class="flex items-center justify-between gap-3 border-t pt-2">
              <span class="text-gray-600">Discount</span>
              <input id="discount" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="0" class="w-28 px-2 py-1 border rounded text-right">
            </label>
            <div class="flex justify-between"><span class="text-gray-600">Tax</span><span id="tax-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between border-t pt-2 text-base"><span class="font-semibold">Proposal total</span><span id="total-cost" class="font-bold text-blue-600">$0.00</span></div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Paint Products</h2>
          <div class="space-y-3 text-sm">
            <label class="block">
              <span class="text-gray-600">Wall/finish paint</span>
              <select id="paint-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <label class="block">
              <span class="text-gray-600">Primer</span>
              <select id="primer-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <p id="material-note" class="text-xs text-gray-500"></p>
          </div>
          <button id="save-estimate" class="w-full mt-4 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60">
            Create Estimate
          </button>
          <p id="save-status" class="hidden mt-3 text-sm text-gray-600" aria-live="polite"></p>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const prepMultipliers = { none: 0.8, light: 1, standard: 1.2, heavy: 1.5 };
    let rates = [];
    let materialsCatalog = [];
    let settings = {};
    let roomCounter = 0;

    function money(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function apiJson(url, options = {}) {
      let res;
      try {
        res = await fetch(url, { credentials: 'include', ...options });
      } catch (err) {
        throw new Error(`Cannot reach the PaintFlow API at ${API_URL}. Start the API dev server or set PUBLIC_API_URL to the running API.`);
      }
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function showSetupError(message) {
      document.getElementById('setup-error-message').textContent = message;
      document.getElementById('setup-error').classList.remove('hidden');
    }

    function clearSetupError() {
      document.getElementById('setup-error-message').textContent = '';
      document.getElementById('setup-error').classList.add('hidden');
    }

    async function loadSetup() {
      clearSetupError();
      const [ratesRes, leadsRes, settingsRes, materialsRes] = await Promise.all([
        apiJson(`${API_URL}/v1/production-rates`),
        apiJson(`${API_URL}/v1/leads?limit=200`),
        apiJson(`${API_URL}/v1/settings/org`),
        apiJson(`${API_URL}/v1/materials`),
      ]);
      rates = ratesRes.data;
      settings = settingsRes.data;
      materialsCatalog = materialsRes.data || [];
      document.getElementById('lead-select').innerHTML =
        '<option value="">Select customer...</option>' +
        leadsRes.data.map(lead => `<option value="${lead.id}">${escapeHtml(lead.name)}</option>`).join('');
      renderMaterialSelectors();
      const templateRooms = consumeTemplateRooms();
      if (templateRooms.length) {
        templateRooms.forEach(room => addRoom(room.name || 'Template room', room.items || []));
        window.showToast('Template loaded into the production estimator.');
      } else {
        addRoom('Interior');
      }
      calculateTotal();
    }

    function rateOptions() {
      const categories = [...new Set(rates.map(rate => rate.category || 'Other'))];
      return categories.map(category => {
        const options = rates
          .filter(rate => (rate.category || 'Other') === category)
          .map(rate => `<option value="${rate.id}">${escapeHtml(cleanRateLabel(rate))} (${rate.ratePerHour} ${rate.unit}/hr)</option>`)
          .join('');
        return `<optgroup label="${escapeHtml(category)}">${options}</optgroup>`;
      }).join('');
    }

    function cleanRateLabel(rate) {
      return String(rate.description || `${rate.category} ${rate.surfaceType}`)
        .replace(/\s*[,\-–—]?\s*(no|light|standard|heavy)\s+prep\b/ig, '')
        .replace(/\s{2,}/g, ' ')
        .trim();
    }

    function isExteriorRate(rate) {
      const text = `${rate?.category || ''} ${rate?.surfaceType || ''} ${rate?.description || ''}`.toLowerCase();
      return /exterior|siding|soffit|fascia|eave|shutter|corner board|cornerboard/.test(text);
    }

    function rateKind(rate) {
      const category = String(rate?.category || '').toLowerCase();
      const description = String(rate?.description || '').toLowerCase();
      const unit = String(rate?.unit || 'sqft').toLowerCase();
      const text = `${category} ${description}`;

      if (/soffit|eave/.test(text)) return 'soffit';
      if (/fascia/.test(text)) return 'fascia';
      if (/corner board|cornerboard|corner/.test(text)) return 'corner_boards';
      if (/exterior_trim|window.*door.*trim|door.*window.*trim/.test(text)) return 'exterior_trim';
      if (/window.*trim|trim.*window|shutter/.test(text)) return 'window_trim';
      if (/door.*trim|trim.*door/.test(text)) return 'door_trim';
      if (/exterior|siding/.test(text) && unit === 'sqft') return 'exterior_body';
      if (unit === 'linear_ft') return 'linear';
      if (unit === 'each') return 'count';
      if (category.includes('wall') || description.includes('wall')) return 'wall_area';
      if (category.includes('ceiling') || description.includes('ceiling')) return 'ceiling_area';
      return 'area';
    }

    function measurementConfig(rate) {
      const kind = rateKind(rate);

      if (kind === 'soffit') {
        return {
          widthLabel: 'Eave run',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Soffit depth',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Soffit area uses eave linear feet times soffit depth. If blank, exterior assumptions are used.',
        };
      }

      if (kind === 'fascia') {
        return {
          widthLabel: 'Fascia run',
          widthPlaceholder: 'Linear ft',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Lin ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: false,
          showQty: true,
          helper: 'Fascia is normally estimated from roofline or house perimeter, then overridden if measured.',
        };
      }

      if (kind === 'exterior_body') {
        return {
          widthLabel: 'Wall run',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Avg height',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Exterior body uses perimeter times wall height and stories, less estimated openings when assumptions are filled.',
        };
      }

      if (kind === 'window_trim') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Window count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Window trim can use the exterior window count with a default trim allowance per window.',
        };
      }

      if (kind === 'exterior_trim') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Lin ft override',
          qtyPlaceholder: 'Optional',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Exterior trim uses window and door counts from the area assumptions, with a linear-foot override when measured.',
        };
      }

      if (kind === 'door_trim') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Door count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Door trim can use the exterior door count with a default trim allowance per door.',
        };
      }

      if (kind === 'corner_boards') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Lin ft override',
          qtyPlaceholder: 'Optional',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Corner board footage is estimated from corner count times wall height and stories.',
        };
      }

      if (kind === 'linear') {
        return {
          widthLabel: 'Linear feet',
          widthPlaceholder: 'Length',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Lin ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: false,
          showQty: true,
          helper: 'Linear items use measured length, or a direct override.',
        };
      }

      if (kind === 'count') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Doors, cabinet fronts, shutters, and similar items are measured by count.',
        };
      }

      if (kind === 'wall_area') {
        return {
          widthLabel: 'Perimeter',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Wall height',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Wall area uses room perimeter times wall height, with optional direct square-foot override.',
        };
      }

      if (kind === 'ceiling_area') {
        return {
          widthLabel: 'Length',
          widthPlaceholder: 'Feet',
          heightLabel: 'Width',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Ceilings use length times width, with optional direct square-foot override.',
        };
      }

      return {
        widthLabel: 'Width',
        widthPlaceholder: 'Feet',
        heightLabel: 'Height',
        heightPlaceholder: 'Feet',
        qtyLabel: 'Sq ft override',
        qtyPlaceholder: 'Optional',
        showWidth: true,
        showHeight: true,
        showQty: true,
        helper: 'Area surfaces use width times height, with optional direct square-foot override.',
      };
    }

    function renderMaterialSelectors() {
      const paintOptions = materialsCatalog
        .filter(material => ['paint', 'primer'].includes(String(material.category || '').toLowerCase()))
        .map(material => `<option value="${material.id}">${escapeHtml([material.brand, material.name].filter(Boolean).join(' - '))} (${money(material.costPerUnit)}/${escapeHtml(material.unit)})</option>`)
        .join('');
      const noMaterial = '<option value="">Use pricing default</option>';
      document.getElementById('paint-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('primer-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('material-note').textContent = paintOptions
        ? 'Coverage, unit cost, and markup are pulled from Materials.'
        : 'Add paint and primer products in Materials to calculate product-specific costs.';
    }

    function selectedMaterial(id) {
      return materialsCatalog.find(material => material.id === id);
    }

    function materialCostForQuantity(quantity, material) {
      if (!material || !material.coverageSqFt || !material.costPerUnit) return null;
      const coverage = Number(material.coverageSqFt || 0);
      if (coverage <= 0) return null;
      const units = Math.max(1, Math.ceil(quantity / coverage));
      const cost = units * Number(material.costPerUnit || 0);
      const markup = Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0);
      const price = cost * (1 + markup / 100);
      return { units, cost, markup, price };
    }

    function consumeTemplateRooms() {
      const raw = sessionStorage.getItem('templateRooms');
      if (!raw) return [];
      sessionStorage.removeItem('templateRooms');
      try {
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch (err) {
        window.showToast('Template data could not be loaded', 'error');
        return [];
      }
    }

    function addRoom(name = '', templateItems = []) {
      roomCounter++;
      const roomId = `room-${roomCounter}`;
      const div = document.createElement('div');
      div.className = 'bg-white rounded-lg shadow-sm border p-4';
      div.id = roomId;
      div.innerHTML = `
        <div class="flex flex-col sm:flex-row gap-3 sm:items-center mb-3">
          <input value="${escapeHtml(name)}" autocomplete="off" placeholder="Room, side, or area name" class="text-lg font-semibold bg-transparent border-b flex-1 min-w-0" data-room-name>
          <select class="px-2 py-2 border rounded text-sm" data-area-type>
            <option value="interior">Interior</option>
            <option value="exterior">Exterior</option>
          </select>
          <div class="flex gap-3">
            <button type="button" class="copy-room text-sm text-blue-600">Copy</button>
            <button type="button" class="remove-room text-sm text-red-600">Remove</button>
          </div>
        </div>
        <div class="hidden mb-4 rounded-lg border bg-blue-50 p-3" data-exterior-assumptions>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
            <label>
              <span class="text-xs text-blue-900">House perimeter</span>
              <input data-exterior="perimeter" type="number" min="0" step="1" inputmode="decimal" autocomplete="off" placeholder="Linear ft" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Stories</span>
              <select data-exterior="stories" class="mt-1 w-full px-2 py-2 border rounded">
                <option value="1">1</option>
                <option value="1.5">1.5</option>
                <option value="2">2</option>
                <option value="3">3</option>
              </select>
            </label>
            <label>
              <span class="text-xs text-blue-900">Wall height</span>
              <input data-exterior="wallHeight" type="number" min="0" step="0.5" inputmode="decimal" autocomplete="off" value="10" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Soffit depth</span>
              <input data-exterior="soffitDepth" type="number" min="0" step="0.25" inputmode="decimal" autocomplete="off" value="2" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Windows</span>
              <input data-exterior="windows" type="number" min="0" step="1" inputmode="numeric" autocomplete="off" value="0" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Doors</span>
              <input data-exterior="doors" type="number" min="0" step="1" inputmode="numeric" autocomplete="off" value="0" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Corners</span>
              <input data-exterior="corners" type="number" min="0" step="1" inputmode="numeric" autocomplete="off" value="4" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
            <label>
              <span class="text-xs text-blue-900">Roofline factor</span>
              <input data-exterior="rooflineFactor" type="number" min="0" step="0.05" inputmode="decimal" autocomplete="off" value="1" class="mt-1 w-full px-2 py-2 border rounded">
            </label>
          </div>
          <p class="mt-2 text-xs text-blue-900">Use field assumptions for exterior trim, fascia, soffit, and siding when exact ladder measurements are impractical. Any line can still be overridden.</p>
        </div>
        <div class="space-y-3" data-items></div>
        <button type="button" class="add-surface mt-3 text-sm text-blue-600">Add surface</button>
      `;
      document.getElementById('rooms-container').appendChild(div);
      syncAreaType(div);
      if (templateItems.length) {
        templateItems.forEach(item => addSurface(roomId, item));
      } else {
        addSurface(roomId);
      }
      return div;
    }

    function findRateForTemplateItem(item = {}) {
      if (item.productionRateId && rates.some(rate => rate.id === item.productionRateId)) return item.productionRateId;
      const category = String(item.category || '').toLowerCase().replace(/[^a-z0-9]/g, '');
      const singularCategory = category.endsWith('s') ? category.slice(0, -1) : category;
      const match = rates.find(rate => {
        const rateCategory = String(rate.category || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        const singularRateCategory = rateCategory.endsWith('s') ? rateCategory.slice(0, -1) : rateCategory;
        const rateSurface = String(rate.surfaceType || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        const rateDescription = String(rate.description || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        return rateCategory === category ||
          rateCategory === singularCategory ||
          singularRateCategory === category ||
          singularRateCategory === singularCategory ||
          rateSurface === category ||
          rateDescription.includes(category) ||
          rateDescription.includes(singularCategory);
      });
      return match?.id || '';
    }

    function addSurface(roomId, item = {}) {
      const container = document.querySelector(`#${roomId} [data-items]`);
      const div = document.createElement('div');
      div.className = 'border rounded-lg p-3 bg-gray-50';
      const rateId = findRateForTemplateItem(item);
      const prepLevel = item.prepLevel || 'standard';
      const quantity = item.quantity || '';
      const coats = item.coats || 2;
      div.innerHTML = `
        <div class="grid sm:grid-cols-2 gap-2 mb-2">
          <select class="px-2 py-2 border rounded text-sm" data-field="rateId">
            <option value="">Select surface...</option>
            ${rateOptions()}
          </select>
          <select class="px-2 py-2 border rounded text-sm" data-field="prepLevel">
            <option value="none" ${prepLevel === 'none' ? 'selected' : ''}>No prep</option>
            <option value="light" ${prepLevel === 'light' ? 'selected' : ''}>Light prep</option>
            <option value="standard" ${prepLevel === 'standard' ? 'selected' : ''}>Standard prep</option>
            <option value="heavy" ${prepLevel === 'heavy' ? 'selected' : ''}>Heavy prep</option>
          </select>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-1">
          <label class="block" data-measure="width">
            <span class="text-xs text-gray-600" data-label="width">Width</span>
            <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Feet" value="${escapeHtml(item.width || '')}" class="mt-1 w-full px-2 py-2 border rounded text-sm" data-field="width">
          </label>
          <label class="block" data-measure="height">
            <span class="text-xs text-gray-600" data-label="height">Height</span>
            <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Feet" value="${escapeHtml(item.height || '')}" class="mt-1 w-full px-2 py-2 border rounded text-sm" data-field="height">
          </label>
          <label class="block" data-measure="quantity">
            <span class="text-xs text-gray-600" data-label="quantity">Qty</span>
            <input type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" placeholder="Optional" value="${escapeHtml(quantity)}" class="mt-1 w-full px-2 py-2 border rounded text-sm" data-field="quantity">
          </label>
          <label class="block">
            <span class="text-xs text-gray-600">Coats</span>
            <select class="mt-1 w-full px-2 py-2 border rounded text-sm" data-field="coats">
              <option value="1" ${Number(coats) === 1 ? 'selected' : ''}>1 coat</option>
              <option value="2" ${Number(coats) === 2 ? 'selected' : ''}>2 coats</option>
              <option value="3" ${Number(coats) === 3 ? 'selected' : ''}>3 coats</option>
            </select>
          </label>
        </div>
        <p class="mb-2 text-xs text-gray-500" data-measure-helper></p>
        <div class="grid grid-cols-2 gap-2 mb-2">
          <input type="number" step="0.25" inputmode="decimal" autocomplete="off" placeholder="Prep hrs +/-" value="${escapeHtml(item.prepAdjustmentHours || '')}" class="px-2 py-2 border rounded text-sm" data-field="prepAdjustmentHours">
          <input type="number" step="0.25" inputmode="decimal" autocomplete="off" placeholder="Paint hrs +/-" value="${escapeHtml(item.paintAdjustmentHours || '')}" class="px-2 py-2 border rounded text-sm" data-field="paintAdjustmentHours">
        </div>
        <div class="flex justify-between items-center text-sm">
          <label class="inline-flex items-center gap-2 text-gray-600">
            <input type="checkbox" class="rounded border-gray-300" data-field="customerVisible" ${item.customerVisible === false ? '' : 'checked'}>
            Show on proposal
          </label>
          <div class="flex items-center gap-3">
            <span class="text-gray-600" data-line-total>$0.00</span>
            <button type="button" class="copy-surface text-blue-600">Copy</button>
            <button type="button" class="remove-surface text-red-600">Remove</button>
          </div>
        </div>
      `;
      container.appendChild(div);
      div.querySelector('[data-field="rateId"]').value = rateId;
      syncSurfaceMeasurement(div);
    }

    function syncSurfaceMeasurement(surface) {
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      const config = measurementConfig(rate);
      const room = surface.closest('#rooms-container > div');
      const widthWrap = surface.querySelector('[data-measure="width"]');
      const heightWrap = surface.querySelector('[data-measure="height"]');
      const qtyWrap = surface.querySelector('[data-measure="quantity"]');

      if (rate && isExteriorRate(rate) && room) {
        room.querySelector('[data-area-type]').value = 'exterior';
        syncAreaType(room);
      }

      widthWrap.classList.toggle('hidden', !config.showWidth);
      heightWrap.classList.toggle('hidden', !config.showHeight);
      qtyWrap.classList.toggle('hidden', !config.showQty);
      surface.querySelector('[data-label="width"]').textContent = config.widthLabel;
      surface.querySelector('[data-label="height"]').textContent = config.heightLabel;
      surface.querySelector('[data-label="quantity"]').textContent = config.qtyLabel;
      surface.querySelector('[data-field="width"]').placeholder = config.widthPlaceholder;
      surface.querySelector('[data-field="height"]').placeholder = config.heightPlaceholder;
      surface.querySelector('[data-field="quantity"]').placeholder = config.qtyPlaceholder;
      surface.querySelector('[data-measure-helper]').textContent = config.helper;
    }

    function syncAreaType(room) {
      const isExterior = room.querySelector('[data-area-type]').value === 'exterior';
      room.querySelector('[data-exterior-assumptions]').classList.toggle('hidden', !isExterior);
    }

    function exteriorAssumptions(room) {
      const read = (key, fallback = 0) => Number(room?.querySelector(`[data-exterior="${key}"]`)?.value || fallback);
      return {
        perimeter: read('perimeter'),
        stories: read('stories', 1),
        wallHeight: read('wallHeight', 10),
        soffitDepth: read('soffitDepth', 2),
        windows: read('windows'),
        doors: read('doors'),
        corners: read('corners', 4),
        rooflineFactor: read('rooflineFactor', 1),
      };
    }

    function exteriorQuantityFromAssumptions(room, rate) {
      if (!room || room.querySelector('[data-area-type]')?.value !== 'exterior') return 0;
      const assumptions = exteriorAssumptions(room);
      const roofline = assumptions.perimeter * Math.max(assumptions.rooflineFactor || 1, 0);
      const openingAllowance = (assumptions.windows * 15) + (assumptions.doors * 21);

      switch (rateKind(rate)) {
        case 'exterior_body':
          return Math.max(0, (assumptions.perimeter * assumptions.wallHeight * assumptions.stories) - openingAllowance);
        case 'soffit':
          return Math.max(0, roofline * assumptions.soffitDepth);
        case 'fascia':
          return Math.max(0, roofline);
        case 'corner_boards':
          return Math.max(0, assumptions.corners * assumptions.wallHeight * assumptions.stories);
        case 'exterior_trim':
          return Math.max(0, (assumptions.windows * 18) + (assumptions.doors * 20));
        case 'window_trim':
          return Math.max(0, assumptions.windows * 18);
        case 'door_trim':
          return Math.max(0, assumptions.doors * 20);
        default:
          return 0;
      }
    }

    function collectSurfaceData(surface) {
      return {
        productionRateId: surface.querySelector('[data-field="rateId"]').value,
        prepLevel: surface.querySelector('[data-field="prepLevel"]').value,
        width: surface.querySelector('[data-field="width"]').value,
        height: surface.querySelector('[data-field="height"]').value,
        quantity: surface.querySelector('[data-field="quantity"]').value,
        coats: surface.querySelector('[data-field="coats"]').value,
        prepAdjustmentHours: surface.querySelector('[data-field="prepAdjustmentHours"]').value,
        paintAdjustmentHours: surface.querySelector('[data-field="paintAdjustmentHours"]').value,
        customerVisible: surface.querySelector('[data-field="customerVisible"]').checked,
      };
    }

    function addLineItem(item = {}) {
      const div = document.createElement('div');
      div.className = 'grid gap-2 sm:grid-cols-[1fr_90px_110px_120px_auto] items-end border rounded-lg p-3 bg-gray-50';
      div.innerHTML = `
        <label class="block">
          <span class="text-xs text-gray-600">Description</span>
          <input data-field="desc" autocomplete="off" value="${escapeHtml(item.desc || '')}" placeholder="Add-on or adjustment" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Qty</span>
          <input data-field="qty" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${escapeHtml(item.qty || 1)}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Price</span>
          <input data-field="rate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${escapeHtml(item.rate || 0)}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Category</span>
          <select data-field="category" class="mt-1 w-full px-3 py-2 border rounded-lg">
            ${['add-on', 'prep', 'repair', 'discount', 'other'].map(category => `<option value="${category}" ${item.category === category ? 'selected' : ''}>${category}</option>`).join('')}
          </select>
        </label>
        <div class="flex items-center justify-between gap-3">
          <label class="inline-flex items-center gap-2 text-xs text-gray-600">
            <input type="checkbox" class="rounded border-gray-300" data-field="customerVisible" ${item.customerVisible === false ? '' : 'checked'}>
            Show
          </label>
          <button type="button" class="remove-line-item text-sm text-red-600">Remove</button>
        </div>
      `;
      document.getElementById('line-items-container').appendChild(div);
      calculateTotal();
    }

    function measuredQuantity(surface, rate) {
      const config = measurementConfig(rate);
      const room = surface.closest('#rooms-container > div');
      const width = Number(surface.querySelector('[data-field="width"]').value || 0);
      const height = Number(surface.querySelector('[data-field="height"]').value || 0);
      const manualQty = Number(surface.querySelector('[data-field="quantity"]').value || 0);
      const assumptionQty = exteriorQuantityFromAssumptions(room, rate);

      if (String(rate?.unit || '').toLowerCase() === 'linear_ft') {
        const quantity = manualQty || width || assumptionQty;
        return { width, height: 0, quantity };
      }

      if (String(rate?.unit || '').toLowerCase() === 'each') {
        return { width: 0, height: 0, quantity: manualQty || assumptionQty };
      }

      const measuredArea = width && height ? width * height : 0;
      const quantity = manualQty || measuredArea || assumptionQty;
      if (!manualQty && measuredArea) surface.querySelector('[data-field="quantity"]').value = measuredArea.toFixed(1);
      return { width: config.showWidth ? width : 0, height: config.showHeight ? height : 0, quantity };
    }

    function collectItems() {
      const taxRate = Number(settings.salesTaxRate || 0);
      const materialMarkup = Number(settings.materialMarkupPercent || 0) / 100;
      const paint = selectedMaterial(document.getElementById('paint-material').value);
      const primer = selectedMaterial(document.getElementById('primer-material').value);
      const items = [];
      let labor = 0;
      let materials = 0;
      let adjustments = 0;
      let hours = 0;

      document.querySelectorAll('#rooms-container > div').forEach(room => {
        const roomName = room.querySelector('[data-room-name]').value.trim() || 'Area';
        room.querySelectorAll('[data-items] > div').forEach(surface => {
          const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
          if (!rate) return;
          const { width, height, quantity } = measuredQuantity(surface, rate);
          if (quantity <= 0) return;

          const prep = surface.querySelector('[data-field="prepLevel"]').value;
          const coats = Math.max(1, Number(surface.querySelector('[data-field="coats"]').value || rate.coats || 2));
          const prepAdjustmentHours = Number(surface.querySelector('[data-field="prepAdjustmentHours"]').value || 0);
          const paintAdjustmentHours = Number(surface.querySelector('[data-field="paintAdjustmentHours"]').value || 0);
          const baseHours = (quantity / Number(rate.ratePerHour || 1)) * coats * (prepMultipliers[prep] || 1.2);
          const itemHours = Math.max(0, baseHours + prepAdjustmentHours + paintAdjustmentHours);
          const itemLabor = itemHours * Number(rate.hourlyRate || settings.defaultLaborRate || 65);
          const isPrimerHeavy = prep === 'heavy' || /primer|prep|cabinet/i.test(`${rate.category} ${rate.description}`);
          const material = isPrimerHeavy && primer ? primer : paint;
          const productCost = materialCostForQuantity(quantity, material);
          const fallbackMaterialUnit = Number(rate.hourlyRate || settings.defaultLaborRate || 65) * 0.12;
          const itemMaterials = productCost ? productCost.price : quantity * fallbackMaterialUnit * (1 + materialMarkup);
          const itemTotal = itemLabor + itemMaterials;

          hours += itemHours;
          labor += itemLabor;
          materials += itemMaterials;
          items.push({
            desc: `${roomName}: ${rate.description || `${rate.category} ${rate.surfaceType}`}`,
            qty: 1,
            rate: Number(itemTotal.toFixed(2)),
            category: rate.unit,
            kind: 'surface',
            customerVisible: surface.querySelector('[data-field="customerVisible"]').checked,
            dimensions: { width, height, quantity, unit: rate.unit },
            notes: `${quantity.toFixed(1)} ${rate.unit}, ${coats} coat${coats === 1 ? '' : 's'}, ${itemHours.toFixed(1)} labor hours, ${prep} prep${material ? `, ${material.brand || ''} ${material.name}` : ''}`,
            labor: {
              hours: Number(itemHours.toFixed(2)),
              rate: Number(rate.hourlyRate || settings.defaultLaborRate || 65),
              cost: Number(itemLabor.toFixed(2)),
              coats,
              prepLevel: prep,
              prepAdjustmentHours,
              paintAdjustmentHours,
            },
            material: material ? {
              id: material.id,
              name: material.name,
              brand: material.brand,
              supplier: material.supplier,
              unit: material.unit,
              quantity: productCost?.units,
              costPerUnit: Number(material.costPerUnit || 0),
              markupPercent: Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0),
              price: productCost ? Number(productCost.price.toFixed(2)) : Number(itemMaterials.toFixed(2)),
            } : undefined,
          });
          surface.querySelector('[data-line-total]').textContent = money(itemTotal);
        });
      });

      document.querySelectorAll('#line-items-container > div').forEach(row => {
        const desc = row.querySelector('[data-field="desc"]').value.trim();
        const qty = Number(row.querySelector('[data-field="qty"]').value || 0);
        const rate = Number(row.querySelector('[data-field="rate"]').value || 0);
        if (!desc || qty <= 0 || rate <= 0) return;
        const total = qty * rate;
        adjustments += total;
        items.push({
          desc,
          qty,
          rate,
          category: row.querySelector('[data-field="category"]').value,
          kind: 'line_item',
          customerVisible: row.querySelector('[data-field="customerVisible"]').checked,
          notes: 'Estimate-specific line item',
        });
      });

      const discount = Number(document.getElementById('discount').value || 0);
      const subtotal = labor + materials + adjustments;
      const taxableSubtotal = Math.max(subtotal - discount, 0);
      const tax = taxableSubtotal * taxRate;
      return { items, hours, labor, materials, adjustments, discount, tax, subtotal, total: taxableSubtotal + tax };
    }

    function buildPackages() {
      const result = collectItems();
      if (result.items.length === 0) return [];
      return [{
        name: 'proposal',
        subtotal: Number(result.subtotal.toFixed(2)),
        discount: Number(result.discount.toFixed(2)),
        tax: Number(result.tax.toFixed(2)),
        total: Number(result.total.toFixed(2)),
        items: result.items,
        lineItems: result.items,
      }];
    }

    function calculateTotal() {
      const result = collectItems();
      document.getElementById('total-hours').textContent = result.hours.toFixed(1);
      document.getElementById('labor-total').textContent = money(result.labor);
      document.getElementById('materials-total').textContent = money(result.materials);
      document.getElementById('adjustments-total').textContent = money(result.adjustments);
      document.getElementById('tax-total').textContent = money(result.tax);
      document.getElementById('total-cost').textContent = money(result.total);
    }

    document.getElementById('add-room').addEventListener('click', () => addRoom());
    document.getElementById('add-line-item').addEventListener('click', () => addLineItem());
    document.getElementById('retry-setup').addEventListener('click', () => {
      loadSetup().catch((err) => {
        console.error('Failed to load production estimator', err);
        showSetupError(err.message || 'Failed to load estimator setup');
      });
    });
    document.getElementById('rooms-container').addEventListener('click', (event) => {
      if (event.target.classList.contains('remove-room')) event.target.closest('#rooms-container > div').remove();
      if (event.target.classList.contains('add-surface')) addSurface(event.target.closest('#rooms-container > div').id);
      if (event.target.classList.contains('remove-surface')) event.target.closest('[data-items] > div').remove();
      if (event.target.classList.contains('copy-surface')) {
        const room = event.target.closest('#rooms-container > div');
        addSurface(room.id, collectSurfaceData(event.target.closest('[data-items] > div')));
      }
      if (event.target.classList.contains('copy-room')) {
        const source = event.target.closest('#rooms-container > div');
        const roomName = source.querySelector('[data-room-name]').value.trim() || 'Area';
        const items = Array.from(source.querySelectorAll('[data-items] > div')).map(collectSurfaceData);
        const copied = addRoom(`${roomName} copy`, items);
        copied.querySelector('[data-area-type]').value = source.querySelector('[data-area-type]').value;
        source.querySelectorAll('[data-exterior]').forEach((input) => {
          copied.querySelector(`[data-exterior="${input.dataset.exterior}"]`).value = input.value;
        });
        syncAreaType(copied);
      }
      calculateTotal();
    });
    document.getElementById('line-items-container').addEventListener('click', (event) => {
      if (event.target.classList.contains('remove-line-item')) {
        event.target.closest('#line-items-container > div').remove();
        calculateTotal();
      }
    });
    document.addEventListener('input', (event) => {
      if (event.target.closest('main')) calculateTotal();
    });
    document.addEventListener('change', (event) => {
      if (event.target.matches('[data-area-type]')) {
        const room = event.target.closest('#rooms-container > div');
        syncAreaType(room);
        room.querySelectorAll('[data-items] > div').forEach(syncSurfaceMeasurement);
      }
      if (event.target.matches('[data-field="rateId"]')) {
        syncSurfaceMeasurement(event.target.closest('[data-items] > div'));
      }
      if (event.target.closest('main')) calculateTotal();
    });

    document.getElementById('save-estimate').addEventListener('click', async () => {
      const button = document.getElementById('save-estimate');
      const status = document.getElementById('save-status');
      const leadId = document.getElementById('lead-select').value;
      const packages = buildPackages();
      if (!leadId) {
        window.showToast('Select a customer first', 'error');
        return;
      }
      if (packages.length === 0) {
        window.showToast('Add at least one measured surface', 'error');
        return;
      }

      try {
        button.disabled = true;
        button.textContent = 'Creating estimate...';
        status.textContent = 'Creating estimate and opening the customer proposal...';
        status.classList.remove('hidden');
        const { data } = await apiJson(`${API_URL}/v1/estimates`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ leadId, packages }),
        });
        window.showToast('Estimate created. Opening it now.');
        window.location.href = `/estimates/${data.id}`;
      } catch (err) {
        window.showToast(err.message || 'Failed to create estimate', 'error');
        status.textContent = err.message || 'Failed to create estimate';
        button.disabled = false;
        button.textContent = 'Create Estimate';
      }
    });

    loadSetup().catch((err) => {
      console.error('Failed to load production estimator', err);
      showSetupError(err.message || 'Failed to load estimator setup');
    });
  </script>
</Base>
