---
import Base from '../../layouts/Base.astro';
---

<Base title="Production Estimate">
  <style>
    @media (max-width: 640px) {
      .production-estimator .production-top-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        width: 100%;
      }
      .production-estimator .production-top-actions > * {
        justify-content: center;
      }
      .production-estimator [data-stage] {
        scroll-margin-top: 4rem;
      }
      .production-room {
        padding: 0.85rem;
      }
      .production-room-header {
        gap: 0.65rem;
      }
      .production-room-actions {
        justify-content: flex-end;
      }
      .production-assumptions {
        padding: 0.75rem;
      }
      .production-assumptions .grid {
        gap: 0.45rem;
      }
      .production-scope-action {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        width: 100%;
      }
      .production-scope-action .btn-primary {
        min-width: 0;
        white-space: normal;
      }
      .production-surface {
        padding: 0.7rem;
      }
      .production-surface [data-measure-helper] {
        display: none;
      }
      .production-surface-actions {
        justify-content: space-between;
        width: 100%;
      }
      .production-estimator aside > div {
        padding: 0.85rem;
      }
    }
  </style>
  <main class="production-estimator max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Production Estimate</h2>
        <p class="text-sm text-gray-600 mt-1">Build pricing from measured substrates, prep level, production rates, labor, and materials.</p>
      </div>
      <div class="production-top-actions flex flex-col sm:flex-row gap-2">
        <a href="/templates" class="btn-secondary btn-sm justify-center">Templates</a>
        <a href="/estimates/new" class="btn-secondary btn-sm justify-center">Quick estimate</a>
      </div>
    </div>

    <div id="setup-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-lg p-4 mb-5">
      <p class="font-medium">Estimator setup could not load</p>
      <p class="text-sm mt-1" id="setup-error-message"></p>
      <div class="flex flex-wrap gap-3 mt-3">
        <button id="retry-setup" type="button" class="btn-primary btn-sm">Retry</button>
        <a href="/settings" class="btn-secondary btn-sm">Check settings</a>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_340px] gap-5">
      <section class="min-w-0 space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-4 scroll-mt-24" data-stage="setup">
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="block">
              <span class="block text-sm font-medium text-gray-700 mb-2">Customer</span>
              <select id="lead-select" class="min-w-0 w-full px-3 py-3 border rounded-lg text-base">
                <option>Loading...</option>
              </select>
            </label>
            <label class="block">
              <span class="block text-sm font-medium text-gray-700 mb-2">Estimate type</span>
              <select id="estimate-type" class="min-w-0 w-full px-3 py-3 border rounded-lg text-base">
                <option value="interior">Interior repaint</option>
                <option value="exterior">Exterior repaint</option>
                <option value="cabinet">Cabinets / specialty</option>
                <option value="custom">Custom / commercial</option>
              </select>
            </label>
          </div>
          <p class="mobile-hide-copy mt-3 text-sm text-gray-600">Choose the estimate type first. The quick-scope builder appears once, then substrates become editable production lines.</p>
        </div>

        <div class="scroll-mt-24 space-y-4" data-stage="scope">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">Rooms & Scope</h2>
              <p id="scope-builder-helper" class="text-sm text-gray-600">Add rooms, elevations, or work spaces, then define the substrates in each one.</p>
            </div>
          </div>
          <div id="quick-scope-builder" class="hidden space-y-3">
            <div id="quick-scope-summary" class="hidden rounded-lg border border-blue-100 bg-blue-50/70 px-3 py-2 text-sm text-blue-950">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <p id="quick-scope-summary-text" class="text-gray-700">Starter scope added. Refine the generated substrates below.</p>
                <button id="edit-quick-scope" type="button" class="btn-text btn-sm justify-center">Review</button>
              </div>
            </div>
            <div id="quick-scope-skip-summary" class="hidden rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-700">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-gray-700">Starter scope skipped. Add rooms, spaces, and substrates manually below.</p>
                <button id="restore-quick-scope" type="button" class="btn-text btn-sm justify-center">Use starter scope</button>
              </div>
            </div>
          </div>
          <div id="rooms-container" class="space-y-4"></div>
          <div id="empty-scope-state" class="rounded-lg border border-dashed border-gray-300 bg-white p-4 text-center">
            <p class="text-sm text-gray-700">Start with a room, exterior elevation, or work space.</p>
            <p class="mt-1 text-xs text-gray-500">Use starter scope for a generated first pass, or add a space manually.</p>
            <button id="start-with-starter-scope" type="button" class="btn-text btn-sm mt-2 justify-center">Use starter scope</button>
          </div>
          <button id="add-room" class="btn-secondary w-full justify-center">
            Add Room or Space
          </button>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4 scroll-mt-24" data-stage="paint">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="font-semibold text-gray-900">Paint Schedule</h2>
              <p class="text-sm text-gray-600">Production handoff by substrate: product, color, status, and order units.</p>
            </div>
            <span id="paint-schedule-count" class="text-sm font-medium text-gray-700">0 substrates</span>
          </div>
          <div id="paint-schedule" class="mt-3 space-y-2 text-sm text-gray-700"></div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4 scroll-mt-24" data-stage="review">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <h2 class="font-semibold text-gray-900">Add-ons & Adjustments</h2>
              <p class="text-sm text-gray-600">Add trip charges, prep allowances, repairs, discounts, or other estimate-specific line items.</p>
            </div>
            <button id="add-line-item" type="button" class="btn-primary btn-sm">Add Line</button>
          </div>
          <div id="line-items-container" class="space-y-3"></div>
        </div>
      </section>

      <aside class="min-w-0 space-y-4 lg:sticky lg:top-20 self-start">
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Estimate Summary</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-gray-600">Labor hours</span><span id="total-hours" class="font-medium">0.0</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Labor</span><span id="labor-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Materials</span><span id="materials-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Adjustments</span><span id="adjustments-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between"><span class="text-gray-600">Customer options</span><span id="optional-total" class="font-medium">$0.00</span></div>
            <label class="flex items-center justify-between gap-3 border-t pt-2">
              <span class="text-gray-600">Discount</span>
              <input id="discount" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="0" class="w-28 px-2 py-1 border rounded text-right">
            </label>
            <div class="flex justify-between"><span class="text-gray-600">Tax</span><span id="tax-total" class="font-medium">$0.00</span></div>
            <div class="flex justify-between border-t pt-2 text-base"><span class="font-semibold">Base proposal total</span><span id="total-cost" class="font-bold text-blue-600">$0.00</span></div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Paint Products</h2>
          <div class="space-y-3 text-sm">
            <label class="block">
              <span class="text-gray-600">Wall/finish paint</span>
              <select id="paint-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <label class="block">
              <span class="text-gray-600">Primer</span>
              <select id="primer-material" class="mt-1 w-full px-3 py-2 border rounded-lg"></select>
            </label>
            <p id="material-note" class="text-xs text-gray-500"></p>
          </div>
          <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
            <button id="save-draft" class="btn-secondary w-full justify-center">
              Save Draft
            </button>
            <button id="save-estimate" class="btn-primary w-full justify-center">
              Send Estimate
            </button>
          </div>
          <p id="save-status" class="hidden mt-3 text-sm text-gray-600" aria-live="polite"></p>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-4">
          <h2 class="font-semibold text-gray-900 mb-3">Production Readiness</h2>
          <div id="production-readiness" class="space-y-2 text-sm text-gray-700"></div>
        </div>
      </aside>
    </div>
  </main>

  <div id="send-preview-modal" class="hidden fixed inset-0 z-50 bg-black/50 p-0 sm:p-4">
    <div class="flex min-h-full items-end justify-center sm:items-center">
      <section class="max-h-[92vh] w-full max-w-3xl overflow-y-auto rounded-t-2xl bg-white shadow-xl sm:rounded-2xl">
        <div class="sticky top-0 z-10 border-b bg-white px-4 py-3 sm:px-5">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold text-gray-950">Review Before Sending</h2>
              <p class="text-sm text-gray-600">This is the customer-facing summary that will be emailed with the proposal link.</p>
            </div>
            <button id="close-send-preview" type="button" class="btn-icon" aria-label="Close preview">X</button>
          </div>
        </div>
        <div id="send-preview-content" class="space-y-4 px-4 py-4 sm:px-5"></div>
        <div class="sticky bottom-0 flex flex-col gap-2 border-t bg-white px-4 py-3 sm:flex-row sm:justify-end sm:px-5">
          <button id="cancel-send-preview" type="button" class="btn-secondary justify-center">Keep Editing</button>
          <button id="confirm-send-estimate" type="button" class="btn-primary justify-center">Send Email</button>
        </div>
      </section>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const prepMultipliers = { none: 0.8, light: 1, standard: 1.2, heavy: 1.5 };
    const applicationMethods = {
      brush_roll: { label: 'Brush & roll', productivity: 1 },
      spray_backroll: { label: 'Spray & back-roll', productivity: 1.35 },
      spray_only: { label: 'Spray only', productivity: 1.6 },
    };
    const ceilingColorSeparationOptions = {
      same_as_walls: {
        label: 'Same color as walls',
        hours: () => 0,
      },
      separate_color: {
        label: 'Separate ceiling color',
        hours: (quantity) => Math.max(0.25, quantity / 350),
      },
      high_contrast_or_complex: {
        label: 'High contrast / complex separation',
        hours: (quantity) => Math.max(0.5, quantity / 220),
      },
    };
    let rates = [];
    let materialsCatalog = [];
    let settings = {};
    let roomCounter = 0;
    let editingEstimateId = new URLSearchParams(window.location.search).get('draft') || '';
    let editingEstimate = null;

    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const number = (value, options = {}) => window.PaintFlowFormat?.number(value, options) ?? Number(value || 0).toLocaleString('en-US', options);

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function apiJson(url, options = {}) {
      let res;
      try {
        res = await fetch(url, { credentials: 'include', ...options });
      } catch (err) {
        throw new Error(`Cannot reach the PaintFlow API at ${API_URL}. Start the API dev server or set PUBLIC_API_URL to the running API.`);
      }
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(apiErrorMessage(payload));
      return payload;
    }

    function apiErrorMessage(payload) {
      const issues = payload?.issues || payload?.details?.formErrors || [];
      const fieldErrors = payload?.details?.fieldErrors || {};
      const issueMessage = Array.isArray(issues) && issues.length
        ? issues.map(issue => `${Array.isArray(issue.path) ? issue.path.join('.') : ''} ${issue.message || issue}`.trim()).join('; ')
        : '';
      const fieldMessage = Object.entries(fieldErrors)
        .flatMap(([field, messages]) => (messages || []).map(message => `${field}: ${message}`))
        .join('; ');
      return fieldMessage || issueMessage || payload?.error || 'Request failed';
    }

    function showSetupError(message) {
      document.getElementById('setup-error-message').textContent = message;
      document.getElementById('setup-error').classList.remove('hidden');
    }

    function clearSetupError() {
      document.getElementById('setup-error-message').textContent = '';
      document.getElementById('setup-error').classList.add('hidden');
    }

    async function loadSetup() {
      clearSetupError();
      const draftRequest = editingEstimateId ? apiJson(`${API_URL}/v1/estimates/${editingEstimateId}`) : Promise.resolve(null);
      const [ratesRes, leadsRes, settingsRes, materialsRes, draftRes] = await Promise.all([
        apiJson(`${API_URL}/v1/production-rates`),
        apiJson(`${API_URL}/v1/leads?limit=200`),
        apiJson(`${API_URL}/v1/settings/org`),
        apiJson(`${API_URL}/v1/materials`),
        draftRequest,
      ]);
      rates = ratesRes.data;
      settings = settingsRes.data;
      materialsCatalog = materialsRes.data || [];
      document.getElementById('lead-select').innerHTML =
        '<option value="">Select customer...</option>' +
        leadsRes.data.map(lead => `<option value="${lead.id}">${escapeHtml(lead.name)}</option>`).join('');
      renderMaterialSelectors();
      editingEstimate = draftRes?.data || null;
      if (editingEstimate) {
        hydrateDraftEstimate(editingEstimate);
        window.showToast('Draft loaded.');
      } else {
        const templateRooms = consumeTemplateRooms();
        if (templateRooms.length) {
          templateRooms.forEach(room => addRoom(room.name || 'Template room', room.items || []));
          window.showToast('Template loaded into the production estimator.');
        }
      }
      applyEstimateType();
      calculateTotal();
    }

    function rateOptions() {
      const categories = [...new Set(rates.map(rate => rate.category || 'Other'))];
      return categories.map(category => {
        const options = rates
          .filter(rate => (rate.category || 'Other') === category)
          .map(rate => `<option value="${rate.id}">${escapeHtml(cleanRateLabel(rate))} (${number(rate.ratePerHour)} ${label(rate.unit)}/hr)</option>`)
          .join('');
        return `<optgroup label="${escapeHtml(label(category))}">${options}</optgroup>`;
      }).join('');
    }

    function cleanRateLabel(rate) {
      return String(rate.description || `${rate.category} ${rate.surfaceType}`)
        .replace(/\s*[,\-–—]?\s*(no|light|standard|heavy)\s+prep\b/ig, '')
        .replace(/\s{2,}/g, ' ')
        .trim();
    }

    function defaultApplicationMethod(rate) {
      const text = `${rate?.category || ''} ${rate?.surfaceType || ''} ${rate?.description || ''}`.toLowerCase();
      if (/spray/.test(text) && /back.?roll/.test(text)) return 'spray_backroll';
      if (/spray/.test(text)) return 'spray_only';
      return 'brush_roll';
    }

    function isExteriorRate(rate) {
      const text = `${rate?.category || ''} ${rate?.surfaceType || ''} ${rate?.description || ''}`.toLowerCase();
      return /exterior|siding|soffit|fascia|eave|shutter|corner board|cornerboard/.test(text);
    }

    function rateKind(rate) {
      const category = String(rate?.category || '').toLowerCase();
      const description = String(rate?.description || '').toLowerCase();
      const unit = String(rate?.unit || 'sqft').toLowerCase();
      const text = `${category} ${description}`;

      if (/soffit|eave/.test(text)) return 'soffit';
      if (/fascia/.test(text)) return 'fascia';
      if (/corner board|cornerboard|corner/.test(text)) return 'corner_boards';
      if (/exterior_trim|window.*door.*trim|door.*window.*trim/.test(text)) return 'exterior_trim';
      if (/window.*trim|trim.*window|shutter/.test(text)) return 'window_trim';
      if (/door.*trim|trim.*door/.test(text)) return 'door_trim';
      if (/exterior|siding/.test(text) && unit === 'sqft') return 'exterior_body';
      if (unit === 'linear_ft') return 'linear';
      if (unit === 'each') return 'count';
      if (category.includes('wall') || description.includes('wall')) return 'wall_area';
      if (category.includes('ceiling') || description.includes('ceiling')) return 'ceiling_area';
      return 'area';
    }

    function measurementConfig(rate) {
      const kind = rateKind(rate);

      if (kind === 'soffit') {
        return {
          widthLabel: 'Eave run',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Soffit depth',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Soffit area uses eave linear feet times soffit depth. If blank, exterior assumptions are used.',
        };
      }

      if (kind === 'fascia') {
        return {
          widthLabel: 'Linear feet',
          widthPlaceholder: 'Linear ft',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: '',
          qtyPlaceholder: '',
          showWidth: true,
          showHeight: false,
          showQty: false,
          helper: 'Fascia uses this measured linear footage, or exterior assumptions when blank.',
        };
      }

      if (kind === 'exterior_body') {
        return {
          widthLabel: 'Wall run',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Avg height',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Exterior body uses perimeter times wall height and stories, less estimated openings when assumptions are filled.',
        };
      }

      if (kind === 'window_trim') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Window count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Window trim can use the exterior window count with a default trim allowance per window.',
        };
      }

      if (kind === 'exterior_trim') {
        return {
          widthLabel: 'Linear feet',
          widthPlaceholder: 'Linear ft',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: '',
          qtyPlaceholder: '',
          showWidth: true,
          showHeight: false,
          showQty: false,
          helper: 'Exterior trim uses this measured linear footage, or window and door assumptions when blank.',
        };
      }

      if (kind === 'door_trim') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Door count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Door trim can use the exterior door count with a default trim allowance per door.',
        };
      }

      if (kind === 'corner_boards') {
        return {
          widthLabel: 'Linear feet',
          widthPlaceholder: 'Linear ft',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: '',
          qtyPlaceholder: '',
          showWidth: true,
          showHeight: false,
          showQty: false,
          helper: 'Corner boards use this measured linear footage, or corner count assumptions when blank.',
        };
      }

      if (kind === 'linear') {
        return {
          widthLabel: 'Linear feet',
          widthPlaceholder: 'Length',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: '',
          qtyPlaceholder: '',
          showWidth: true,
          showHeight: false,
          showQty: false,
          helper: 'Linear items use this measured length.',
        };
      }

      if (kind === 'count') {
        return {
          widthLabel: '',
          widthPlaceholder: '',
          heightLabel: '',
          heightPlaceholder: '',
          qtyLabel: 'Count',
          qtyPlaceholder: 'Count',
          showWidth: false,
          showHeight: false,
          showQty: true,
          helper: 'Doors, cabinet fronts, shutters, and similar items are measured by count.',
        };
      }

      if (kind === 'wall_area') {
        return {
          widthLabel: 'Perimeter',
          widthPlaceholder: 'Linear ft',
          heightLabel: 'Wall height',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Wall area uses room perimeter times wall height, with optional direct square-foot override.',
        };
      }

      if (kind === 'ceiling_area') {
        return {
          widthLabel: 'Length',
          widthPlaceholder: 'Feet',
          heightLabel: 'Width',
          heightPlaceholder: 'Feet',
          qtyLabel: 'Sq ft override',
          qtyPlaceholder: 'Optional',
          showWidth: true,
          showHeight: true,
          showQty: true,
          helper: 'Ceilings use length times width, with optional direct square-foot override.',
        };
      }

      return {
        widthLabel: 'Width',
        widthPlaceholder: 'Feet',
        heightLabel: 'Height',
        heightPlaceholder: 'Feet',
        qtyLabel: 'Sq ft override',
        qtyPlaceholder: 'Optional',
        showWidth: true,
        showHeight: true,
        showQty: true,
        helper: 'Measured substrates use width times height, with optional direct square-foot override.',
      };
    }

    function renderMaterialSelectors() {
      const paintOptions = materialsCatalog
        .filter(material => ['paint', 'primer'].includes(String(material.category || '').toLowerCase()))
        .map(material => materialOption(material))
        .join('');
      const noMaterial = '<option value="">Use pricing default</option>';
      document.getElementById('paint-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('primer-material').innerHTML = noMaterial + paintOptions;
      document.getElementById('material-note').textContent = paintOptions
        ? 'Coverage, unit cost, and markup are pulled from Materials.'
        : 'Add paint and primer products in Materials to calculate product-specific costs.';
    }

    function selectedMaterial(id) {
      return materialsCatalog.find(material => material.id === id);
    }

    function packageItems(pkg) {
      return Array.isArray(pkg?.items) ? pkg.items : Array.isArray(pkg?.lineItems) ? pkg.lineItems : [];
    }

    function draftSurfaceParts(item) {
      const [area = 'Interior', rawLabel = item.desc || 'Scope item'] = String(item.desc || '').split(/:\s(.+)/);
      const label = rawLabel || area;
      const surfaceMatch = label.match(/^(.*)\s+(walls?|ceilings?|trim|doors?|cabinets?|siding|soffits?|fascia|corner boards?)$/i);
      return {
        roomName: item.roomName || area.trim() || 'Interior',
        label: label.trim(),
        group: item.group || (surfaceMatch ? surfaceMatch[1].trim() : ''),
        surfaceName: item.surfaceName || (surfaceMatch ? surfaceMatch[2].trim() : label.trim()),
      };
    }

    function rateForDraftItem(item) {
      if (item.productionRateId && rates.some(rate => rate.id === item.productionRateId)) return item.productionRateId;
      const text = `${item.desc || ''} ${item.category || ''}`.toLowerCase();
      const unit = String(item.dimensions?.unit || item.category || '').toLowerCase();
      const kind = /ceiling/.test(text) ? 'ceilings'
        : /trim|baseboard|casing|crown/.test(text) ? 'trim'
          : /door/.test(text) ? 'doors'
            : /soffit/.test(text) ? 'soffits'
              : /fascia/.test(text) ? 'fascia'
                : /siding/.test(text) ? 'siding'
                  : 'walls';
      return rates.find(rate => rateKind(rate) === kind && String(rate.unit || '').toLowerCase() === unit)?.id
        || rates.find(rate => interiorRateKind(rate) === kind && String(rate.unit || '').toLowerCase() === unit)?.id
        || rates.find(rate => rateKind(rate) === kind)?.id
        || rates.find(rate => interiorRateKind(rate) === kind)?.id
        || '';
    }

    function hydrateDraftEstimate(estimate) {
      if (!estimate || estimate.status !== 'draft') {
        window.showToast('Only draft estimates can be edited here.', 'error');
        return;
      }
      document.getElementById('lead-select').value = estimate.leadId || '';
      document.querySelector('h2').textContent = 'Edit Draft Estimate';
      document.getElementById('save-estimate').textContent = 'Send Estimate';
      document.getElementById('rooms-container').innerHTML = '';
      document.getElementById('line-items-container').innerHTML = '';
      roomCounter = 0;

      const pkg = Array.isArray(estimate.packages) ? estimate.packages[0] : null;
      const items = packageItems(pkg);
      if (!items.length) {
        syncScopeBuilderVisibility();
        return;
      }

      const roomsByName = new Map();
      items.filter(item => item.kind !== 'line_item').forEach((item) => {
        const parts = draftSurfaceParts(item);
        if (!roomsByName.has(parts.roomName)) {
          const room = addRoom(parts.roomName, [], { seedSurface: false });
          roomsByName.set(parts.roomName, room);
        }
        const room = roomsByName.get(parts.roomName);
        if (parts.group) ensureSurfaceGroup(room.querySelector('[data-items]'), parts.group);
        addSurface(room.id, {
          productionRateId: rateForDraftItem(item),
          label: parts.label,
          group: parts.group,
          surfaceName: parts.surfaceName,
          width: item.dimensions?.width || '',
          height: item.dimensions?.height || '',
          quantity: item.dimensions?.quantity || '',
          coats: item.labor?.coats || 2,
          prepLevel: item.labor?.prepLevel || 'standard',
          applicationMethod: item.labor?.applicationMethod || 'brush_roll',
          prepAdjustmentHours: item.labor?.prepAdjustmentHours || '',
          paintAdjustmentHours: item.labor?.paintAdjustmentHours || '',
          materialId: item.material?.id || '',
          colorName: item.material?.colorName || '',
          colorCode: item.material?.colorCode || '',
          colorStatus: item.material?.status || 'TBD',
          crewNote: item.material?.crewNote || '',
          customerVisible: item.customerVisible !== false,
          optional: Boolean(item.optional),
        });
      });

      items.filter(item => item.kind === 'line_item').forEach(item => addLineItem({
        desc: item.desc,
        qty: item.qty,
        rate: item.rate,
        category: item.category,
        customerVisible: item.customerVisible,
        optional: item.optional,
      }));

      if (!roomsByName.size) syncScopeBuilderVisibility();
      document.getElementById('discount').value = Number(pkg?.discount || 0);
    }

    function materialOption(material, selectedId = '') {
      const selected = material.id === selectedId ? 'selected' : '';
      return `<option value="${material.id}" ${selected}>${escapeHtml([material.brand, material.name].filter(Boolean).join(' - '))} (${money(material.costPerUnit)}/${escapeHtml(material.unit)})</option>`;
    }

    function surfaceMaterialOptions(selectedId = '') {
      const options = materialsCatalog
        .filter(material => ['paint', 'primer'].includes(String(material.category || '').toLowerCase()))
        .map(material => materialOption(material, selectedId))
        .join('');
      return '<option value="">Use estimate paint product / sheen</option>' + options;
    }

    function materialCostForQuantity(quantity, material) {
      if (!material || !material.coverageSqFt || !material.costPerUnit) return null;
      const coverage = Number(material.coverageSqFt || 0);
      if (coverage <= 0) return null;
      const units = Math.max(1, Math.ceil(quantity / coverage));
      const cost = units * Number(material.costPerUnit || 0);
      const markup = Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0);
      const price = cost * (1 + markup / 100);
      return { units, cost, markup, price };
    }

    function fallbackMaterialCost(quantity, rate, coats, materialMarkup) {
      const unit = String(rate?.unit || 'sqft').toLowerCase();
      const baseRate = unit === 'linear_ft' ? 0.18 : unit === 'each' ? 8 : 0.35;
      return quantity * baseRate * Math.max(1, coats) * (1 + materialMarkup);
    }

    function consumeTemplateRooms() {
      const raw = sessionStorage.getItem('templateRooms');
      if (!raw) return [];
      sessionStorage.removeItem('templateRooms');
      try {
