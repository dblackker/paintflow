          <input type="text" autocomplete="off" placeholder="Crew note / production handoff" value="${escapeHtml(item.crewNote || '')}" class="min-w-0 w-full px-2 py-2 border rounded text-sm" data-field="crewNote">
        </div>
        <div class="flex flex-col gap-2 text-sm sm:flex-row sm:items-center sm:justify-between">
          <div class="flex flex-wrap items-center gap-3">
            <label class="inline-flex items-center gap-2 text-gray-600">
              <input type="checkbox" class="rounded border-gray-300" data-field="customerVisible" ${item.customerVisible === false ? '' : 'checked'}>
              Show on proposal
            </label>
            <label class="inline-flex items-center gap-2 text-gray-600" title="Optional items are customer-selectable add-ons and are excluded from the base proposal total.">
              <input type="checkbox" class="rounded border-gray-300" data-field="optional" ${item.optional ? 'checked' : ''}>
              Customer option
            </label>
          </div>
          <div class="production-surface-actions flex items-center gap-3">
            <span class="text-gray-600" data-line-total>$0.00</span>
          </div>
        </div>
      `;
      container.appendChild(div);
      div.querySelector('[data-field="rateId"]').value = rateId;
      syncSurfaceMeasurement(div);
      return div;
    }

    function findExteriorRate(kind) {
      return rates.find(rate => rateKind(rate) === kind) || null;
    }

    function surfaceRateKind(surface) {
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      return rate ? rateKind(rate) : '';
    }

    function interiorRateKind(rate) {
      const category = String(rate?.category || '').toLowerCase();
      const description = String(rate?.description || '').toLowerCase();
      const text = `${category} ${description}`;
      if (/ceiling/.test(text)) return 'ceilings';
      if (/wall/.test(text)) return 'walls';
      if (/trim|baseboard|casing|crown/.test(text)) return 'trim';
      if (/door/.test(text)) return 'doors';
      return '';
    }

    function interiorSurfaceKind(surface) {
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      return interiorRateKind(rate);
    }

    function findInteriorRate(kind) {
      return rates.find(rate => interiorRateKind(rate) === kind) || null;
    }

    function ceilingColorSeparation(surface) {
      const value = surface?.querySelector('[data-field="ceilingColorSeparation"]')?.value || 'same_as_walls';
      return ceilingColorSeparationOptions[value] ? value : 'same_as_walls';
    }

    function ceilingColorSeparationHours(surface, quantity) {
      if (interiorSurfaceKind(surface) !== 'ceilings') return 0;
      const option = ceilingColorSeparationOptions[ceilingColorSeparation(surface)] || ceilingColorSeparationOptions.same_as_walls;
      return Number(option.hours(Number(quantity || 0)) || 0);
    }

    function syncCeilingColorSeparation(surface) {
      const isCeiling = interiorSurfaceKind(surface) === 'ceilings';
      const control = surface?.querySelector('[data-ceiling-color-separation]');
      if (!control) return;
      control.classList.toggle('hidden', !isCeiling);
    }

    function derivedInteriorMeasurement(surface) {
      const room = surface.closest('#rooms-container > div');
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      const kind = interiorSurfaceKind(surface);
      if (!room || !['ceilings', 'trim'].includes(kind)) return null;

      const storedRoomItem = generatedRoomItem(room);
      const roomItems = storedRoomItem ? [storedRoomItem] : interiorRoomItems(room);
      if (!roomItems.length) return null;
      const matchedRoom = storedRoomItem || (surface.dataset.group
        ? roomItems.find(item => item.label.toLowerCase() === surface.dataset.group.toLowerCase())
        : roomItems.length === 1 ? roomItems[0] : null);
      if (!matchedRoom) return null;

      const assumptions = generatedRoomAssumptions(room) || interiorAssumptions(room);
      const quantities = interiorQuantitiesForRoom(matchedRoom, assumptions);
      const unit = String(rate?.unit || '').toLowerCase();

      if (kind === 'ceilings' && quantities.ceilings > 0) {
        return {
          kind,
          width: matchedRoom.length,
          height: matchedRoom.width,
          quantity: quantities.ceilings,
          target: unit === 'linear_ft' ? 'width' : 'area',
        };
      }
      if (kind === 'trim' && quantities.trim > 0) {
        return {
          kind,
          width: quantities.trim,
          height: 0,
          quantity: quantities.trim,
          target: unit === 'linear_ft' ? 'width' : 'quantity',
        };
      }
      return null;
    }

    function applyDerivedInteriorMeasurement(surface) {
      const derived = derivedInteriorMeasurement(surface);
      if (!derived) {
        window.showToast?.('Room metrics are not available for this substrate yet', 'error');
        return;
      }

      const widthInput = surface.querySelector('[data-field="width"]');
      const heightInput = surface.querySelector('[data-field="height"]');
      const quantityInput = surface.querySelector('[data-field="quantity"]');

      if (derived.kind === 'ceilings') {
        widthInput.value = Number(derived.width).toFixed(1);
        heightInput.value = Number(derived.height).toFixed(1);
        quantityInput.value = Number(derived.quantity).toFixed(1);
      } else if (derived.target === 'width') {
        widthInput.value = Number(derived.width).toFixed(1);
        heightInput.value = '';
        quantityInput.value = '';
      } else {
        widthInput.value = '';
        heightInput.value = '';
        quantityInput.value = Number(derived.quantity).toFixed(1);
      }

      calculateTotal();
      window.showToast?.('Measurement populated from room metrics', 'success');
    }

    function isEmptyGeneratedPlaceholder(surface) {
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      const hasMeasurements = ['width', 'height', 'quantity', 'prepAdjustmentHours', 'paintAdjustmentHours']
        .some(field => Number(surface.querySelector(`[data-field="${field}"]`)?.value || 0) > 0);
      return !hasMeasurements && (!rate || !isExteriorRate(rate));
    }

    function ensureSurfaceGroup(container, groupName) {
      if (!groupName) return;
      const existing = Array.from(container.querySelectorAll('[data-surface-group]'))
        .find(group => group.dataset.surfaceGroup === groupName);
      if (existing) return;
      const header = document.createElement('div');
      header.dataset.surfaceGroup = groupName;
      header.className = 'mt-4 mb-2 flex items-center gap-2';
      header.innerHTML = `
        <input value="${escapeHtml(groupName)}" autocomplete="off" class="min-w-0 max-w-full border-0 border-b border-transparent bg-transparent px-0 py-1 text-sm font-semibold text-gray-800 focus:border-blue-500 focus:outline-none sm:max-w-52" data-group-name>
        <span class="h-px flex-1 bg-gray-200"></span>
      `;
      container.appendChild(header);
    }

    function cleanupSurfaceGroups(container) {
      container.querySelectorAll('[data-surface-group]').forEach((header) => {
        const hasItems = Array.from(container.querySelectorAll('[data-surface-item]'))
          .some(surface => surface.dataset.group === header.dataset.surfaceGroup);
        if (!hasItems) header.remove();
      });
    }

    function groupDisplayName(surface) {
      if (!surface.dataset.group) return '';
      const header = Array.from(surface.closest('[data-items]').querySelectorAll('[data-surface-group]'))
        .find(group => group.dataset.surfaceGroup === surface.dataset.group);
      return header?.querySelector('[data-group-name]')?.value.trim() || surface.dataset.group;
    }

    function surfaceDisplayName(surface, rate) {
      if (!surface.dataset.group) {
        return surface.querySelector('[data-field="label"]').value.trim() || rate.description || `${rate.category} ${rate.surfaceType}`;
      }
      const groupName = groupDisplayName(surface);
      const surfaceName = surface.dataset.surfaceName || surface.querySelector('[data-field="label"]').value.trim();
      return `${groupName} ${surfaceName}`.trim();
    }

    function roomName(room) {
      return room?.querySelector('[data-room-name]')?.value.trim() || '';
    }

    function findRoomByName(name) {
      const normalized = String(name || '').trim().toLowerCase();
      if (!normalized) return null;
      return Array.from(document.querySelectorAll('#rooms-container > div'))
        .find(room => roomName(room).toLowerCase() === normalized) || null;
    }

    function isStarterPlaceholderRoom(room) {
      if (!room) return false;
      const name = roomName(room);
      return /^Room \d+$/i.test(name) && !room.querySelector('[data-surface-item]');
    }

    function tagGeneratedInteriorRoom(room, roomItem, assumptions) {
      room.dataset.generatedInteriorRoom = 'true';
      room.dataset.interiorRoomLabel = roomItem.label;
      room.dataset.interiorLength = String(roomItem.length);
      room.dataset.interiorWidth = String(roomItem.width);
      room.dataset.interiorWindows = String(roomItem.windows);
      room.dataset.interiorDoors = String(roomItem.doors);
      room.dataset.interiorCeilingHeight = String(assumptions.ceilingHeight);
      room.dataset.interiorTrimScope = assumptions.trimScope;
      room.dataset.interiorIncludeCeilings = String(assumptions.includeCeilings);
      room.dataset.interiorIncludeDoors = String(assumptions.includeDoors);
    }

    function generatedRoomAssumptions(room) {
      if (room?.dataset.generatedInteriorRoom !== 'true') return null;
      return {
        ceilingHeight: Number(room.dataset.interiorCeilingHeight || 9),
        trimScope: room.dataset.interiorTrimScope || 'base-casing',
        includeCeilings: room.dataset.interiorIncludeCeilings !== 'false',
        includeDoors: room.dataset.interiorIncludeDoors !== 'false',
      };
    }

    function generatedRoomItem(room) {
      if (room?.dataset.generatedInteriorRoom !== 'true') return null;
      return {
        label: room.dataset.interiorRoomLabel || roomName(room),
        length: Number(room.dataset.interiorLength || 0),
        width: Number(room.dataset.interiorWidth || 0),
        windows: Number(room.dataset.interiorWindows || 0),
        doors: Number(room.dataset.interiorDoors || 0),
      };
    }

    function displaySurfaceNameFromLegacy(surface) {
      const raw = surface.dataset.surfaceName || surface.querySelector('[data-field="label"]')?.value || 'Substrate';
      return String(raw).replace(/^\w/, char => char.toUpperCase());
    }

    function migrateLegacyGroupedInteriorScope(room, roomItems, assumptions) {
      if (!/^Room \d+$/i.test(roomName(room))) return;
      const legacySurfaces = Array.from(room.querySelectorAll('[data-surface-item]'))
        .filter(surface => surface.dataset.group);
      if (!legacySurfaces.length) return;

      legacySurfaces.forEach((surface) => {
        const matchingRoom = roomItems.find(item => item.label.toLowerCase() === surface.dataset.group.toLowerCase());
        if (!matchingRoom) return;
        const targetRoom = findRoomByName(matchingRoom.label) || addRoom(matchingRoom.label, [], { seedSurface: false });
        targetRoom.querySelector('[data-area-type]').value = 'interior';
        tagGeneratedInteriorRoom(targetRoom, matchingRoom, assumptions);
        const data = collectSurfaceData(surface);
        data.group = '';
        data.label = displaySurfaceNameFromLegacy(surface);
        data.surfaceName = data.label;
        const duplicate = Array.from(targetRoom.querySelectorAll('[data-surface-item] [data-field="label"]'))
          .some(input => input.value.trim().toLowerCase() === data.label.toLowerCase());
        if (!duplicate) addSurface(targetRoom.id, data);
      });

      room.remove();
    }

    function generateInteriorScope(room) {
      if (room) {
        room.querySelector('[data-area-type]').value = 'interior';
        syncAreaType(room);
      }

      const roomItems = interiorRoomItems(room);
      if (!roomItems.length) {
        window.showToast?.('Add at least one room count before generating interior scope', 'error');
        return;
      }

      const rateByKind = {
        walls: findInteriorRate('walls'),
        ceilings: findInteriorRate('ceilings'),
        trim: findInteriorRate('trim'),
        doors: findInteriorRate('doors'),
      };
      const neededKinds = new Set();
      const assumptions = interiorAssumptions(room);
      roomItems.forEach((roomItem) => {
        const quantities = interiorQuantitiesForRoom(roomItem, assumptions);
        if (quantities.walls > 0) neededKinds.add('walls');
        if (quantities.ceilings > 0) neededKinds.add('ceilings');
        if (quantities.trim > 0) neededKinds.add('trim');
        if (quantities.doors > 0) neededKinds.add('doors');
      });
      const missingRates = Array.from(neededKinds).filter(kind => !rateByKind[kind]);
      if (missingRates.length) {
        window.showToast?.(`Add production rates for: ${missingRates.join(', ')}`, 'error');
        return;
      }

      Array.from(room?.querySelectorAll('[data-surface-item]') || [])
        .filter(isEmptyGeneratedPlaceholder)
        .forEach(surface => surface.remove());

      const added = [];
      if (isStarterPlaceholderRoom(room)) {
        room.remove();
      } else if (room) {
        migrateLegacyGroupedInteriorScope(room, roomItems, assumptions);
      }

      roomItems.forEach((roomItem) => {
        const targetRoom = findRoomByName(roomItem.label) || addRoom(roomItem.label, [], { seedSurface: false });
        targetRoom.querySelector('[data-area-type]').value = 'interior';
        tagGeneratedInteriorRoom(targetRoom, roomItem, assumptions);
        Array.from(targetRoom.querySelectorAll('[data-surface-item]'))
          .filter(isEmptyGeneratedPlaceholder)
          .forEach(surface => surface.remove());
        const existingLabels = new Set(Array.from(targetRoom.querySelectorAll('[data-surface-item] [data-field="label"]'))
          .map(input => input.value.trim().toLowerCase())
          .filter(Boolean));
        const quantities = interiorQuantitiesForRoom(roomItem, assumptions);
        [
          { kind: 'walls', surfaceName: 'Walls', quantity: quantities.walls },
          { kind: 'ceilings', surfaceName: 'Ceiling', quantity: quantities.ceilings },
          { kind: 'trim', surfaceName: 'Trim', quantity: quantities.trim },
          { kind: 'doors', surfaceName: 'Doors', quantity: quantities.doors },
        ].filter(item => item.quantity > 0).forEach((item) => {
          const label = item.surfaceName;
          if (existingLabels.has(label.toLowerCase())) return;
          const rate = rateByKind[item.kind];
          addSurface(targetRoom.id, {
            productionRateId: rate.id,
            label,
            surfaceName: item.surfaceName,
            prepLevel: 'standard',
            quantity: Number(item.quantity.toFixed(1)),
            coats: rate.coats || 2,
            customerVisible: true,
          });
          existingLabels.add(label.toLowerCase());
          added.push(label);
        });
      });

      syncScopeBuilderVisibility();
      updateInteriorPreview(primaryScopeRoom() || document.querySelector('#rooms-container > div'));
      calculateTotal();

      if (added.length) {
        setQuickScopeCollapsed(true, `Starter scope added: ${added.length} interior line${added.length === 1 ? '' : 's'}. Refine room names, measurements, products, and options below.`);
        window.showToast?.(`Added ${added.length} itemized interior scope line${added.length === 1 ? '' : 's'}`, 'success');
      } else {
        setQuickScopeCollapsed(true, 'Starter scope is already itemized. Refine room names, measurements, products, and options below.');
        window.showToast?.('Interior room-count scope is already itemized', 'success');
      }
    }

    function generateExteriorScope(room) {
      const targetRoom = room || addRoom(estimateDefaultAreaName(), [], { seedSurface: false });
      targetRoom.querySelector('[data-area-type]').value = 'exterior';
      syncAreaType(targetRoom);

      const items = [
        { kind: 'exterior_body', label: 'Exterior siding' },
        { kind: 'soffit', label: 'Exterior soffits' },
        { kind: 'fascia', label: 'Exterior fascia' },
        { kind: 'exterior_trim', label: 'Exterior trim' },
        { kind: 'corner_boards', label: 'Exterior corner boards' },
      ];
      const added = [];
      const missingRates = [];

      Array.from(targetRoom.querySelectorAll('[data-surface-item]'))
        .filter(isEmptyGeneratedPlaceholder)
        .forEach(surface => surface.remove());

      const existingKinds = new Set(Array.from(targetRoom.querySelectorAll('[data-surface-item]')).map(surfaceRateKind).filter(Boolean));

      items.forEach((item) => {
        if (existingKinds.has(item.kind)) return;
        const rate = findExteriorRate(item.kind);
        if (!rate) {
          missingRates.push(item.label);
          return;
        }
        addSurface(targetRoom.id, {
          productionRateId: rate.id,
          prepLevel: 'standard',
          coats: rate.coats || 2,
          customerVisible: true,
        });
        added.push(item.label);
      });

      syncScopeBuilderVisibility();
      updateExteriorPreview(targetRoom);
      calculateTotal();

      if (added.length) {
        setQuickScopeCollapsed(true, `Starter scope added: ${added.length} exterior line${added.length === 1 ? '' : 's'}. Refine measurements, products, and options below.`);
        window.showToast?.(`Added ${added.length} exterior scope line${added.length === 1 ? '' : 's'} from assumptions`, 'success');
      } else if (missingRates.length) {
        window.showToast?.(`Add production rates for: ${missingRates.join(', ')}`, 'error');
      } else {
        setQuickScopeCollapsed(true, 'Starter exterior scope is already itemized. Refine measurements, products, and options below.');
        window.showToast?.('Exterior scope already includes the standard assumption-based lines', 'success');
      }
    }

    function syncSurfaceMeasurement(surface) {
      const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
      const config = measurementConfig(rate);
      const room = surface.closest('#rooms-container > div');
      const widthWrap = surface.querySelector('[data-measure="width"]');
      const heightWrap = surface.querySelector('[data-measure="height"]');
      const qtyWrap = surface.querySelector('[data-measure="quantity"]');

      if (rate && isExteriorRate(rate) && room) {
        document.getElementById('estimate-type').value = 'exterior';
        applyEstimateType();
      }

      widthWrap.classList.toggle('hidden', !config.showWidth);
      heightWrap.classList.toggle('hidden', !config.showHeight);
      qtyWrap.classList.toggle('hidden', !config.showQty);
      surface.querySelector('.populate-derived-measure')?.classList.toggle('hidden', !derivedInteriorMeasurement(surface));
      syncCeilingColorSeparation(surface);
      surface.querySelector('[data-label="width"]').textContent = config.widthLabel;
      surface.querySelector('[data-label="height"]').textContent = config.heightLabel;
      surface.querySelector('[data-label="quantity"]').textContent = config.qtyLabel;
      surface.querySelector('[data-field="width"]').placeholder = config.widthPlaceholder;
      surface.querySelector('[data-field="height"]').placeholder = config.heightPlaceholder;
      surface.querySelector('[data-field="quantity"]').placeholder = config.qtyPlaceholder;
      surface.querySelector('[data-measure-helper]').textContent = config.helper;
    }

    function quickScopeBuilder() {
      return document.getElementById('quick-scope-builder');
    }

    function primaryScopeRoom() {
      const builder = quickScopeBuilder();
      return document.getElementById(builder?.dataset.scopeRoomId || '') || document.querySelector('#rooms-container > div');
    }

    function scopeControlRoot(room) {
      const builder = quickScopeBuilder();
      if (!room) return builder;
      return builder?.dataset.scopeRoomId === room?.id ? builder : room;
    }

    function setQuickScopeCollapsed(collapsed, summaryText = '', mode = 'generated') {
      const builder = quickScopeBuilder();
      const summary = document.getElementById('quick-scope-summary');
      const skipSummary = document.getElementById('quick-scope-skip-summary');
      const summaryCopy = document.getElementById('quick-scope-summary-text');
      const helper = document.getElementById('scope-builder-helper');
      if (!builder || !summary || !skipSummary) return;
      builder.dataset.collapsed = String(collapsed);
      builder.dataset.collapsedMode = collapsed ? mode : '';
      summary.classList.toggle('hidden', !collapsed || mode !== 'generated');
      skipSummary.classList.toggle('hidden', !collapsed || mode !== 'skipped');
      helper?.classList.toggle('hidden', collapsed);
      if (summaryText && summaryCopy) summaryCopy.textContent = summaryText;
      const room = primaryScopeRoom();
      if (room) syncAreaType(room);
      else syncStarterPanels();
    }

    function syncQuickScopeBuilder() {
      const builder = quickScopeBuilder();
      if (!builder) return;
      const firstRoom = document.querySelector('#rooms-container > div');
      const starterOpen = builder.dataset.starterOpen === 'true';
      document.getElementById('empty-scope-state')?.classList.toggle('hidden', Boolean(firstRoom) || starterOpen);
      builder.classList.toggle('hidden', !firstRoom && !starterOpen);
      builder.dataset.scopeRoomId = firstRoom?.id || '';
      const interiorPanel = builder.querySelector('[data-interior-assumptions]')
        || document.querySelector('#rooms-container [data-interior-assumptions]');
      const exteriorPanel = builder.querySelector('[data-exterior-assumptions]')
        || document.querySelector('#rooms-container [data-exterior-assumptions]');
      if (interiorPanel && interiorPanel.parentElement !== builder) builder.appendChild(interiorPanel);
      if (exteriorPanel && exteriorPanel.parentElement !== builder) builder.appendChild(exteriorPanel);
      document.querySelectorAll('#rooms-container [data-interior-assumptions], #rooms-container [data-exterior-assumptions]')
        .forEach(panel => panel.remove());
      syncStarterPanels();
    }

    function syncScopeBuilderVisibility() {
      const rooms = Array.from(document.querySelectorAll('#rooms-container > div'));
      syncQuickScopeBuilder();
      rooms.forEach((room) => {
        syncAreaType(room);
      });
    }

    function openStarterScopeBuilder() {
      const builder = quickScopeBuilder();
      if (!builder) return;
      builder.dataset.starterOpen = 'true';
      if (!builder.querySelector('[data-interior-assumptions]') && !document.querySelector('#rooms-container [data-interior-assumptions]')) {
        const temporaryRoom = addRoom(estimateDefaultAreaName(), [], { seedSurface: false });
        temporaryRoom.remove();
      }
      setQuickScopeCollapsed(false);
      syncScopeBuilderVisibility();
      builder.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function applyEstimateType() {
      document.querySelectorAll('#rooms-container > div').forEach((room) => {
        room.querySelector('[data-area-type]').value = estimateAreaType();
        const nameInput = room.querySelector('[data-room-name]');
        const currentName = nameInput.value.trim();
        if (shouldAutoNameSpace(currentName)) {
          nameInput.value = estimateDefaultAreaName();
        }
      });
      syncScopeBuilderVisibility();
    }

    function estimateAreaType() {
      return document.getElementById('estimate-type')?.value === 'exterior' ? 'exterior' : 'interior';
    }

    function estimateDefaultAreaName() {
      const type = document.getElementById('estimate-type')?.value || 'interior';
      const nextIndex = document.querySelectorAll('#rooms-container > div').length + 1;
      return ({
        interior: `Room ${nextIndex}`,
        exterior: `Exterior elevation ${nextIndex}`,
        cabinet: `Cabinet area ${nextIndex}`,
        custom: `Work area ${nextIndex}`,
      })[type] || `Space ${nextIndex}`;
    }

    function shouldAutoNameSpace(name) {
      return ['', 'Interior', 'Exterior', 'Cabinets', 'Custom area', 'Area'].includes(name);
    }

    function syncAreaType(room) {
      const ownsScopeBuilder = quickScopeBuilder()?.dataset.scopeRoomId === room?.id;
      const quickScopeCollapsed = quickScopeBuilder()?.dataset.collapsed === 'true';
      const estimateType = document.getElementById('estimate-type')?.value || 'interior';
      room.querySelector('[data-area-type]').value = estimateAreaType();
      const isExterior = estimateAreaType() === 'exterior';
      const root = scopeControlRoot(room);
      root?.querySelector('[data-interior-assumptions]')?.classList.toggle('hidden', quickScopeCollapsed || !ownsScopeBuilder || estimateType !== 'interior' || isExterior);
      root?.querySelector('[data-exterior-assumptions]')?.classList.toggle('hidden', quickScopeCollapsed || !ownsScopeBuilder || estimateType !== 'exterior' || !isExterior);
      updateInteriorPreview(room);
      updateExteriorPreview(room);
    }

    function syncStarterPanels() {
      const builder = quickScopeBuilder();
      if (!builder) return;
      const quickScopeCollapsed = builder.dataset.collapsed === 'true';
      const estimateType = document.getElementById('estimate-type')?.value || 'interior';
      const hasScopeRoom = Boolean(primaryScopeRoom());
      const isOpenWithoutRoom = builder.dataset.starterOpen === 'true' && !hasScopeRoom;
      if (!isOpenWithoutRoom) return;
      builder.querySelector('[data-interior-assumptions]')?.classList.toggle('hidden', quickScopeCollapsed || estimateType !== 'interior');
      builder.querySelector('[data-exterior-assumptions]')?.classList.toggle('hidden', quickScopeCollapsed || estimateType !== 'exterior');
      updateInteriorPreview(null);
      updateExteriorPreview(null);
    }

    function interiorAssumptions(room) {
      const root = scopeControlRoot(room);
      const numberValue = (key, fallback = 0) => Number(root?.querySelector(`[data-interior="${key}"]`)?.value || fallback);
      const checked = (key) => Boolean(root?.querySelector(`[data-interior="${key}"]`)?.checked);
      return {
        bedrooms: numberValue('bedrooms'),
        bathrooms: numberValue('bathrooms'),
        livingRooms: numberValue('livingRooms'),
        diningRooms: numberValue('diningRooms'),
        kitchens: numberValue('kitchens'),
        hallways: numberValue('hallways'),
        closets: numberValue('closets'),
        ceilingHeight: numberValue('ceilingHeight', 9),
        trimScope: root?.querySelector('[data-interior="trimScope"]')?.value || 'base-casing',
        includeCeilings: checked('includeCeilings'),
        includeDoors: checked('includeDoors'),
      };
    }

    function interiorRoomDimension(room, roomType, dimension, fallback) {
      const input = scopeControlRoot(room)?.querySelector(`[data-interior-size="${roomType}"][data-dimension="${dimension}"]`);
      const value = Number(input?.value || fallback);
      return Number.isFinite(value) && value > 0 ? value : fallback;
    }

    function interiorRoomSize(room, roomType, fallbackLength, fallbackWidth) {
      return {
        length: interiorRoomDimension(room, roomType, 'length', fallbackLength),
        width: interiorRoomDimension(room, roomType, 'width', fallbackWidth),
      };
    }

    function interiorRoomTypes(room) {
      const assumptions = interiorAssumptions(room);
      const bedroom = interiorRoomSize(room, 'bedroom', 12, 12);
      const bathroom = interiorRoomSize(room, 'bathroom', 8, 8);
      const livingRoom = interiorRoomSize(room, 'livingRoom', 18, 16);
      const diningRoom = interiorRoomSize(room, 'diningRoom', 14, 12);
      const kitchen = interiorRoomSize(room, 'kitchen', 14, 12);
      const hallway = interiorRoomSize(room, 'hallway', 14, 4);
      const closet = interiorRoomSize(room, 'closet', 6, 4);
      return [
        { name: 'Bedroom', count: assumptions.bedrooms, ...bedroom, windows: 1, doors: 1 },
        { name: 'Bathroom', count: assumptions.bathrooms, ...bathroom, windows: 0.5, doors: 1 },
        { name: 'Living room', count: assumptions.livingRooms, ...livingRoom, windows: 3, doors: 1 },
        { name: 'Dining room', count: assumptions.diningRooms, ...diningRoom, windows: 2, doors: 1 },
        { name: 'Kitchen', count: assumptions.kitchens, ...kitchen, windows: 1, doors: 1 },
        { name: 'Hallway', count: assumptions.hallways, ...hallway, windows: 0, doors: 0 },
        { name: 'Closet', count: assumptions.closets, ...closet, windows: 0, doors: 1 },
      ].filter(type => type.count > 0);
    }

    function interiorRoomItems(room) {
      return interiorRoomTypes(room).flatMap(type => {
        const count = Math.max(0, Math.floor(type.count));
        return Array.from({ length: count }, (_, index) => ({
          ...type,
          label: `${type.name} ${index + 1}`,
          count: 1,
        }));
      });
    }

    function interiorQuantitiesForRoom(roomItem, assumptions) {
      const perimeter = (roomItem.length + roomItem.width) * 2;
      const walls = Math.max(0, (perimeter * assumptions.ceilingHeight) - (roomItem.windows * 15) - (roomItem.doors * 21));
      const ceilings = assumptions.includeCeilings ? roomItem.length * roomItem.width : 0;
      const casing = assumptions.trimScope.includes('casing') ? (roomItem.doors * 14) + (roomItem.windows * 16) : 0;
      const crown = assumptions.trimScope.includes('crown') ? perimeter : 0;
      const trim = assumptions.trimScope === 'none' ? 0 : perimeter + casing + crown;
      const doors = assumptions.includeDoors ? Math.round(roomItem.doors) : 0;
      return { walls, ceilings, trim, doors };
    }

    function interiorAssumptionQuantities(room) {
      const assumptions = interiorAssumptions(room);
      let walls = 0;
      let ceilings = 0;
      let trim = 0;
      let doors = 0;

      interiorRoomItems(room).forEach((roomItem) => {
        const quantities = interiorQuantitiesForRoom(roomItem, assumptions);
        walls += quantities.walls;
        ceilings += quantities.ceilings;
        trim += quantities.trim;
        doors += quantities.doors;
      });

      return {
        walls,
        ceilings,
        trim,
        doors,
        roomCount: interiorRoomItems(room).length,
      };
    }

    function updateInteriorPreview(room) {
      const targetRoom = primaryScopeRoom() || room;
      const preview = scopeControlRoot(targetRoom)?.querySelector('[data-interior-preview]');
      if (!preview) return;
      const quantities = interiorAssumptionQuantities(targetRoom);
      const hasInteriorSurface = Boolean(targetRoom) && Array.from(targetRoom.querySelectorAll('[data-surface-item]')).some((surface) => interiorSurfaceKind(surface));
      const roomSchedule = interiorRoomTypes(targetRoom)
        .map(type => `${type.count} ${type.name.toLowerCase()} @ ${type.length} x ${type.width}`)
        .join(', ');

      if (!quantities.roomCount) {
        preview.innerHTML = '<p class="font-medium">Add room counts to preview assumed interior quantities.</p><p class="mt-1 text-emerald-800">Generated rooms use standard allowances and remain editable after they are added.</p>';
        return;
      }

      preview.innerHTML = `
        <div class="font-medium">${hasInteriorSurface ? 'Assumed quantities feeding selected interior lines' : 'Assumed quantities ready for interior lines'}</div>
        <div class="mt-1 text-emerald-800">${escapeHtml(roomSchedule)}</div>
        <div class="mt-2 grid gap-2 min-[420px]:grid-cols-2 sm:grid-cols-4">
          <span>Walls: ${quantities.walls.toFixed(0)} sqft</span>
          <span>Ceilings: ${quantities.ceilings.toFixed(0)} sqft</span>
          <span>Trim: ${quantities.trim.toFixed(0)} lin ft</span>
          <span>Doors: ${quantities.doors} each</span>
        </div>
        ${hasInteriorSurface ? '' : '<p class="mt-2 text-emerald-800">Generate interior scope to turn these assumptions into price.</p>'}
      `;
    }

    function exteriorAssumptions(room) {
      const root = scopeControlRoot(room);
      const read = (key, fallback = 0) => Number(root?.querySelector(`[data-exterior="${key}"]`)?.value || fallback);
      return {
        perimeter: read('perimeter'),
        stories: read('stories', 1),
        wallHeight: read('wallHeight', 10),
        soffitDepth: read('soffitDepth', 2),
        windows: read('windows'),
        doors: read('doors'),
        corners: read('corners', 4),
        rooflineFactor: read('rooflineFactor', 1),
      };
    }

    function exteriorAssumptionQuantities(room) {
      const assumptions = exteriorAssumptions(room);
      const roofline = assumptions.perimeter * Math.max(assumptions.rooflineFactor || 1, 0);
      const openingAllowance = (assumptions.windows * 15) + (assumptions.doors * 21);
      return {
        siding: Math.max(0, (assumptions.perimeter * assumptions.wallHeight * assumptions.stories) - openingAllowance),
        soffit: Math.max(0, roofline * assumptions.soffitDepth),
        fascia: Math.max(0, roofline),
        trim: Math.max(0, (assumptions.windows * 18) + (assumptions.doors * 20)),
        corners: Math.max(0, assumptions.corners * assumptions.wallHeight * assumptions.stories),
      };
    }

    function updateExteriorPreview(room) {
      const targetRoom = primaryScopeRoom() || room;
      const preview = scopeControlRoot(targetRoom)?.querySelector('[data-assumption-preview]');
      if (!preview) return;

      const assumptions = exteriorAssumptions(targetRoom);
      const quantities = exteriorAssumptionQuantities(targetRoom);
      const hasExteriorSurface = Boolean(targetRoom) && Array.from(targetRoom.querySelectorAll('[data-surface-item]')).some((surface) => {
        const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
        return rate && isExteriorRate(rate);
      });

      if (!assumptions.perimeter) {
        preview.innerHTML = '<p class="font-medium">Add house perimeter to preview assumed exterior quantities.</p>';
        return;
      }

      preview.innerHTML = `
        <div class="font-medium">${hasExteriorSurface ? 'Assumed quantities feeding selected exterior lines' : 'Assumed quantities ready for exterior lines'}</div>
        <div class="mt-2 grid gap-2 min-[420px]:grid-cols-2 sm:grid-cols-5">
          <span>Siding: ${quantities.siding.toFixed(0)} sqft</span>
          <span>Soffit: ${quantities.soffit.toFixed(0)} sqft</span>
          <span>Fascia: ${quantities.fascia.toFixed(0)} lin ft</span>
          <span>Trim: ${quantities.trim.toFixed(0)} lin ft</span>
          <span>Corners: ${quantities.corners.toFixed(0)} lin ft</span>
        </div>
        ${hasExteriorSurface ? '' : '<p class="mt-2 text-blue-800">Select Exterior siding, soffits, fascia, exterior trim, or corner boards below to turn these assumptions into price.</p>'}
      `;
    }

    function exteriorQuantityFromAssumptions(room, rate) {
      if (!room || estimateAreaType() !== 'exterior') return 0;
      const quantities = exteriorAssumptionQuantities(room);

      switch (rateKind(rate)) {
        case 'exterior_body':
          return quantities.siding;
        case 'soffit':
          return quantities.soffit;
        case 'fascia':
          return quantities.fascia;
        case 'corner_boards':
          return quantities.corners;
        case 'exterior_trim':
          return quantities.trim;
        case 'window_trim':
          return exteriorAssumptions(room).windows * 18;
        case 'door_trim':
          return exteriorAssumptions(room).doors * 20;
        default:
          return 0;
      }
    }

    function collectSurfaceData(surface) {
      return {
        productionRateId: surface.querySelector('[data-field="rateId"]').value,
        label: surface.querySelector('[data-field="label"]').value,
        group: surface.dataset.group || '',
        surfaceName: surface.dataset.surfaceName || '',
        applicationMethod: surface.querySelector('[data-field="applicationMethod"]').value,
        prepLevel: surface.querySelector('[data-field="prepLevel"]').value,
        width: surface.querySelector('[data-field="width"]').value,
        height: surface.querySelector('[data-field="height"]').value,
        quantity: surface.querySelector('[data-field="quantity"]').value,
        coats: surface.querySelector('[data-field="coats"]').value,
        prepAdjustmentHours: surface.querySelector('[data-field="prepAdjustmentHours"]').value,
        paintAdjustmentHours: surface.querySelector('[data-field="paintAdjustmentHours"]').value,
        ceilingColorSeparation: surface.querySelector('[data-field="ceilingColorSeparation"]')?.value || 'same_as_walls',
        materialId: surface.querySelector('[data-field="materialId"]').value,
        colorName: surface.querySelector('[data-field="colorName"]').value,
        colorCode: surface.querySelector('[data-field="colorCode"]').value,
        colorStatus: surface.querySelector('[data-field="colorStatus"]').value,
        crewNote: surface.querySelector('[data-field="crewNote"]').value,
        customerVisible: surface.querySelector('[data-field="customerVisible"]').checked,
        optional: surface.querySelector('[data-field="optional"]').checked,
      };
    }

    function addLineItem(item = {}) {
      const div = document.createElement('div');
      div.className = 'grid gap-2 sm:grid-cols-[minmax(0,1fr)_90px_110px_120px_auto] items-end border rounded-lg p-3 bg-gray-50';
      div.innerHTML = `
        <label class="block">
          <span class="text-xs text-gray-600">Description</span>
          <input data-field="desc" autocomplete="off" value="${escapeHtml(item.desc || '')}" placeholder="Add-on or adjustment" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Qty</span>
          <input data-field="qty" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${escapeHtml(item.qty || 1)}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Price</span>
          <input data-field="rate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" value="${escapeHtml(item.rate || 0)}" class="mt-1 w-full px-3 py-2 border rounded-lg">
        </label>
        <label class="block">
          <span class="text-xs text-gray-600">Category</span>
          <select data-field="category" class="mt-1 w-full px-3 py-2 border rounded-lg">
            ${['add-on', 'prep', 'repair', 'discount', 'other'].map(category => `<option value="${category}" ${item.category === category ? 'selected' : ''}>${label(category)}</option>`).join('')}
          </select>
        </label>
        <div class="flex items-center justify-between gap-3">
          <div class="flex flex-col gap-1">
            <label class="inline-flex items-center gap-2 text-xs text-gray-600">
              <input type="checkbox" class="rounded border-gray-300" data-field="customerVisible" ${item.customerVisible === false ? '' : 'checked'}>
              Show
            </label>
            <label class="inline-flex items-center gap-2 text-xs text-gray-600" title="Show as a customer-selectable option.">
              <input type="checkbox" class="rounded border-gray-300" data-field="optional" ${item.optional ? 'checked' : ''}>
              Option
            </label>
          </div>
          <button type="button" class="remove-line-item btn-text btn-sm text-red-700">Remove</button>
        </div>
      `;
      document.getElementById('line-items-container').appendChild(div);
      calculateTotal();
    }

    function measuredQuantity(surface, rate) {
      const config = measurementConfig(rate);
      const room = surface.closest('#rooms-container > div');
      const width = Number(surface.querySelector('[data-field="width"]').value || 0);
      const height = Number(surface.querySelector('[data-field="height"]').value || 0);
      const manualQty = Number(surface.querySelector('[data-field="quantity"]').value || 0);
      const assumptionQty = exteriorQuantityFromAssumptions(room, rate);

      if (String(rate?.unit || '').toLowerCase() === 'linear_ft') {
        const quantity = manualQty || width || assumptionQty;
        return { width: quantity, height: 0, quantity };
      }

      if (String(rate?.unit || '').toLowerCase() === 'each') {
        return { width: 0, height: 0, quantity: manualQty || assumptionQty };
      }

      const measuredArea = width && height ? width * height : 0;
      const quantity = manualQty || measuredArea || assumptionQty;
      if (!manualQty && measuredArea) surface.querySelector('[data-field="quantity"]').value = measuredArea.toFixed(1);
      return { width: config.showWidth ? width : 0, height: config.showHeight ? height : 0, quantity };
    }

    function collectItems() {
      const taxRate = Number(settings.salesTaxRate || 0);
      const materialMarkup = Number(settings.materialMarkupPercent || 0) / 100;
      const paint = selectedMaterial(document.getElementById('paint-material').value);
      const primer = selectedMaterial(document.getElementById('primer-material').value);
      const items = [];
      let labor = 0;
      let materials = 0;
      let adjustments = 0;
      let hours = 0;
      let optionalTotal = 0;

      document.querySelectorAll('#rooms-container > div').forEach(room => {
        const roomName = room.querySelector('[data-room-name]').value.trim() || 'Unnamed space';
        room.querySelectorAll('[data-surface-item]').forEach(surface => {
          const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
          if (!rate) return;
          const { width, height, quantity } = measuredQuantity(surface, rate);
          if (quantity <= 0) {
            surface.querySelector('[data-line-total]').textContent = '$0.00';
            return;
          }

          const prep = surface.querySelector('[data-field="prepLevel"]').value;
          const applicationMethod = surface.querySelector('[data-field="applicationMethod"]').value;
          const application = applicationMethods[applicationMethod] || applicationMethods.brush_roll;
          const coats = Math.max(1, Number(surface.querySelector('[data-field="coats"]').value || rate.coats || 2));
          const prepAdjustmentHours = Number(surface.querySelector('[data-field="prepAdjustmentHours"]').value || 0);
          const paintAdjustmentHours = Number(surface.querySelector('[data-field="paintAdjustmentHours"]').value || 0);
          const ceilingSeparation = ceilingColorSeparation(surface);
          const ceilingSeparationOption = ceilingColorSeparationOptions[ceilingSeparation] || ceilingColorSeparationOptions.same_as_walls;
          const ceilingSeparationHours = ceilingColorSeparationHours(surface, quantity);
          const surfaceMaterial = selectedMaterial(surface.querySelector('[data-field="materialId"]').value);
          const colorName = surface.querySelector('[data-field="colorName"]').value.trim();
          const colorCode = surface.querySelector('[data-field="colorCode"]').value.trim();
          const colorStatus = surface.querySelector('[data-field="colorStatus"]').value;
          const crewNote = surface.querySelector('[data-field="crewNote"]').value.trim();
          const adjustedRatePerHour = Number(rate.ratePerHour || 1) * Number(application.productivity || 1);
          const baseHours = (quantity / adjustedRatePerHour) * coats * (prepMultipliers[prep] || 1.2);
          const itemHours = Math.max(0, baseHours + prepAdjustmentHours + paintAdjustmentHours + ceilingSeparationHours);
          const itemLabor = itemHours * Number(rate.hourlyRate || settings.defaultLaborRate || 65);
          const isPrimerHeavy = prep === 'heavy' || /primer|prep|cabinet/i.test(`${rate.category} ${rate.description}`);
          const material = surfaceMaterial || (isPrimerHeavy && primer ? primer : paint);
          const productCost = materialCostForQuantity(quantity * coats, material);
          const itemMaterials = productCost ? productCost.price : fallbackMaterialCost(quantity, rate, coats, materialMarkup);
          const itemTotal = itemLabor + itemMaterials;
          const lineLabel = surfaceDisplayName(surface, rate);
          const isOptional = surface.querySelector('[data-field="optional"]').checked;

          if (isOptional) {
            optionalTotal += itemTotal;
          } else {
            hours += itemHours;
            labor += itemLabor;
            materials += itemMaterials;
          }
          items.push({
            desc: `${roomName}: ${lineLabel}`,
            qty: 1,
            rate: Number(itemTotal.toFixed(2)),
            category: rate.unit,
            kind: 'surface',
            customerVisible: surface.querySelector('[data-field="customerVisible"]').checked,
            optional: isOptional,
            productionRateId: rate.id,
            roomName,
            group: surface.dataset.group || '',
            surfaceName: surface.dataset.surfaceName || '',
            dimensions: { width, height, quantity, unit: rate.unit },
            notes: `${quantity.toFixed(1)} ${rate.unit}, ${coats} coat${coats === 1 ? '' : 's'}, ${application.label}, ${itemHours.toFixed(1)} labor hours, ${prep} prep${ceilingSeparationHours ? `, ${ceilingSeparationOption.label} (+${ceilingSeparationHours.toFixed(1)} hrs)` : ''}${material ? `, ${material.brand || ''} ${material.name}` : ''}${colorName ? `, ${colorName}` : ''}${colorCode ? ` (${colorCode})` : ''}${crewNote ? `, crew: ${crewNote}` : ''}`,
            labor: {
              hours: Number(itemHours.toFixed(2)),
              rate: Number(rate.hourlyRate || settings.defaultLaborRate || 65),
              cost: Number(itemLabor.toFixed(2)),
              coats,
              prepLevel: prep,
              applicationMethod,
              productionRatePerHour: Number(adjustedRatePerHour.toFixed(2)),
              prepAdjustmentHours,
              paintAdjustmentHours,
              ceilingColorSeparation: ceilingSeparation,
              ceilingColorSeparationHours: Number(ceilingSeparationHours.toFixed(2)),
            },
            material: material ? {
              id: material.id,
              name: material.name,
              brand: material.brand,
              supplier: material.supplier,
              unit: material.unit,
              quantity: productCost?.units,
              costPerUnit: Number(material.costPerUnit || 0),
              markupPercent: Number(material.markupPercent ?? settings.materialMarkupPercent ?? 0),
              price: productCost ? Number(productCost.price.toFixed(2)) : Number(itemMaterials.toFixed(2)),
              colorName,
              colorCode,
              status: colorStatus,
              crewNote,
            } : undefined,
          });
          surface.querySelector('[data-line-total]').textContent = money(itemTotal);
        });
      });

      document.querySelectorAll('#line-items-container > div').forEach(row => {
        const desc = row.querySelector('[data-field="desc"]').value.trim();
        const qty = Number(row.querySelector('[data-field="qty"]').value || 0);
        const rate = Number(row.querySelector('[data-field="rate"]').value || 0);
        if (!desc || qty <= 0 || rate <= 0) return;
        const total = qty * rate;
        const isOptional = row.querySelector('[data-field="optional"]').checked;
        if (isOptional) optionalTotal += total;
        else adjustments += total;
        items.push({
          desc,
          qty,
          rate,
          category: row.querySelector('[data-field="category"]').value,
          kind: 'line_item',
          customerVisible: row.querySelector('[data-field="customerVisible"]').checked,
          optional: isOptional,
          notes: 'Estimate-specific line item',
        });
      });

      const discount = Number(document.getElementById('discount').value || 0);
      const subtotal = labor + materials + adjustments;
      const taxableSubtotal = Math.max(subtotal - discount, 0);
      const tax = taxableSubtotal * taxRate;
      return { items, hours, labor, materials, adjustments, optionalTotal, discount, tax, subtotal, total: taxableSubtotal + tax };
    }

    function buildPackages() {
      const result = collectItems();
      if (result.items.length === 0) return [];
      return [{
        name: 'proposal',
        estimateType: document.getElementById('estimate-type')?.value || 'interior',
        subtotal: Number(result.subtotal.toFixed(2)),
        discount: Number(result.discount.toFixed(2)),
        tax: Number(result.tax.toFixed(2)),
        total: Number(result.total.toFixed(2)),
        optionalTotal: Number(result.optionalTotal.toFixed(2)),
        items: result.items,
        lineItems: result.items,
      }];
    }

    function selectedLeadLabel() {
      const select = document.getElementById('lead-select');
      return select.options[select.selectedIndex]?.textContent?.trim() || 'Selected customer';
    }

    function proposalSurfaceLabel(item) {
      const raw = String(item.desc || '');
      const [, label = raw] = raw.match(/^[^:]+:\s(.+)$/) || [];
      return label || raw || 'Scope item';
    }

    function proposalItemDetail(item) {
      if (item.kind === 'line_item') return item.notes || 'Additional scope';
      const labor = item.labor || {};
      const material = item.material;
      const product = material?.name ? `Paint: ${[material.brand, material.name].filter(Boolean).join(' ')}` : 'Paint: TBD';
      const color = [material?.colorName, material?.colorCode].filter(Boolean).join(' ');
      return [
        labor.coats ? `${Number(labor.coats)} coat${Number(labor.coats) === 1 ? '' : 's'}` : '',
        labor.prepLevel ? `${label(labor.prepLevel)} prep` : '',
        product,
        color,
      ].filter(Boolean).join(' - ') || 'Included';
    }

    function groupedProposalItems(items) {
      const groups = new Map();
      items.forEach((item) => {
        const key = item.roomName || String(item.desc || 'Project').split(':')[0] || 'Project';
        if (!groups.has(key)) groups.set(key, []);
        groups.get(key).push(item);
      });
      return Array.from(groups.entries()).map(([name, groupItems]) => ({ name, items: groupItems }));
    }

    function renderSendPreview() {
      const packages = buildPackages();
      const pkg = packages[0];
      const content = document.getElementById('send-preview-content');
      if (!pkg) {
        window.showToast('Add at least one measured substrate', 'error');
        return false;
      }
      const visibleItems = pkg.items.filter(item => item.customerVisible !== false);
      const included = visibleItems.filter(item => !item.optional);
      const optional = visibleItems.filter(item => item.optional);
      const groups = groupedProposalItems(included);
      const estimateType = document.getElementById('estimate-type')?.value || 'painting';
      const subjectPreview = `${selectedLeadLabel()} ${estimateType} painting proposal`;
      content.innerHTML = `
        <div class="rounded-lg border bg-gray-50 p-3">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Customer</p>
              <p class="font-semibold text-gray-950">${escapeHtml(selectedLeadLabel())}</p>
            </div>
            <div class="sm:text-right">
              <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Proposal total</p>
              <p class="text-lg font-bold text-gray-950">${money(pkg.total)}</p>
            </div>
          </div>
          <div class="mt-3 rounded-md border bg-white p-3 text-sm">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Email preview</p>
            <p class="mt-1 font-medium text-gray-950">${escapeHtml(subjectPreview)}</p>
            <p class="mt-1 text-gray-600">Includes estimator contact details, this compact scope summary, and a secure link to review, approve, sign, and pay the deposit.</p>
          </div>
        </div>
        <div class="space-y-2">
          ${groups.map(group => `
            <section class="rounded-lg border bg-white">
              <div class="flex items-center justify-between gap-3 border-b bg-gray-50 px-3 py-2">
                <h3 class="font-semibold text-gray-950">${escapeHtml(group.name)}</h3>
                <span class="text-xs text-gray-500">${group.items.length} substrate${group.items.length === 1 ? '' : 's'}</span>
              </div>
              <div class="divide-y">
                ${group.items.map(item => `
                  <div class="grid gap-1 px-3 py-2 text-sm sm:grid-cols-[9rem_1fr]">
                    <p class="font-medium text-gray-900">${escapeHtml(proposalSurfaceLabel(item))}</p>
                    <p class="text-gray-600">${escapeHtml(proposalItemDetail(item))}</p>
                  </div>
                `).join('')}
              </div>
            </section>
          `).join('')}
        </div>
        ${optional.length ? `
          <section class="rounded-lg border bg-white p-3">
            <h3 class="font-semibold text-gray-950">Customer Options</h3>
            <div class="mt-2 space-y-1 text-sm text-gray-700">
              ${optional.map(item => `
                <div class="grid gap-1 border-t py-2 sm:grid-cols-[1fr_auto]">
                  <span>
                    <span class="block font-medium text-gray-900">${escapeHtml(proposalSurfaceLabel(item))}</span>
                    <span class="block text-gray-600">${escapeHtml(proposalItemDetail(item))}</span>
                  </span>
                  <span class="font-semibold text-gray-900">${money(Number(item.qty || 1) * Number(item.rate || 0))}</span>
                </div>
              `).join('')}
            </div>
          </section>
        ` : ''}
      `;
      document.getElementById('send-preview-modal').classList.remove('hidden');
      return true;
    }

    function closeSendPreview() {
      document.getElementById('send-preview-modal').classList.add('hidden');
    }

    function calculateTotal() {
      const result = collectItems();
      document.getElementById('total-hours').textContent = result.hours.toFixed(1);
      document.getElementById('labor-total').textContent = money(result.labor);
      document.getElementById('materials-total').textContent = money(result.materials);
      document.getElementById('adjustments-total').textContent = money(result.adjustments);
      document.getElementById('optional-total').textContent = money(result.optionalTotal);
      document.getElementById('tax-total').textContent = money(result.tax);
      document.getElementById('total-cost').textContent = money(result.total);
      updatePaintSchedule(result.items);
      updateProductionReadiness(result.items);
      updateWorkflowState(result);
    }

    function updatePaintSchedule(items) {
      const panel = document.getElementById('paint-schedule');
      const count = document.getElementById('paint-schedule-count');
      const surfaceItems = items.filter(item => item.kind === 'surface' && item.customerVisible !== false);
      count.textContent = `${surfaceItems.length} substrate${surfaceItems.length === 1 ? '' : 's'}`;
      if (!surfaceItems.length) {
        panel.innerHTML = '<p class="rounded-md border border-dashed border-gray-300 p-3 text-gray-500">Add scope lines to build the paint schedule.</p>';
        return;
      }

      panel.innerHTML = surfaceItems.map(item => {
        const material = item.material;
        const status = material?.status || 'TBD';
        const statusClass = ['Approved', 'Ordered', 'Delivered'].includes(status) ? 'bg-green-50 text-green-700 border-green-200' : 'bg-amber-50 text-amber-800 border-amber-200';
        const color = [material?.colorName, material?.colorCode].filter(Boolean).join(' ');
        return `
          <div class="rounded-lg border p-3">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="font-medium text-gray-900">${escapeHtml(item.desc)}</div>
                <div class="mt-1 text-xs text-gray-500">${escapeHtml(item.dimensions.quantity.toFixed(1))} ${escapeHtml(item.dimensions.unit)} · ${material?.quantity || 0} ${escapeHtml(material?.unit || 'units')}</div>
              </div>
              <span class="inline-flex w-fit rounded-full border px-2 py-1 text-xs font-medium ${statusClass}">${escapeHtml(status)}</span>
            </div>
            <div class="mt-2 grid gap-2 text-xs sm:grid-cols-3">
              <div><span class="text-gray-500">Product</span><div class="font-medium text-gray-800">${material ? escapeHtml([material.brand, material.name].filter(Boolean).join(' - ')) : 'Missing product'}</div></div>
              <div><span class="text-gray-500">Color</span><div class="font-medium text-gray-800">${color ? escapeHtml(color) : 'TBD'}</div></div>
              <div><span class="text-gray-500">Crew note</span><div class="font-medium text-gray-800">${escapeHtml(material?.crewNote || 'None')}</div></div>
            </div>
          </div>
        `;
      }).join('');
    }

    function updateProductionReadiness(items) {
      const panel = document.getElementById('production-readiness');
      const surfaceItems = items.filter(item => item.kind === 'surface' && item.customerVisible !== false);
      const materialItems = surfaceItems.filter(item => item.material);
      const missingProduct = surfaceItems.length - materialItems.length;
      const missingColor = materialItems.filter(item => !item.material.colorName || !item.material.colorCode || item.material.status === 'TBD').length;
      const unapprovedColor = materialItems.filter(item => ['Selected', 'Changed'].includes(item.material.status)).length;
      const zeroQuantitySurfaces = Array.from(document.querySelectorAll('[data-surface-item]')).filter(surface => {
        const rate = rates.find(item => item.id === surface.querySelector('[data-field="rateId"]').value);
        return rate && measuredQuantity(surface, rate).quantity <= 0;
      }).length;
      const missingCustomer = document.getElementById('lead-select').value ? 0 : 1;
      const orderUnits = materialItems.reduce((sum, item) => sum + Number(item.material.quantity || 0), 0);
      const statusClass = (count) => count ? 'text-amber-700' : 'text-green-700';

      panel.innerHTML = `
        <div class="flex justify-between"><span>Paint order units</span><span class="font-medium">${orderUnits.toFixed(0)}</span></div>
        <div class="flex justify-between ${statusClass(missingCustomer)}"><span>Missing customer</span><span class="font-medium">${missingCustomer}</span></div>
        <div class="flex justify-between ${statusClass(zeroQuantitySurfaces)}"><span>Zero-quantity substrates</span><span class="font-medium">${zeroQuantitySurfaces}</span></div>
        <div class="flex justify-between ${statusClass(missingProduct)}"><span>Missing products</span><span class="font-medium">${missingProduct}</span></div>
        <div class="flex justify-between ${statusClass(missingColor)}"><span>Color selections needed</span><span class="font-medium">${missingColor}</span></div>
        <div class="flex justify-between ${statusClass(unapprovedColor)}"><span>Colors awaiting approval</span><span class="font-medium">${unapprovedColor}</span></div>
        <p class="text-xs text-gray-500">Use per-substrate product and color fields to prepare ordering and job handoff. Sheen should live in the selected paint product because it changes cost and coverage.</p>
      `;
    }

    function updateWorkflowState(result) {
      const checks = {
        setup: Boolean(document.getElementById('lead-select').value),
        scope: result.items.some(item => item.kind === 'surface'),
        paint: result.items.some(item => item.material?.colorName && item.material?.colorCode && item.material?.status !== 'TBD'),
        review: result.total > 0,
      };
    }

    document.getElementById('add-room').addEventListener('click', () => addRoom(estimateDefaultAreaName()));
    document.getElementById('start-with-starter-scope').addEventListener('click', openStarterScopeBuilder);
    document.getElementById('add-line-item').addEventListener('click', () => addLineItem());
    document.getElementById('estimate-type').addEventListener('change', () => {
      setQuickScopeCollapsed(false);
      applyEstimateType();
      calculateTotal();
    });
    document.getElementById('retry-setup').addEventListener('click', () => {
      loadSetup().catch((err) => {
        console.error('Failed to load production estimator', err);
        showSetupError(err.message || 'Failed to load estimator setup');
      });
    });
    document.getElementById('edit-quick-scope').addEventListener('click', () => {
      setQuickScopeCollapsed(false);
    });
    document.getElementById('restore-quick-scope').addEventListener('click', () => {
      setQuickScopeCollapsed(false);
    });
    document.getElementById('quick-scope-builder').addEventListener('click', (event) => {
      if (event.target.classList.contains('assumption-info')) {
        const button = event.target;
        const panel = button.closest('.relative').querySelector('[data-assumption-info]');
        const willOpen = panel.classList.contains('hidden');
        document.querySelectorAll('[data-assumption-info]').forEach(info => info.classList.add('hidden'));
        document.querySelectorAll('.assumption-info').forEach(infoButton => infoButton.setAttribute('aria-expanded', 'false'));
        panel.classList.toggle('hidden', !willOpen);
        button.setAttribute('aria-expanded', String(willOpen));
        event.stopPropagation();
        return;
      }
      const room = primaryScopeRoom();
      if (event.target.classList.contains('skip-quick-scope')) {
        setQuickScopeCollapsed(true, '', 'skipped');
        return;
      }
      if (event.target.classList.contains('generate-exterior-scope')) {
        generateExteriorScope(room);
        return;
      }
      if (event.target.classList.contains('generate-interior-scope')) {
        generateInteriorScope(room);
      }
    });
    document.getElementById('rooms-container').addEventListener('click', (event) => {
      if (event.target.classList.contains('assumption-info')) {
        const button = event.target;
        const panel = button.closest('.relative').querySelector('[data-assumption-info]');
        const willOpen = panel.classList.contains('hidden');
        document.querySelectorAll('[data-assumption-info]').forEach(info => info.classList.add('hidden'));
        document.querySelectorAll('.assumption-info').forEach(infoButton => infoButton.setAttribute('aria-expanded', 'false'));
        panel.classList.toggle('hidden', !willOpen);
        button.setAttribute('aria-expanded', String(willOpen));
        event.stopPropagation();
        return;
      }
      if (event.target.classList.contains('generate-exterior-scope')) {
        generateExteriorScope(event.target.closest('#rooms-container > div'));
        return;
      }
      if (event.target.classList.contains('generate-interior-scope')) {
        generateInteriorScope(event.target.closest('#rooms-container > div'));
        return;
      }
      if (event.target.classList.contains('remove-room')) {
        event.target.closest('#rooms-container > div').remove();
        syncScopeBuilderVisibility();
      }
      if (event.target.classList.contains('add-surface')) addSurface(event.target.closest('#rooms-container > div').id);
      if (event.target.classList.contains('populate-derived-measure')) {
        applyDerivedInteriorMeasurement(event.target.closest('[data-surface-item]'));
        return;
      }
      if (event.target.classList.contains('copy-room')) {
        const source = event.target.closest('#rooms-container > div');
        const roomName = source.querySelector('[data-room-name]').value.trim() || 'Unnamed space';
        const items = Array.from(source.querySelectorAll('[data-surface-item]')).map(collectSurfaceData);
        const copied = addRoom(`${roomName} copy`, items);
        copied.querySelector('[data-area-type]').value = source.querySelector('[data-area-type]').value;
        source.querySelectorAll('[data-exterior]').forEach((input) => {
          copied.querySelector(`[data-exterior="${input.dataset.exterior}"]`).value = input.value;
        });
        syncScopeBuilderVisibility();
      }
      calculateTotal();
    });
    document.addEventListener('click', (event) => {
      if (event.target.closest('[data-assumption-info]')) return;
      document.querySelectorAll('[data-assumption-info]').forEach(info => info.classList.add('hidden'));
      document.querySelectorAll('.assumption-info').forEach(button => button.setAttribute('aria-expanded', 'false'));
    });
    document.getElementById('line-items-container').addEventListener('click', (event) => {
      if (event.target.classList.contains('remove-line-item')) {
        event.target.closest('#line-items-container > div').remove();
        calculateTotal();
      }
    });
    document.addEventListener('input', (event) => {
      if (event.target.matches('[data-interior], [data-interior-size]')) {
        updateInteriorPreview(primaryScopeRoom());
      }
      if (event.target.matches('[data-exterior]')) {
        updateExteriorPreview(primaryScopeRoom());
      }
      if (event.target.closest('main')) calculateTotal();
    });
    document.addEventListener('change', (event) => {
      if (event.target.matches('[data-interior], [data-interior-size]')) {
        updateInteriorPreview(primaryScopeRoom());
      }
      if (event.target.matches('[data-field="rateId"]')) {
        const surface = event.target.closest('[data-surface-item]');
        syncSurfaceMeasurement(surface);
        const rate = rates.find(item => item.id === event.target.value);
        surface.querySelector('[data-field="applicationMethod"]').value = defaultApplicationMethod(rate);
        updateInteriorPreview(surface.closest('#rooms-container > div'));
        updateExteriorPreview(surface.closest('#rooms-container > div'));
      }
      if (event.target.closest('main')) calculateTotal();
    });

    async function persistEstimate(statusValue = 'sent') {
      const previewOpen = !document.getElementById('send-preview-modal').classList.contains('hidden');
      const button = document.getElementById(statusValue === 'draft' ? 'save-draft' : previewOpen ? 'confirm-send-estimate' : 'save-estimate');
      const otherButton = document.getElementById(statusValue === 'draft' ? 'save-estimate' : 'save-draft');
      const status = document.getElementById('save-status');
      const leadId = document.getElementById('lead-select').value;
      const packages = buildPackages();
      if (!leadId) {
        window.showToast('Select a customer first', 'error');
        return;
      }
      if (statusValue !== 'draft' && packages.length === 0) {
        window.showToast('Add at least one measured substrate', 'error');
        return;
      }

      try {
        button.disabled = true;
        otherButton.disabled = true;
        button.textContent = statusValue === 'draft' ? 'Saving draft...' : 'Sending email...';
        status.textContent = statusValue === 'draft' ? 'Saving draft estimate...' : 'Creating estimate, sending email, and opening the customer proposal...';
        status.classList.remove('hidden');
        const isEditingDraft = Boolean(editingEstimateId);
        const { data } = await apiJson(isEditingDraft ? `${API_URL}/v1/estimates/${editingEstimateId}` : `${API_URL}/v1/estimates`, {
          method: isEditingDraft ? 'PATCH' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ leadId, packages, status: statusValue }),
        });
        let sendResult = null;
        if (statusValue !== 'draft') {
          const sendPayload = await apiJson(`${API_URL}/v1/estimates/${data.id}/send-email`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Idempotency-Key': crypto.randomUUID(),
            },
          });
          sendResult = sendPayload?.data || null;
        }
        window.showToast(statusValue === 'draft' ? 'Draft saved.' : 'Estimate emailed. Opening it now.');
        editingEstimateId = data.id;
        closeSendPreview();
        const previewUrl = sendResult?.previewUrl || data.customerPreviewUrl || data.publicUrl || `/estimates/${data.id}`;
        const previewPath = new URL(previewUrl, window.location.origin).pathname;
        window.location.href = statusValue === 'draft' ? '/estimates?status=draft' : previewPath;
      } catch (err) {
        window.showToast(err.message || 'Failed to save estimate', 'error');
        status.textContent = err.message || 'Failed to save estimate';
        button.disabled = false;
        otherButton.disabled = false;
        button.textContent = statusValue === 'draft' ? 'Save Draft' : previewOpen ? 'Send Email' : 'Send Estimate';
      }
    }

    document.getElementById('save-draft').addEventListener('click', () => persistEstimate('draft'));
    document.getElementById('save-estimate').addEventListener('click', () => {
      const leadId = document.getElementById('lead-select').value;
      if (!leadId) {
        window.showToast('Select a customer first', 'error');
        return;
      }
      renderSendPreview();
    });
    document.getElementById('close-send-preview').addEventListener('click', closeSendPreview);
    document.getElementById('cancel-send-preview').addEventListener('click', closeSendPreview);
    document.getElementById('confirm-send-estimate').addEventListener('click', () => persistEstimate('sent'));

    loadSetup().catch((err) => {
      console.error('Failed to load production estimator', err);
      showSetupError(err.message || 'Failed to load estimator setup');
    });
  </script>
</Base>
