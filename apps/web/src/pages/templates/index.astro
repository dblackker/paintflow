---
import Layout from '../../components/Layout.astro';
---

<Layout title="Message Templates">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Message Templates</h1>
        <p class="text-gray-600">Customize automated emails and SMS messages</p>
      </div>
      <button onclick="document.getElementById('new-modal').classList.remove('hidden')" class="px-4 py-2 bg-blue-600 text-white rounded-lg">+ New Template</button>
    </div>

    <div id="templates-list" class="space-y-4"></div>

    <div id="new-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg p-6 w-full max-w-2xl">
        <h2 class="text-xl font-bold mb-4">Create Template</h2>
        <form id="template-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <select name="type" required class="px-3 py-2 border rounded">
              <option value="">Select type</option>
              <option value="estimate_followup_1">Estimate Follow-up #1</option>
              <option value="estimate_followup_2">Estimate Follow-up #2</option>
              <option value="estimate_followup_3">Estimate Follow-up #3</option>
              <option value="job_complete">Job Complete</option>
              <option value="review_request">Review Request</option>
            </select>
            <select name="channel" required class="px-3 py-2 border rounded">
              <option value="sms">SMS</option>
              <option value="email">Email</option>
            </select>
          </div>
          <input type="text" name="subject" placeholder="Subject (email only)" class="w-full px-3 py-2 border rounded">
          <input type="text" name="subject" placeholder="Subject (email only)" class="w-full px-3 py-2 border rounded">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-sm text-gray-600">Insert variable:</span>
              <button type="button" onclick="insertVar('customer_name')" class="px-2 py-1 text-xs border rounded hover:bg-gray-50">{customer_name}</button>
              <button type="button" onclick="insertVar('estimate_total')" class="px-2 py-1 text-xs border rounded hover:bg-gray-50">{estimate_total}</button>
              <button type="button" onclick="insertVar('company_name')" class="px-2 py-1 text-xs border rounded hover:bg-gray-50">{company_name}</button>
              <button type="button" onclick="insertVar('job_address')" class="px-2 py-1 text-xs border rounded hover:bg-gray-50">{job_address}</button>
            </div>
            <textarea name="body" id="template-body" rows="6" placeholder="Message body..." required class="w-full px-3 py-2 border rounded font-mono text-sm"></textarea>
            <div class="mt-2 p-3 bg-gray-50 rounded text-sm">
              <p class="text-gray-600 mb-1">Preview:</p>
              <p id="preview" class="font-mono text-xs text-gray-700"></p>
            </div>
          </div>
        
        if (data.length === 0) {
          container.innerHTML = '<p class="text-gray-500">No templates yet</p>';
          return;
        }
        
        container.innerHTML = data.map(t => `
          <div class="bg-white rounded-lg shadow-sm border p-4">
            <div class="flex justify-between">
              <div>
                <h3 class="font-semibold">${t.type.replace(/_/g, ' ')}</h3>
                <p class="text-sm text-gray-600">${t.channel.toUpperCase()} • Delay: ${t.delayDays} days</p>
              </div>
              <span class="text-sm ${t.enabled ? 'text-green-600' : 'text-gray-400'}">${t.enabled ? 'Enabled' : 'Disabled'}</span>
            </div>
            <p class="mt-2 text-sm font-mono bg-gray-50 p-2 rounded truncate">${t.body}</p>
          </div>
        `).join('');
      } catch (err) {
        console.error(err);
      }
    }
    
    document.getElementById('template-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      data.enabled = formData.has('enabled');
      data.delayDays = parseInt(data.delayDays) || 0;
      
      await fetch(`${API_URL}/v1/templates`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data),
      });
      document.getElementById('new-modal').classList.add('hidden');
      e.target.reset();
      loadTemplates();
    });
    
    loadTemplates();
  </script>
</Layout>

    // Variable insertion
    window.insertVar = (varName) => {
      const textarea = document.getElementById('template-body');
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const text = textarea.value;
      const before = text.substring(0, start);
      const after = text.substring(end);
      textarea.value = before + `{${varName}}` + after;
      textarea.focus();
      textarea.setSelectionRange(start + varName.length + 2, start + varName.length + 2);
      updatePreview();
    };

    // Live preview
    function updatePreview() {
      const body = document.getElementById('template-body')?.value || '';
      const preview = body
        .replace(/\{customer_name\}/g, 'John Smith')
        .replace(/\{estimate_total\}/g, '$5,200')
        .replace(/\{company_name\}/g, 'Black Line Painting')
        .replace(/\{job_address\}/g, '123 Main St');
      document.getElementById('preview').textContent = preview;
    }

    document.getElementById('template-body')?.addEventListener('input', updatePreview);
    updatePreview();
