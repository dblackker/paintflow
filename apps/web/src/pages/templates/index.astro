---
import Layout from '../../components/Layout.astro';
---

<Layout title="Message Templates">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Message Templates</h1>
        <p class="text-gray-600">Customize automated emails and SMS messages</p>
      </div>
      <button onclick="document.getElementById('new-modal').classList.remove('hidden')" class="px-4 py-2 bg-blue-600 text-white rounded-lg">+ New Template</button>
    </div>

    <div id="templates-list" class="space-y-4"></div>

    <div id="new-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg p-6 w-full max-w-2xl">
        <h2 class="text-xl font-bold mb-4">Create Template</h2>
        <form id="template-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <select name="type" required class="px-3 py-2 border rounded">
              <option value="">Select type</option>
              <option value="estimate_followup_1">Estimate Follow-up #1</option>
              <option value="estimate_followup_2">Estimate Follow-up #2</option>
              <option value="estimate_followup_3">Estimate Follow-up #3</option>
              <option value="job_complete">Job Complete</option>
              <option value="review_request">Review Request</option>
            </select>
            <select name="channel" required class="px-3 py-2 border rounded">
              <option value="sms">SMS</option>
              <option value="email">Email</option>
            </select>
          </div>
          <input type="text" name="subject" placeholder="Subject (email only)" class="w-full px-3 py-2 border rounded">
          <textarea name="body" rows="6" placeholder="Message body. Use customer_name, estimate_total..." required class="w-full px-3 py-2 border rounded font-mono text-sm"></textarea>
          <div class="flex items-center gap-4">
            <label class="flex items-center gap-2">
              <input type="checkbox" name="enabled" checked>
              <span class="text-sm">Enabled</span>
            </label>
            <input type="number" name="delayDays" placeholder="Delay days" value="0" class="px-3 py-2 border rounded w-32">
          </div>
          <div class="flex gap-3">
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Save</button>
            <button type="button" onclick="document.getElementById('new-modal').classList.add('hidden')" class="px-4 py-2 border rounded">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
    
    async function loadTemplates() {
      try {
        const res = await fetch(`${API_URL}/v1/templates`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById('templates-list');
        
        if (data.length === 0) {
          container.innerHTML = '<p class="text-gray-500">No templates yet</p>';
          return;
        }
        
        container.innerHTML = data.map(t => `
          <div class="bg-white rounded-lg shadow-sm border p-4">
            <div class="flex justify-between">
              <div>
                <h3 class="font-semibold">${t.type.replace(/_/g, ' ')}</h3>
                <p class="text-sm text-gray-600">${t.channel.toUpperCase()} • Delay: ${t.delayDays} days</p>
              </div>
              <span class="text-sm ${t.enabled ? 'text-green-600' : 'text-gray-400'}">${t.enabled ? 'Enabled' : 'Disabled'}</span>
            </div>
            <p class="mt-2 text-sm font-mono bg-gray-50 p-2 rounded truncate">${t.body}</p>
          </div>
        `).join('');
      } catch (err) {
        console.error(err);
      }
    }
    
    document.getElementById('template-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      data.enabled = formData.has('enabled');
      data.delayDays = parseInt(data.delayDays) || 0;
      
      await fetch(`${API_URL}/v1/templates`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data),
      });
      document.getElementById('new-modal').classList.add('hidden');
      e.target.reset();
      loadTemplates();
    });
    
    loadTemplates();
  </script>
</Layout>
