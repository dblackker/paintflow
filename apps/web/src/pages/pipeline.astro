---
import Base from '../layouts/Base.astro';
---

<Base title="Pipeline">
  <div class="min-h-screen bg-gray-50">
    <main class="max-w-[92rem] mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Customer workflow</p>
          <h1 class="text-2xl sm:text-3xl font-semibold text-gray-950">Pipeline</h1>
          <p class="mt-2 max-w-3xl text-sm text-gray-600">Track customers from lead capture through estimate, scheduling, production, and closeout.</p>
        </div>
        <div class="mobile-action-row flex flex-wrap gap-2">
          <a class="btn-secondary btn-sm" href="/leads?new=1">Add lead</a>
          <a class="btn-primary btn-sm" href="/estimates/production">Create estimate</a>
        </div>
      </div>

      <section id="pipeline-summary" class="mt-5 grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Pipeline value</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Active customers</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Open activities</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Needs attention</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
      </section>

      <section class="mobile-filter-panel mt-5 bg-white border rounded-lg p-3">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex overflow-x-auto gap-2 pb-1" id="group-filters">
            <button class="pipeline-filter" type="button" data-group="all">All</button>
            <button class="pipeline-filter is-active" type="button" data-group="sales">Sales</button>
            <button class="pipeline-filter" type="button" data-group="handoff">Handoff</button>
            <button class="pipeline-filter" type="button" data-group="production">Production</button>
            <button class="pipeline-filter" type="button" data-group="closeout">Closeout</button>
          </div>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input id="attention-only" type="checkbox" class="rounded border-gray-300">
            Needs attention only
          </label>
        </div>
      </section>

      <section id="pipeline-root" class="mt-5">
        <div class="bg-white border rounded-lg p-8 text-center text-gray-500">Loading pipeline...</div>
      </section>

      <section id="drop-rail" class="pipeline-drop-rail hidden" aria-live="polite"></section>
    </main>
  </div>

  <div id="activity-modal" class="hidden fixed inset-0 z-40">
    <div class="absolute inset-0 bg-black/35" data-close-activity></div>
    <div class="absolute inset-x-3 top-8 mx-auto max-w-lg rounded-lg border bg-white shadow-xl">
      <form id="activity-form" class="p-4 sm:p-5 space-y-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-gray-950">Add activity</h2>
            <p id="activity-customer" class="text-sm text-gray-600"></p>
          </div>
          <button type="button" class="btn-icon" data-close-activity aria-label="Close activity form">&times;</button>
        </div>
        <input type="hidden" name="leadId">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="text-sm font-medium text-gray-700">Type
            <select name="type" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
              <option value="follow_up">Follow-up</option>
              <option value="call">Call</option>
              <option value="text">Text</option>
              <option value="email">Email</option>
              <option value="site_visit">Site visit</option>
              <option value="task">Task</option>
              <option value="note">Note</option>
            </select>
          </label>
          <label class="text-sm font-medium text-gray-700">Due
            <input name="dueAt" type="datetime-local" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
          </label>
        </div>
        <label class="block text-sm font-medium text-gray-700">Title
          <input name="title" required maxlength="255" autocomplete="off" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Call after estimate review">
        </label>
        <label class="block text-sm font-medium text-gray-700">Notes
          <textarea name="notes" rows="3" maxlength="5000" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Optional internal context"></textarea>
        </label>
        <div class="flex justify-end gap-2">
          <button type="button" class="btn-secondary btn-sm" data-close-activity>Cancel</button>
          <button id="save-activity" type="submit" class="btn-primary btn-sm">Save activity</button>
        </div>
      </form>
    </div>
  </div>

  <div id="transition-modal" class="hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/35" data-close-transition></div>
    <div class="absolute inset-x-3 top-8 mx-auto max-w-lg rounded-lg border bg-white shadow-xl">
      <form id="transition-form" class="p-4 sm:p-5 space-y-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-gray-950">Move customer</h2>
            <p id="transition-customer" class="text-sm text-gray-600"></p>
          </div>
          <button type="button" class="btn-icon" data-close-transition aria-label="Close move form">&times;</button>
        </div>
        <input type="hidden" name="leadId">
        <label class="block text-sm font-medium text-gray-700">Pipeline stage
          <select name="targetStage" class="mt-1 w-full rounded-md border px-3 py-2 text-sm"></select>
        </label>
        <label class="block text-sm font-medium text-gray-700">Reason or note
          <textarea name="reason" rows="3" maxlength="1000" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Why is this moving? Required when archiving or marking won without a signed estimate."></textarea>
        </label>
        <div class="rounded-lg border bg-gray-50 p-3">
          <p class="text-sm font-semibold text-gray-900">Optional follow-up</p>
          <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="text-sm font-medium text-gray-700">Task
              <input name="activityTitle" maxlength="255" autocomplete="off" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Call customer Friday">
            </label>
            <label class="text-sm font-medium text-gray-700">Due
              <input name="dueAt" type="datetime-local" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
            </label>
          </div>
        </div>
        <div id="transition-helper" class="rounded-md bg-blue-50 px-3 py-2 text-sm text-blue-900"></div>
        <div class="flex justify-end gap-2">
          <button type="button" class="btn-secondary btn-sm" data-close-transition>Cancel</button>
          <button id="save-transition" type="submit" class="btn-primary btn-sm">Move customer</button>
        </div>
      </form>
    </div>
  </div>

  <style is:global>
    .pipeline-filter {
      border: 1px solid var(--pf-border);
      border-radius: 999px;
      color: var(--pf-text-muted);
      flex: 0 0 auto;
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.45rem 0.8rem;
    }
    .pipeline-filter.is-active {
      background: var(--pf-primary);
      border-color: var(--pf-primary);
      color: white;
    }
    .pipeline-board {
      display: grid;
      gap: 1rem;
      grid-auto-columns: minmax(16rem, 18rem);
      grid-auto-flow: column;
      max-width: 100%;
      min-width: 0;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      width: 100%;
    }
    .pipeline-board:not(.pipeline-board-all) {
      grid-auto-columns: initial;
      grid-auto-flow: initial;
      grid-template-columns: repeat(auto-fit, minmax(min(13.5rem, 100%), 1fr));
      overflow-x: visible;
    }
    .pipeline-stage {
      min-height: 18rem;
      transition: border-color 150ms ease, background-color 150ms ease;
    }
    .pipeline-board.is-dragging .pipeline-stage {
      background: #f8fbff;
      border-color: #bfdbfe;
      border-style: dashed;
      box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.08);
    }
    .pipeline-stage.is-drop-target {
      background: #dbeafe;
      border-color: #2563eb;
      border-style: solid;
      box-shadow: inset 0 0 0 2px rgba(37, 99, 235, 0.22), 0 10px 24px rgba(37, 99, 235, 0.12);
    }
    .pipeline-stage-header {
      position: sticky;
      top: calc(var(--pf-app-nav-height, 4rem) + 0.5rem);
      z-index: 2;
    }
    .pipeline-card[draggable="true"] {
      cursor: grab;
    }
    .pipeline-card.is-dragging {
      opacity: 0.55;
    }
    .pipeline-drop-rail {
      position: fixed;
      inset-inline: 1rem;
      bottom: 1rem;
      z-index: 70;
      border: 1px solid var(--pf-border);
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
      display: grid;
      gap: 0.5rem;
      grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
      padding: 0.6rem;
    }
    .pipeline-drop-rail.hidden {
      display: none;
    }
    .pipeline-drop-chip {
      border: 1px dashed #93c5fd;
      border-radius: 999px;
      color: #1d4ed8;
      font-size: 0.78rem;
      font-weight: 700;
      min-height: 2.25rem;
      padding: 0.4rem 0.7rem;
      text-align: center;
    }
    .pipeline-drop-chip.is-drop-target {
      background: #2563eb;
      border-color: #2563eb;
      color: white;
    }
    @media (max-width: 760px) {
      .pipeline-board {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        overflow-x: visible;
      }
      .pipeline-board > section {
        padding: 0.7rem;
        min-height: 8rem;
      }
      .pipeline-board article {
        padding: 0.75rem;
      }
      #group-filters {
        margin-inline: -0.15rem;
        padding-inline: 0.15rem;
        width: 100%;
      }
      .pipeline-filter {
        font-size: 0.78rem;
        min-height: 2rem;
        padding: 0.35rem 0.65rem;
      }
      .pipeline-stage-header {
        position: static;
      }
      .pipeline-drop-rail {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const root = document.getElementById('pipeline-root');
    const summary = document.getElementById('pipeline-summary');
    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString()}`;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const escapeHtml = (value = '') => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    let pipelineData = { stages: [], cards: [], summary: {} };
    let activeGroup = 'sales';
    let attentionOnly = false;
    let dragPayload = null;
    let pendingTransition = null;

    async function apiJson(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function compactDate(value) {
      return value ? new Date(value).toLocaleDateString([], { month: 'short', day: 'numeric' }) : 'No due date';
    }

    function formatAddress(address = {}) {
      return window.PaintFlowFormat?.address(address) || [address.street, [address.city, address.state].filter(Boolean).join(', '), address.postalCode].filter(Boolean).join(' ');
    }

    function stageCards(stageId) {
      return pipelineData.cards
        .filter((card) => card.stage === stageId && (!attentionOnly || card.warnings.length))
        .sort((a, b) => {
          const warningDelta = Number(Boolean(b.warnings.length)) - Number(Boolean(a.warnings.length));
          if (warningDelta) return warningDelta;
          const aDue = a.nextActivity?.dueAt ? new Date(a.nextActivity.dueAt).getTime() : Number.MAX_SAFE_INTEGER;
          const bDue = b.nextActivity?.dueAt ? new Date(b.nextActivity.dueAt).getTime() : Number.MAX_SAFE_INTEGER;
          if (aDue !== bDue) return aDue - bDue;
          return Number(b.daysInStage || 0) - Number(a.daysInStage || 0);
        });
    }

    function renderSummary() {
      const data = pipelineData.summary || {};
      const values = [
        money(data.totalValue || 0, { cents: false }),
        data.activeCustomers || 0,
        data.openActivities || 0,
        data.staleCount || 0,
      ];
      [...summary.querySelectorAll('p.text-xl')].forEach((node, index) => {
        node.textContent = values[index];
      });
    }

    function renderCard(card) {
      const address = formatAddress(card.address);
      const addressLine = address
        ? window.PaintFlowFormat?.addressLink(address, { className: 'mt-1 block truncate text-xs text-gray-600 hover:text-blue-700 hover:underline' }) || `<span class="mt-1 block truncate text-xs text-gray-600">${escapeHtml(address)}</span>`
        : `<p class="mt-1 truncate text-xs text-gray-600">${escapeHtml(card.source || 'No address')}</p>`;
      return `
        <article class="pipeline-card mobile-card-row rounded-lg border bg-white p-3 shadow-sm" draggable="true" data-lead-id="${escapeHtml(card.leadId)}" data-stage="${escapeHtml(card.stage)}" data-name="${escapeHtml(card.name)}">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <a class="block truncate text-sm font-semibold text-gray-950 hover:text-blue-700" href="${escapeHtml(card.href)}">${escapeHtml(card.name)}</a>
              ${addressLine}
            </div>
            <p class="shrink-0 text-sm font-semibold text-gray-950">${money(card.value, { cents: false })}</p>
          </div>
          <div class="mt-3 flex items-center justify-between gap-2 text-xs text-gray-600">
            ${window.PaintFlowUI?.contactActions({ phone: card.phone, email: card.email, leadId: card.leadId }) || ''}
            <span class="shrink-0">${card.daysInStage}d in stage</span>
          </div>
          ${card.nextActivity ? `
            <div class="mt-3 rounded-md bg-blue-50 px-2.5 py-2 text-xs text-blue-900">
              <p class="font-semibold">${escapeHtml(label(card.nextActivity.type))}: ${escapeHtml(card.nextActivity.title)}</p>
              <p>${compactDate(card.nextActivity.dueAt)}</p>
            </div>
          ` : ''}
          ${card.warnings.length ? `
            <div class="mt-3 space-y-1">
              ${card.warnings.map((warning) => `<p class="rounded-md bg-amber-50 px-2 py-1 text-xs font-medium text-amber-800">${escapeHtml(warning)}</p>`).join('')}
            </div>
          ` : ''}
          <div class="mt-3 flex items-center justify-between gap-2 border-t pt-3">
            <a class="text-xs font-semibold text-blue-700" href="/leads/${card.leadId}">Profile</a>
            <div class="flex gap-1.5">
              <button class="btn-secondary btn-sm" type="button" data-move-card="${card.leadId}" data-stage="${escapeHtml(card.stage)}" data-name="${escapeHtml(card.name)}">Move</button>
              <button class="btn-secondary btn-sm" type="button" data-add-activity="${card.leadId}" data-name="${escapeHtml(card.name)}">Activity</button>
            </div>
          </div>
        </article>
      `;
    }

    function render() {
      renderSummary();
      const stages = pipelineData.stages.filter((stage) => activeGroup === 'all' || stage.group === activeGroup);
      if (!stages.length) {
        root.innerHTML = '<div class="bg-white border rounded-lg p-8 text-center text-gray-500">No stages available.</div>';
        return;
      }
      root.innerHTML = `
        <div class="pipeline-board pipeline-board-${escapeHtml(activeGroup)}">
          ${stages.map((stage) => {
            const cards = stageCards(stage.id);
            const value = cards.reduce((sum, card) => sum + Number(card.value || 0), 0);
            return `
              <section class="pipeline-stage rounded-lg border bg-gray-50 p-3" data-stage-id="${escapeHtml(stage.id)}">
                <div class="pipeline-stage-header mb-3 flex items-start justify-between gap-2 rounded-md bg-gray-50/95 pb-2">
                  <div>
                    <h2 class="text-sm font-semibold text-gray-950">${escapeHtml(stage.label)}</h2>
                    <p class="text-xs text-gray-600">${cards.length} customers</p>
                  </div>
                  <span class="rounded-full bg-white px-2 py-1 text-xs font-semibold text-gray-700">${money(value, { cents: false })}</span>
                </div>
                <div class="space-y-3">${cards.length ? cards.map(renderCard).join('') : '<div class="rounded-lg border border-dashed bg-white p-4 text-sm text-gray-500">Drop a customer here or use Move.</div>'}</div>
              </section>
            `;
          }).join('')}
        </div>
      `;
    }

    function visibleStages() {
      return pipelineData.stages.filter((stage) => activeGroup === 'all' || stage.group === activeGroup);
    }

    function renderDropRail() {
      const rail = document.getElementById('drop-rail');
      if (!dragPayload) {
        rail.classList.add('hidden');
        rail.innerHTML = '';
        return;
      }
      rail.innerHTML = visibleStages()
        .filter((stage) => stage.id !== dragPayload.currentStage)
        .map((stage) => `<button class="pipeline-drop-chip" type="button" data-rail-stage="${escapeHtml(stage.id)}">${escapeHtml(stage.label)}</button>`)
        .join('');
      rail.classList.remove('hidden');
    }

    function resetDragUi() {
      dragPayload = null;
      document.querySelector('.pipeline-board')?.classList.remove('is-dragging');
      document.querySelectorAll('.pipeline-stage.is-drop-target, .pipeline-drop-chip.is-drop-target').forEach((node) => node.classList.remove('is-drop-target'));
      renderDropRail();
    }

    function beginTransitionToStage(targetStage) {
      if (!dragPayload || dragPayload.currentStage === targetStage) return;
      const card = findCard(dragPayload.leadId);
      const payload = {
        leadId: dragPayload.leadId,
        name: dragPayload.name || card?.name || 'Customer',
        currentStage: dragPayload.currentStage || card?.stage,
        targetStage,
      };
      resetDragUi();
      openTransitionModal(payload);
    }

    async function loadPipeline() {
      try {
        const payload = await apiJson('/v1/pipeline');
        if (!payload) return;
        pipelineData = payload.data;
        render();
      } catch (err) {
        root.innerHTML = `<div class="bg-white border rounded-lg p-8 text-center text-red-600">${escapeHtml(err.message || 'Failed to load pipeline')}</div>`;
      }
    }

    function openActivityModal(leadId, name) {
      const modal = document.getElementById('activity-modal');
      const form = document.getElementById('activity-form');
      form.reset();
      form.elements.leadId.value = leadId;
      form.elements.title.value = 'Follow up with customer';
      document.getElementById('activity-customer').textContent = name;
      modal.classList.remove('hidden');
      form.elements.title.focus();
    }

    function closeActivityModal() {
      document.getElementById('activity-modal').classList.add('hidden');
    }

    function stageLabel(stageId) {
      return pipelineData.stages.find((stage) => stage.id === stageId)?.label || label(stageId);
    }

    function transitionHelper(targetStage) {
      if (targetStage === 'lost') return 'Archive lost work with a short reason so win/loss reports and future follow-ups stay useful.';
      if (targetStage === 'estimate_sent') return 'This stage is normally set automatically when an estimate is sent.';
      if (['scheduled', 'in_production', 'punch_list', 'completed_review'].includes(targetStage)) return 'Production stages are normally driven by the job status once a job exists.';
      if (['won_deposit_pending', 'ready_to_schedule'].includes(targetStage)) return 'This is normally set after a customer signs an estimate, but you can move it manually for offline commitments.';
      return 'Use this when the customer interaction happened outside PaintFlow.';
    }

    function openTransitionModal({ leadId, name, currentStage, targetStage }) {
      const modal = document.getElementById('transition-modal');
      const form = document.getElementById('transition-form');
      const select = form.elements.targetStage;
      form.reset();
      select.innerHTML = pipelineData.stages.map((stage) => `<option value="${escapeHtml(stage.id)}">${escapeHtml(stage.label)}</option>`).join('');
      form.elements.leadId.value = leadId;
      select.value = targetStage || currentStage || 'contacted';
      pendingTransition = { leadId, fromStage: currentStage, name };
      document.getElementById('transition-customer').textContent = `${name} · ${stageLabel(currentStage)} to ${stageLabel(select.value)}`;
      document.getElementById('transition-helper').textContent = transitionHelper(select.value);
      modal.classList.remove('hidden');
      select.focus();
    }

    function closeTransitionModal() {
      document.getElementById('transition-modal').classList.add('hidden');
      pendingTransition = null;
    }

    function findCard(leadId) {
      return pipelineData.cards.find((card) => card.leadId === leadId || card.id === leadId);
    }

    document.addEventListener('click', (event) => {
      const activityButton = event.target.closest('[data-add-activity]');
      if (activityButton) openActivityModal(activityButton.dataset.addActivity, activityButton.dataset.name);
      if (event.target.closest('[data-close-activity]')) closeActivityModal();
      const moveButton = event.target.closest('[data-move-card]');
      if (moveButton) openTransitionModal({
        leadId: moveButton.dataset.moveCard,
        name: moveButton.dataset.name,
        currentStage: moveButton.dataset.stage,
        targetStage: moveButton.dataset.stage,
      });
      if (event.target.closest('[data-close-transition]')) closeTransitionModal();
    });

    document.addEventListener('dragstart', (event) => {
      const card = event.target.closest('.pipeline-card');
      if (!card) return;
      card.classList.add('is-dragging');
      dragPayload = {
        leadId: card.dataset.leadId,
        currentStage: card.dataset.stage,
        name: card.dataset.name,
      };
      document.querySelector('.pipeline-board')?.classList.add('is-dragging');
      renderDropRail();
      event.dataTransfer.effectAllowed = 'move';
      event.dataTransfer.setData('text/plain', JSON.stringify(dragPayload));
    });

    document.addEventListener('dragend', (event) => {
      event.target.closest?.('.pipeline-card')?.classList.remove('is-dragging');
      resetDragUi();
    });

    document.addEventListener('dragover', (event) => {
      const stage = event.target.closest('.pipeline-stage, .pipeline-drop-chip');
      if (!stage || !dragPayload) return;
      event.preventDefault();
      document.querySelectorAll('.pipeline-stage.is-drop-target, .pipeline-drop-chip.is-drop-target').forEach((node) => {
        if (node !== stage) node.classList.remove('is-drop-target');
      });
      stage.classList.add('is-drop-target');
    });

    document.addEventListener('dragleave', (event) => {
      const stage = event.target.closest('.pipeline-stage, .pipeline-drop-chip');
      if (!stage || stage.contains(event.relatedTarget)) return;
      stage.classList.remove('is-drop-target');
    });

    document.addEventListener('drop', (event) => {
      const stage = event.target.closest('.pipeline-stage, .pipeline-drop-chip');
      if (!stage) return;
      event.preventDefault();
      const data = JSON.parse(event.dataTransfer.getData('text/plain') || '{}');
      dragPayload = dragPayload || data;
      beginTransitionToStage(stage.dataset.stageId || stage.dataset.railStage);
    });

    document.getElementById('drop-rail').addEventListener('click', (event) => {
      const chip = event.target.closest('[data-rail-stage]');
      if (!chip || !dragPayload) return;
      beginTransitionToStage(chip.dataset.railStage);
    });

    document.getElementById('transition-form').addEventListener('change', (event) => {
      if (event.target.name !== 'targetStage' || !pendingTransition) return;
      document.getElementById('transition-customer').textContent = `${pendingTransition.name} · ${stageLabel(pendingTransition.fromStage)} to ${stageLabel(event.target.value)}`;
      document.getElementById('transition-helper').textContent = transitionHelper(event.target.value);
    });

    document.getElementById('group-filters').addEventListener('click', (event) => {
      const button = event.target.closest('[data-group]');
      if (!button) return;
      activeGroup = button.dataset.group;
      document.querySelectorAll('.pipeline-filter').forEach((node) => node.classList.toggle('is-active', node === button));
      render();
    });

    document.getElementById('attention-only').addEventListener('change', (event) => {
      attentionOnly = event.target.checked;
      render();
    });

    document.getElementById('activity-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const save = document.getElementById('save-activity');
      const formData = new FormData(form);
      save.disabled = true;
      try {
        await apiJson('/v1/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({
            leadId: formData.get('leadId'),
            type: formData.get('type'),
            title: formData.get('title'),
            notes: formData.get('notes') || null,
            dueAt: formData.get('dueAt') ? new Date(formData.get('dueAt')).toISOString() : null,
          }),
        });
        closeActivityModal();
        window.showToast?.('Activity saved', 'success');
        await loadPipeline();
      } catch (err) {
        window.showToast?.(err.message || 'Failed to save activity', 'error');
      } finally {
        save.disabled = false;
      }
    });

    document.getElementById('transition-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const save = document.getElementById('save-transition');
      const formData = new FormData(form);
      save.disabled = true;
      try {
        const payload = await apiJson(`/v1/pipeline/cards/${formData.get('leadId')}/transition`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({
            targetStage: formData.get('targetStage'),
            reason: formData.get('reason') || null,
            activityTitle: formData.get('activityTitle') || null,
            dueAt: formData.get('dueAt') ? new Date(formData.get('dueAt')).toISOString() : null,
          }),
        });
        closeTransitionModal();
        window.showToast?.(payload?.data?.unchanged ? 'No pipeline change needed' : 'Customer moved', 'success');
        await loadPipeline();
      } catch (err) {
        window.showToast?.(err.message || 'Failed to move customer', 'error');
      } finally {
        save.disabled = false;
      }
    });

    loadPipeline();
  </script>
</Base>
