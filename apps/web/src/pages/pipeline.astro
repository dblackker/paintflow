---
import Base from '../layouts/Base.astro';
---

<Base title="Pipeline">
  <div class="min-h-screen bg-gray-50">
    <main class="max-w-[92rem] mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-medium text-gray-600">Customer workflow</p>
          <h1 class="text-2xl sm:text-3xl font-semibold text-gray-950">Pipeline</h1>
          <p class="mt-2 max-w-3xl text-sm text-gray-600">Track customers from lead capture through estimate, scheduling, production, and closeout.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a class="btn-secondary btn-sm" href="/leads?new=1">Add lead</a>
          <a class="btn-primary btn-sm" href="/estimates/production">Create estimate</a>
        </div>
      </div>

      <section id="pipeline-summary" class="mt-5 grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Pipeline value</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Active customers</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Open activities</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
        <div class="bg-white border rounded-lg p-4"><p class="text-xs uppercase font-semibold text-gray-500">Needs attention</p><p class="mt-1 text-xl font-semibold text-gray-950">--</p></div>
      </section>

      <section class="mt-5 bg-white border rounded-lg p-3">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex overflow-x-auto gap-2 pb-1" id="group-filters">
            <button class="pipeline-filter is-active" type="button" data-group="all">All</button>
            <button class="pipeline-filter" type="button" data-group="sales">Sales</button>
            <button class="pipeline-filter" type="button" data-group="handoff">Handoff</button>
            <button class="pipeline-filter" type="button" data-group="production">Production</button>
            <button class="pipeline-filter" type="button" data-group="closeout">Closeout</button>
          </div>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input id="attention-only" type="checkbox" class="rounded border-gray-300">
            Needs attention only
          </label>
        </div>
      </section>

      <section id="pipeline-root" class="mt-5">
        <div class="bg-white border rounded-lg p-8 text-center text-gray-500">Loading pipeline...</div>
      </section>
    </main>
  </div>

  <div id="activity-modal" class="hidden fixed inset-0 z-40">
    <div class="absolute inset-0 bg-black/35" data-close-activity></div>
    <div class="absolute inset-x-3 top-8 mx-auto max-w-lg rounded-lg border bg-white shadow-xl">
      <form id="activity-form" class="p-4 sm:p-5 space-y-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-gray-950">Add activity</h2>
            <p id="activity-customer" class="text-sm text-gray-600"></p>
          </div>
          <button type="button" class="btn-icon" data-close-activity aria-label="Close activity form">&times;</button>
        </div>
        <input type="hidden" name="leadId">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="text-sm font-medium text-gray-700">Type
            <select name="type" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
              <option value="follow_up">Follow-up</option>
              <option value="call">Call</option>
              <option value="text">Text</option>
              <option value="email">Email</option>
              <option value="site_visit">Site visit</option>
              <option value="task">Task</option>
              <option value="note">Note</option>
            </select>
          </label>
          <label class="text-sm font-medium text-gray-700">Due
            <input name="dueAt" type="datetime-local" class="mt-1 w-full rounded-md border px-3 py-2 text-sm">
          </label>
        </div>
        <label class="block text-sm font-medium text-gray-700">Title
          <input name="title" required maxlength="255" autocomplete="off" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Call after estimate review">
        </label>
        <label class="block text-sm font-medium text-gray-700">Notes
          <textarea name="notes" rows="3" maxlength="5000" class="mt-1 w-full rounded-md border px-3 py-2 text-sm" placeholder="Optional internal context"></textarea>
        </label>
        <div class="flex justify-end gap-2">
          <button type="button" class="btn-secondary btn-sm" data-close-activity>Cancel</button>
          <button id="save-activity" type="submit" class="btn-primary btn-sm">Save activity</button>
        </div>
      </form>
    </div>
  </div>

  <style is:global>
    .pipeline-filter {
      border: 1px solid var(--pf-border);
      border-radius: 999px;
      color: var(--pf-text-muted);
      flex: 0 0 auto;
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.45rem 0.8rem;
    }
    .pipeline-filter.is-active {
      background: var(--pf-primary);
      border-color: var(--pf-primary);
      color: white;
    }
    .pipeline-board {
      display: grid;
      gap: 1rem;
      grid-auto-columns: minmax(17rem, 19rem);
      grid-auto-flow: column;
      max-width: 100%;
      min-width: 0;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      width: 100%;
    }
    @media (max-width: 760px) {
      .pipeline-board {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        overflow-x: visible;
      }
    }
  </style>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const root = document.getElementById('pipeline-root');
    const summary = document.getElementById('pipeline-summary');
    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString()}`;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const escapeHtml = (value = '') => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    let pipelineData = { stages: [], cards: [], summary: {} };
    let activeGroup = 'all';
    let attentionOnly = false;

    async function apiJson(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function compactDate(value) {
      return value ? new Date(value).toLocaleDateString([], { month: 'short', day: 'numeric' }) : 'No due date';
    }

    function formatAddress(address = {}) {
      return window.PaintFlowFormat?.address(address) || [address.street, [address.city, address.state].filter(Boolean).join(', '), address.postalCode].filter(Boolean).join(' ');
    }

    function stageCards(stageId) {
      return pipelineData.cards.filter((card) => card.stage === stageId && (!attentionOnly || card.warnings.length));
    }

    function renderSummary() {
      const data = pipelineData.summary || {};
      const values = [
        money(data.totalValue || 0, { cents: false }),
        data.activeCustomers || 0,
        data.openActivities || 0,
        data.staleCount || 0,
      ];
      [...summary.querySelectorAll('p.text-xl')].forEach((node, index) => {
        node.textContent = values[index];
      });
    }

    function renderCard(card) {
      const address = formatAddress(card.address);
      const addressLine = address
        ? window.PaintFlowFormat?.addressLink(address, { className: 'mt-1 block truncate text-xs text-gray-600 hover:text-blue-700 hover:underline' }) || `<span class="mt-1 block truncate text-xs text-gray-600">${escapeHtml(address)}</span>`
        : `<p class="mt-1 truncate text-xs text-gray-600">${escapeHtml(card.source || 'No address')}</p>`;
      return `
        <article class="rounded-lg border bg-white p-3 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <a class="block truncate text-sm font-semibold text-gray-950 hover:text-blue-700" href="${escapeHtml(card.href)}">${escapeHtml(card.name)}</a>
              ${addressLine}
            </div>
            <p class="shrink-0 text-sm font-semibold text-gray-950">${money(card.value, { cents: false })}</p>
          </div>
          <div class="mt-3 flex flex-wrap gap-2 text-xs text-gray-600">
            ${card.phone ? `<a class="hover:text-blue-700" href="tel:${escapeHtml(card.phone)}">${escapeHtml(phone(card.phone))}</a>` : '<span>No phone</span>'}
            <span>${card.daysInStage}d in stage</span>
          </div>
          ${card.nextActivity ? `
            <div class="mt-3 rounded-md bg-blue-50 px-2.5 py-2 text-xs text-blue-900">
              <p class="font-semibold">${escapeHtml(label(card.nextActivity.type))}: ${escapeHtml(card.nextActivity.title)}</p>
              <p>${compactDate(card.nextActivity.dueAt)}</p>
            </div>
          ` : ''}
          ${card.warnings.length ? `
            <div class="mt-3 space-y-1">
              ${card.warnings.map((warning) => `<p class="rounded-md bg-amber-50 px-2 py-1 text-xs font-medium text-amber-800">${escapeHtml(warning)}</p>`).join('')}
            </div>
          ` : ''}
          <div class="mt-3 flex items-center justify-between gap-2 border-t pt-3">
            <a class="text-xs font-semibold text-blue-700" href="/leads/${card.leadId}">Profile</a>
            <button class="rounded-md border px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-50" type="button" data-add-activity="${card.leadId}" data-name="${escapeHtml(card.name)}">Add activity</button>
          </div>
        </article>
      `;
    }

    function render() {
      renderSummary();
      const stages = pipelineData.stages.filter((stage) => activeGroup === 'all' || stage.group === activeGroup);
      if (!stages.length) {
        root.innerHTML = '<div class="bg-white border rounded-lg p-8 text-center text-gray-500">No stages available.</div>';
        return;
      }
      root.innerHTML = `
        <div class="pipeline-board">
          ${stages.map((stage) => {
            const cards = stageCards(stage.id);
            const value = cards.reduce((sum, card) => sum + Number(card.value || 0), 0);
            return `
              <section class="rounded-lg border bg-gray-50 p-3">
                <div class="mb-3 flex items-start justify-between gap-2">
                  <div>
                    <h2 class="text-sm font-semibold text-gray-950">${escapeHtml(stage.label)}</h2>
                    <p class="text-xs text-gray-600">${cards.length} customers</p>
                  </div>
                  <span class="rounded-full bg-white px-2 py-1 text-xs font-semibold text-gray-700">${money(value, { cents: false })}</span>
                </div>
                <div class="space-y-3">${cards.length ? cards.map(renderCard).join('') : '<div class="rounded-lg border border-dashed bg-white p-4 text-sm text-gray-500">No customers here.</div>'}</div>
              </section>
            `;
          }).join('')}
        </div>
      `;
    }

    async function loadPipeline() {
      try {
        const payload = await apiJson('/v1/pipeline');
        if (!payload) return;
        pipelineData = payload.data;
        render();
      } catch (err) {
        root.innerHTML = `<div class="bg-white border rounded-lg p-8 text-center text-red-600">${escapeHtml(err.message || 'Failed to load pipeline')}</div>`;
      }
    }

    function openActivityModal(leadId, name) {
      const modal = document.getElementById('activity-modal');
      const form = document.getElementById('activity-form');
      form.reset();
      form.elements.leadId.value = leadId;
      form.elements.title.value = 'Follow up with customer';
      document.getElementById('activity-customer').textContent = name;
      modal.classList.remove('hidden');
      form.elements.title.focus();
    }

    function closeActivityModal() {
      document.getElementById('activity-modal').classList.add('hidden');
    }

    document.addEventListener('click', (event) => {
      const activityButton = event.target.closest('[data-add-activity]');
      if (activityButton) openActivityModal(activityButton.dataset.addActivity, activityButton.dataset.name);
      if (event.target.closest('[data-close-activity]')) closeActivityModal();
    });

    document.getElementById('group-filters').addEventListener('click', (event) => {
      const button = event.target.closest('[data-group]');
      if (!button) return;
      activeGroup = button.dataset.group;
      document.querySelectorAll('.pipeline-filter').forEach((node) => node.classList.toggle('is-active', node === button));
      render();
    });

    document.getElementById('attention-only').addEventListener('change', (event) => {
      attentionOnly = event.target.checked;
      render();
    });

    document.getElementById('activity-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const save = document.getElementById('save-activity');
      const formData = new FormData(form);
      save.disabled = true;
      try {
        await apiJson('/v1/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({
            leadId: formData.get('leadId'),
            type: formData.get('type'),
            title: formData.get('title'),
            notes: formData.get('notes') || null,
            dueAt: formData.get('dueAt') ? new Date(formData.get('dueAt')).toISOString() : null,
          }),
        });
        closeActivityModal();
        window.showToast?.('Activity saved', 'success');
        await loadPipeline();
      } catch (err) {
        window.showToast?.(err.message || 'Failed to save activity', 'error');
      } finally {
        save.disabled = false;
      }
    });

    loadPipeline();
  </script>
</Base>
