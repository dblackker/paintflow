---
import Base from '../../layouts/Base.astro';
import DetailBackButton from '../../components/DetailBackButton.astro';
---

<Base title="Customer Detail">
  <div class="min-h-screen bg-gray-50">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <div class="mb-4">
        <DetailBackButton href="/leads" label="Back to leads" />
      </div>
      <div id="customer-root" class="space-y-5">
        <div class="bg-white border rounded-lg p-8 text-center text-gray-500">Loading customer...</div>
      </div>
    </main>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const leadId = window.location.pathname.split('/').pop();
    const root = document.getElementById('customer-root');

    const statusLabels = {
      new: 'New',
      contacted: 'Contacted',
      estimate_sent: 'Estimate sent',
      won: 'Won',
      lost: 'Lost',
      draft: 'Draft',
      sent: 'Sent',
      accepted: 'Accepted',
      declined: 'Declined',
      canceled: 'Canceled',
      superseded: 'Superseded',
      voided: 'Voided',
      partially_refunded: 'Partially refunded',
      refunded: 'Refunded',
      succeeded: 'Paid',
    };

    const currency = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const dateLabel = (value) => value ? new Date(value).toLocaleDateString() : 'Not set';
    const dateTimeLabel = (value) => value ? new Date(value).toLocaleString([], { month: 'numeric', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) : 'Not set';
    const escapeHtml = (value = '') => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    const formatAddress = (record, options = {}) => window.PaintFlowFormat?.address(record, '', options) || [record.streetAddress, [record.city, record.state].filter(Boolean).join(', '), record.postalCode].filter(Boolean).join(' ');
    const addressLink = (address, className = 'hover:text-blue-700 hover:underline') => window.PaintFlowFormat?.addressLink(address, { className }) || escapeHtml(address || 'No jobsite address');
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const statusBadge = (value, options = {}) => window.PaintFlowUI?.statusBadge({ value, ...options }) || `<span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">${escapeHtml(options.label || label(value))}</span>`;
    const photoSrc = (photo) => photo?.source === 'Job' && photo?.id
      ? `${API_URL}/v1/uploads/photos/file/${encodeURIComponent(photo.id)}`
      : photo?.url || '';

    async function apiJson(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function latestEstimate(estimates) {
      return [...estimates].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))[0];
    }

    function nextAction({ customer, estimates, jobs }) {
      const activeJob = jobs.find((job) => !['completed', 'cancelled'].includes(job.status));
      if (activeJob) {
        return { label: 'Open active job', href: `/jobs/${activeJob.id}` };
      }
      const sent = estimates.find((estimate) => estimate.status === 'sent');
      if (sent) {
        return { label: 'Follow up on estimate', href: `/estimates/${sent.id}` };
      }
      const draft = estimates.find((estimate) => estimate.status === 'draft');
      if (draft) {
        return { label: 'Edit draft estimate', href: `/estimates/production?estimateId=${draft.id}` };
      }
      return { label: 'Create estimate', href: `/estimates/production?leadId=${customer.id}` };
    }

    function renderStat(label, value, help, href = '') {
      const tag = href ? 'a' : 'div';
      const attrs = href ? `href="${escapeHtml(href)}"` : '';
      return `
        <${tag} ${attrs} class="block bg-white border rounded-lg p-4 hover:border-blue-300 hover:shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">${label}</p>
          <p class="text-2xl font-semibold text-gray-950 mt-1">${value}</p>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </${tag}>
      `;
    }

    function customerPreviewHref(estimate) {
      return new URL(estimate.customerPreviewUrl || estimate.publicUrl || `/estimates/${estimate.id}`, window.location.origin).pathname;
    }

    function estimateActions(estimate) {
      return window.PaintFlowUI?.estimateActions({
        estimate,
        previewHref: customerPreviewHref(estimate),
        editHref: `/estimates/production?estimateId=${estimate.id}`,
        className: 'justify-end shrink-0',
      }) || '';
    }

    function renderEstimates(estimates) {
      if (!estimates.length) {
        return '<div class="p-5 text-sm text-gray-500">No estimates yet.</div>';
      }
      const estimateTimeline = (estimate) => [
        ['Created', estimate.createdAt],
        ['Sent', estimate.sentAt],
        ['Accepted', estimate.signedAt],
        ['Client viewed', estimate.clientViewedAt],
      ]
        .filter(([, value]) => value)
        .map(([name, value]) => `<p>${name} ${dateTimeLabel(value)}</p>`)
        .join('');
      return estimates.map((estimate) => `
        <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-3 p-3 sm:p-4">
          <div class="min-w-0">
            <div class="flex min-w-0 items-center gap-2">
              <p class="shrink-0 font-semibold text-gray-950">${currency(estimate.total)}</p>
              ${statusBadge(estimate.status, { label: statusLabels[estimate.status] || estimate.status })}
            </div>
            <div class="mt-1 space-y-0.5 text-xs leading-5 text-gray-600">${estimateTimeline(estimate)}</div>
          </div>
          <div class="shrink-0 justify-self-end">${estimateActions(estimate)}</div>
        </div>
      `).join('');
    }

    function renderJobs(jobs) {
      if (!jobs.length) {
        return '<div class="p-5 text-sm text-gray-500">No jobs yet. Accepted estimates will become production work here.</div>';
      }
      return jobs.map((job) => `
        <a class="block p-4 hover:bg-gray-50" href="/jobs/${job.id}">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <div>
              <p class="font-medium text-gray-950">${escapeHtml(job.name)}</p>
              <p class="text-sm text-gray-600">Created ${dateLabel(job.createdAt)}${job.completedAt ? ` &middot; Completed ${dateLabel(job.completedAt)}` : ''}</p>
            </div>
            <div class="sm:text-right">
              ${statusBadge(job.status)}
              <p class="text-sm font-medium mt-1">${job.budget == null ? 'No budget' : currency(job.budget)}</p>
            </div>
          </div>
        </a>
      `).join('');
    }

    function renderMessages(messages) {
      if (!messages.length) {
        return '<div class="p-5 text-sm text-gray-500">No message history yet.</div>';
      }
      return messages.map((message) => `
        <div class="p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-sm font-medium">${message.direction === 'inbound' ? 'Customer' : 'Team'} message</p>
            <p class="text-xs text-gray-500">${dateLabel(message.createdAt)}</p>
          </div>
          <p class="text-sm text-gray-700 mt-1">${escapeHtml(message.body)}</p>
        </div>
      `).join('');
    }

    function renderEmailSends(emailSends = []) {
      if (!emailSends.length) {
        return '<div class="p-5 text-sm text-gray-500">No email history yet.</div>';
      }
      return emailSends.map((email) => `
        <details class="p-4">
          <summary class="cursor-pointer list-none">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-sm font-semibold text-gray-950">${escapeHtml(email.subject)}</p>
                  ${statusBadge(email.status || 'sent')}
                </div>
                <p class="mt-1 text-xs text-gray-500">${escapeHtml(email.templateName || 'Email')} &middot; Sent ${dateLabel(email.sentAt)} to ${escapeHtml(email.toEmail)}</p>
                ${email.previewText ? `<p class="mt-1 text-sm text-gray-600">${escapeHtml(email.previewText)}</p>` : ''}
              </div>
              <span class="btn-text btn-sm pointer-events-none">View email</span>
            </div>
          </summary>
          <div class="mt-3 rounded-lg border bg-gray-50 p-2">
            <iframe
              title="Sent email preview"
              class="h-80 w-full rounded-md bg-white"
              sandbox=""
              srcdoc="${escapeHtml(email.renderedHtml || '<p>Email preview unavailable.</p>')}"
            ></iframe>
          </div>
        </details>
      `).join('');
    }

    function renderPayments(payments = []) {
      if (!payments.length) {
        return '<div class="p-5 text-sm text-gray-500">No payment history yet.</div>';
      }
      return payments.map((payment) => {
        const amount = Number(payment.amount || 0);
        const refunded = Number(payment.refundedAmount || 0);
        const refundable = Math.max(amount - refunded, 0);
        return `
          <details class="p-4">
            <summary class="cursor-pointer list-none">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="font-semibold text-gray-950">${currency(amount)}</p>
                    ${statusBadge(payment.status || 'succeeded', { label: statusLabels[payment.status] || label(payment.status || 'succeeded') })}
                  </div>
                  <p class="mt-1 text-xs text-gray-500">${escapeHtml(payment.description || 'Customer payment')} &middot; ${dateLabel(payment.receivedAt)}</p>
                  ${refunded > 0 ? `<p class="mt-1 text-sm text-red-700">${currency(refunded)} refunded</p>` : ''}
                </div>
                <span class="btn-text btn-sm pointer-events-none">${refundable > 0 ? 'Refund' : 'View'}</span>
              </div>
            </summary>
            <div class="mt-3 rounded-lg border bg-gray-50 p-3">
              <dl class="grid grid-cols-2 gap-3 text-sm">
                <div><dt class="text-gray-500">Paid</dt><dd class="font-medium">${currency(amount)}</dd></div>
                <div><dt class="text-gray-500">Refundable</dt><dd class="font-medium">${currency(refundable)}</dd></div>
                <div><dt class="text-gray-500">Source</dt><dd class="font-medium">${escapeHtml(label(payment.source || 'stripe'))}</dd></div>
                <div><dt class="text-gray-500">Payment ID</dt><dd class="font-mono text-xs">${escapeHtml(payment.id.slice(0, 8))}</dd></div>
              </dl>
              ${refundable > 0 ? `
                <form class="mt-4 grid gap-2 sm:grid-cols-[8rem_1fr_auto]" data-refund-payment="${payment.id}">
                  <label class="text-sm">
                    <span class="sr-only">Refund amount</span>
                    <input name="amount" type="number" min="0.01" max="${refundable.toFixed(2)}" step="0.01" value="${refundable.toFixed(2)}" class="w-full rounded-md border px-3 py-2" aria-label="Refund amount">
                  </label>
                  <label class="text-sm">
                    <span class="sr-only">Refund reason</span>
                    <input name="reason" type="text" maxlength="500" class="w-full rounded-md border px-3 py-2" placeholder="Reason, credit, or damage note">
                  </label>
                  <button type="submit" class="btn-secondary btn-sm text-red-700 justify-center">Issue refund</button>
                </form>
              ` : ''}
            </div>
          </details>
        `;
      }).join('');
    }

    function renderPhotos(photos) {
      const all = [...photos.estimates.map((photo) => ({ ...photo, source: 'Estimate' })), ...photos.jobs.map((photo) => ({ ...photo, source: 'Job' }))];
      if (!all.length) {
        return '<div class="p-5 text-sm text-gray-500">No site or job photos yet.</div>';
      }
      return `
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 p-4">
          ${all.slice(0, 12).map((photo) => `
            <a href="${escapeHtml(photoSrc(photo))}" target="_blank" rel="noreferrer" class="block border rounded-lg overflow-hidden bg-gray-50">
              <div class="aspect-[4/3] bg-gray-100">
                <img
                  src="${escapeHtml(photoSrc(photo))}"
                  alt="${escapeHtml(`${photo.source} photo`)}"
                  class="h-full w-full object-cover"
                  loading="lazy"
                  onerror="this.replaceWith(Object.assign(document.createElement('div'), { className: 'flex h-full w-full items-center justify-center p-3 text-center text-xs text-gray-500', textContent: 'Photo preview unavailable' }))"
                >
              </div>
              <div class="p-2">
                <p class="text-xs font-medium text-gray-700">${escapeHtml(photo.source)} photo</p>
                <p class="text-xs text-gray-500">${dateLabel(photo.createdAt)}</p>
              </div>
            </a>
          `).join('')}
        </div>
      `;
    }

    function renderActivity(activity, customer) {
      const items = activity.length ? activity : [
        { action: 'lead.created', entityType: 'lead', createdAt: customer.createdAt },
        ...(customer.updatedAt && customer.updatedAt !== customer.createdAt ? [{ action: 'lead.updated', entityType: 'lead', createdAt: customer.updatedAt }] : []),
      ];
      return items.map((item) => `
        <div class="p-4 flex items-start gap-3">
          <div class="mt-1 h-2 w-2 rounded-full bg-blue-600"></div>
          <div>
            <p class="text-sm font-medium">${escapeHtml(label(item.action.replaceAll('.', ' ')))}</p>
            <p class="text-xs text-gray-500">${dateLabel(item.createdAt)}</p>
          </div>
        </div>
      `).join('');
    }

    function renderActivities(activities = []) {
      if (!activities.length) {
        return '<div class="p-4 text-sm text-gray-500">No planned activities yet.</div>';
      }
      return activities.map((activity) => `
        <div class="p-4 flex items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <p class="text-sm font-medium text-gray-950">${escapeHtml(activity.title)}</p>
              ${statusBadge(activity.status)}
            </div>
            <p class="mt-1 text-xs text-gray-500">${escapeHtml(label(activity.type))}${activity.dueAt ? ` &middot; Due ${new Date(activity.dueAt).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })}` : ' &middot; No due date'}</p>
            ${activity.notes ? `<p class="mt-2 text-sm text-gray-600">${escapeHtml(activity.notes)}</p>` : ''}
          </div>
          ${activity.status === 'open' ? `<button type="button" class="btn-secondary btn-sm" data-complete-activity="${activity.id}">Done</button>` : ''}
        </div>
      `).join('');
    }

    function renderFollowUps(data) {
      const followUps = [];
      const sentEstimate = data.estimates.find((estimate) => estimate.status === 'sent');
      const acceptedEstimate = data.estimates.find((estimate) => estimate.status === 'accepted');
      const completedJob = data.jobs.find((job) => job.status === 'completed');
      if (sentEstimate) followUps.push(`Follow up on estimate sent ${dateLabel(sentEstimate.sentAt || sentEstimate.createdAt)}.`);
      if (acceptedEstimate && !data.jobs.some((job) => job.estimateId === acceptedEstimate.id)) followUps.push('Accepted estimate needs a scheduled job.');
      if (completedJob) followUps.push('Completed job is ready for review request and before/after photo selection.');
      if (!followUps.length) followUps.push('No urgent follow-up detected. Keep contact details current and create the next estimate when ready.');
      return followUps.map((item) => `<li>${escapeHtml(item)}</li>`).join('');
    }

    function render(data) {
      const customer = data.customer;
      const action = nextAction(data);
      const recentEstimate = latestEstimate(data.estimates);
      root.innerHTML = `
        <section class="bg-white border rounded-lg p-5 sm:p-6">
          <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h1 class="text-2xl sm:text-3xl font-semibold text-gray-950">${escapeHtml(customer.name)}</h1>
                ${statusBadge(customer.status, { label: statusLabels[customer.status] || customer.status })}
              </div>
              <p class="text-sm text-gray-600 mt-2">${escapeHtml(customer.source || 'No source')} &middot; Created ${dateLabel(customer.createdAt)}</p>
              <div class="mt-3 text-base font-medium text-gray-950">${addressLink(formatAddress(customer, { multiline: true }), 'inline text-base font-medium text-gray-950 hover:text-blue-700 hover:underline') || 'No jobsite address on file'}</div>
              <div class="flex flex-wrap gap-2 mt-4">
                ${window.PaintFlowUI?.contactActions({ phone: customer.phone, email: customer.email, leadId: customer.id }) || ''}
                <a class="btn-primary btn-sm" href="${action.href}">${action.label}</a>
              </div>
            </div>
            <div class="lg:text-right text-sm text-gray-700">
              <p>${escapeHtml(customer.phone ? phone(customer.phone) : 'No phone')}</p>
              <p>${escapeHtml(customer.email || 'No email')}</p>
              <div class="mt-2 max-w-xs text-gray-600">${formatAddress(customer) ? addressLink(formatAddress(customer, { multiline: true }), 'inline text-gray-600 hover:text-blue-700 hover:underline') : ''}</div>
              <p class="text-gray-500 mt-2">Updated ${dateLabel(customer.updatedAt)}</p>
            </div>
          </div>
        </section>

        <section class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          ${renderStat('Estimates', data.estimates.length, recentEstimate ? `${currency(recentEstimate.total)} latest` : 'No estimate yet', '#customer-estimates')}
          ${renderStat('Jobs', data.jobs.length, data.jobs.find((job) => job.status !== 'completed') ? 'Active production' : 'No active job', '#customer-jobs')}
          ${renderStat('Payments', currency((data.payments || []).reduce((sum, payment) => sum + Number(payment.amount || 0) - Number(payment.refundedAmount || 0), 0)), `${data.payments?.length || 0} recorded`, '#customer-payments')}
          ${renderStat('Messages', data.messages.length + (data.emailSends?.length || 0), 'Text and email history', customer.phone ? `/sms?leadId=${customer.id}` : '#customer-messages')}
          ${renderStat('Photos', data.photos.estimates.length + data.photos.jobs.length, 'Estimate and job media', '#customer-photos')}
        </section>

        <section class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.5fr)_minmax(320px,1fr)] gap-5">
          <div class="space-y-5">
            <section id="customer-estimates" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b"><h2 class="font-semibold">Estimates</h2></div>
              <div class="divide-y">${renderEstimates(data.estimates)}</div>
            </section>
            <section id="customer-jobs" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b"><h2 class="font-semibold">Jobs</h2></div>
              <div class="divide-y">${renderJobs(data.jobs)}</div>
            </section>
            <section id="customer-photos" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b"><h2 class="font-semibold">Photos</h2></div>
              ${renderPhotos(data.photos)}
            </section>
          </div>
          <aside class="space-y-5">
            <section class="bg-white border rounded-lg">
              <div class="p-4 border-b"><h2 class="font-semibold">Follow-Up</h2></div>
              <ul class="p-4 text-sm text-gray-700 space-y-2 list-disc list-inside">${renderFollowUps(data)}</ul>
            </section>
            <section class="bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b">
                <h2 class="font-semibold">Activities</h2>
              </div>
              <form id="customer-activity-form" class="border-b p-4 space-y-3">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <select name="type" class="rounded-md border px-3 py-2 text-sm" aria-label="Activity type">
                    <option value="follow_up">Follow-up</option>
                    <option value="call">Call</option>
                    <option value="text">Text</option>
                    <option value="email">Email</option>
                    <option value="site_visit">Site visit</option>
                    <option value="task">Task</option>
                    <option value="note">Note</option>
                  </select>
                  <input name="dueAt" type="datetime-local" class="rounded-md border px-3 py-2 text-sm" aria-label="Due date">
                </div>
                <input name="title" required maxlength="255" class="w-full rounded-md border px-3 py-2 text-sm" placeholder="Next action">
                <div class="flex justify-end">
                  <button id="customer-activity-save" type="submit" class="btn-primary btn-sm">Save activity</button>
                </div>
              </form>
              <div id="customer-activities-list" class="divide-y">${renderActivities(data.activities)}</div>
            </section>
            <section id="customer-emails" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b flex items-center justify-between gap-3">
                <h2 class="font-semibold">Emails</h2>
                <span class="text-xs text-gray-500">${data.emailSends?.length || 0} sent</span>
              </div>
              <div class="divide-y max-h-[520px] overflow-auto">${renderEmailSends(data.emailSends || [])}</div>
            </section>
            <section id="customer-payments" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b flex items-center justify-between gap-3">
                <h2 class="font-semibold">Payments</h2>
                <span class="text-xs text-gray-500">${data.payments?.length || 0} recorded</span>
              </div>
              <div class="divide-y max-h-[520px] overflow-auto">${renderPayments(data.payments || [])}</div>
            </section>
            <section id="customer-messages" class="scroll-mt-24 bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b flex items-center justify-between gap-3">
                <h2 class="font-semibold">Messages</h2>
                <a class="btn-secondary btn-sm ${customer.phone ? '' : 'pointer-events-none opacity-50'}" href="${customer.phone ? `/sms?leadId=${customer.id}` : '#'}">Open thread</a>
              </div>
              <div class="divide-y max-h-[420px] overflow-auto">${renderMessages(data.messages)}</div>
            </section>
            <section class="bg-white border rounded-lg overflow-hidden">
              <div class="p-4 border-b"><h2 class="font-semibold">Activity</h2></div>
              <div class="divide-y">${renderActivity(data.activity, customer)}</div>
            </section>
          </aside>
        </section>
      `;
      if (window.location.hash) {
        requestAnimationFrame(() => document.querySelector(window.location.hash)?.scrollIntoView({ block: 'start' }));
      }
    }

    apiJson(`/v1/leads/${leadId}`)
      .then((payload) => payload && render(payload.data))
      .catch((err) => {
        root.innerHTML = `<div class="bg-white border rounded-lg p-8 text-center text-red-600">${escapeHtml(err.message || 'Failed to load customer')}</div>`;
      });

    window.addEventListener('paintflow:payment-recorded', async () => {
      const payload = await apiJson(`/v1/leads/${leadId}`);
      if (payload) render(payload.data);
    });

    window.addEventListener('paintflow:estimate-updated', async () => {
      const payload = await apiJson(`/v1/leads/${leadId}`);
      if (payload) render(payload.data);
    });

    document.addEventListener('submit', async (event) => {
      const refundForm = event.target?.closest('[data-refund-payment]');
      if (refundForm) {
        event.preventDefault();
        const button = refundForm.querySelector('button[type="submit"]');
        const formData = new FormData(refundForm);
        button.disabled = true;
        try {
          await apiJson(`/v1/payments/${refundForm.dataset.refundPayment}/refund`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({
              amount: Number(formData.get('amount')),
              reason: formData.get('reason') || undefined,
            }),
          });
          window.showToast?.('Refund submitted', 'success');
          const payload = await apiJson(`/v1/leads/${leadId}`);
          if (payload) render(payload.data);
        } catch (err) {
          window.showToast?.(err.message || 'Failed to issue refund', 'error');
          button.disabled = false;
        }
        return;
      }

      if (event.target?.id !== 'customer-activity-form') return;
      event.preventDefault();
      const form = event.target;
      const save = document.getElementById('customer-activity-save');
      const formData = new FormData(form);
      save.disabled = true;
      try {
        await apiJson('/v1/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({
            leadId,
            type: formData.get('type'),
            title: formData.get('title'),
            dueAt: formData.get('dueAt') ? new Date(formData.get('dueAt')).toISOString() : null,
          }),
        });
        window.showToast?.('Activity saved', 'success');
        const payload = await apiJson(`/v1/leads/${leadId}`);
        if (payload) render(payload.data);
      } catch (err) {
        window.showToast?.(err.message || 'Failed to save activity', 'error');
      } finally {
        save.disabled = false;
      }
    });

    document.addEventListener('click', async (event) => {
      const cancelEstimateButton = event.target.closest('[data-cancel-estimate]');
      if (cancelEstimateButton) {
        const shouldCancel = window.confirm('Cancel this estimate? The customer preview will no longer be approvable.');
        if (!shouldCancel) return;
        cancelEstimateButton.disabled = true;
        try {
          await apiJson(`/v1/estimates/${cancelEstimateButton.dataset.cancelEstimate}/cancel`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({ reason: 'Canceled from customer detail' }),
          });
          window.showToast?.('Estimate canceled', 'success');
          const payload = await apiJson(`/v1/leads/${leadId}`);
          if (payload) render(payload.data);
        } catch (err) {
          window.showToast?.(err.message || 'Failed to cancel estimate', 'error');
          cancelEstimateButton.disabled = false;
        }
        return;
      }

      const button = event.target.closest('[data-complete-activity]');
      if (!button) return;
      button.disabled = true;
      try {
        await apiJson(`/v1/activities/${button.dataset.completeActivity}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'done' }),
        });
        window.showToast?.('Activity completed', 'success');
        const payload = await apiJson(`/v1/leads/${leadId}`);
        if (payload) render(payload.data);
      } catch (err) {
        window.showToast?.(err.message || 'Failed to update activity', 'error');
        button.disabled = false;
      }
    });
  </script>
</Base>
