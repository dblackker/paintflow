---
import '../styles/design-system.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sign in - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="max-w-md w-full space-y-8">
      <div class="text-center">
        <h1 class="text-3xl font-bold text-gray-900">PaintFlow</h1>
        <p class="mt-2 text-gray-600">Sign in securely with a one-time email link</p>
      </div>
      
      <form id="login-form" class="mt-8 space-y-6">
        <div>
          <label for="email" class="sr-only">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            inputmode="email"
            enterkeyhint="send"
            required
            class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            placeholder="Email address"
          />
        </div>

        <div>
          <button
            type="submit"
            class="btn-primary w-full justify-center"
          >
            Email me a sign-in link
          </button>
        </div>
      </form>

      <p class="text-center text-sm text-gray-500">
        No password to remember. Each link <span id="demo-shortcut-trigger">expires</span> after 15 minutes.
      </p>

      <div id="message" class="hidden mt-4 p-4 rounded-lg"></div>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const message = document.getElementById('message') as HTMLDivElement;
      const demoShortcutTrigger = document.getElementById('demo-shortcut-trigger') as HTMLSpanElement | null;
      const DEMO_EMAIL = 'demo@goldenbrush.paintflow.local';
      const DEMO_CREW_EMAIL = 'devon@goldenbrush.example';
      const DEMO_LOGIN_EMAILS = new Set([DEMO_EMAIL, DEMO_CREW_EMAIL]);
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
      const IS_DEMO_OR_DEV = Boolean(import.meta.env.DEV)
        || ['localhost', '127.0.0.1'].includes(window.location.hostname)
        || window.location.hostname === 'paintflow-demo.pages.dev'
        || API_URL.includes('paintflow-api-demo');
      const params = new URLSearchParams(window.location.search);
      let demoShortcutClicks = 0;

      function signInToDemo(email = DEMO_EMAIL) {
        message.className = 'mt-4 p-4 rounded-lg bg-green-50 text-green-800';
        message.textContent = 'Signing you in to the demo workspace...';
        message.classList.remove('hidden');
        const appOrigin = window.location.hostname === '127.0.0.1'
          ? `${window.location.protocol}//localhost:${window.location.port}`
          : window.location.origin;
        const demoApiUrl = window.location.hostname === '127.0.0.1' && API_URL.includes('127.0.0.1')
          ? API_URL.replace('127.0.0.1', 'localhost')
          : API_URL;
        const redirectTo = `${appOrigin}${email === DEMO_CREW_EMAIL ? '/time' : '/dashboard'}`;
        window.location.href = `${demoApiUrl}/v1/auth/demo-login?email=${encodeURIComponent(email)}&redirectTo=${encodeURIComponent(redirectTo)}`;
      }

      if (params.get('error')) {
        message.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800';
        message.textContent = params.get('error') || 'Sign-in failed';
        message.classList.remove('hidden');
      }

      if (IS_DEMO_OR_DEV) {
        demoShortcutTrigger?.addEventListener('click', () => {
          demoShortcutClicks += 1;
          if (demoShortcutClicks >= 12) {
            demoShortcutClicks = 0;
            signInToDemo();
          }
        });
      }
      
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const email = String(formData.get('email') || '').trim().toLowerCase();
        
        const button = form.querySelector('button') as HTMLButtonElement;
        button.disabled = true;
        button.textContent = 'Sending...';
        
        try {
          if (DEMO_LOGIN_EMAILS.has(email) && IS_DEMO_OR_DEV) {
            signInToDemo(email);
            return;
          }

          const res = await fetch(`${API_URL}/v1/auth/magic-link`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
            credentials: 'include',
          });
          
          const data = await res.json();
          
          if (res.ok) {
            if (data.autoLogin && data.redirectUrl) {
              message.className = 'mt-4 p-4 rounded-lg bg-green-50 text-green-800';
              message.textContent = 'Signing you in to the demo workspace...';
              message.classList.remove('hidden');
              window.location.href = data.redirectUrl;
              return;
            }

            message.className = 'mt-4 p-4 rounded-lg bg-green-50 text-green-800';
            message.textContent = 'Check your email for a one-time sign-in link.';
            message.classList.remove('hidden');
            form.reset();
            
            // Dev mode: show token
            if (data.devToken) {
              const devLink = document.createElement('a');
              devLink.href = `${API_URL}/v1/auth/verify?token=${data.devToken}`;
              devLink.textContent = 'Development sign-in shortcut';
              devLink.className = 'block mt-2 text-sm underline';
              message.appendChild(devLink);
            }
          } else {
            throw new Error(data.error || 'Failed to send magic link');
          }
        } catch (err) {
          message.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800';
          message.textContent = err instanceof Error ? err.message : 'Something went wrong';
          message.classList.remove('hidden');
        } finally {
          button.disabled = false;
          button.textContent = 'Email me a sign-in link';
        }
      });
    </script>
  </body>
</html>
