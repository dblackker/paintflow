---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job - PaintFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <a href="/jobs" class="text-gray-600">← Jobs</a>
        <h1 class="text-xl font-semibold">Job Costs</h1>
        <div class="w-20"></div>
      </div>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div id="job-header" class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <div class="text-center py-8 text-gray-500">Loading...</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <h2 class="font-semibold">Labor Hours</h2>
            <button id="add-labor" class="text-sm text-blue-600">Add Hours</button>
          </div>
          <div id="labor-list" class="divide-y"></div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <h2 class="font-semibold">Material Costs</h2>
            <button id="add-material-cost" class="text-sm text-blue-600">Add Cost</button>
          </div>
          <div id="material-costs-list" class="divide-y"></div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Profitability</h3>
          <div id="margin-summary" class="space-y-3"></div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Estimated vs Actual</h3>
          <div id="comparison" class="space-y-2 text-sm"></div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
    const jobId = window.location.pathname.split('/').pop();

    async function loadJob() {
      const res = await fetch(`${API_URL}/v1/jobs/${jobId}`, { credentials: 'include' });
      const { data } = await res.json();
      renderJob(data);
      loadCosts();
    }

    function renderJob(job) {
      document.getElementById('job-header').innerHTML = `
        <div class="flex justify-between items-start">
          <div>
            <h2 class="text-xl font-semibold">${job.title}</h2>
            <p class="text-gray-600">${job.clientName}</p>
          </div>
          <div class="text-right">
            <p class="text-2xl font-bold">$${parseFloat(job.totalAmount || 0).toFixed(2)}</p>
            <p class="text-sm text-gray-600">Contract Value</p>
          </div>
        </div>
      `;
    }

    async function loadCosts() {
      const res = await fetch(`${API_URL}/v1/jobs/${jobId}/costs`, { credentials: 'include' });
      const { data } = await res.json();
      renderCosts(data);
    }

    function renderCosts(costs) {
      const labor = costs.filter(c => c.category === 'labor');
      const materials = costs.filter(c => c.category === 'materials');
      
      const laborTotal = labor.reduce((sum, c) => sum + parseFloat(c.totalCost), 0);
      const materialsTotal = materials.reduce((sum, c) => sum + parseFloat(c.totalCost), 0);
      const totalCost = laborTotal + materialsTotal;
      
      document.getElementById('labor-list').innerHTML = labor.length ? labor.map(c => `
        <div class="p-4 flex justify-between">
          <div>
            <p class="font-medium">${c.description}</p>
            <p class="text-sm text-gray-600">${c.quantity} hrs @ $${c.unitCost}/hr</p>
          </div>
          <p class="font-semibold">$${parseFloat(c.totalCost).toFixed(2)}</p>
        </div>
      `).join('') : '<div class="p-4 text-gray-500 text-sm">No labor costs tracked</div>';
      
      document.getElementById('material-costs-list').innerHTML = materials.length ? materials.map(c => `
        <div class="p-4 flex justify-between">
          <div>
            <p class="font-medium">${c.description}</p>
            <p class="text-sm text-gray-600">${c.quantity} units @ $${c.unitCost}</p>
          </div>
          <p class="font-semibold">$${parseFloat(c.totalCost).toFixed(2)}</p>
        </div>
      `).join('') : '<div class="p-4 text-gray-500 text-sm">No material costs tracked</div>';
      
      // Get job value
      const jobValue = parseFloat(document.querySelector('#job-header .text-2xl')?.textContent?.replace('$', '') || '0');
      const profit = jobValue - totalCost;
      const margin = jobValue > 0 ? (profit / jobValue * 100) : 0;
      
      document.getElementById('margin-summary').innerHTML = `
        <div class="flex justify-between">
          <span class="text-gray-600">Labor</span>
          <span class="font-semibold">$${laborTotal.toFixed(2)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Materials</span>
          <span class="font-semibold">$${materialsTotal.toFixed(2)}</span>
        </div>
        <div class="border-t pt-3 flex justify-between">
          <span class="font-medium">Total Cost</span>
          <span class="font-bold">$${totalCost.toFixed(2)}</span>
        </div>
        <div class="border-t pt-3 flex justify-between">
          <span class="font-medium">Profit</span>
          <span class="font-bold ${profit >= 0 ? 'text-green-600' : 'text-red-600'}">$${profit.toFixed(2)}</span>
        </div>
        <div class="flex justify-between">
          <span class="font-medium">Margin</span>
          <span class="font-bold ${margin >= 30 ? 'text-green-600' : margin >= 15 ? 'text-yellow-600' : 'text-red-600'}">${margin.toFixed(1)}%</span>
        </div>
      `;
    }

    loadJob();
  </script>
</body>
</html>
