---
import '../../styles/design-system.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Costing - PaintFlow</title>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <a href="/jobs" class="text-gray-600 hover:text-gray-900">&larr; Jobs</a>
        <h1 class="text-xl font-semibold">Job Costing</h1>
        <button id="complete-btn" class="hidden px-3 py-2 text-sm bg-green-100 text-green-800 rounded hover:bg-green-200">Mark Complete</button>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div id="job-header" class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <div class="text-center py-8 text-gray-500">Loading...</div>
    </div>

    <div id="kpis" class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <div>
              <h2 class="font-semibold">Actual Costs</h2>
              <p class="text-xs text-gray-500">Labor, materials, supplies, subcontractors, equipment, and other job costs</p>
            </div>
            <button id="add-cost-btn" class="text-sm px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Add Cost</button>
          </div>
          <div id="cost-list" class="divide-y"></div>
        </section>

        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
            <div>
              <h2 class="font-semibold">Crew Timecard</h2>
              <p class="text-xs text-gray-500">Log daily crew hours for this job. Pay and burdened rates are managed in Team.</p>
            </div>
          </div>
          <form id="timecard-form" class="p-4 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-[180px_1fr_auto] gap-3">
              <label>
                <span class="form-label">Work date</span>
                <input name="date" type="date" autocomplete="off" class="input" required>
              </label>
              <label>
                <span class="form-label">Crew note</span>
                <input name="notes" type="text" autocomplete="off" class="input" placeholder="Prep, spray, trim, punch list">
              </label>
              <button class="btn-primary md:self-end">Submit timecard</button>
            </div>
            <div id="crew-timecard-rows" class="divide-y border rounded-lg overflow-hidden"></div>
          </form>
        </section>

        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h2 class="font-semibold">Labor Timecards</h2>
            <p class="text-xs text-gray-500">Crew hours tied to this job and rolled into actual labor costs.</p>
          </div>
          <div id="time-entry-list" class="divide-y"></div>
        </section>

        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <h2 class="font-semibold">Change Orders</h2>
            <button id="add-change-order-btn" class="text-sm text-blue-600">Add Change Order</button>
          </div>
          <div id="change-order-list" class="divide-y"></div>
        </section>

        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h2 class="font-semibold">Material Purchases</h2>
            <p class="text-xs text-gray-500">Imported invoices linked to this job</p>
          </div>
          <div id="purchase-list" class="divide-y"></div>
        </section>

        <section class="bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <h2 class="font-semibold">Job Photos</h2>
              <p class="text-xs text-gray-500">Before, progress, and after photos for production proof and future marketing.</p>
            </div>
          </div>
          <form id="job-photo-form" class="p-4 grid grid-cols-1 md:grid-cols-[150px_1fr_1fr_auto] gap-3 items-end">
            <label>
              <span class="form-label">Type</span>
              <select name="type" class="input">
                <option value="before">Before</option>
                <option value="progress" selected>Progress</option>
                <option value="after">After</option>
              </select>
            </label>
            <label>
              <span class="form-label">Caption</span>
              <input name="caption" type="text" autocomplete="off" class="input" placeholder="Kitchen after, south wall prep">
            </label>
            <label>
              <span class="form-label">Photo</span>
              <input name="file" type="file" accept="image/*" capture="environment" class="input" required>
            </label>
            <button id="job-photo-submit" class="btn-primary">Upload</button>
          </form>
          <div id="job-photo-list" class="border-t"></div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Cost Breakdown</h3>
          <div id="breakdown" class="space-y-3"></div>
        </section>

        <section class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Budget Signals</h3>
          <div id="budget-signals" class="space-y-3 text-sm"></div>
        </section>
      </aside>
    </div>
  </main>

  <div id="cost-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-20 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 id="cost-modal-title" class="text-lg font-semibold mb-4">Add Job Cost</h3>
      <form id="cost-form" class="space-y-3">
        <input type="hidden" name="costId">
        <select name="category" required class="w-full px-3 py-2 border rounded">
          <option value="materials">Materials</option>
          <option value="supplies">Supplies</option>
          <option value="labor">Labor</option>
          <option value="subcontractor">Subcontractor</option>
          <option value="equipment">Equipment</option>
          <option value="other">Other</option>
        </select>
        <input name="description" required autocomplete="off" placeholder="Description" class="w-full px-3 py-2 border rounded">
        <div class="grid grid-cols-2 gap-3">
          <input name="quantity" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" required placeholder="Quantity" class="px-3 py-2 border rounded">
          <input name="unitCost" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" required placeholder="Unit cost" class="px-3 py-2 border rounded">
        </div>
        <div class="flex gap-3 pt-3">
          <button type="button" id="cancel-cost-btn" class="flex-1 px-4 py-2 border rounded">Cancel</button>
          <button id="save-cost-btn" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded">Add</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const jobId = window.location.pathname.split('/').pop();
    let costing = null;
    let teamMembers = [];
    let timeEntries = [];
    let jobPhotos = [];

    const currency = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const percent = (value) => `${Number(value || 0).toFixed(1)}%`;
    const dateLabel = (value) => value ? new Date(value).toLocaleDateString() : '';
    const escapeHtml = (value = '') => String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    const formatAddress = (record) => [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', '), record.leadPostalCode].filter(Boolean).join(' ');
    const mapsUrl = (address) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address || '')}`;
    const addressLink = (address) => address
      ? `<a class="block truncate text-sm text-gray-700 hover:text-blue-700 hover:underline" href="${mapsUrl(address)}" target="_blank" rel="noreferrer">${escapeHtml(address)}</a>`
      : '<span class="block truncate text-sm text-gray-700">No jobsite address</span>';
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;

    function customerProfileLink(job) {
      if (!job.leadId) return '<p class="text-gray-600">No customer linked</p>';
      const name = job.leadName || 'Customer';
      const address = formatAddress(job);
      return `
        <div class="mt-2 min-w-0 rounded-lg pr-2">
          <a href="/leads/${job.leadId}" class="block truncate font-medium text-gray-950 hover:text-blue-700">${escapeHtml(name)}</a>
          ${addressLink(address)}
          <span class="block text-xs text-gray-500">${escapeHtml(job.leadPhone ? phone(job.leadPhone) : job.leadEmail || 'Open customer profile')}</span>
        </div>
      `;
    }

    async function api(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, {
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
        ...options,
      });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    async function loadCosting() {
      const [costingPayload, membersPayload, timePayload] = await Promise.all([
        api(`/v1/jobs/${jobId}/costing`),
        api('/v1/team/members'),
        api(`/v1/team/time?jobId=${jobId}`),
      ]);
      if (!costingPayload) return;
      costing = costingPayload.data;
      teamMembers = membersPayload?.data || [];
      timeEntries = timePayload?.data || [];
      await loadJobPhotos();
      render();
    }

    async function loadJobPhotos() {
      try {
        const payload = await api(`/v1/uploads/photos/${jobId}`);
        jobPhotos = payload?.data || [];
      } catch (err) {
        console.warn('Job photos unavailable', err);
        jobPhotos = [];
      }
    }

    function render() {
      renderHeader();
      renderKpis();
      renderCosts();
      renderTimecardRows();
      renderTimeEntries();
      renderChangeOrders();
      renderPurchases();
      renderJobPhotos();
      renderBreakdown();
      renderBudgetSignals();
    }

    function renderHeader() {
      const { job, revenue } = costing;
      document.getElementById('complete-btn').classList.toggle('hidden', job.status === 'completed');
      document.getElementById('job-header').innerHTML = `
        <div class="flex flex-col md:flex-row md:justify-between gap-4">
          <div>
            <h2 class="text-2xl font-semibold">${escapeHtml(job.name)}</h2>
            ${customerProfileLink(job)}
            <p class="text-sm text-gray-500 mt-1">Status: <span class="font-medium">${escapeHtml(label(job.status))}</span></p>
          </div>
          <div class="text-left md:text-right">
            <p class="text-3xl font-bold">${currency(revenue.total)}</p>
            <p class="text-sm text-gray-600">Total revenue with approved change orders</p>
          </div>
        </div>
      `;
    }

    function renderKpis() {
      const { revenue, costs, profitability, production } = costing;
      const cards = [
        ['Revenue', currency(revenue.total), 'Contract plus approved change orders'],
        ['Actual Cost', currency(costs.total), 'All tracked costs'],
        ['Gross Profit', currency(profitability.grossProfit), 'Revenue less actual costs'],
        ['Gross Margin', percent(profitability.grossMargin), 'Gross profit divided by revenue'],
        ['Labor Hours', Number(production.laborHours || 0).toFixed(2), `${currency(production.averageLaborRate)}/hr avg`],
      ];
      document.getElementById('kpis').innerHTML = cards.map(([label, value, help]) => `
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <p class="text-xs uppercase text-gray-500 font-semibold">${label}</p>
          <p class="text-2xl font-bold mt-1">${value}</p>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `).join('');
    }

    function renderCosts() {
      const costs = costing.lists.costs;
      const container = document.getElementById('cost-list');
      if (!costs.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No actual job costs have been logged.</div>';
        return;
      }
      container.innerHTML = costs.map((cost) => `
        <div class="p-4 grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-3 sm:items-start">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <p class="font-medium">${escapeHtml(cost.description)}</p>
              <span class="px-2 py-0.5 text-xs rounded bg-gray-100 text-gray-700">${escapeHtml(label(cost.category))}</span>
            </div>
            <p class="text-sm text-gray-600">${Number(cost.quantity).toFixed(2)} x ${currency(cost.unitCost)} · ${dateLabel(cost.createdAt)}</p>
          </div>
          <div class="flex items-center justify-between gap-3 sm:justify-end sm:text-right">
            <p class="font-semibold">${currency(cost.totalCost)}</p>
            <div class="flex items-center gap-2">
              <button type="button" class="rounded-md border px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-50" data-edit-cost="${cost.id}">Edit</button>
              <button type="button" class="rounded-md border px-2 py-1 text-xs font-semibold text-red-700 hover:bg-red-50" data-delete-cost="${cost.id}" data-cost-description="${escapeHtml(cost.description)}">Remove</button>
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderTimecardRows() {
      const container = document.getElementById('crew-timecard-rows');
      if (!teamMembers.length) {
        container.innerHTML = `
          <div class="p-5 text-sm text-gray-600">
            Add active crew members on the <a href="/team" class="text-blue-700 font-medium">Team page</a> before logging job timecards.
          </div>
        `;
        return;
      }

      container.innerHTML = teamMembers.map((member) => `
        <div class="p-3 sm:p-4 grid grid-cols-1 md:grid-cols-[minmax(0,1fr)_120px_minmax(0,1fr)] gap-3 items-center bg-white">
          <label class="flex items-center gap-3 min-w-0">
            <input type="checkbox" data-member-enabled="${member.id}" class="h-5 w-5 rounded">
            <span class="min-w-0">
              <span class="block font-medium truncate">${escapeHtml(member.name || 'Crew member')}</span>
              <span class="block text-xs text-gray-500">${escapeHtml(member.role || 'crew')}</span>
            </span>
          </label>
          <label>
            <span class="form-label">Hours</span>
            <input data-member-hours="${member.id}" type="number" min="0" max="24" step="0.25" inputmode="decimal" autocomplete="off" class="input" placeholder="0.00">
          </label>
          <label>
            <span class="form-label">Work performed</span>
            <input data-member-note="${member.id}" type="text" autocomplete="off" class="input" placeholder="Cut, roll, prep">
          </label>
        </div>
      `).join('');
    }

    function renderTimeEntries() {
      const container = document.getElementById('time-entry-list');
      if (!timeEntries.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No crew timecards have been submitted for this job.</div>';
        return;
      }

      const totalHours = timeEntries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = timeEntries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      container.innerHTML = `
        <div class="p-4 bg-gray-50 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <p class="text-sm text-gray-600">${Number(totalHours).toFixed(2)} logged hours</p>
          <p class="font-semibold">${currency(totalCost)} labor cost</p>
        </div>
        ${timeEntries.map((entry) => `
          <div class="p-4 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-3">
            <div>
              <p class="font-medium">${escapeHtml(entry.teamMemberName || 'Crew member')}</p>
              <p class="text-sm text-gray-600">${Number(entry.hours).toFixed(2)} hrs on ${dateLabel(entry.date)}${entry.description ? ` &middot; ${escapeHtml(entry.description)}` : ''}</p>
            </div>
            <div class="sm:text-right">
              <p class="font-semibold">${currency(entry.totalCost)}</p>
              <p class="text-xs text-gray-500">${currency(entry.hourlyRate)}/hr burdened</p>
            </div>
          </div>
        `).join('')}
      `;
    }

    function renderChangeOrders() {
      const orders = costing.lists.changeOrders;
      const container = document.getElementById('change-order-list');
      if (!orders.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No change orders yet.</div>';
        return;
      }
      container.innerHTML = orders.map((order) => `
        <div class="p-4 flex justify-between gap-4">
          <div>
            <p class="font-medium">${escapeHtml(order.description)}</p>
            <p class="text-sm text-gray-600">${escapeHtml(order.createdBy)} · ${dateLabel(order.createdAt)}</p>
          </div>
          <div class="text-right">
            <p class="font-semibold">${currency(order.amount)}</p>
            <span class="px-2 py-0.5 text-xs rounded ${order.status === 'approved' || order.status === 'completed' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'}">${escapeHtml(label(order.status))}</span>
          </div>
        </div>
      `).join('');
    }

    function renderPurchases() {
      const purchases = costing.lists.materialPurchases;
      const container = document.getElementById('purchase-list');
      if (!purchases.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No material invoices imported for this job.</div>';
        return;
      }
      container.innerHTML = purchases.map((purchase) => `
        <div class="p-4 flex justify-between gap-4">
          <div>
            <p class="font-medium">${escapeHtml(purchase.supplier)}</p>
            <p class="text-sm text-gray-600">Invoice ${escapeHtml(purchase.invoiceNumber || 'not set')} · ${dateLabel(purchase.invoiceDate || purchase.createdAt)}</p>
          </div>
          <p class="font-semibold">${currency(purchase.totalAmount)}</p>
        </div>
      `).join('');
    }

    function renderJobPhotos() {
      const container = document.getElementById('job-photo-list');
      if (!jobPhotos.length) {
        container.innerHTML = '<div class="p-5 text-sm text-gray-500">No job photos uploaded yet.</div>';
        return;
      }

      container.innerHTML = `
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3 p-4">
          ${jobPhotos.map((photo) => `
            <a href="${escapeHtml(photo.url)}" target="_blank" rel="noreferrer" class="block border rounded-lg overflow-hidden bg-gray-50">
              <div class="aspect-[4/3] bg-gray-100 flex items-center justify-center text-xs text-gray-500">Photo</div>
              <div class="p-2">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-xs font-semibold uppercase text-gray-600">${escapeHtml(photo.type || 'progress')}</span>
                  <span class="text-xs text-gray-500">${dateLabel(photo.createdAt)}</span>
                </div>
                ${photo.caption ? `<p class="text-xs text-gray-700 mt-1 truncate">${escapeHtml(photo.caption)}</p>` : ''}
              </div>
            </a>
          `).join('')}
        </div>
      `;
    }

    function renderBreakdown() {
      const { costs } = costing;
      const rows = [
        ['Labor', costs.labor],
        ['Materials', costs.materials],
        ['Supplies', costs.supplies],
        ['Other', costs.expenses],
      ];
      document.getElementById('breakdown').innerHTML = rows.map(([label, value]) => `
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">${label}</span>
            <span class="font-medium">${currency(value)}</span>
          </div>
          <div class="h-2 bg-gray-100 rounded">
            <div class="h-2 bg-blue-600 rounded" style="width:${costs.total > 0 ? Math.min(100, (value / costs.total) * 100) : 0}%"></div>
          </div>
        </div>
      `).join('');
    }

    function renderBudgetSignals() {
      const { budget, profitability } = costing;
      const materialVariance = budget.materialVariance;
      document.getElementById('budget-signals').innerHTML = `
        <div class="flex justify-between">
          <span class="text-gray-600">Estimated materials</span>
          <span class="font-medium">${budget.estimatedMaterials == null ? 'Not estimated' : currency(budget.estimatedMaterials)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Material variance</span>
          <span class="font-medium ${materialVariance == null || materialVariance <= 0 ? 'text-green-600' : 'text-red-600'}">${materialVariance == null ? 'Not available' : currency(materialVariance)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Cost to revenue</span>
          <span class="font-medium">${percent(profitability.costToRevenue)}</span>
        </div>
      `;
    }

    function openCostModal(cost = null) {
      const form = document.getElementById('cost-form');
      form.reset();
      form.elements.costId.value = cost?.id || '';
      if (cost) {
        form.elements.category.value = cost.category;
        form.elements.description.value = cost.description || '';
        form.elements.quantity.value = Number(cost.quantity || 0);
        form.elements.unitCost.value = Number(cost.unitCost || 0);
      }
      document.getElementById('cost-modal-title').textContent = cost ? 'Edit Job Cost' : 'Add Job Cost';
      document.getElementById('save-cost-btn').textContent = cost ? 'Save' : 'Add';
      document.getElementById('cost-modal').classList.remove('hidden');
      form.elements.description.focus();
    }

    function closeCostModal() {
      document.getElementById('cost-modal').classList.add('hidden');
      document.getElementById('cost-form').reset();
      document.getElementById('cost-modal-title').textContent = 'Add Job Cost';
      document.getElementById('save-cost-btn').textContent = 'Add';
    }

    document.getElementById('add-cost-btn').addEventListener('click', () => {
      openCostModal();
    });

    document.getElementById('cancel-cost-btn').addEventListener('click', () => {
      closeCostModal();
    });

    document.getElementById('cost-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const data = Object.fromEntries(new FormData(form));
      const costId = data.costId;
      delete data.costId;
      await api(costId ? `/v1/jobs/${jobId}/costs/${costId}` : `/v1/jobs/${jobId}/costs`, {
        method: costId ? 'PATCH' : 'POST',
        body: JSON.stringify(data),
      });
      closeCostModal();
      await loadCosting();
    });

    document.getElementById('cost-list').addEventListener('click', async (event) => {
      const editButton = event.target.closest('[data-edit-cost]');
      if (editButton) {
        const cost = costing.lists.costs.find((item) => item.id === editButton.dataset.editCost);
        if (cost) openCostModal(cost);
        return;
      }

      const button = event.target.closest('[data-delete-cost]');
      if (!button) return;
      const description = button.dataset.costDescription || 'this cost';
      if (!confirm(`Remove ${description}? This will update job costing totals.`)) return;
      button.disabled = true;
      button.textContent = 'Removing...';
      try {
        await api(`/v1/jobs/${jobId}/costs/${button.dataset.deleteCost}`, { method: 'DELETE' });
        await loadCosting();
      } catch (err) {
        alert(err.message || 'Failed to remove cost');
        button.disabled = false;
        button.textContent = 'Remove';
      }
    });

    document.getElementById('timecard-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const data = Object.fromEntries(new FormData(form));
      const entries = teamMembers.map((member) => {
        const enabled = document.querySelector(`[data-member-enabled="${member.id}"]`)?.checked;
        const hours = Number(document.querySelector(`[data-member-hours="${member.id}"]`)?.value || 0);
        const description = document.querySelector(`[data-member-note="${member.id}"]`)?.value || data.notes || '';
        return enabled && hours > 0 ? { teamMemberId: member.id, hours, description } : null;
      }).filter(Boolean);

      if (!entries.length) {
        alert('Select at least one crew member and enter hours.');
        return;
      }

      await api('/v1/team/timecards', {
        method: 'POST',
        body: JSON.stringify({ jobId, date: data.date, notes: data.notes, entries }),
      });
      form.reset();
      form.querySelector('input[name="date"]').valueAsDate = new Date();
      await loadCosting();
    });

    document.getElementById('job-photo-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const submit = document.getElementById('job-photo-submit');
      const formData = new FormData(form);
      formData.set('jobId', jobId);
      submit.disabled = true;
      submit.textContent = 'Uploading...';
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photo`, {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(payload.error || 'Upload failed');
        form.reset();
        await loadJobPhotos();
        renderJobPhotos();
      } catch (err) {
        alert(err.message || 'Upload failed');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Upload';
      }
    });

    document.getElementById('complete-btn').addEventListener('click', async () => {
      if (!confirm('Mark this job completed?')) return;
      await api(`/v1/jobs/${jobId}`, {
        method: 'PATCH',
        body: JSON.stringify({ status: 'completed', completedAt: new Date().toISOString() }),
      });
      await loadCosting();
    });

    document.getElementById('add-change-order-btn').addEventListener('click', async () => {
      const description = prompt('Change order description:');
      const amount = prompt('Amount:');
      if (!description || !amount || !costing.job.estimateId) return;
      await api('/v1/change-orders', {
        method: 'POST',
        body: JSON.stringify({
          jobId,
          estimateId: costing.job.estimateId,
          description,
          amount: Number(amount),
          createdBy: 'contractor',
        }),
      });
      await loadCosting();
    });

    document.querySelector('#timecard-form input[name="date"]').valueAsDate = new Date();
    loadCosting().catch((err) => {
      document.getElementById('job-header').innerHTML = `<div class="p-6 text-red-600">${escapeHtml(err.message)}</div>`;
    });
  </script>
</body>
</html>
