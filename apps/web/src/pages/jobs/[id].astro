---
import '../../styles/design-system.css';
import Toast from '../../components/Toast.astro';
import ContactSummary from '../../components/ContactSummary.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Icon from '../../components/Icon.astro';
import DetailBackButton from '../../components/DetailBackButton.astro';
import AuthBridge from '../../components/AuthBridge.astro';
import BulkTimecardModal from '../../components/BulkTimecardModal.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Detail - PaintFlow</title>
  <AuthBridge />
  <style>
    .job-detail-nav-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 0.75rem;
      min-height: 4rem;
    }

    .job-photo-mobile-copy {
      display: none;
    }

    .job-detail-nav-action {
      justify-self: end;
    }

    .job-photo-form {
      grid-template-columns: minmax(8rem, 10rem) minmax(0, 1fr) minmax(0, 1.2fr) auto;
    }

    @media (max-width: 640px) {
      nav .h-16 {
        height: 3.5rem;
      }
      nav h1 {
        font-size: 1rem;
      }
      .job-detail-nav-row {
        grid-template-columns: 2.5rem minmax(0, 1fr);
        min-height: 3.5rem;
      }
      .job-detail-nav-action {
        display: none !important;
      }
      .job-detail-main {
        padding-top: 1rem;
      }
      #job-header {
        padding: 0.9rem;
      }
      #job-header h2 {
        font-size: 1.2rem;
        line-height: 1.2;
      }
      .job-section > div:first-child {
        padding: 0.85rem;
      }
      .job-section form,
      .job-section .p-4 {
        padding: 0.85rem;
      }
      .cost-row,
      .time-entry-row,
      .change-order-row,
      .purchase-row {
        padding: 0.85rem;
      }
      .job-side-panel {
        padding: 0.9rem;
      }
      .job-mobile-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .job-mobile-actions > * {
        justify-content: center;
      }
      .job-photo-desktop-copy {
        display: none;
      }
      .job-photo-mobile-copy {
        display: inline;
      }
      .job-photo-form {
        display: grid;
        grid-template-columns: 1fr;
      }
      #cost-modal,
      #change-order-modal,
      #approval-link-modal {
        align-items: end;
        padding: 0;
      }
      #cost-modal > div,
      #change-order-modal > div,
      #approval-link-modal > div {
        border-radius: 1rem 1rem 0 0;
        max-height: 92dvh;
        overflow-y: auto;
        width: 100%;
      }
    }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="job-detail-nav-row h-16">
        <DetailBackButton href="/jobs" label="Back to jobs" />
        <button id="complete-btn" class="job-detail-nav-action hidden btn-tonal btn-sm">Mark Complete</button>
      </div>
    </div>
  </nav>

  <main class="job-detail-main max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div id="job-header" class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <div class="text-center py-8 text-gray-500">Loading...</div>
    </div>

    <div id="kpis" class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 space-y-6">
        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <div>
              <h2 class="font-semibold">Actual Costs</h2>
              <p class="text-xs text-gray-500">Labor, materials, supplies, subcontractors, equipment, and other job costs</p>
            </div>
            <button id="add-cost-btn" class="btn-primary btn-sm">
              <Icon name="plus" />
              Add Cost
            </button>
          </div>
          <div id="cost-list" class="divide-y"></div>
        </section>

        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
            <div>
              <h2 class="font-semibold">Crew Timecard</h2>
              <p class="text-xs text-gray-500">Fast end-of-day crew hours for this job. Pay and burdened rates are managed in Team.</p>
            </div>
            <button id="open-job-bulk-timecard-btn" type="button" class="btn-tonal btn-sm">
              <Icon name="plus" />
              Crew timecard
            </button>
          </div>
          <div id="crew-timecard-summary" class="p-4"></div>
        </section>

        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h2 class="font-semibold">Labor Timecards</h2>
            <p class="text-xs text-gray-500">Crew hours tied to this job and rolled into actual labor costs.</p>
          </div>
          <div id="time-entry-list" class="divide-y"></div>
        </section>

        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <h2 class="font-semibold">Change Orders</h2>
            <button id="add-change-order-btn" type="button" class="btn-secondary btn-sm">Add Change Order</button>
          </div>
          <div id="change-order-list" class="divide-y"></div>
        </section>

        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h2 class="font-semibold">Material Purchases</h2>
            <p class="text-xs text-gray-500">Imported invoices linked to this job</p>
          </div>
          <div id="purchase-list" class="divide-y"></div>
        </section>

        <section class="job-section bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <h2 class="font-semibold">Job Photos</h2>
              <p class="text-xs text-gray-500">
                <span class="job-photo-desktop-copy">Before, progress, and after photos for production proof and future marketing.</span>
                <span class="job-photo-mobile-copy">Track before, progress, and after photos.</span>
              </p>
            </div>
          </div>
          <form id="job-photo-form" class="job-photo-form p-4 grid gap-3 items-end">
            <label>
              <span class="form-label">Type</span>
              <select name="type" class="input">
                <option value="before">Before</option>
                <option value="progress" selected>Progress</option>
                <option value="after">After</option>
              </select>
            </label>
            <label>
              <span class="form-label">Caption</span>
              <input name="caption" type="text" autocomplete="off" class="input" placeholder="Kitchen after, south wall prep">
            </label>
            <label>
              <span class="form-label">Photo</span>
              <input name="file" type="file" accept="image/*" class="input" required>
            </label>
            <button id="job-photo-submit" class="btn-primary">Add photo</button>
          </form>
          <div id="job-photo-list" class="border-t"></div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="job-side-panel bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Cost Breakdown</h3>
          <div id="breakdown" class="space-y-3"></div>
        </section>

        <section class="job-side-panel bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Budget Signals</h3>
          <div id="budget-signals" class="space-y-3 text-sm"></div>
        </section>
      </aside>
    </div>
  </main>

  <div id="cost-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-20 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h3 id="cost-modal-title" class="text-lg font-semibold mb-4">Add Job Cost</h3>
      <form id="cost-form" class="space-y-3">
        <input type="hidden" name="costId">
        <select name="category" required class="w-full px-3 py-2 border rounded">
          <option value="materials">Materials</option>
          <option value="supplies">Supplies</option>
          <option value="labor">Labor</option>
          <option value="subcontractor">Subcontractor</option>
          <option value="equipment">Equipment</option>
          <option value="other">Other</option>
        </select>
        <input name="description" required autocomplete="off" placeholder="Description" class="w-full px-3 py-2 border rounded">
        <div class="grid grid-cols-2 gap-3">
          <input name="quantity" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" required placeholder="Quantity" class="px-3 py-2 border rounded">
          <input name="unitCost" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" required placeholder="Unit cost" class="px-3 py-2 border rounded">
        </div>
        <div class="flex gap-3 pt-3">
          <button type="button" id="cancel-cost-btn" class="btn-secondary flex-1 justify-center">Cancel</button>
          <button id="save-cost-btn" class="btn-primary flex-1 justify-center">Add</button>
        </div>
      </form>
    </div>
  </div>
  <div id="change-order-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-20 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg p-6 w-full max-w-md shadow-xl">
      <h3 class="text-lg font-semibold">Add Change Order</h3>
      <p class="mt-1 text-sm text-gray-600">Track approved or pending scope changes separately from the original contract.</p>
      <form id="change-order-form" class="mt-5 space-y-4">
        <label class="block">
          <span class="form-label">Description</span>
          <textarea name="description" required rows="3" autocomplete="off" class="input resize-none" placeholder="Add garage door trim, extra prep, color change"></textarea>
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label>
            <span class="form-label">Amount</span>
            <input name="amount" type="number" min="0.01" step="0.01" inputmode="decimal" autocomplete="off" required class="input" placeholder="0.00">
          </label>
          <label>
            <span class="form-label">Status</span>
            <select name="status" class="input">
              <option value="pending">Pending</option>
              <option value="approved">Approved</option>
              <option value="completed">Completed</option>
            </select>
          </label>
        </div>
        <label class="block">
          <span class="form-label">Requested by</span>
          <select name="createdBy" class="input">
            <option value="contractor">Contractor</option>
            <option value="customer">Customer</option>
          </select>
        </label>
        <div class="rounded-lg border p-3">
          <label class="flex items-start gap-3">
            <input name="paymentRequired" type="checkbox" value="true" class="mt-1">
            <span>
              <span class="block text-sm font-medium text-gray-900">Require online payment after approval</span>
              <span class="block text-xs text-gray-600">Use this for added work that should be paid before or during production.</span>
            </span>
          </label>
          <label class="mt-3 block">
            <span class="form-label">Amount due at approval</span>
            <select name="depositPercent" class="input">
              <option value="100">100% of change order</option>
              <option value="50">50% deposit</option>
              <option value="25">25% deposit</option>
            </select>
          </label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-change-order-btn" class="btn-secondary flex-1">Cancel</button>
          <button id="save-change-order-btn" class="btn-primary flex-1">Add</button>
        </div>
      </form>
    </div>
  </div>
  <div id="approval-link-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-30 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg p-6 w-full max-w-lg shadow-xl">
      <h3 class="text-lg font-semibold">Customer Approval Link</h3>
      <p class="mt-1 text-sm text-gray-600">This secure portal link lets the customer review, approve, and pay for the change order. It expires in 14 days.</p>
      <label class="mt-4 block">
        <span class="form-label">Approval link</span>
        <input id="approval-link-input" readonly class="input" value="">
      </label>
      <div class="mt-4 flex flex-col sm:flex-row gap-3">
        <button type="button" id="copy-approval-link-btn" class="btn-primary flex-1">Copy link</button>
        <button type="button" id="close-approval-link-btn" class="btn-secondary flex-1">Close</button>
      </div>
    </div>
  </div>
  <BulkTimecardModal
    idPrefix="job-bulk"
    showJob={false}
    title="Crew Timecard"
    description="Log this job for multiple crew members from one compact end-of-day entry."
  />
  <ContactSummary defineOnly />
  <StatusBadge defineOnly />
  <Toast />

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const jobId = window.location.pathname.split('/').pop();
    let costing = null;
    let teamMembers = [];
    let timeEntries = [];
    let jobPhotos = [];
    let isSavingBulkTime = false;
    let jobBulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
    const jobBulkSelection = new Map();
    const jobBulkHours = new Map();

    const currency = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const percent = (value) => `${Number(value || 0).toFixed(1)}%`;
    const dateLabel = (value) => value ? new Date(value).toLocaleDateString() : '';
    const formatDate = (date) => date.toISOString().split('T')[0];
    const escapeHtml = (value = '') => String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    const roleLabels = {
      admin: 'Admin',
      crew: 'Crew member',
      crew_lead: 'Crew lead',
      estimator: 'Estimator',
      painter: 'Painter',
      prep: 'Prep crew',
    };
    const iconSvg = (name) => {
      const icons = {
        edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
        trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
      };
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${icons[name] || ''}</svg>`;
    };
    const formatAddress = (record) => [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', '), record.leadPostalCode].filter(Boolean).join(' ');
    const mapsUrl = (address) => `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address || '')}`;
    const addressLink = (address) => address
      ? `
        <span class="pf-address-inline text-sm text-gray-700">
          <span class="pf-address-text">${escapeHtml(address)}</span>
          <a class="pf-address-map-button" href="${mapsUrl(address)}" target="_blank" rel="noreferrer" aria-label="Open address in maps" title="Open in maps">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z" stroke="currentColor" stroke-width="1.8" />
              <circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.8" />
            </svg>
          </a>
        </span>
      `
      : '<span class="block truncate text-sm text-gray-700">No jobsite address</span>';
    const photoSrc = (photo) => photo?.id
      ? `${API_URL}/v1/uploads/photos/file/${encodeURIComponent(photo.id)}`
      : photo?.url || '';
    const label = (value) => {
      if (window.PaintFlowFormat?.label) return window.PaintFlowFormat.label(value);
      const text = String(value || '').trim();
      const known = {
        estimate_sent: 'Estimate sent',
        in_progress: 'In progress',
        past_due: 'Past due',
      };
      const key = text.toLowerCase();
      if (known[key]) return known[key];
      return text
        .replace(/[_-]+/g, ' ')
        .replace(/\s+/g, ' ')
        .replace(/\b\w/g, (char) => char.toUpperCase())
        .replace(/\b(And|Or|Of|The)\b/g, (word) => word.toLowerCase());
    };
    const statusBadge = (value, options = {}) => window.PaintFlowUI?.statusBadge({ value, ...options }) || `<span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">${escapeHtml(options.label || label(value))}</span>`;
    const streetAddress = (job) => String(job.leadStreetAddress || '').trim();
    const jobScope = (job) => {
      const name = String(job.name || '').trim();
      const haystack = name.toLowerCase();
      if (/(exterior|siding|fascia|soffit|roofline|repaint)/.test(haystack)) return 'Exterior';
      if (/(cabinet|vanity|built-in)/.test(haystack)) return 'Cabinets';
      if (/(commercial|office|workspace|tenant)/.test(haystack)) return 'Commercial';
      if (/(interior|bedroom|bathroom|kitchen|living|walls|ceilings|trim|doors)/.test(haystack)) return 'Interior';
      return '';
    };
    const displayJobName = (job) => {
      const name = String(job.name || '').trim();
      const leadName = String(job.leadName || '').trim();
      const street = streetAddress(job);
      const scope = jobScope(job);
      const genericNames = [
        `${leadName} - proposal`,
        `${leadName} painting project`,
        `${leadName} painting`,
        `${leadName} - job`,
      ].map((item) => item.toLowerCase());
      if (leadName && genericNames.includes(name.toLowerCase())) {
        return [leadName, scope, street].filter(Boolean).join(' - ');
      }
      if (leadName && scope && street && !name.includes(' - ')) return [leadName, scope, street].join(' - ');
      return name || [leadName || 'Customer', street].filter(Boolean).join(' - ');
    };

    function customerProfileLink(job) {
      if (!job.leadId) return '<p class="text-gray-600">No customer linked</p>';
      const name = job.leadName || 'Customer';
      const address = formatAddress(job);
      return `<div class="mt-2">${window.PaintFlowUI?.contactSummary({
        leadId: job.leadId,
        name,
        address,
        phone: job.leadPhone,
        email: job.leadEmail,
        size: 'md',
      }) || `<p class="font-medium text-gray-950">${escapeHtml(name)}</p>${addressLink(address)}`}</div>`;
    }

    async function api(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, {
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
        ...options,
      });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    async function loadCosting() {
      const [costingPayload, membersPayload, timePayload] = await Promise.all([
        api(`/v1/jobs/${jobId}/costing`),
        api('/v1/team/members'),
        api(`/v1/team/time?jobId=${jobId}`),
      ]);
      if (!costingPayload) return;
      costing = costingPayload.data;
      teamMembers = membersPayload?.data || [];
      timeEntries = timePayload?.data || [];
      await loadJobPhotos();
      render();
    }

    async function loadJobPhotos() {
      try {
        const payload = await api(`/v1/uploads/photos/${jobId}`);
        jobPhotos = payload?.data || [];
      } catch (err) {
        console.warn('Job photos unavailable', err);
        jobPhotos = [];
      }
    }

    function render() {
      renderHeader();
      renderKpis();
      renderCosts();
      renderTimecardSummary();
      renderJobBulkTimecard();
      renderTimeEntries();
      renderChangeOrders();
      renderPurchases();
      renderJobPhotos();
      renderBreakdown();
      renderBudgetSignals();
    }

    function renderHeader() {
      const { job, revenue } = costing;
      document.getElementById('complete-btn').classList.toggle('hidden', job.status === 'completed');
      document.getElementById('job-header').innerHTML = `
        <div class="flex flex-col md:flex-row md:justify-between gap-4">
          <div>
            <h2 class="text-2xl font-semibold">${escapeHtml(displayJobName(job))}</h2>
            ${customerProfileLink(job)}
            <div class="mt-2">${statusBadge(job.status)}</div>
          </div>
          <div class="text-left md:text-right">
            <p class="text-3xl font-bold">${currency(revenue.total)}</p>
            <p class="text-sm text-gray-600">Total revenue with approved change orders</p>
          </div>
        </div>
      `;
    }

    function renderKpis() {
      const { revenue, costs, profitability, production } = costing;
      const cards = [
        ['Revenue', currency(revenue.total), 'Contract plus approved change orders'],
        ['Actual Cost', currency(costs.total), 'All tracked costs'],
        ['Gross Profit', currency(profitability.grossProfit), 'Revenue less actual costs'],
        ['Gross Margin', percent(profitability.grossMargin), 'Gross profit divided by revenue'],
        ['Labor Hours', Number(production.laborHours || 0).toFixed(2), `${currency(production.averageLaborRate)}/hr avg`],
      ];
      document.getElementById('kpis').innerHTML = cards.map(([label, value, help]) => `
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <p class="text-xs uppercase text-gray-500 font-semibold">${label}</p>
          <p class="text-2xl font-bold mt-1">${value}</p>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `).join('');
    }

    function renderCosts() {
      const costs = costing.lists.costs;
      const container = document.getElementById('cost-list');
      if (!costs.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No actual job costs have been logged.</div>';
        return;
      }
      container.innerHTML = costs.map((cost) => `
        <div class="cost-row p-4 grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-3 sm:items-start">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <p class="font-medium">${escapeHtml(cost.description)}</p>
              ${statusBadge(cost.category, { tone: 'neutral' })}
            </div>
            <p class="text-sm text-gray-600">${Number(cost.quantity).toFixed(2)} x ${currency(cost.unitCost)} · ${dateLabel(cost.createdAt)}</p>
          </div>
          <div class="flex items-center justify-between gap-3 sm:justify-end sm:text-right">
            <p class="font-semibold">${currency(cost.totalCost)}</p>
            <div class="flex items-center gap-1.5">
              <button type="button" class="btn-icon btn-icon-tonal" data-edit-cost="${cost.id}" aria-label="Edit ${escapeHtml(cost.description)}">${iconSvg('edit')}</button>
              <button type="button" class="btn-icon btn-icon-outlined btn-icon-danger" data-delete-cost="${cost.id}" data-cost-description="${escapeHtml(cost.description)}" aria-label="Remove ${escapeHtml(cost.description)}">${iconSvg('trash')}</button>
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderTimecardSummary() {
      const container = document.getElementById('crew-timecard-summary');
      if (!teamMembers.length) {
        container.innerHTML = `
          <div class="text-sm text-gray-600">
            Add active crew members on the <a href="/team" class="text-blue-700 font-medium">Team page</a> before logging job timecards.
          </div>
        `;
        return;
      }

      const totalHours = timeEntries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const lastEntry = timeEntries
        .slice()
        .sort((a, b) => new Date(b.date || b.createdAt || 0).getTime() - new Date(a.date || a.createdAt || 0).getTime())[0];
      container.innerHTML = `
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
          <div class="rounded-lg border border-[var(--pf-border)] bg-gray-50 p-3">
            <p class="text-xs font-semibold uppercase text-gray-500">Active crew</p>
            <p class="mt-1 text-lg font-semibold">${teamMembers.length}</p>
          </div>
          <div class="rounded-lg border border-[var(--pf-border)] bg-gray-50 p-3">
            <p class="text-xs font-semibold uppercase text-gray-500">Logged hours</p>
            <p class="mt-1 text-lg font-semibold">${Number(totalHours).toFixed(2)}</p>
          </div>
          <div class="rounded-lg border border-[var(--pf-border)] bg-gray-50 p-3">
            <p class="text-xs font-semibold uppercase text-gray-500">Last entry</p>
            <p class="mt-1 text-sm font-medium text-gray-900">${lastEntry ? dateLabel(lastEntry.date || lastEntry.createdAt) : 'None yet'}</p>
          </div>
        </div>
      `;
    }

    function availableJobBulkRoles() {
      return Array.from(new Set(teamMembers.map((member) => member.role || 'crew'))).sort((a, b) => {
        const order = ['crew_lead', 'painter', 'prep'];
        const aIndex = order.indexOf(a);
        const bIndex = order.indexOf(b);
        if (aIndex !== -1 || bIndex !== -1) return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex);
        return (roleLabels[a] || a).localeCompare(roleLabels[b] || b);
      });
    }

    function syncJobBulkSelection() {
      const memberIds = new Set(teamMembers.map((member) => member.id));
      teamMembers.forEach((member) => {
        if (!jobBulkSelection.has(member.id)) jobBulkSelection.set(member.id, true);
        if (!jobBulkHours.has(member.id)) jobBulkHours.set(member.id, getJobBulkDefaultHours());
      });
      Array.from(jobBulkSelection.keys()).forEach((id) => {
        if (!memberIds.has(id)) jobBulkSelection.delete(id);
      });
      Array.from(jobBulkHours.keys()).forEach((id) => {
        if (!memberIds.has(id)) jobBulkHours.delete(id);
      });
    }

    function getJobBulkDefaultHours() {
      const value = Number(document.getElementById('job-bulk-default-hours')?.value || 8);
      return Number.isFinite(value) && value >= 0 ? value : 8;
    }

    function getJobBulkSelectedEntries() {
      return teamMembers
        .filter((member) => jobBulkSelection.get(member.id))
        .map((member) => ({
          member,
          hours: Number(jobBulkHours.get(member.id) ?? getJobBulkDefaultHours()),
        }))
        .filter((entry) => Number.isFinite(entry.hours) && entry.hours > 0);
    }

    function updateJobBulkSummary() {
      const summary = document.getElementById('job-bulk-selection-summary');
      if (!summary) return;
      const selected = getJobBulkSelectedEntries();
      const visibleIds = new Set(
        teamMembers
          .filter((member) => jobBulkRoleFilters.has(member.role || 'crew'))
          .map((member) => member.id)
      );
      const hiddenSelected = selected.filter(({ member }) => !visibleIds.has(member.id)).length;
      const totalHours = selected.reduce((sum, entry) => sum + entry.hours, 0);
      const averageHours = selected.length ? totalHours / selected.length : 0;
      const parts = [
        `${selected.length} employee${selected.length === 1 ? '' : 's'} selected`,
        `${averageHours.toFixed(2).replace(/\.00$/, '')} hr avg`,
        `${totalHours.toFixed(2).replace(/\.00$/, '')} total hrs`,
      ];
      if (hiddenSelected) parts.push(`${hiddenSelected} hidden by filters`);
      summary.textContent = parts.join(' - ');
    }

    function renderJobBulkRoleFilters() {
      const container = document.getElementById('job-bulk-role-filters');
      if (!container) return;
      const roles = availableJobBulkRoles();
      container.innerHTML = roles.length
        ? roles.map((role) => `
          <button type="button" class="pf-filter-chip ${jobBulkRoleFilters.has(role) ? 'pf-filter-chip-active' : ''}" data-job-bulk-role="${escapeHtml(role)}" aria-pressed="${jobBulkRoleFilters.has(role) ? 'true' : 'false'}">
            ${escapeHtml(roleLabels[role] || role)}
          </button>
        `).join('')
        : '<p class="text-sm text-gray-500">No active crew members available.</p>';
      container.querySelectorAll('[data-job-bulk-role]').forEach((filter) => {
        filter.addEventListener('click', () => {
          const role = filter.dataset.jobBulkRole;
          if (jobBulkRoleFilters.has(role)) jobBulkRoleFilters.delete(role);
          else jobBulkRoleFilters.add(role);
          renderJobBulkRoleFilters();
          renderJobBulkMemberRows();
        });
      });
    }

    function renderJobBulkMemberRows() {
      const container = document.getElementById('job-bulk-members');
      if (!container) return;
      const visibleMembers = teamMembers.filter((member) => jobBulkRoleFilters.has(member.role || 'crew'));
      if (!visibleMembers.length) {
        container.innerHTML = '<div class="p-4 text-sm text-gray-500">No crew match the selected roles. Add another role filter to include more people.</div>';
        updateJobBulkSelectionAction();
        updateJobBulkSummary();
        return;
      }
      container.innerHTML = visibleMembers.map((member) => `
        <label class="bulk-member-row grid sm:grid-cols-[minmax(0,1fr)_8rem] gap-3 items-center p-3 hover:bg-gray-50">
          <span class="flex items-center gap-3 min-w-0">
            <input type="checkbox" data-job-bulk-member="${member.id}" class="h-5 w-5" ${jobBulkSelection.get(member.id) ? 'checked' : ''}>
            <span class="min-w-0">
              <span class="block font-medium truncate">${escapeHtml(member.name || 'Crew member')}</span>
              <span class="block text-xs text-gray-500">${escapeHtml(roleLabels[member.role] || member.role || 'Crew')}</span>
            </span>
          </span>
          <input type="number" data-job-bulk-hours="${member.id}" min="0" max="24" step="0.25" inputmode="decimal" class="input" value="${jobBulkHours.get(member.id) ?? getJobBulkDefaultHours()}">
        </label>
      `).join('');
      container.querySelectorAll('[data-job-bulk-member]').forEach((checkbox) => {
        checkbox.addEventListener('change', () => {
          jobBulkSelection.set(checkbox.dataset.jobBulkMember, checkbox.checked);
          updateJobBulkSelectionAction();
          updateJobBulkSummary();
        });
      });
      container.querySelectorAll('[data-job-bulk-hours]').forEach((input) => {
        input.addEventListener('input', () => {
          jobBulkHours.set(input.dataset.jobBulkHours, Number(input.value || 0));
          updateJobBulkSummary();
        });
      });
      updateJobBulkSelectionAction();
      updateJobBulkSummary();
    }

    function updateJobBulkSelectionAction() {
      const button = document.getElementById('job-bulk-select-visible');
      if (!button) return;
      const visible = Array.from(document.querySelectorAll('[data-job-bulk-member]'));
      if (!visible.length) {
        button.textContent = 'Select visible';
        button.disabled = true;
        updateJobBulkSummary();
        return;
      }
      button.disabled = false;
      const checked = visible.filter((checkbox) => checkbox.checked).length;
      button.textContent = checked === visible.length ? 'Clear visible' : 'Select visible';
      updateJobBulkSummary();
    }

    function renderJobBulkTimecard() {
      syncJobBulkSelection();
      renderJobBulkRoleFilters();
      renderJobBulkMemberRows();
    }

    function openJobBulkModal() {
      const form = document.getElementById('job-bulk-time-form');
      form.reset();
      form.elements.date.value = formatDate(new Date());
      document.getElementById('job-bulk-default-hours').value = '8';
      if (!jobBulkRoleFilters.size) jobBulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
      teamMembers.forEach((member) => jobBulkSelection.set(member.id, true));
      teamMembers.forEach((member) => jobBulkHours.set(member.id, 8));
      renderJobBulkTimecard();
      document.getElementById('job-bulk-modal').classList.remove('hidden');
    }

    function closeJobBulkModal() {
      document.getElementById('job-bulk-modal').classList.add('hidden');
    }

    function renderTimeEntries() {
      const container = document.getElementById('time-entry-list');
      if (!timeEntries.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No crew timecards have been submitted for this job.</div>';
        return;
      }

      const totalHours = timeEntries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = timeEntries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      container.innerHTML = `
        <div class="p-4 bg-gray-50 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <p class="text-sm text-gray-600">${Number(totalHours).toFixed(2)} logged hours</p>
          <p class="font-semibold">${currency(totalCost)} labor cost</p>
        </div>
        ${timeEntries.map((entry) => `
          <div class="time-entry-row p-4 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-3">
            <div>
              <p class="font-medium">${escapeHtml(entry.teamMemberName || 'Crew member')}</p>
              <p class="text-sm text-gray-600">${Number(entry.hours).toFixed(2)} hrs on ${dateLabel(entry.date)}${entry.description ? ` &middot; ${escapeHtml(entry.description)}` : ''}</p>
            </div>
            <div class="sm:text-right">
              <p class="font-semibold">${currency(entry.totalCost)}</p>
              <p class="text-xs text-gray-500">${currency(entry.hourlyRate)}/hr burdened</p>
            </div>
          </div>
        `).join('')}
      `;
    }

    function renderChangeOrders() {
      const orders = costing.lists.changeOrders;
      const container = document.getElementById('change-order-list');
      if (!orders.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No change orders yet.</div>';
        return;
      }
      container.innerHTML = orders.map((order) => `
        <div class="change-order-row p-4 grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-3">
          <div class="min-w-0">
            <p class="font-medium">${escapeHtml(order.description)}</p>
            <p class="text-sm text-gray-600">${escapeHtml(order.createdBy)} · ${dateLabel(order.createdAt)}</p>
            <div class="mt-2 flex flex-wrap gap-2">
              ${statusBadge(order.status)}
              ${order.paymentRequired ? statusBadge(order.paymentStatus, { label: `Payment ${label(order.paymentStatus)}` }) : ''}
              ${order.sentAt ? '<span class="rounded-full bg-gray-100 px-2 py-1 text-xs font-medium text-gray-700">Sent</span>' : ''}
            </div>
          </div>
          <div class="sm:text-right">
            <p class="font-semibold">${currency(order.amount)}</p>
            ${order.paymentRequired ? `<p class="text-xs text-gray-500">${currency(order.paymentDueAmount || order.amount)} due on approval</p>` : '<p class="text-xs text-gray-500">No payment required</p>'}
            <div class="job-mobile-actions mt-3 flex flex-wrap sm:justify-end gap-2">
              ${order.status === 'pending' ? `<button type="button" class="btn-secondary btn-sm" title="Emails the secure approval and payment link to the customer." data-send-change-order="${order.id}">${order.sentAt ? 'Resend email' : 'Send for approval'}</button>` : ''}
              ${order.status === 'pending' ? `<button type="button" class="btn-secondary btn-sm" data-approve-change-order="${order.id}">Mark approved</button>` : ''}
              ${order.status === 'approved' ? `<button type="button" class="btn-secondary btn-sm" data-complete-change-order="${order.id}">Mark complete</button>` : ''}
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderPurchases() {
      const purchases = costing.lists.materialPurchases;
      const container = document.getElementById('purchase-list');
      if (!purchases.length) {
        container.innerHTML = '<div class="p-6 text-sm text-gray-500">No material invoices imported for this job.</div>';
        return;
      }
      container.innerHTML = purchases.map((purchase) => `
        <div class="purchase-row p-4 flex justify-between gap-4">
          <div>
            <p class="font-medium">${escapeHtml(purchase.supplier)}</p>
            <p class="text-sm text-gray-600">Invoice ${escapeHtml(purchase.invoiceNumber || 'not set')} · ${dateLabel(purchase.invoiceDate || purchase.createdAt)}</p>
          </div>
          <p class="font-semibold">${currency(purchase.totalAmount)}</p>
        </div>
      `).join('');
    }

    function renderJobPhotos() {
      const container = document.getElementById('job-photo-list');
      if (!jobPhotos.length) {
        container.innerHTML = '<div class="p-5 text-sm text-gray-500">No job photos uploaded yet.</div>';
        return;
      }

      container.innerHTML = `
        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3 p-4">
          ${jobPhotos.map((photo) => `
            <a href="${escapeHtml(photoSrc(photo))}" target="_blank" rel="noreferrer" class="block border rounded-lg overflow-hidden bg-gray-50">
              <div class="aspect-[4/3] bg-gray-100">
                <img
                  src="${escapeHtml(photoSrc(photo))}"
                  alt="${escapeHtml(photo.caption || `${label(photo.type || 'progress')} job photo`)}"
                  class="h-full w-full object-cover"
                  loading="lazy"
                  onerror="this.replaceWith(Object.assign(document.createElement('div'), { className: 'flex h-full w-full items-center justify-center p-3 text-center text-xs text-gray-500', textContent: 'Photo preview unavailable' }))"
                >
              </div>
              <div class="p-2">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-xs font-semibold uppercase text-gray-600">${escapeHtml(photo.type || 'progress')}</span>
                  <span class="text-xs text-gray-500">${dateLabel(photo.createdAt)}</span>
                </div>
                ${photo.caption ? `<p class="text-xs text-gray-700 mt-1 truncate">${escapeHtml(photo.caption)}</p>` : ''}
              </div>
            </a>
          `).join('')}
        </div>
      `;
    }

    function renderBreakdown() {
      const { costs } = costing;
      const rows = [
        ['Labor', costs.labor],
        ['Materials', costs.materials],
        ['Supplies', costs.supplies],
        ['Other', costs.expenses],
      ];
      document.getElementById('breakdown').innerHTML = rows.map(([label, value]) => `
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600">${label}</span>
            <span class="font-medium">${currency(value)}</span>
          </div>
          <div class="h-2 bg-gray-100 rounded">
            <div class="h-2 bg-blue-600 rounded" style="width:${costs.total > 0 ? Math.min(100, (value / costs.total) * 100) : 0}%"></div>
          </div>
        </div>
      `).join('');
    }

    function renderBudgetSignals() {
      const { budget, profitability } = costing;
      const materialVariance = budget.materialVariance;
      document.getElementById('budget-signals').innerHTML = `
        <div class="flex justify-between">
          <span class="text-gray-600">Estimated materials</span>
          <span class="font-medium">${budget.estimatedMaterials == null ? 'Not estimated' : currency(budget.estimatedMaterials)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Material variance</span>
          <span class="font-medium ${materialVariance == null || materialVariance <= 0 ? 'text-green-600' : 'text-red-600'}">${materialVariance == null ? 'Not available' : currency(materialVariance)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-600">Cost to revenue</span>
          <span class="font-medium">${percent(profitability.costToRevenue)}</span>
        </div>
      `;
    }

    function openCostModal(cost = null) {
      const form = document.getElementById('cost-form');
      form.reset();
      form.elements.costId.value = cost?.id || '';
      if (cost) {
        form.elements.category.value = cost.category;
        form.elements.description.value = cost.description || '';
        form.elements.quantity.value = Number(cost.quantity || 0);
        form.elements.unitCost.value = Number(cost.unitCost || 0);
      }
      document.getElementById('cost-modal-title').textContent = cost ? 'Edit Job Cost' : 'Add Job Cost';
      document.getElementById('save-cost-btn').textContent = cost ? 'Save' : 'Add';
      document.getElementById('cost-modal').classList.remove('hidden');
      form.elements.description.focus();
    }

    function closeCostModal() {
      document.getElementById('cost-modal').classList.add('hidden');
      document.getElementById('cost-form').reset();
      document.getElementById('cost-modal-title').textContent = 'Add Job Cost';
      document.getElementById('save-cost-btn').textContent = 'Add';
    }

    function openChangeOrderModal() {
      if (!costing?.job?.estimateId) {
        window.showToast?.('Change orders require a job created from an estimate.', 'error');
        return;
      }
      const form = document.getElementById('change-order-form');
      form.reset();
      document.getElementById('change-order-modal').classList.remove('hidden');
      form.elements.description.focus();
    }

    function closeChangeOrderModal() {
      document.getElementById('change-order-modal').classList.add('hidden');
      document.getElementById('change-order-form').reset();
    }

    function openApprovalLinkModal(link) {
      const input = document.getElementById('approval-link-input');
      input.value = link;
      document.getElementById('approval-link-modal').classList.remove('hidden');
      input.focus();
      input.select();
    }

    function closeApprovalLinkModal() {
      document.getElementById('approval-link-modal').classList.add('hidden');
      document.getElementById('approval-link-input').value = '';
    }

    document.getElementById('add-cost-btn').addEventListener('click', () => {
      openCostModal();
    });

    document.getElementById('cancel-cost-btn').addEventListener('click', () => {
      closeCostModal();
    });

    document.getElementById('cost-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const data = Object.fromEntries(new FormData(form));
      const costId = data.costId;
      delete data.costId;
      await api(costId ? `/v1/jobs/${jobId}/costs/${costId}` : `/v1/jobs/${jobId}/costs`, {
        method: costId ? 'PATCH' : 'POST',
        body: JSON.stringify(data),
      });
      closeCostModal();
      await loadCosting();
    });

    document.getElementById('cost-list').addEventListener('click', async (event) => {
      const editButton = event.target.closest('[data-edit-cost]');
      if (editButton) {
        const cost = costing.lists.costs.find((item) => item.id === editButton.dataset.editCost);
        if (cost) openCostModal(cost);
        return;
      }

      const button = event.target.closest('[data-delete-cost]');
      if (!button) return;
      const description = button.dataset.costDescription || 'this cost';
      if (!confirm(`Remove ${description}? This will update job costing totals.`)) return;
      button.disabled = true;
      button.textContent = 'Removing...';
      try {
        await api(`/v1/jobs/${jobId}/costs/${button.dataset.deleteCost}`, { method: 'DELETE' });
        await loadCosting();
      } catch (err) {
        alert(err.message || 'Failed to remove cost');
        button.disabled = false;
        button.textContent = 'Remove';
      }
    });

    document.getElementById('open-job-bulk-timecard-btn').addEventListener('click', openJobBulkModal);
    document.getElementById('cancel-job-bulk-btn').addEventListener('click', closeJobBulkModal);
    document.getElementById('close-job-bulk-modal-btn').addEventListener('click', closeJobBulkModal);
    document.getElementById('job-bulk-default-hours').addEventListener('input', () => {
      const defaultHours = getJobBulkDefaultHours();
      teamMembers.forEach((member) => jobBulkHours.set(member.id, defaultHours));
      document.querySelectorAll('[data-job-bulk-hours]').forEach((input) => {
        input.value = defaultHours;
      });
      updateJobBulkSummary();
    });
    document.getElementById('job-bulk-select-visible').addEventListener('click', () => {
      const visible = Array.from(document.querySelectorAll('[data-job-bulk-member]'));
      const shouldSelect = visible.some((checkbox) => !checkbox.checked);
      visible.forEach((checkbox) => {
        checkbox.checked = shouldSelect;
        jobBulkSelection.set(checkbox.dataset.jobBulkMember, shouldSelect);
      });
      updateJobBulkSelectionAction();
      updateJobBulkSummary();
    });
    document.getElementById('job-bulk-time-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSavingBulkTime) return;
      const form = event.currentTarget;
      const submit = document.getElementById('submit-job-bulk-btn');
      const data = Object.fromEntries(new FormData(form));
      const selected = getJobBulkSelectedEntries().map(({ member, hours }) => ({
        teamMemberId: member.id,
        hours,
        description: data.description || 'Crew labor',
      }));

      if (!selected.length) {
        window.showToast?.('Select at least one crew member and enter hours.', 'error');
        return;
      }

      isSavingBulkTime = true;
      submit.disabled = true;
      submit.textContent = 'Logging...';
      try {
        await api('/v1/team/timecards', {
          method: 'POST',
          headers: { 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({
            jobId,
            date: data.date,
            notes: data.description || undefined,
            entries: selected,
          }),
        });
        closeJobBulkModal();
        await loadCosting();
        window.showToast?.(`Logged time for ${selected.length} crew members`, 'success');
      } catch (err) {
        window.showToast?.(err.message || 'Failed to submit timecard', 'error');
      } finally {
        isSavingBulkTime = false;
        submit.disabled = false;
        submit.textContent = 'Log crew time';
      }
    });

    document.getElementById('job-photo-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      const submit = document.getElementById('job-photo-submit');
      const formData = new FormData(form);
      formData.set('jobId', jobId);
      submit.disabled = true;
      submit.textContent = 'Adding...';
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photo`, {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(payload.error || 'Upload failed');
        form.reset();
        await loadJobPhotos();
        renderJobPhotos();
      } catch (err) {
        alert(err.message || 'Upload failed');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Add photo';
      }
    });

    document.getElementById('complete-btn').addEventListener('click', async () => {
      if (!confirm('Mark this job completed?')) return;
      await api(`/v1/jobs/${jobId}`, {
        method: 'PATCH',
        body: JSON.stringify({ status: 'completed', completedAt: new Date().toISOString() }),
      });
      await loadCosting();
    });

    document.getElementById('add-change-order-btn').addEventListener('click', () => {
      openChangeOrderModal();
    });

    document.getElementById('cancel-change-order-btn').addEventListener('click', () => {
      closeChangeOrderModal();
    });

    document.getElementById('close-approval-link-btn').addEventListener('click', () => {
      closeApprovalLinkModal();
    });

    document.getElementById('copy-approval-link-btn').addEventListener('click', async () => {
      const input = document.getElementById('approval-link-input');
      input.focus();
      input.select();
      const copied = await navigator.clipboard?.writeText(input.value).then(() => true).catch(() => false);
      window.showToast?.(copied ? 'Approval link copied' : 'Select the link and copy it manually', copied ? 'success' : 'error');
    });

    document.getElementById('change-order-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!costing?.job?.estimateId) {
        window.showToast?.('Change orders require a job created from an estimate.', 'error');
        return;
      }

      const form = event.currentTarget;
      const submit = document.getElementById('save-change-order-btn');
      const data = Object.fromEntries(new FormData(form));
      const amount = Number(data.amount);
      const paymentRequired = data.paymentRequired === 'true';
      if (!data.description?.trim() || !Number.isFinite(amount) || amount <= 0) {
        window.showToast?.('Enter a description and a positive amount.', 'error');
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Adding...';
      try {
        await api('/v1/change-orders', {
          method: 'POST',
          body: JSON.stringify({
            jobId,
            estimateId: costing.job.estimateId,
            description: data.description.trim(),
            amount,
            status: data.status || 'pending',
            createdBy: data.createdBy || 'contractor',
            paymentRequired,
            depositPercent: paymentRequired ? Number(data.depositPercent || 100) : 0,
          }),
        });
        closeChangeOrderModal();
        await loadCosting();
        window.showToast?.('Change order added', 'success');
      } catch (err) {
        window.showToast?.(err.message || 'Failed to add change order', 'error');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Add';
      }
    });

    document.getElementById('change-order-list').addEventListener('click', async (event) => {
      const sendButton = event.target.closest('[data-send-change-order]');
      if (sendButton) {
        sendButton.disabled = true;
        const originalText = sendButton.textContent;
        sendButton.textContent = 'Sending...';
        try {
          const payload = await api(`/v1/change-orders/${sendButton.dataset.sendChangeOrder}/send-email`, {
            method: 'POST',
            headers: { 'Idempotency-Key': crypto.randomUUID() },
          });
          const link = payload?.data?.link;
          if (link) {
            const copied = await navigator.clipboard?.writeText(link).then(() => true).catch(() => false);
            if (!copied) {
              openApprovalLinkModal(link);
              window.showToast?.(`Change order emailed to ${payload.data.to}. Select the link and copy it manually if needed.`, 'success');
            } else {
              window.showToast?.(`Change order emailed to ${payload.data.to}. Link copied for your records.`, 'success');
            }
          } else {
            window.showToast?.('Change order email sent', 'success');
          }
          await loadCosting();
        } catch (err) {
          window.showToast?.(err.message || 'Failed to send change order', 'error');
        } finally {
          sendButton.disabled = false;
          sendButton.textContent = originalText;
        }
        return;
      }

      const completeButton = event.target.closest('[data-complete-change-order]');
      if (completeButton) {
        completeButton.disabled = true;
        completeButton.textContent = 'Completing...';
        try {
          await api(`/v1/change-orders/${completeButton.dataset.completeChangeOrder}`, {
            method: 'PATCH',
            headers: { 'Idempotency-Key': crypto.randomUUID() },
            body: JSON.stringify({ status: 'completed' }),
          });
          await loadCosting();
          window.showToast?.('Change order marked complete', 'success');
        } catch (err) {
          window.showToast?.(err.message || 'Failed to complete change order', 'error');
        } finally {
          completeButton.disabled = false;
          completeButton.textContent = 'Mark complete';
        }
        return;
      }

      const approveButton = event.target.closest('[data-approve-change-order]');
      if (!approveButton) return;
      if (!confirm('Mark this change order approved? This adds it to job revenue.')) return;
      approveButton.disabled = true;
      approveButton.textContent = 'Approving...';
      try {
        await api(`/v1/change-orders/${approveButton.dataset.approveChangeOrder}`, {
          method: 'PATCH',
          headers: { 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({ status: 'approved' }),
        });
        await loadCosting();
        window.showToast?.('Change order approved', 'success');
      } catch (err) {
        window.showToast?.(err.message || 'Failed to approve change order', 'error');
      } finally {
        approveButton.disabled = false;
        approveButton.textContent = 'Mark approved';
      }
    });

    loadCosting().catch((err) => {
      document.getElementById('job-header').innerHTML = `<div class="p-6 text-red-600">${escapeHtml(err.message)}</div>`;
    });
  </script>
</body>
</html>
