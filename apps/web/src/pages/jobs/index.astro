---
import Base from '../../layouts/Base.astro';
---

<Base title="Jobs">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Jobs</h2>
        <p class="text-gray-600">Manage active projects, crews, photos, time, and job costs.</p>
      </div>

      <div id="jobs-list" class="space-y-4">
        <div class="p-8 text-center text-gray-500">Loading jobs...</div>
      </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let teamMembers = [];

    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: options.cents === false ? 0 : 2, maximumFractionDigits: options.cents === false ? 0 : 2 })}`;
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function customerProfileLink(job) {
      if (!job.leadId) return '';
      const name = job.leadName || 'Customer';
      const address = formatAddress(job);
      const contact = job.leadPhone ? phone(job.leadPhone) : job.leadEmail || 'Open customer profile';
      return `
        <div class="mt-2 min-w-0 rounded-lg pr-2">
          <a href="/leads/${job.leadId}" class="block truncate text-sm font-medium text-gray-950 hover:text-blue-700">${escapeHtml(name)}</a>
          ${window.PaintFlowFormat?.addressLink(address) || `<span class="block truncate text-sm text-gray-700">${escapeHtml(address || 'No jobsite address')}</span>`}
          <span class="block truncate text-xs text-gray-500">${escapeHtml(contact)}</span>
        </div>
      `;
    }

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead') || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', '), record.leadPostalCode].filter(Boolean).join(' ');
    }

    function displayJobName(job) {
      const name = String(job.name || '').trim();
      const leadName = String(job.leadName || '').trim();
      if (leadName && name.toLowerCase() === `${leadName} - proposal`.toLowerCase()) {
        return `${leadName} Painting Project`;
      }
      return name || `${leadName || 'Customer'} Painting Project`;
    }

    async function apiJson(url, options = {}) {
      const res = await fetch(url, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function teamOptions() {
      return teamMembers.map(member => `
        <option value="${member.id}" data-rate="${Number(member.hourlyRate || 0)}">
          ${escapeHtml(member.name)}${member.role ? ` - ${escapeHtml(member.role)}` : ''} (${money(member.hourlyRate)}/hr)
        </option>
      `).join('');
    }
    
    async function loadJobs() {
      try {
        const [{ data }, membersRes] = await Promise.all([
          apiJson(`${API_URL}/v1/jobs`),
          apiJson(`${API_URL}/v1/team/members`),
        ]);
        teamMembers = membersRes.data || [];
        const container = document.getElementById('jobs-list');
        
        if (data.length === 0) {
          container.innerHTML = '<div class="p-8 text-center text-gray-500">No jobs yet. Create an estimate first!</div>';
          return;
        }
        
        const jobsWithCosts = await Promise.all(data.map(async job => {
          const costRes = await fetch(`${API_URL}/v1/jobs/${job.id}/costing`, { credentials: 'include' });
          const { data: costing } = await costRes.json();
          return { ...job, costing };
        }));
        
        container.innerHTML = jobsWithCosts.map(job => {
          const margin = Number(job.costing.profitability.grossMargin || 0);
          const marginColor = margin > 30 ? 'text-green-600' : margin > 15 ? 'text-yellow-600' : 'text-red-600';
          
          return `
            <div class="bg-white rounded-lg shadow-sm border p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-lg font-semibold">${escapeHtml(displayJobName(job))}</h3>
                  <p class="text-sm text-gray-600">${label(job.status)}</p>
                  ${customerProfileLink(job)}
                </div>
                <div class="flex items-center gap-3">
                  ${job.status === 'completed' ? `
                    <button onclick="requestReview('${job.id}')" class="px-3 py-1 text-sm bg-yellow-100 text-yellow-800 rounded hover:bg-yellow-200">
                      Request Review
                    </button>
                  ` : ''}
                  <span class="text-2xl font-bold ${marginColor}">${margin.toFixed(1)}%</span>
                </div>
              </div>
              
              <div class="grid grid-cols-3 gap-4 text-sm mb-4">
                <div>
                  <p class="text-gray-600">Revenue</p>
                  <p class="font-semibold">${money(job.costing.revenue.total)}</p>
                </div>
                <div>
                  <p class="text-gray-600">Actual Cost</p>
                  <p class="font-semibold">${money(job.costing.costs.total)}</p>
                </div>
                <div>
                  <p class="text-gray-600">Profit</p>
                  <p class="font-semibold">${money(job.costing.profitability.grossProfit)}</p>
                </div>
              </div>
              
              <div class="pt-4 border-t">
                <div class="flex justify-between items-center mb-3">
                  <h4 class="font-medium">Time Entries</h4>
                  <button onclick="document.getElementById('time-${job.id}').classList.toggle('hidden')" class="text-sm text-blue-600 hover:text-blue-700">+ Log Time</button>
                </div>
                
                <div id="time-${job.id}" class="hidden mb-4 p-4 bg-gray-50 rounded-lg">
                  <form class="time-form space-y-3" data-job-id="${job.id}">
                    ${teamMembers.length ? `
                      <select name="teamMemberId" autocomplete="off" required class="w-full px-3 py-2 border rounded text-sm">
                        <option value="">Select team member...</option>
                        ${teamOptions()}
                      </select>
                    ` : `
                      <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-3 text-sm text-yellow-900">
                        Add crew members in <a href="/team" class="font-medium underline">Team</a> before logging labor.
                      </div>
                    `}
                    <input type="number" min="0" step="0.25" inputmode="decimal" autocomplete="off" name="hours" placeholder="Hours worked" required class="w-full px-3 py-2 border rounded text-sm" />
                    <input type="date" name="date" autocomplete="off" required class="w-full px-3 py-2 border rounded text-sm" />
                    <input type="text" name="description" autocomplete="off" placeholder="Work performed" class="w-full px-3 py-2 border rounded text-sm" />
                    <button type="submit" ${teamMembers.length ? '' : 'disabled'} class="w-full px-3 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60">Log Team Hours</button>
                  </form>
                </div>
                <div class="flex gap-2 pt-4 border-t">
                  <a href="/jobs/${job.id}" class="px-3 py-1 text-sm bg-blue-100 text-blue-800 rounded hover:bg-blue-200">
                    Open Job
                  </a>
                  <button onclick="markComplete('${job.id}')" class="px-3 py-1 text-sm bg-green-100 text-green-800 rounded hover:bg-green-200 ${job.status === 'completed' ? 'hidden' : ''}">
                    Mark Complete
                  </button>
                </div>
              </div>
            </div>
          `;
        }).join('');
        
        document.querySelectorAll('.time-form').forEach(form => {
          form.querySelector('input[name="date"]').valueAsDate = new Date();
          
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const jobId = e.target.dataset.jobId;
            
            try {
              const button = e.target.querySelector('button[type="submit"]');
              button.disabled = true;
              button.textContent = 'Logging time...';
              await apiJson(`${API_URL}/v1/team/time`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  jobId,
                  teamMemberId: formData.get('teamMemberId'),
                  hours: parseFloat(formData.get('hours')),
                  description: formData.get('description'),
                  date: new Date(`${formData.get('date')}T12:00:00`).toISOString(),
                }),
              });
              window.showToast('Time logged', 'success');
              loadJobs();
            } catch (err) {
              console.error(err);
              window.showToast(err.message || 'Failed to log time', 'error');
              const button = e.target.querySelector('button[type="submit"]');
              button.disabled = false;
              button.textContent = 'Log Team Hours';
            }
          });
        });
      } catch (err) {
        console.error(err);
      }
    }
    
    window.markComplete = async (jobId) => {
      if (!confirm('Mark this job as completed?')) return;
      
      try {
        await fetch(`${API_URL}/v1/jobs/${jobId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ status: 'completed', completedAt: new Date().toISOString() }),
        });
        window.showToast('Job marked complete', 'success');
        loadJobs();
      } catch (err) {
        console.error(err);
        window.showToast('Failed to update job', 'error');
      }
    };
    
    window.requestReview = async (jobId) => {
      if (!confirm('Send review request to customer?')) return;
      
      try {
        const res = await fetch(`${API_URL}/v1/reviews/request`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ jobId }),
        });
        
        if (res.ok) {
          window.showToast('Review request sent!', 'success');
        } else {
          window.showToast('Failed to send request', 'error');
        }
      } catch (err) {
        console.error(err);
        window.showToast('Failed to send request', 'error');
      }
    };

    window.uploadPhoto = async (jobId) => {
      const fileInput = document.getElementById(`photo-file-${jobId}`);
      const file = fileInput.files[0];
      if (!file) return alert('Select a photo');
      
      const formData = new FormData();
      formData.append('file', file);
      formData.append('jobId', jobId);
      formData.append('type', document.getElementById(`photo-type-${jobId}`).value);
      formData.append('caption', document.getElementById(`photo-caption-${jobId}`).value);
      
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photo`, {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        if (res.ok) {
          window.showToast('Photo uploaded!', 'success');
          fileInput.value = '';
          loadJobPhotos(jobId);
        }
      } catch (err) {
        window.showToast('Upload failed', 'error');
      }
    };
    
    async function loadJobPhotos(jobId) {
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photos/${jobId}`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById(`photos-${jobId}`);
        if (data.length === 0) {
          container.innerHTML = '<p class="text-xs text-gray-500 col-span-3">No photos yet</p>';
          return;
        }
        container.innerHTML = data.map(p => `
          <div class="relative group">
            <img src="${p.url}" class="w-full h-24 object-cover rounded" />
            <div class="absolute bottom-0 left-0 right-0 bg-black bg-opacity-60 text-white text-xs px-1 py-0.5 rounded-b">
              ${p.type}
            </div>
          </div>
        `).join('');
      } catch (err) {
        console.error('Failed to load photos', err);
      }
    }

    async function loadChangeOrders(jobId) {
      try {
        const res = await fetch(`${API_URL}/v1/change-orders?jobId=${jobId}`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById(`change-orders-${jobId}`);
        if (data.length === 0) {
          container.innerHTML = '<p class="text-xs text-gray-500">No change orders</p>';
          return;
        }
        container.innerHTML = data.map(co => `
          <div class="text-sm p-2 border rounded ${co.status === 'approved' ? 'bg-green-50' : ''}">
            <div class="flex justify-between">
              <span class="font-medium">${money(co.amount)}</span>
              <span class="text-xs px-2 py-0.5 rounded ${co.status === 'approved' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'}">${label(co.status)}</span>
            </div>
            <p class="text-xs text-gray-600 mt-1">${co.description}</p>
            ${co.status === 'pending' ? `<button onclick="approveChangeOrder('${co.id}', '${jobId}')" class="mt-1 text-xs text-blue-600">Approve</button>` : ''}
          </div>
        `).join('');
      } catch (err) {
        console.error(err);
      }
    }
    
    window.approveChangeOrder = async (id, jobId) => {
      await fetch(`${API_URL}/v1/change-orders/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ status: 'approved' }),
      });
      loadChangeOrders(jobId);
    };
    
    window.createChangeOrder = async (jobId, estimateId) => {
      const desc = prompt('Description:');
      const amount = prompt('Amount:');
      if (!desc || !amount) return;
      
      await fetch(`${API_URL}/v1/change-orders`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ jobId, estimateId, description: desc, amount: parseFloat(amount), createdBy: 'contractor' }),
      });
      loadChangeOrders(jobId);
    };
    
    loadJobs();
  </script>
</Base>
