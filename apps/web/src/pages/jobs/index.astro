---
import Base from '../../layouts/Base.astro';
import BulkTimecardModal from '../../components/BulkTimecardModal.astro';
---

<Base title="Jobs">
  <style>
    @media (max-width: 640px) {
      .jobs-card {
        padding: 0.85rem;
      }
      .jobs-card-header {
        gap: 0.75rem;
      }
      .jobs-card h3 {
        font-size: 1rem;
        line-height: 1.25;
      }
      .jobs-margin {
        align-items: end;
        display: flex;
        gap: 0.4rem;
        justify-content: space-between;
        margin-top: 0.45rem;
        width: 100%;
      }
      .jobs-metrics {
        gap: 0.5rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-bottom: 0.75rem;
      }
      .jobs-metrics > div {
        border: 1px solid var(--pf-border);
        border-radius: var(--pf-radius);
        padding: 0.55rem;
      }
      .jobs-metrics p:first-child {
        font-size: 0.68rem;
      }
      .jobs-metrics p:last-child {
        font-size: 0.85rem;
      }
      .jobs-time-panel {
        padding: 0.75rem;
      }
      .bulk-member-row {
        grid-template-columns: minmax(0, 1fr);
      }
    }
  </style>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <div class="mb-6">
        <h2 class="pf-page-title">Jobs</h2>
      </div>

      <div id="jobs-list" class="space-y-3 sm:space-y-4">
        <div class="p-8 text-center text-gray-500">Loading jobs...</div>
      </div>
  </main>

  <BulkTimecardModal
    idPrefix="jobs-bulk"
    showAddSegment={false}
    title="Crew Timecard"
    description="Fast end-of-day crew entry. The selected job is prefilled from the job card you opened."
  />

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let teamMembers = [];
    let jobs = [];
    let isSavingBulkTime = false;
    let bulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
    const bulkSelection = new Map();
    const bulkHours = new Map();
    const roleLabels = {
      admin: 'Admin',
      crew: 'Crew member',
      crew_lead: 'Crew lead',
      estimator: 'Estimator',
      painter: 'Painter',
      prep: 'Prep crew',
    };

    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: options.cents === false ? 0 : 2, maximumFractionDigits: options.cents === false ? 0 : 2 })}`;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const statusBadge = (value) => window.PaintFlowUI?.statusBadge({ value }) || `<span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-700">${escapeHtml(label(value))}</span>`;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function customerProfileLink(job) {
      if (!job.leadId) return '';
      const name = job.leadName || 'Customer';
      const address = formatAddress(job);
      return `<div class="mt-2">${window.PaintFlowUI?.contactSummary({
        leadId: job.leadId,
        name,
        address,
        phone: job.leadPhone,
        email: job.leadEmail,
      }) || `<p class="text-sm font-medium text-gray-950">${escapeHtml(name)}</p>`}</div>`;
    }

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead', { includePostalCode: false }) || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', ')].filter(Boolean).join(' ');
    }

    function streetAddress(job) {
      return String(job.leadStreetAddress || '').trim();
    }

    function jobAddress(job = {}) {
      return [
        job.leadStreetAddress || job.streetAddress,
        [job.leadCity || job.city, job.leadState || job.state].filter(Boolean).join(', '),
        job.leadPostalCode || job.postalCode,
      ].filter(Boolean).join(' ');
    }

    function jobOptionLabel(job = {}) {
      const address = jobAddress(job);
      return address ? `${address} - ${job.name}` : job.name;
    }

    function jobScope(job) {
      const name = String(job.name || '').trim();
      const haystack = name.toLowerCase();
      if (/(exterior|siding|fascia|soffit|roofline|repaint)/.test(haystack)) return 'Exterior';
      if (/(cabinet|vanity|built-in)/.test(haystack)) return 'Cabinets';
      if (/(commercial|office|workspace|tenant)/.test(haystack)) return 'Commercial';
      if (/(interior|bedroom|bathroom|kitchen|living|walls|ceilings|trim|doors)/.test(haystack)) return 'Interior';
      return '';
    }

    function displayJobName(job) {
      const name = String(job.name || '').trim();
      const leadName = String(job.leadName || '').trim();
      const street = streetAddress(job);
      const scope = jobScope(job);
      const genericNames = [
        `${leadName} - proposal`,
        `${leadName} painting project`,
        `${leadName} painting`,
        `${leadName} - job`,
      ].map((item) => item.toLowerCase());
      if (leadName && genericNames.includes(name.toLowerCase())) {
        return [leadName, scope, street].filter(Boolean).join(' - ');
      }
      if (leadName && scope && street && !name.includes(' - ')) return [leadName, scope, street].join(' - ');
      return name || [leadName || 'Customer', street].filter(Boolean).join(' - ');
    }

    async function apiJson(url, options = {}) {
      const res = await fetch(url, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function teamOptions() {
      return teamMembers.map(member => `
        <option value="${member.id}" data-rate="${Number(member.hourlyRate || 0)}">
          ${escapeHtml(member.name)}${member.role ? ` - ${escapeHtml(member.role)}` : ''} (${money(member.hourlyRate)}/hr)
        </option>
      `).join('');
    }
    
    async function loadJobs() {
      try {
        const [{ data }, membersRes] = await Promise.all([
          apiJson(`${API_URL}/v1/jobs`),
          apiJson(`${API_URL}/v1/team/members`),
        ]);
        teamMembers = membersRes.data || [];
        jobs = data || [];
        const container = document.getElementById('jobs-list');
        
        if (data.length === 0) {
          container.innerHTML = `
            <div class="rounded-lg border bg-white p-5 sm:p-8">
              <div class="mx-auto max-w-2xl text-center">
                <p class="pf-section-title">No jobs yet</p>
                <p class="pf-copy mt-2">Manage active projects, crews, photos, time, and job costs after a customer accepts a proposal. A signed estimate becomes production work here.</p>
              </div>
              <div class="mt-5 grid gap-3 sm:grid-cols-3">
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">1. Send estimate</p>
                  <p class="pf-copy mt-1">Build the scope and payment schedule from Estimates.</p>
                </div>
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">2. Customer signs</p>
                  <p class="pf-copy mt-1">Signing creates the job even if payment is due later.</p>
                </div>
                <div class="rounded-lg border bg-gray-50 p-3">
                  <p class="pf-row-title">3. Run production</p>
                  <p class="pf-copy mt-1">Schedule, log time, add photos, and track margin.</p>
                </div>
              </div>
              <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
                <a class="btn-primary justify-center" href="/estimates/production">Start estimate</a>
                <a class="btn-secondary justify-center" href="/pipeline">View pipeline</a>
              </div>
            </div>
          `;
          return;
        }
        
        const jobsWithCosts = await Promise.all(data.map(async job => {
          const costRes = await fetch(`${API_URL}/v1/jobs/${job.id}/costing`, { credentials: 'include' });
          const { data: costing } = await costRes.json();
          return { ...job, costing };
        }));
        
        container.innerHTML = jobsWithCosts.map(job => {
          const margin = Number(job.costing.profitability.grossMargin || 0);
          const marginColor = margin > 30 ? 'text-green-600' : margin > 15 ? 'text-yellow-600' : 'text-red-600';
          
          return `
            <div class="jobs-card bg-white rounded-lg shadow-sm border p-6">
              <div class="jobs-card-header flex flex-col sm:flex-row sm:justify-between sm:items-start mb-4">
                <div class="min-w-0">
                  <h3 class="pf-section-title">${escapeHtml(displayJobName(job))}</h3>
                  <div class="mt-1">${statusBadge(job.status)}</div>
                  ${customerProfileLink(job)}
                </div>
                <div class="jobs-margin flex items-center gap-3">
                  ${job.status === 'completed' ? `
                    <button onclick="requestReview('${job.id}')" class="btn-tonal btn-sm">
                      Request Review
                    </button>
                  ` : ''}
                  <span class="text-xl sm:text-2xl font-bold ${marginColor}">${margin.toFixed(1)}%</span>
                </div>
              </div>
              
              <div class="jobs-metrics grid grid-cols-3 gap-4 text-sm mb-4">
                <div>
                  <p class="pf-page-copy">Revenue</p>
                  <p class="pf-section-title">${money(job.costing.revenue.total)}</p>
                </div>
                <div>
                  <p class="pf-page-copy">Actual Cost</p>
                  <p class="pf-section-title">${money(job.costing.costs.total)}</p>
                </div>
                <div>
                  <p class="pf-page-copy">Profit</p>
                  <p class="pf-section-title">${money(job.costing.profitability.grossProfit)}</p>
                </div>
              </div>
              
              <div class="pt-4 border-t">
                <div class="flex justify-between items-center mb-3">
                  <h4 class="font-medium">Crew time</h4>
                  <button onclick="openJobsBulkTimecard('${job.id}')" class="btn-tonal btn-sm">
                    <span aria-hidden="true">+</span>
                    Log Time
                  </button>
                </div>
                <p class="mb-4 text-sm text-gray-600">Open a crew timecard with this job preselected, then adjust crew and hours as needed.</p>
                <div class="mobile-action-row flex flex-col sm:flex-row gap-2 pt-4 border-t">
                  <a href="/jobs/${job.id}" class="btn-primary btn-sm justify-center">
                    Open Job
                  </a>
                  <button onclick="markComplete('${job.id}')" class="btn-tonal btn-sm justify-center ${job.status === 'completed' ? 'hidden' : ''}">
                    Mark Complete
                  </button>
                </div>
              </div>
            </div>
          `;
        }).join('');
        populateBulkJobSelect();
        renderBulkTimecard();
      } catch (err) {
        console.error(err);
      }
    }

    function activeMembers() {
      return teamMembers.filter((member) => member.isActive !== false);
    }

    function populateBulkJobSelect(selectedJobId = '') {
      const select = document.getElementById('jobs-bulk-job-select');
      if (!select) return;
      select.innerHTML = '<option value="">Select job...</option>' +
        jobs.map((job) => `<option value="${job.id}">${escapeHtml(jobOptionLabel(job))}</option>`).join('');
      if (selectedJobId) select.value = selectedJobId;
    }

    function availableBulkRoles() {
      return Array.from(new Set(activeMembers().map((member) => member.role || 'crew'))).sort((a, b) => {
        const order = ['crew_lead', 'painter', 'prep'];
        const aIndex = order.indexOf(a);
        const bIndex = order.indexOf(b);
        if (aIndex !== -1 || bIndex !== -1) return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex);
        return (roleLabels[a] || a).localeCompare(roleLabels[b] || b);
      });
    }

    function syncBulkSelection() {
      const members = activeMembers();
      const memberIds = new Set(members.map((member) => member.id));
      members.forEach((member) => {
        if (!bulkSelection.has(member.id)) bulkSelection.set(member.id, true);
        if (!bulkHours.has(member.id)) bulkHours.set(member.id, getBulkDefaultHours());
      });
      Array.from(bulkSelection.keys()).forEach((id) => {
        if (!memberIds.has(id)) bulkSelection.delete(id);
      });
      Array.from(bulkHours.keys()).forEach((id) => {
        if (!memberIds.has(id)) bulkHours.delete(id);
      });
    }

    function getBulkDefaultHours() {
      const value = Number(document.getElementById('jobs-bulk-default-hours')?.value || 8);
      return Number.isFinite(value) && value >= 0 ? value : 8;
    }

    function getBulkSelectedEntries() {
      return activeMembers()
        .filter((member) => bulkSelection.get(member.id))
        .map((member) => ({
          member,
          hours: Number(bulkHours.get(member.id) ?? getBulkDefaultHours()),
        }))
        .filter((entry) => Number.isFinite(entry.hours) && entry.hours > 0);
    }

    function updateBulkSummary() {
      const summary = document.getElementById('jobs-bulk-selection-summary');
      if (!summary) return;
      const selected = getBulkSelectedEntries();
      const visibleIds = new Set(
        activeMembers()
          .filter((member) => bulkRoleFilters.has(member.role || 'crew'))
          .map((member) => member.id)
      );
      const hiddenSelected = selected.filter(({ member }) => !visibleIds.has(member.id)).length;
      const totalHours = selected.reduce((sum, entry) => sum + entry.hours, 0);
      const averageHours = selected.length ? totalHours / selected.length : 0;
      const parts = [
        `${selected.length} employee${selected.length === 1 ? '' : 's'} selected`,
        `${averageHours.toFixed(2).replace(/\.00$/, '')} hr avg`,
        `${totalHours.toFixed(2).replace(/\.00$/, '')} total hrs`,
      ];
      if (hiddenSelected) parts.push(`${hiddenSelected} hidden by filters`);
      summary.textContent = parts.join(' - ');
    }

    function renderBulkRoleFilters() {
      const container = document.getElementById('jobs-bulk-role-filters');
      if (!container) return;
      const roles = availableBulkRoles();
      container.innerHTML = roles.length
        ? roles.map((role) => `
          <button type="button" class="pf-filter-chip ${bulkRoleFilters.has(role) ? 'pf-filter-chip-active' : ''}" data-jobs-bulk-role="${escapeHtml(role)}" aria-pressed="${bulkRoleFilters.has(role) ? 'true' : 'false'}">
            ${escapeHtml(roleLabels[role] || role)}
          </button>
        `).join('')
        : '<p class="text-sm text-gray-500">No active crew members available.</p>';
      container.querySelectorAll('[data-jobs-bulk-role]').forEach((filter) => {
        filter.addEventListener('click', () => {
          const role = filter.dataset.jobsBulkRole;
          if (bulkRoleFilters.has(role)) bulkRoleFilters.delete(role);
          else bulkRoleFilters.add(role);
          renderBulkRoleFilters();
          renderBulkMemberRows();
        });
      });
    }

    function renderBulkMemberRows() {
      const container = document.getElementById('jobs-bulk-members');
      if (!container) return;
      const visibleMembers = activeMembers().filter((member) => bulkRoleFilters.has(member.role || 'crew'));
      if (!visibleMembers.length) {
        container.innerHTML = '<div class="p-4 text-sm text-gray-500">No crew match the selected roles. Add another role filter to include more people.</div>';
        updateBulkSelectionAction();
        updateBulkSummary();
        return;
      }
      container.innerHTML = visibleMembers.map((member) => `
        <label class="bulk-member-row grid sm:grid-cols-[minmax(0,1fr)_8rem] gap-3 items-center p-3 hover:bg-gray-50">
          <span class="flex items-center gap-3 min-w-0">
            <input type="checkbox" data-jobs-bulk-member="${member.id}" class="h-5 w-5" ${bulkSelection.get(member.id) ? 'checked' : ''}>
            <span class="min-w-0">
              <span class="block font-medium truncate">${escapeHtml(member.name)}</span>
              <span class="block text-xs text-gray-500">${escapeHtml(roleLabels[member.role] || member.role || 'Crew')}</span>
            </span>
          </span>
          <input type="number" data-jobs-bulk-hours="${member.id}" min="0" max="24" step="0.25" inputmode="decimal" class="input" value="${bulkHours.get(member.id) ?? getBulkDefaultHours()}">
        </label>
      `).join('');
      container.querySelectorAll('[data-jobs-bulk-member]').forEach((checkbox) => {
        checkbox.addEventListener('change', () => {
          bulkSelection.set(checkbox.dataset.jobsBulkMember, checkbox.checked);
          updateBulkSelectionAction();
          updateBulkSummary();
        });
      });
      container.querySelectorAll('[data-jobs-bulk-hours]').forEach((input) => {
        input.addEventListener('input', () => {
          bulkHours.set(input.dataset.jobsBulkHours, Number(input.value || 0));
          updateBulkSummary();
        });
      });
      updateBulkSelectionAction();
      updateBulkSummary();
    }

    function updateBulkSelectionAction() {
      const button = document.getElementById('jobs-bulk-select-visible');
      if (!button) return;
      const visible = Array.from(document.querySelectorAll('[data-jobs-bulk-member]'));
      const allSelected = visible.length > 0 && visible.every((checkbox) => checkbox.checked);
      button.textContent = allSelected ? 'Clear visible' : 'Select visible';
    }

    function renderBulkTimecard() {
      syncBulkSelection();
      renderBulkRoleFilters();
      renderBulkMemberRows();
    }

    window.openJobsBulkTimecard = (jobId) => {
      const form = document.getElementById('jobs-bulk-time-form');
      form.reset();
      document.getElementById('jobs-bulk-default-hours').value = '8';
      form.querySelector('input[name="date"]').valueAsDate = new Date();
      populateBulkJobSelect(jobId);
      if (!bulkRoleFilters.size) bulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
      activeMembers().forEach((member) => bulkSelection.set(member.id, true));
      activeMembers().forEach((member) => bulkHours.set(member.id, 8));
      renderBulkTimecard();
      document.getElementById('jobs-bulk-modal').classList.remove('hidden');
    };

    function closeBulkModal() {
      document.getElementById('jobs-bulk-modal').classList.add('hidden');
    }

    document.getElementById('cancel-jobs-bulk-btn').addEventListener('click', closeBulkModal);
    document.getElementById('close-jobs-bulk-modal-btn').addEventListener('click', closeBulkModal);
    document.getElementById('jobs-bulk-default-hours').addEventListener('input', () => {
      const defaultHours = getBulkDefaultHours();
      activeMembers().forEach((member) => bulkHours.set(member.id, defaultHours));
      document.querySelectorAll('[data-jobs-bulk-hours]').forEach((input) => {
        input.value = defaultHours;
      });
      updateBulkSummary();
    });
    document.getElementById('jobs-bulk-select-visible').addEventListener('click', () => {
      const visible = Array.from(document.querySelectorAll('[data-jobs-bulk-member]'));
      const allSelected = visible.length > 0 && visible.every((checkbox) => checkbox.checked);
      const shouldSelect = !allSelected;
      visible.forEach((checkbox) => {
        checkbox.checked = shouldSelect;
        bulkSelection.set(checkbox.dataset.jobsBulkMember, shouldSelect);
      });
      updateBulkSelectionAction();
      updateBulkSummary();
    });
    document.getElementById('jobs-bulk-time-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSavingBulkTime) return;

      const submit = document.getElementById('submit-jobs-bulk-btn');
      const form = event.currentTarget;
      const formData = new FormData(form);
      const selected = getBulkSelectedEntries().map(({ member, hours }) => ({
        teamMemberId: member.id,
        hours,
        description: formData.get('description') || undefined,
      }));

      if (!selected.length) {
        window.showToast?.('Select at least one crew member', 'error');
        return;
      }

      isSavingBulkTime = true;
      submit.disabled = true;
      submit.textContent = 'Logging crew time...';

      try {
        await apiJson(`${API_URL}/v1/team/timecards`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            jobId: formData.get('jobId'),
            date: new Date(`${formData.get('date')}T12:00:00`).toISOString(),
            notes: formData.get('description') || undefined,
            entries: selected,
          }),
        });
        window.showToast?.('Crew time logged', 'success');
        closeBulkModal();
        loadJobs();
      } catch (err) {
        console.error(err);
        window.showToast?.(err.message || 'Failed to submit timecard', 'error');
      } finally {
        isSavingBulkTime = false;
        submit.disabled = false;
        submit.textContent = 'Log crew time';
      }
    });
    
    window.markComplete = async (jobId) => {
      if (!confirm('Mark this job as completed?')) return;
      
      try {
        await fetch(`${API_URL}/v1/jobs/${jobId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ status: 'completed', completedAt: new Date().toISOString() }),
        });
        window.showToast('Job marked complete', 'success');
        loadJobs();
      } catch (err) {
        console.error(err);
        window.showToast('Failed to update job', 'error');
      }
    };
    
    window.requestReview = async (jobId) => {
      if (!confirm('Send review request to customer?')) return;
      
      try {
        const res = await fetch(`${API_URL}/v1/reviews/request`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ jobId }),
        });
        
        if (res.ok) {
          window.showToast('Review request sent!', 'success');
        } else {
          window.showToast('Failed to send request', 'error');
        }
      } catch (err) {
        console.error(err);
        window.showToast('Failed to send request', 'error');
      }
    };

    window.uploadPhoto = async (jobId) => {
      const fileInput = document.getElementById(`photo-file-${jobId}`);
      const file = fileInput.files[0];
      if (!file) return alert('Select a photo');
      
      const formData = new FormData();
      formData.append('file', file);
      formData.append('jobId', jobId);
      formData.append('type', document.getElementById(`photo-type-${jobId}`).value);
      formData.append('caption', document.getElementById(`photo-caption-${jobId}`).value);
      
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photo`, {
          method: 'POST',
          credentials: 'include',
          body: formData,
        });
        if (res.ok) {
          window.showToast('Photo uploaded!', 'success');
          fileInput.value = '';
          loadJobPhotos(jobId);
        }
      } catch (err) {
        window.showToast('Upload failed', 'error');
      }
    };
    
    async function loadJobPhotos(jobId) {
      try {
        const res = await fetch(`${API_URL}/v1/uploads/photos/${jobId}`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById(`photos-${jobId}`);
        if (data.length === 0) {
          container.innerHTML = '<p class="text-xs text-gray-500 col-span-3">No photos yet</p>';
          return;
        }
        container.innerHTML = data.map(p => `
          <div class="relative group">
            <img src="${p.url}" class="w-full h-24 object-cover rounded" />
            <div class="absolute bottom-0 left-0 right-0 bg-black bg-opacity-60 text-white text-xs px-1 py-0.5 rounded-b">
              ${p.type}
            </div>
          </div>
        `).join('');
      } catch (err) {
        console.error('Failed to load photos', err);
      }
    }

    async function loadChangeOrders(jobId) {
      try {
        const res = await fetch(`${API_URL}/v1/change-orders?jobId=${jobId}`, { credentials: 'include' });
        const { data } = await res.json();
        const container = document.getElementById(`change-orders-${jobId}`);
        if (data.length === 0) {
          container.innerHTML = '<p class="pf-meta">No change orders</p>';
          return;
        }
        container.innerHTML = data.map(co => `
          <div class="text-sm p-2 border rounded ${co.status === 'approved' ? 'bg-green-50' : ''}">
            <div class="flex justify-between">
              <span class="font-medium">${money(co.amount)}</span>
              ${statusBadge(co.status)}
            </div>
            <p class="text-xs text-gray-600 mt-1">${co.description}</p>
            ${co.status === 'pending' ? `<button onclick="approveChangeOrder('${co.id}', '${jobId}')" class="btn-text btn-sm mt-1">Approve</button>` : ''}
          </div>
        `).join('');
      } catch (err) {
        console.error(err);
      }
    }
    
    window.approveChangeOrder = async (id, jobId) => {
      await fetch(`${API_URL}/v1/change-orders/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ status: 'approved' }),
      });
      loadChangeOrders(jobId);
    };
    
    window.createChangeOrder = async (jobId, estimateId) => {
      const desc = prompt('Description:');
      const amount = prompt('Amount:');
      if (!desc || !amount) return;
      
      await fetch(`${API_URL}/v1/change-orders`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ jobId, estimateId, description: desc, amount: parseFloat(amount), createdBy: 'contractor' }),
      });
      loadChangeOrders(jobId);
    };
    
    loadJobs();
  </script>
</Base>
