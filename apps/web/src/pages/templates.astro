---
import Base from '../layouts/Base.astro';
---

<Base title="Estimate Templates">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Estimate Templates</h2>
        <p class="text-sm text-gray-600 mt-1">Reuse room and surface configurations in the production estimator.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-2">
        <a href="/estimates/production" class="w-full sm:w-auto text-center bg-blue-600 text-white px-4 py-3 sm:py-2 rounded-lg hover:bg-blue-700 font-medium">Open production estimator</a>
        <a href="/estimates" class="w-full sm:w-auto text-center px-4 py-2 border rounded-lg bg-white hover:bg-gray-50">Estimates</a>
      </div>
    </div>

    <div id="templates-grid" class="grid md:grid-cols-2 gap-4">
      <div class="bg-white border rounded-lg p-8 text-center text-gray-500">Loading templates...</div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    async function loadTemplates() {
      try {
        const res = await fetch(`${API_URL}/v1/estimate-templates`, { credentials: 'include' });
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        const { data, error } = await res.json();
        if (!res.ok) throw new Error(error || 'Failed to load templates');
        renderTemplates(data || []);
      } catch (err) {
        document.getElementById('templates-grid').innerHTML = '<div class="bg-white border rounded-lg p-8 text-center text-gray-500">Templates could not be loaded.</div>';
        window.showToast(err.message || 'Failed to load templates', 'error');
      }
    }

    function renderTemplates(templates) {
      const grid = document.getElementById('templates-grid');
      if (!templates.length) {
        grid.innerHTML = '<div class="bg-white border rounded-lg p-8 text-center text-gray-500">No estimate templates yet.</div>';
        return;
      }
      grid.innerHTML = templates.map(template => `
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <h3 class="font-semibold">${escapeHtml(template.name)}</h3>
              <p class="text-sm text-gray-600">${escapeHtml(template.description || '')}</p>
            </div>
            ${template.isShared ? '<span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">Built-in</span>' : ''}
          </div>
          <div class="text-xs text-gray-500 mb-3">
            ${(template.rooms || []).length} room(s) - Used ${template.usageCount || 0}x
          </div>
          <div class="flex gap-2">
            <button type="button" onclick="useTemplate('${template.id}')" class="flex-1 py-2 bg-blue-600 text-white rounded text-sm">Use Template</button>
            <button type="button" onclick="deleteTemplate('${template.id}')" class="px-3 py-2 border rounded text-sm">Delete</button>
          </div>
        </div>
      `).join('');
    }

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    window.useTemplate = async function useTemplate(id) {
      try {
        const res = await fetch(`${API_URL}/v1/estimate-templates/${id}/use`, {
          method: 'POST',
          credentials: 'include',
        });
        const { data, error } = await res.json();
        if (!res.ok) throw new Error(error || 'Failed to use template');
        sessionStorage.setItem('templateRooms', JSON.stringify(data.rooms));
        window.showToast('Template loaded. Opening production estimator.');
        window.location.href = '/estimates/production';
      } catch (err) {
        window.showToast(err.message || 'Failed to use template', 'error');
      }
    };

    window.deleteTemplate = async function deleteTemplate(id) {
      if (!confirm('Delete this template?')) return;
      try {
        const res = await fetch(`${API_URL}/v1/estimate-templates/${id}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        if (!res.ok) {
          const { error } = await res.json().catch(() => ({}));
          throw new Error(error || 'Failed to delete template');
        }
        window.showToast('Template deleted');
        loadTemplates();
      } catch (err) {
        window.showToast(err.message || 'Failed to delete template', 'error');
      }
    };

    loadTemplates();
  </script>
</Base>
