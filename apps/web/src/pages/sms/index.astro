---
import Base from '../../layouts/Base.astro';
---

<Base title="Messages">
  <div class="h-[calc(100dvh-4rem)] overflow-hidden bg-gray-50">
    <main class="mx-auto flex h-full max-w-7xl flex-col px-0 sm:px-4 lg:px-8">
      <header class="shrink-0 border-b bg-white px-4 py-3 sm:mt-5 sm:rounded-t-lg sm:border sm:border-b-0">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h1 class="pf-page-title">Messages</h1>
            <p class="pf-copy">Team-visible SMS history tied to each customer.</p>
          </div>
          <a href="/leads" class="btn-secondary btn-sm shrink-0">Customers</a>
        </div>
      </header>

      <section class="grid min-h-0 flex-1 grid-cols-1 overflow-hidden bg-white sm:rounded-b-lg sm:border lg:grid-cols-[360px_minmax(0,1fr)]">
        <aside id="conversation-pane" class="flex min-h-0 flex-col border-r lg:flex">
          <div class="border-b p-3">
            <label class="block">
              <span class="sr-only">Search conversations</span>
              <input id="conversation-search" type="search" autocomplete="off" enterkeyhint="search" class="input" placeholder="Search customer, phone, or message">
            </label>
          </div>
          <div id="conversation-list" class="min-h-0 flex-1 overflow-y-auto divide-y">
            <div class="p-8 text-center text-gray-500">Loading conversations...</div>
          </div>
        </aside>

        <section id="thread-pane" class="hidden min-h-0 flex-col lg:flex">
          <div class="shrink-0 flex items-center gap-3 border-b p-3">
            <button id="back-to-inbox" class="btn-secondary btn-sm lg:hidden" type="button">Inbox</button>
            <div class="min-w-0 flex-1">
              <h2 id="thread-name" class="truncate font-semibold text-gray-950">Select a conversation</h2>
              <p id="thread-meta" class="truncate text-sm text-gray-600">Customer history will appear here.</p>
            </div>
            <a id="customer-link" class="btn-secondary btn-sm hidden" href="#">CRM</a>
          </div>

          <div id="messages" class="min-h-0 flex-1 overflow-y-auto overscroll-contain bg-gray-50 p-3 sm:p-5">
            <div class="mx-auto mt-10 max-w-sm rounded-lg border bg-white p-5 text-center text-sm text-gray-600">
              Select a conversation to view the full SMS history.
            </div>
          </div>

          <div id="composer-wrap" class="sticky bottom-0 z-10 shrink-0 border-t bg-white p-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] shadow-[0_-8px_20px_rgba(15,23,42,0.06)] sm:p-4">
            <div id="quick-replies" class="mb-2 flex gap-2 overflow-x-auto pb-1"></div>
            <form id="send-form" class="grid grid-cols-[1fr_auto] gap-2">
              <label class="min-w-0">
                <span class="sr-only">Message</span>
                <textarea id="message-input" rows="1" maxlength="1000" enterkeyhint="send" class="input max-h-32 min-h-11 resize-none" placeholder="Type a message..." disabled></textarea>
              </label>
              <button id="send-button" type="submit" class="btn-primary self-end" disabled>Send</button>
            </form>
            <div class="mt-2 flex items-center justify-between gap-3 text-xs text-gray-500">
              <span id="send-status">SMS is logged to the customer CRM history.</span>
              <span id="char-count">0/1000</span>
            </div>
          </div>
        </section>
      </section>
    </main>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const params = new URLSearchParams(window.location.search);
    const initialLeadId = params.get('leadId');
    const conversationPane = document.getElementById('conversation-pane');
    const threadPane = document.getElementById('thread-pane');
    const listEl = document.getElementById('conversation-list');
    const messagesEl = document.getElementById('messages');
    const inputEl = document.getElementById('message-input');
    const sendButton = document.getElementById('send-button');
    const sendStatus = document.getElementById('send-status');
    const charCount = document.getElementById('char-count');
    const customerLink = document.getElementById('customer-link');
    const quickRepliesEl = document.getElementById('quick-replies');
    const quickReplyTemplates = [
      'Hi, just checking in on your painting project. Do you have any questions for us?',
      'We can take a look this week. What day works best for you?',
      'Thanks. I’ll update your estimate and send it over shortly.',
      'Your job is on schedule. I’ll send another update after today’s work is complete.',
    ];
    let conversations = [];
    let selectedLeadId = null;
    let currentThread = [];
    let isSending = false;

    const escapeHtml = (value = '') => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    const dateTime = (value) => value ? new Date(value).toLocaleString([], { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '';
    const dateShort = (value) => value ? new Date(value).toLocaleDateString([], { month: 'short', day: 'numeric' }) : '';
    const phone = (value) => window.PaintFlowFormat?.phone(value) ?? value;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;

    async function apiJson(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function groupConversations(rows) {
      const grouped = new Map();
      rows.forEach((message) => {
        if (!message.leadId) return;
        if (!grouped.has(message.leadId)) {
          grouped.set(message.leadId, {
            leadId: message.leadId,
            leadName: message.leadName || `Customer ${message.leadId.slice(0, 8)}`,
            leadPhone: message.leadPhone || '',
            leadEmail: message.leadEmail || '',
            leadStatus: message.leadStatus || '',
            lastMessage: message,
            unread: 0,
            messages: [],
          });
        }
        const conversation = grouped.get(message.leadId);
        conversation.messages.push(message);
        if (new Date(message.createdAt) > new Date(conversation.lastMessage.createdAt)) conversation.lastMessage = message;
        if (message.direction === 'inbound' && !message.read) conversation.unread += 1;
      });
      return Array.from(grouped.values()).sort((a, b) => new Date(b.lastMessage.createdAt) - new Date(a.lastMessage.createdAt));
    }

    function conversationMatches(conversation, query) {
      if (!query) return true;
      const haystack = [
        conversation.leadName,
        conversation.leadPhone,
        conversation.leadEmail,
        conversation.leadStatus,
        conversation.lastMessage?.body,
      ].join(' ').toLowerCase();
      return haystack.includes(query.toLowerCase());
    }

    function renderConversations() {
      const query = document.getElementById('conversation-search').value.trim();
      const visible = conversations.filter((conversation) => conversationMatches(conversation, query));
      if (!visible.length) {
        listEl.innerHTML = '<div class="p-8 text-center text-sm text-gray-500">No conversations match this view.</div>';
        return;
      }

      listEl.innerHTML = visible.map((conversation) => `
        <button class="w-full p-3 text-left hover:bg-gray-50 ${conversation.leadId === selectedLeadId ? 'bg-blue-50' : ''}" data-lead-id="${conversation.leadId}">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <p class="truncate font-medium text-gray-950">${escapeHtml(conversation.leadName)}</p>
                ${conversation.unread ? `<span class="rounded-full bg-blue-600 px-2 py-0.5 text-xs font-semibold text-white">${conversation.unread}</span>` : ''}
              </div>
              <p class="truncate text-sm text-gray-600">${escapeHtml(conversation.lastMessage?.body || '')}</p>
              <p class="mt-1 text-xs text-gray-500">${escapeHtml(conversation.leadPhone ? phone(conversation.leadPhone) : 'No phone')} &middot; ${escapeHtml(label(conversation.leadStatus || 'No status'))}</p>
            </div>
            <span class="shrink-0 text-xs text-gray-500">${dateShort(conversation.lastMessage?.createdAt)}</span>
          </div>
        </button>
      `).join('');
    }

    function renderQuickReplies() {
      quickRepliesEl.innerHTML = quickReplyTemplates.map((reply) => `
        <button type="button" class="btn-secondary btn-sm shrink-0 quick-reply" data-reply="${escapeHtml(reply)}">${escapeHtml(reply.split('.')[0])}</button>
      `).join('');
    }

    function renderThread(lead, thread) {
      currentThread = thread;
      document.getElementById('thread-name').textContent = lead.name;
      document.getElementById('thread-meta').textContent = [lead.phone ? phone(lead.phone) : 'No phone', lead.email, label(lead.status)].filter(Boolean).join(' · ');
      customerLink.href = `/leads/${lead.id}`;
      customerLink.classList.remove('hidden');
      inputEl.disabled = !lead.phone;
      sendButton.disabled = !lead.phone;
      inputEl.placeholder = lead.phone ? 'Type a message...' : 'Add a phone number before sending SMS';

      if (!thread.length) {
        messagesEl.innerHTML = `
          <div class="mx-auto mt-10 max-w-sm rounded-lg border bg-white p-5 text-center text-sm text-gray-600">
            No messages yet. Start with a concise, customer-friendly update.
          </div>
        `;
      } else {
        messagesEl.innerHTML = thread.map((message) => `
          <div class="mb-3 flex ${message.direction === 'outbound' ? 'justify-end' : 'justify-start'}">
            <div class="max-w-[82%] rounded-2xl px-3 py-2 shadow-sm ${message.direction === 'outbound' ? 'bg-blue-600 text-white rounded-br-md' : 'bg-white border text-gray-900 rounded-bl-md'}">
              <p class="whitespace-pre-wrap text-sm leading-relaxed">${escapeHtml(message.body)}</p>
              <p class="mt-1 text-[11px] ${message.direction === 'outbound' ? 'text-blue-50' : 'text-gray-500'}">${dateTime(message.createdAt)}</p>
            </div>
          </div>
        `).join('');
      }
      messagesEl.scrollTop = messagesEl.scrollHeight;
      conversationPane.classList.add('hidden');
      threadPane.classList.remove('hidden');
      threadPane.classList.add('flex');
      if (window.innerWidth >= 1024) conversationPane.classList.remove('hidden');
    }

    async function loadConversations({ keepThread = true } = {}) {
      const payload = await apiJson('/v1/sms/inbox');
      if (!payload) return;
      conversations = groupConversations(payload.data || []);
      renderConversations();
      if (initialLeadId && !selectedLeadId) {
        await selectConversation(initialLeadId);
      } else if (keepThread && selectedLeadId) {
        await selectConversation(selectedLeadId, { silent: true });
      }
    }

    async function selectConversation(leadId, { silent = false } = {}) {
      selectedLeadId = leadId;
      renderConversations();
      if (!silent) {
        sendStatus.textContent = 'Loading conversation...';
      }
      const payload = await apiJson(`/v1/sms/thread/${leadId}`);
      if (!payload) return;
      renderThread(payload.data.lead, payload.data.messages || []);
      sendStatus.textContent = 'SMS is logged to the customer CRM history.';
    }

    async function sendMessage(body) {
      if (!body || !selectedLeadId || isSending) return;
      isSending = true;
      sendButton.disabled = true;
      sendButton.textContent = 'Sending...';
      sendStatus.textContent = 'Sending message...';
      try {
        await apiJson('/v1/sms/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
          body: JSON.stringify({ body, leadId: selectedLeadId }),
        });
        inputEl.value = '';
        updateCharCount();
        await loadConversations({ keepThread: true });
        sendStatus.textContent = 'Message sent and logged.';
      } catch (err) {
        sendStatus.textContent = err.message || 'Failed to send message';
        window.showToast(err.message || 'Failed to send message', 'error');
      } finally {
        isSending = false;
        sendButton.disabled = !selectedLeadId;
        sendButton.textContent = 'Send';
      }
    }

    function updateCharCount() {
      charCount.textContent = `${inputEl.value.length}/1000`;
      inputEl.style.height = 'auto';
      inputEl.style.height = `${Math.min(inputEl.scrollHeight, 128)}px`;
    }

    listEl.addEventListener('click', (event) => {
      const button = event.target.closest('[data-lead-id]');
      if (!button) return;
      selectConversation(button.dataset.leadId);
    });

    document.getElementById('back-to-inbox').addEventListener('click', () => {
      threadPane.classList.add('hidden');
      conversationPane.classList.remove('hidden');
    });

    document.getElementById('conversation-search').addEventListener('input', renderConversations);
    inputEl.addEventListener('input', updateCharCount);
    inputEl.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        document.getElementById('send-form').requestSubmit();
      }
    });
    document.getElementById('send-form').addEventListener('submit', (event) => {
      event.preventDefault();
      sendMessage(inputEl.value.trim());
    });
    document.getElementById('quick-replies').addEventListener('click', (event) => {
      const button = event.target.closest('.quick-reply');
      if (!button || inputEl.disabled) return;
      inputEl.value = button.dataset.reply || '';
      inputEl.focus();
      updateCharCount();
    });

    renderQuickReplies();
    updateCharCount();
    loadConversations().catch((err) => {
      listEl.innerHTML = `<div class="p-8 text-center text-red-600">${escapeHtml(err.message || 'Failed to load messages')}</div>`;
    });
    setInterval(() => loadConversations({ keepThread: true }).catch(() => {}), 15000);
  </script>
</Base>
