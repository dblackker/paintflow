---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import BulkTimecardModal from '../components/BulkTimecardModal.astro';
---

<Base title="Time Tracking - PaintFlow">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <style>
    @media (max-width: 640px) {
      .time-toolbar {
        padding: 0.75rem;
      }
      .time-toolbar .pf-segmented-group {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        width: 100%;
      }
      .time-toolbar .pf-segmented-group > button {
        min-width: 0;
        padding-inline: 0.35rem;
      }
      #timesheet {
        gap: 0.65rem;
      }
      .punch-actions {
        grid-template-columns: 1fr;
      }
      .bulk-member-row {
        grid-template-columns: minmax(0, 1fr) 5.75rem;
      }
    }
    :global(.time-desktop-cell) {
      display: none;
    }
    :global(.time-entry-actions) {
      align-items: center;
      display: flex;
      gap: 0.375rem;
      justify-content: flex-end;
    }
    #punch-map {
      min-height: 22rem;
    }
    .time-map-marker {
      align-items: center;
      background: var(--pf-color-primary);
      border: 2px solid #fff;
      border-radius: 50% 50% 50% 0;
      box-shadow: 0 4px 12px rgb(0 0 0 / 0.28);
      color: #fff;
      display: flex;
      height: 2rem;
      justify-content: center;
      position: relative;
      transform: rotate(-45deg);
      width: 2rem;
    }
    .time-map-marker::after {
      background: rgb(0 0 0 / 0.16);
      border-radius: 999px;
      bottom: -0.42rem;
      content: "";
      height: 0.28rem;
      left: 50%;
      position: absolute;
      transform: translateX(-50%) rotate(45deg);
      width: 0.85rem;
    }
    .time-map-marker-in {
      background: var(--pf-color-primary);
    }
    .time-map-marker-out {
      background: var(--pf-status-success-text);
    }
    .time-map-marker-flagged {
      background: var(--pf-status-warning-text);
    }
    .time-map-marker-glyph {
      align-items: center;
      display: flex;
      height: 1.15rem;
      justify-content: center;
      transform: rotate(45deg);
      width: 1.15rem;
    }
    .time-map-marker-glyph svg {
      height: 1rem;
      stroke-width: 2.5;
      width: 1rem;
    }
    .time-map-marker-review {
      align-items: center;
      background: #fff;
      border: 1px solid var(--pf-status-warning-text);
      border-radius: 999px;
      color: var(--pf-status-warning-text);
      display: flex;
      font-size: 0.65rem;
      font-weight: 800;
      height: 0.9rem;
      justify-content: center;
      position: absolute;
      right: -0.28rem;
      top: -0.18rem;
      transform: rotate(45deg);
      width: 0.9rem;
    }
    @media (min-width: 1024px) {
      :global(.time-mobile-summary) {
        display: none;
      }
      :global(.time-desktop-cell) {
        display: block;
      }
    }
  </style>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
      <div>
        <p class="text-sm font-semibold text-brand-700">Field Operations</p>
        <h1 class="text-2xl sm:text-3xl font-bold">Time Tracking</h1>
        <p id="time-page-copy" class="text-gray-600 max-w-2xl">Review daily timecards, drill into individual entries, and correct job hours without touching pay rates.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
        <button id="bulk-time-btn" class="btn-primary w-full sm:w-auto hidden">Log crew time</button>
      </div>
    </div>

    <section id="punch-clock" class="surface-panel p-4 sm:p-5 mb-4 sm:mb-6">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">Mobile time clock</p>
          <h2 class="text-lg font-semibold mt-1">Punch in / out</h2>
          <p id="punch-status-copy" class="text-sm text-gray-600 mt-1">Loading punch status...</p>
        </div>
        <div id="punch-current" class="text-sm lg:text-right"></div>
      </div>
      <div id="punch-controls" class="mt-4 grid gap-3"></div>
      <div id="punch-review" class="mt-4 hidden"></div>
    </section>

    <section id="time-map-panel" class="surface-panel p-4 sm:p-5 mb-4 sm:mb-6 hidden">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-4">
        <div>
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">GPS punch map</p>
          <h2 class="text-lg font-semibold mt-1">Crew location snapshot</h2>
          <p class="text-sm text-gray-600 mt-1">Shows GPS points captured at clock-in and clock-out. PaintFlow does not show off-clock locations.</p>
        </div>
        <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] gap-2 items-center w-full lg:w-auto lg:min-w-[18rem]">
          <button id="prev-map-day" class="btn-icon btn-icon-outlined" aria-label="Previous day"><Icon name="chevron-left" /></button>
          <span id="map-day-label" class="text-center font-semibold text-sm"></span>
          <button id="next-map-day" class="btn-icon btn-icon-outlined" aria-label="Next day"><Icon name="chevron-right" /></button>
        </div>
      </div>
      <div id="map-summary" class="grid grid-cols-2 lg:grid-cols-4 gap-2 mb-3"></div>
      <div class="grid lg:grid-cols-[minmax(0,1fr)_21rem] gap-4">
        <div id="punch-map" class="rounded-xl border border-[var(--pf-border)] bg-[var(--pf-surface-muted)] overflow-hidden"></div>
        <div>
          <div class="flex items-center justify-between gap-3 mb-2">
            <h3 class="font-semibold text-sm">Punches</h3>
            <button id="refresh-map-btn" class="btn-text btn-sm">Refresh</button>
          </div>
          <div id="map-events" class="space-y-2 max-h-[22rem] overflow-y-auto pr-1"></div>
        </div>
      </div>
    </section>

    <section class="time-toolbar surface-panel p-4 mb-4 sm:mb-6">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
        <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] gap-2 items-center w-full lg:w-auto lg:min-w-[22rem]">
          <button id="prev-week" class="btn-icon btn-icon-outlined" aria-label="Previous week"><Icon name="chevron-left" /></button>
          <span id="week-range" class="text-center font-semibold text-sm sm:text-base"></span>
          <button id="next-week" class="btn-icon btn-icon-outlined" aria-label="Next week"><Icon name="chevron-right" /></button>
        </div>
        <div id="time-view-controls" class="pf-segmented-group justify-center lg:justify-end" aria-label="Time grouping">
          <button type="button" data-view-mode="day">Day</button>
          <button type="button" data-view-mode="job">Job</button>
          <button type="button" data-view-mode="employee">Employee</button>
        </div>
      </div>
    </section>

    <div id="week-summary" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-6"></div>

    <div id="loading" class="text-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
      <p class="mt-4 text-gray-600">Loading timesheet...</p>
    </div>

    <div id="timesheet" class="space-y-4 hidden"></div>

    <div id="empty" class="hidden surface-panel p-12 text-center">
      <p class="text-gray-500">No time entries this week</p>
      <button id="empty-log-time-btn" onclick="document.getElementById('bulk-time-btn')?.click()" class="btn-primary btn-sm mt-4">Log crew time</button>
    </div>
  </main>

  <div id="modal" class="mobile-sheet hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl max-w-lg w-full p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 id="modal-title" class="text-lg font-semibold">Log Time</h2>
          <p class="text-sm text-gray-600">Labor cost is calculated from the team member's burdened rate.</p>
        </div>
        <button type="button" id="close-modal-btn" class="btn-icon" aria-label="Close"><Icon name="close" /></button>
      </div>
      <form id="time-form" class="space-y-4">
        <input type="hidden" name="id">
        <label class="block">
          <span class="form-label">Crew member</span>
          <select name="teamMemberId" id="member-select" class="input" required>
            <option value="">Select crew member...</option>
          </select>
        </label>
        <label class="block">
          <span class="form-label">Job</span>
          <select name="jobId" id="job-select" class="input" required>
            <option value="">Select job...</option>
          </select>
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="block">
            <span class="form-label">Work date</span>
            <input type="date" name="date" autocomplete="off" class="input" required>
          </label>
          <label class="block">
            <span class="form-label">Hours</span>
            <input type="number" name="hours" min="0" max="24" step="0.25" inputmode="decimal" autocomplete="off" placeholder="8" class="input" required>
          </label>
        </div>
        <label class="block">
          <span class="form-label">Work performed</span>
          <input type="text" name="description" autocomplete="off" enterkeyhint="done" placeholder="Prep, spray, trim, punch list" class="input">
        </label>
        <div class="mobile-sticky-actions flex flex-col sm:flex-row gap-3 pt-2 sm:static sm:m-0 sm:border-0 sm:bg-transparent sm:p-0">
          <button type="button" id="cancel-btn" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" id="save-time-btn" class="btn-primary flex-1">Save time</button>
        </div>
      </form>
    </div>
  </div>

  <BulkTimecardModal />

  <div id="forgot-clock-in-modal" class="mobile-sheet hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl max-w-md w-full p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 class="text-lg font-semibold">Forgot clock-in</h2>
          <p class="text-sm text-gray-600">Enter the actual start time and a note for lead review.</p>
        </div>
        <button type="button" id="close-forgot-clock-in-btn" class="btn-icon" aria-label="Close"><Icon name="close" /></button>
      </div>
      <form id="forgot-clock-in-form" class="space-y-4">
        <label class="block">
          <span class="form-label">Actual clock-in time</span>
          <input id="forgot-in-time" name="startedAt" type="datetime-local" class="input" required>
        </label>
        <label class="block">
          <span class="form-label">Reason for lead review</span>
          <textarea id="forgot-in-reason" name="reason" class="input min-h-24" maxlength="500" placeholder="Forgot to clock in before starting prep." required></textarea>
        </label>
        <div class="mobile-sticky-actions flex flex-col sm:flex-row gap-3 pt-2 sm:static sm:m-0 sm:border-0 sm:bg-transparent sm:p-0">
          <button type="button" id="cancel-forgot-clock-in-btn" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" id="submit-forgot-clock-in-btn" class="btn-primary flex-1">Submit for review</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let currentWeekStart = getWeekStart(new Date());
    let allEntries = [];
    let members = [];
    let jobs = [];
    let punchStatus = null;
    let canManageTime = false;
    let currentMapDate = new Date();
    let punchMap = null;
    let punchMapLayer = null;
    let isMapReady = false;
    let isSavingTime = false;
    let isSavingBulkTime = false;
    let isPunching = false;
    let bulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
    const bulkSelection = new Map();
    const bulkHours = new Map();
    const supportedViewModes = new Set(['day', 'job', 'employee']);
    let viewMode = supportedViewModes.has(localStorage.getItem('paintflow.time.viewMode'))
      ? localStorage.getItem('paintflow.time.viewMode')
      : 'day';
    const collapsedGroups = new Set();

    const currency = (value) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const roleLabels = {
      admin: 'Admin',
      crew: 'Crew member',
      crew_lead: 'Crew lead',
      estimator: 'Estimator',
      painter: 'Painter',
      prep: 'Prep crew',
    };

    function escapeHtml(value = '') {
      return String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }

    function iconSvg(name) {
      const icons = {
        edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
        plus: '<path d="M12 5v14M5 12h14" />',
        trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
      };
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${icons[name] || ''}</svg>`;
    }

    function getWeekStart(date) {
      const d = new Date(date);
      const day = d.getDay();
      const diff = d.getDate() - day + (day === 0 ? -6 : 1);
      d.setHours(0, 0, 0, 0);
      return new Date(d.setDate(diff));
    }

    function formatDate(date) {
      return date.toISOString().split('T')[0];
    }

    function dateKey(value) {
      return formatDate(new Date(value));
    }

    function toDateTimeLocal(date = new Date()) {
      const local = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
      return local.toISOString().slice(0, 16);
    }

    async function api(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, {
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
        ...options,
      });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    async function loadData() {
      document.getElementById('loading').classList.remove('hidden');
      document.getElementById('timesheet').classList.add('hidden');
      document.getElementById('empty').classList.add('hidden');

      try {
        const [timePayload, punchPayload] = await Promise.all([
          api('/v1/team/time'),
          api('/v1/team/punch/status').catch((err) => ({ data: { memberResolutionError: err.message } })),
        ]);

        punchStatus = punchPayload.data || {};
        canManageTime = Boolean(punchStatus?.canManage);
        const [membersPayload, jobsPayload] = canManageTime
          ? await Promise.all([api('/v1/team/members'), api('/v1/jobs')])
          : [
              { data: punchStatus?.member ? [punchStatus.member] : [] },
              { data: punchStatus?.jobs || [] },
            ];

        members = membersPayload.data || [];
        jobs = jobsPayload.data || [];
        allEntries = timePayload.data || [];
        applyTimeAccessMode();
        populateSelects();
        renderPunchClock();
        renderBulkEntry();
        renderTimesheet();
        renderMapVisibility();
        if (canManageTime) loadMapData();
      } catch (e) {
        document.getElementById('loading').innerHTML = `<p class="text-red-600">${escapeHtml(e.message || 'Failed to load')}</p>`;
      }
    }

    function applyTimeAccessMode() {
      const isCrewOnly = Boolean(punchStatus?.member && !canManageTime);
      document.body.classList.toggle('pf-crew-time-mode', isCrewOnly);
      document.getElementById('time-page-copy').textContent = isCrewOnly
        ? 'Clock in, clock out, and review your own timecards. Location is captured for each punch.'
        : 'Review daily timecards, drill into individual entries, and correct job hours without touching pay rates.';
      document.getElementById('time-view-controls').classList.toggle('hidden', isCrewOnly);
      document.getElementById('empty-log-time-btn').classList.toggle('hidden', isCrewOnly);
      if (isCrewOnly) viewMode = 'day';
    }

    function renderMapVisibility() {
      document.getElementById('time-map-panel').classList.toggle('hidden', !canManageTime);
    }

    function populateSelects() {
      const sortedJobs = sortJobsByRecentTime(jobs);
      document.getElementById('member-select').innerHTML = '<option value="">Select crew member...</option>' +
        members.map((member) => `<option value="${member.id}">${escapeHtml(member.name)}</option>`).join('');
      document.getElementById('job-select').innerHTML = '<option value="">Select job...</option>' +
        sortedJobs.map((job) => `<option value="${job.id}">${escapeHtml(jobOptionLabel(job))}</option>`).join('');
      document.getElementById('bulk-job-select').innerHTML = '<option value="">Select job...</option>' +
        sortedJobs.map((job) => `<option value="${job.id}">${escapeHtml(jobOptionLabel(job))}</option>`).join('');
    }

    function jobAddress(job = {}) {
      return window.PaintFlowFormat?.address({
        streetAddress: job.leadStreetAddress || job.streetAddress,
        city: job.leadCity || job.city,
        state: job.leadState || job.state,
        postalCode: job.leadPostalCode || job.postalCode,
      }, '', { includePostalCode: false }) || [
        job.leadStreetAddress || job.streetAddress,
        [job.leadCity || job.city, job.leadState || job.state].filter(Boolean).join(', '),
      ].filter(Boolean).join(' ');
    }

    function jobOptionLabel(job = {}) {
      const address = jobAddress(job);
      const customer = job.leadName ? ` - ${job.leadName}` : '';
      return address ? `${address}${customer} - ${job.name}` : `${job.name}${customer}`;
    }

    function timeSortValue(value) {
      if (!value) return 0;
      const date = new Date(value);
      const time = date.getTime();
      return Number.isFinite(time) ? time : 0;
    }

    function latestLoggedTimeByJob() {
      return allEntries.reduce((latest, entry) => {
        if (!entry.jobId) return latest;
        const value = Math.max(
          timeSortValue(entry.actualEndAt),
          timeSortValue(entry.roundedEndAt),
          timeSortValue(entry.date),
          timeSortValue(entry.createdAt),
        );
        latest.set(entry.jobId, Math.max(latest.get(entry.jobId) || 0, value));
        return latest;
      }, new Map());
    }

    function fallbackJobSortValue(job = {}) {
      return Math.max(
        timeSortValue(job.scheduledStartAt),
        timeSortValue(job.updatedAt),
        timeSortValue(job.createdAt),
      );
    }

    function sortJobsByRecentTime(sourceJobs = []) {
      const latestByJob = latestLoggedTimeByJob();
      return [...sourceJobs].sort((a, b) => {
        const aLatest = latestByJob.get(a.id) || 0;
        const bLatest = latestByJob.get(b.id) || 0;
        if (aLatest !== bLatest) return bLatest - aLatest;
        return fallbackJobSortValue(b) - fallbackJobSortValue(a);
      });
    }

    function punchJobOptions() {
      const jobsById = new Map(jobs.map((job) => [job.id, job]));
      const sourceJobs = sortJobsByRecentTime(
        (punchStatus?.jobs?.length ? punchStatus.jobs : jobs)
          .map((job) => ({ ...jobsById.get(job.id), ...job }))
      );
      const options = sourceJobs
        .map((job) => `<option value="${job.id}">${escapeHtml(jobOptionLabel(job))}</option>`)
        .join('');
      return `<option value="">No job selected - flag for review</option>${options}`;
    }

    function punchMemberOptions() {
      return (punchStatus?.members || [])
        .map((member) => `<option value="${member.id}" ${member.id === punchStatus?.member?.id ? 'selected' : ''}>${escapeHtml(member.name)}</option>`)
        .join('');
    }

    function activePunchHours(session) {
      return ((Date.now() - new Date(session.startedAtActual).getTime()) / 36e5).toFixed(2);
    }

    function mapLink(latitude, longitude, label) {
      if (!latitude || !longitude) return '';
      const href = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${latitude},${longitude}`)}`;
      return `<a class="text-xs font-medium text-brand-700" href="${href}" target="_blank" rel="noreferrer">${label}</a>`;
    }

    function localDateLabel(date) {
      return date.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
    }

    function localDayBounds(date) {
      const start = new Date(date);
      start.setHours(0, 0, 0, 0);
      const end = new Date(start);
      end.setDate(end.getDate() + 1);
      return { start: start.toISOString(), end: end.toISOString() };
    }

    function punchTypeLabel(type = '') {
      if (type.includes('clock_out')) return 'Clock out';
      if (type.includes('clock_in')) return 'Clock in';
      if (type.includes('reminder')) return 'Reminder';
      return type.replace(/[_-]/g, ' ');
    }

    function eventAddress(event = {}) {
      if (!event.address) return '';
      return window.PaintFlowFormat?.address(event.address, '', { includePostalCode: false }) || [
        event.address.streetAddress,
        [event.address.city, event.address.state].filter(Boolean).join(', '),
      ].filter(Boolean).join(' ');
    }

    async function ensureLeaflet() {
      if (window.L) return window.L;
      if (!window.__paintflowLeafletPromise) {
        window.__paintflowLeafletPromise = new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
          script.onload = () => resolve(window.L);
          script.onerror = () => reject(new Error('Failed to load map library'));
          document.head.appendChild(script);
        });
      }
      return window.__paintflowLeafletPromise;
    }

    async function initializePunchMap() {
      if (isMapReady) return;
      const L = await ensureLeaflet();
      punchMap = L.map('punch-map', { scrollWheelZoom: false });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        maxZoom: 19,
      }).addTo(punchMap);
      punchMapLayer = L.layerGroup().addTo(punchMap);
      punchMap.setView([39.8283, -98.5795], 4);
      isMapReady = true;
    }

    function mapMarkerIcon(event) {
      const L = window.L;
      const isOut = event.type.includes('clock_out');
      const isFlagged = event.reviewRequired;
      const glyph = isOut
        ? '<svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 19V7" /><path d="m7 12 5-5 5 5" /></svg>'
        : '<svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v12" /><path d="m7 12 5 5 5-5" /></svg>';
      return L.divIcon({
        className: 'time-map-marker-wrap',
        html: `<span class="time-map-marker ${isFlagged ? 'time-map-marker-flagged' : isOut ? 'time-map-marker-out' : 'time-map-marker-in'}"><span class="time-map-marker-glyph">${glyph}</span>${isFlagged ? '<span class="time-map-marker-review">!</span>' : ''}</span>`,
        iconSize: [34, 42],
        iconAnchor: [17, 34],
        popupAnchor: [0, -30],
      });
    }

    async function loadMapData() {
      if (!canManageTime) return;
      document.getElementById('map-day-label').textContent = localDateLabel(currentMapDate);
      document.getElementById('map-events').innerHTML = '<p class="text-sm text-gray-500 p-3">Loading punch locations...</p>';
      const { start, end } = localDayBounds(currentMapDate);
      try {
        const payload = await api(`/v1/team/time/map?start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`);
        await renderPunchMap(payload.data || { events: [], summary: {} });
      } catch (error) {
        document.getElementById('map-events').innerHTML = `<p class="text-sm text-red-600 p-3">${escapeHtml(error.message || 'Failed to load map')}</p>`;
      }
    }

    async function renderPunchMap(data) {
      await initializePunchMap();
      const L = window.L;
      const events = data.events || [];
      const summary = data.summary || {};
      document.getElementById('map-summary').innerHTML = [
        ['Clock-ins', summary.clockIns || 0],
        ['Clock-outs', summary.clockOuts || 0],
        ['Crew', summary.employees || 0],
        ['Jobs', summary.jobs || 0],
      ].map(([label, value]) => `
        <div class="rounded-lg border border-[var(--pf-border)] bg-white px-3 py-2">
          <p class="text-xs text-gray-500">${label}</p>
          <p class="text-lg font-semibold">${value}</p>
        </div>
      `).join('');

      punchMapLayer.clearLayers();
      if (!events.length) {
        document.getElementById('map-events').innerHTML = '<p class="text-sm text-gray-500 p-3">No GPS punch locations for this day.</p>';
        punchMap.setView([39.8283, -98.5795], 4);
        return;
      }

      const bounds = [];
      events.forEach((event) => {
        const latLng = [Number(event.latitude), Number(event.longitude)];
        bounds.push(latLng);
        const address = eventAddress(event);
        L.marker(latLng, { icon: mapMarkerIcon(event) })
          .bindPopup(`
            <strong>${escapeHtml(event.teamMemberName)}</strong><br>
            ${escapeHtml(punchTypeLabel(event.type))} at ${escapeHtml(new Date(event.occurredAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }))}<br>
            ${escapeHtml(event.jobName || 'Unassigned job')}<br>
            ${address ? escapeHtml(address) : ''}
          `)
          .addTo(punchMapLayer);
      });
      punchMap.fitBounds(bounds, { padding: [28, 28], maxZoom: 15 });

      document.getElementById('map-events').innerHTML = events.map((event) => {
        const address = eventAddress(event);
        const time = new Date(event.occurredAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
        return `
          <button type="button" class="w-full rounded-lg border border-[var(--pf-border)] bg-white p-3 text-left hover:bg-[var(--pf-surface-muted)]" data-map-event="${event.id}">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-medium text-sm truncate">${escapeHtml(event.teamMemberName)}</p>
                <p class="text-xs text-gray-600">${escapeHtml(punchTypeLabel(event.type))} - ${escapeHtml(time)}</p>
              </div>
              ${event.reviewRequired ? '<span class="chip pf-status-warning">Review</span>' : ''}
            </div>
            <p class="text-xs text-gray-600 mt-1 truncate">${escapeHtml(event.jobName || 'Unassigned job')}</p>
            ${address ? `<p class="text-xs text-gray-500 truncate">${escapeHtml(address)}</p>` : ''}
          </button>
        `;
      }).join('');
      document.querySelectorAll('[data-map-event]').forEach((button) => {
        button.addEventListener('click', () => {
          const event = events.find((item) => item.id === button.dataset.mapEvent);
          if (!event) return;
          punchMap.setView([Number(event.latitude), Number(event.longitude)], 16);
        });
      });
    }

    function renderPunchClock() {
      const controls = document.getElementById('punch-controls');
      const current = document.getElementById('punch-current');
      const copy = document.getElementById('punch-status-copy');
      const review = document.getElementById('punch-review');
      const status = punchStatus || {};
      const active = status.activeSession;
      const memberName = status.member?.name || 'Crew member';

      if (status.memberResolutionError && !status.canManage) {
        copy.textContent = status.memberResolutionError;
        current.innerHTML = '';
        controls.innerHTML = '<p class="text-sm text-gray-600">Ask an owner to link your login email to an active crew member on the Team page.</p>';
        review.classList.add('hidden');
        return;
      }

      if (active) {
        copy.textContent = `${memberName} is punched in. GPS is captured again when clocking out.`;
        current.innerHTML = `
          <span class="chip">Clocked in</span>
          <p class="font-semibold mt-1">${escapeHtml(active.jobName || 'Job')}</p>
          <p class="text-gray-600">Started ${new Date(active.startedAtActual).toLocaleString()} • ${activePunchHours(active)} hrs</p>
          ${active.status === 'missed_clock_out' ? '<p class="text-red-700 font-medium mt-1">Past the max shift window. Check the forgotten clock-out option if the actual end time was earlier.</p>' : ''}
        `;
        controls.innerHTML = `
          <div class="grid punch-actions gap-3">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input id="forgot-clock-out-toggle" type="checkbox" class="h-4 w-4">
                <span>I forgot to clock out earlier</span>
              </label>
              <button id="punch-out-btn" class="btn-primary">Clock out</button>
            </div>
            <div id="forgot-clock-out-fields" class="hidden grid sm:grid-cols-2 gap-3 rounded-lg border border-[var(--pf-border)] bg-[var(--pf-surface-muted)] p-3">
              <label class="block">
                <span class="form-label">Actual clock-out time</span>
                <input id="punch-out-time" type="datetime-local" class="input" value="${toDateTimeLocal()}">
              </label>
              <label class="block">
                <span class="form-label">Reason for lead review</span>
                <input id="punch-out-note" class="input" placeholder="Finished at 4:30, forgot to clock out">
              </label>
            </div>
          </div>
          <p class="text-xs text-gray-500">Normal clock-out uses the current time. Check the forgotten clock-out option only when the actual end time was earlier.</p>
        `;
      } else {
        copy.textContent = `${memberName} is not punched in. Start a job timer from the field with location permission enabled.`;
        current.innerHTML = '<span class="chip">Not clocked in</span>';
        controls.innerHTML = `
          <div class="grid punch-actions ${status.canManage ? 'sm:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)_auto]' : 'sm:grid-cols-[minmax(0,1fr)_auto]'} gap-3 items-end">
            ${status.canManage ? `<label class="block"><span class="form-label">Crew member</span><select id="punch-member" class="input">${punchMemberOptions()}</select></label>` : ''}
            <label class="block">
              <span class="form-label">Job / location</span>
              <select id="punch-job" class="input">${punchJobOptions()}</select>
            </label>
            <div class="flex flex-col sm:flex-row gap-2">
              <button type="button" id="punch-in-btn" class="btn-primary">Clock in</button>
              <button type="button" id="forgot-in-btn" class="btn-text btn-sm">Forgot clock-in</button>
            </div>
          </div>
          <p class="text-xs text-gray-500">Street address is shown first when available. Leaving job blank flags the shift for lead review.</p>
        `;
      }

      renderPunchReview();
      document.getElementById('bulk-time-btn').classList.toggle('hidden', !status.canManage);
      document.getElementById('punch-in-btn')?.addEventListener('click', () => punchIn(false));
      document.getElementById('forgot-in-btn')?.addEventListener('click', openForgotClockInModal);
      document.getElementById('forgot-clock-out-toggle')?.addEventListener('change', toggleForgotClockOutFields);
      document.getElementById('punch-out-btn')?.addEventListener('click', punchOut);
    }

    function toggleForgotClockOutFields(event) {
      const fields = document.getElementById('forgot-clock-out-fields');
      fields?.classList.toggle('hidden', !event.target.checked);
    }

    function availableRoles() {
      return Array.from(new Set(members.map((member) => member.role || 'crew'))).sort((a, b) => {
        const order = ['crew_lead', 'painter', 'prep'];
        const aIndex = order.indexOf(a);
        const bIndex = order.indexOf(b);
        if (aIndex !== -1 || bIndex !== -1) return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex);
        return (roleLabels[a] || a).localeCompare(roleLabels[b] || b);
      });
    }

    function renderBulkEntry() {
      const button = document.getElementById('bulk-time-btn');
      button.classList.toggle('hidden', !punchStatus?.canManage);
      syncBulkSelection();
      renderBulkRoleFilters();
      renderBulkMemberRows();
    }

    function syncBulkSelection() {
      const memberIds = new Set(members.map((member) => member.id));
      members.forEach((member) => {
        if (!bulkSelection.has(member.id)) bulkSelection.set(member.id, true);
        if (!bulkHours.has(member.id)) bulkHours.set(member.id, getBulkDefaultHours());
      });
      Array.from(bulkSelection.keys()).forEach((id) => {
        if (!memberIds.has(id)) bulkSelection.delete(id);
      });
      Array.from(bulkHours.keys()).forEach((id) => {
        if (!memberIds.has(id)) bulkHours.delete(id);
      });
    }

    function getBulkDefaultHours() {
      const value = Number(document.getElementById('bulk-default-hours')?.value || 8);
      return Number.isFinite(value) && value >= 0 ? value : 8;
    }

    function getBulkSelectedEntries() {
      return members
        .filter((member) => bulkSelection.get(member.id))
        .map((member) => ({
          member,
          hours: Number(bulkHours.get(member.id) ?? getBulkDefaultHours()),
        }))
        .filter((entry) => Number.isFinite(entry.hours) && entry.hours > 0);
    }

    function updateBulkSummary() {
      const summary = document.getElementById('bulk-selection-summary');
      if (!summary) return;
      const selected = getBulkSelectedEntries();
      const visibleIds = new Set(
        members
          .filter((member) => bulkRoleFilters.has(member.role || 'crew'))
          .map((member) => member.id)
      );
      const hiddenSelected = selected.filter(({ member }) => !visibleIds.has(member.id)).length;
      const totalHours = selected.reduce((sum, entry) => sum + entry.hours, 0);
      const averageHours = selected.length ? totalHours / selected.length : 0;
      const parts = [
        `${selected.length} employee${selected.length === 1 ? '' : 's'} selected`,
        `${averageHours.toFixed(2).replace(/\.00$/, '')} hr avg`,
        `${totalHours.toFixed(2).replace(/\.00$/, '')} total hrs`,
      ];
      if (hiddenSelected) {
        parts.push(`${hiddenSelected} hidden by filters`);
      }
      summary.textContent = parts.join(' • ');
    }

    function renderBulkRoleFilters() {
      const container = document.getElementById('bulk-role-filters');
      if (!container) return;
      const roles = availableRoles();
      container.innerHTML = roles.length
        ? roles.map((role) => `
          <button type="button" class="pf-filter-chip ${bulkRoleFilters.has(role) ? 'pf-filter-chip-active' : ''}" data-bulk-role="${escapeHtml(role)}" aria-pressed="${bulkRoleFilters.has(role) ? 'true' : 'false'}">
            ${escapeHtml(roleLabels[role] || role)}
          </button>
        `).join('')
        : '<p class="text-sm text-gray-500">No active crew members available.</p>';
      container.querySelectorAll('[data-bulk-role]').forEach((filter) => {
        filter.addEventListener('click', () => {
          const role = filter.dataset.bulkRole;
          if (bulkRoleFilters.has(role)) bulkRoleFilters.delete(role);
          else bulkRoleFilters.add(role);
          renderBulkRoleFilters();
          renderBulkMemberRows();
        });
      });
    }

    function renderBulkMemberRows() {
      const container = document.getElementById('bulk-members');
      if (!container) return;
      const visibleMembers = members.filter((member) => bulkRoleFilters.has(member.role || 'crew'));
      if (!visibleMembers.length) {
        container.innerHTML = '<div class="p-4 text-sm text-gray-500">No crew match the selected roles. Add another role filter to include more people.</div>';
        updateBulkSelectionAction();
        updateBulkSummary();
        return;
      }
      container.innerHTML = visibleMembers.map((member) => `
        <label class="bulk-member-row grid grid-cols-[minmax(0,1fr)_5.75rem] sm:grid-cols-[minmax(0,1fr)_8rem] gap-3 items-center p-3 hover:bg-gray-50">
          <span class="flex items-center gap-3 min-w-0">
            <input type="checkbox" data-bulk-member="${member.id}" class="h-5 w-5" ${bulkSelection.get(member.id) ? 'checked' : ''}>
            <span class="min-w-0">
              <span class="block font-medium truncate">${escapeHtml(member.name)}</span>
              <span class="block text-xs text-gray-500">${escapeHtml(roleLabels[member.role] || member.role || 'Crew')}</span>
            </span>
          </span>
          <input type="number" data-bulk-hours="${member.id}" min="0" max="24" step="0.25" inputmode="decimal" autocomplete="off" enterkeyhint="done" aria-label="Hours for ${escapeHtml(member.name)}" class="input text-right" value="${bulkHours.get(member.id) ?? getBulkDefaultHours()}">
        </label>
      `).join('');
      container.querySelectorAll('[data-bulk-member]').forEach((checkbox) => {
        checkbox.addEventListener('change', () => {
          bulkSelection.set(checkbox.dataset.bulkMember, checkbox.checked);
          updateBulkSelectionAction();
          updateBulkSummary();
        });
      });
      container.querySelectorAll('[data-bulk-hours]').forEach((input) => {
        input.addEventListener('focus', () => {
          requestAnimationFrame(() => {
            try {
              input.select();
            } catch {
              // Some mobile browsers restrict selection APIs on numeric inputs.
            }
          });
        });
        input.addEventListener('input', () => {
          bulkHours.set(input.dataset.bulkHours, Number(input.value || 0));
          updateBulkSummary();
        });
      });
      updateBulkSelectionAction();
      updateBulkSummary();
    }

    function updateBulkSelectionAction() {
      const button = document.getElementById('bulk-select-visible');
      if (!button) return;
      const visible = Array.from(document.querySelectorAll('[data-bulk-member]'));
      if (!visible.length) {
        button.textContent = 'Select visible';
        button.disabled = true;
        updateBulkSummary();
        return;
      }
      button.disabled = false;
      const checked = visible.filter((checkbox) => checkbox.checked).length;
      button.textContent = checked === visible.length ? 'Clear visible' : 'Select visible';
      updateBulkSummary();
    }

    function openBulkModal() {
      const form = document.getElementById('bulk-time-form');
      form.reset();
      form.elements.date.value = formatDate(new Date());
      document.getElementById('bulk-default-hours').value = '8';
      if (!bulkRoleFilters.size) bulkRoleFilters = new Set(['crew_lead', 'painter', 'prep']);
      members.forEach((member) => bulkSelection.set(member.id, true));
      members.forEach((member) => bulkHours.set(member.id, 8));
      renderBulkEntry();
      document.getElementById('bulk-modal').classList.remove('hidden');
    }

    function closeBulkModal() {
      document.getElementById('bulk-modal').classList.add('hidden');
    }

    function openForgotClockInModal() {
      const form = document.getElementById('forgot-clock-in-form');
      form.reset();
      document.getElementById('forgot-in-time').value = toDateTimeLocal();
      document.getElementById('forgot-in-reason').value = 'Forgot to clock in; entered later from the app.';
      document.getElementById('forgot-clock-in-modal').classList.remove('hidden');
    }

    function closeForgotClockInModal() {
      document.getElementById('forgot-clock-in-modal').classList.add('hidden');
    }

    function renderPunchReview() {
      const review = document.getElementById('punch-review');
      const rows = punchStatus?.reviewQueue || [];
      if (!punchStatus?.canManage) {
        review.classList.add('hidden');
        review.innerHTML = '';
        return;
      }
      review.classList.remove('hidden');
      review.innerHTML = `
        <div class="border-t border-[var(--pf-border)] pt-4">
          <div class="flex items-center justify-between gap-3 mb-3">
            <div>
              <h3 class="font-semibold">Time approvals</h3>
              <p class="text-sm text-gray-600">Crew leads review missed punches, late clock-outs, long shifts, missing job assignments, and manual punch overrides here.</p>
            </div>
            <span class="chip">${rows.length}</span>
          </div>
          <div class="space-y-2">
            ${rows.length ? rows.map((row) => `
              <article class="rounded-lg border border-[var(--pf-border)] p-3 grid gap-3 sm:grid-cols-[1fr_auto] sm:items-center">
                <div>
                  <p class="font-semibold">${escapeHtml(row.teamMemberName)} • ${escapeHtml(row.jobName)}</p>
                  <p class="text-sm text-gray-600">${escapeHtml(row.reviewLabel)} • Started ${new Date(row.startedAtActual).toLocaleString()}</p>
                  ${!row.jobId ? '<p class="text-xs font-medium text-red-700">Assign a job from the timesheet row before approval.</p>' : ''}
                  ${row.endedAtActual ? `<p class="text-xs text-gray-500">Ended ${new Date(row.endedAtActual).toLocaleString()}</p>` : '<p class="text-xs text-red-700">Still needs clock-out</p>'}
                  <p class="mt-1 flex flex-wrap gap-3">
                    ${mapLink(row.startLatitude, row.startLongitude, 'Start GPS')}
                    ${mapLink(row.endLatitude, row.endLongitude, 'End GPS')}
                  </p>
                </div>
                <div class="flex gap-2 justify-end">
                  <button class="btn-secondary btn-sm" data-review-punch="${row.id}" data-review-status="approved" ${!row.jobId ? 'disabled title="Assign a job before approval"' : ''}>Approve</button>
                  <button class="btn-secondary btn-sm" data-review-punch="${row.id}" data-review-status="rejected">Reject</button>
                </div>
              </article>
            `).join('') : `
              <div class="rounded-lg border border-[var(--pf-border)] bg-[var(--pf-surface-muted)] p-4 text-sm text-gray-600">
                No time entries need approval right now. Approved overrides remain labeled in the timesheet rows below.
              </div>
            `}
          </div>
        </div>
      `;
      review.querySelectorAll('[data-review-punch]').forEach((button) => {
        button.addEventListener('click', () => reviewPunch(button.dataset.reviewPunch, button.dataset.reviewStatus));
      });
    }

    function getSelectedPunchMemberId() {
      return document.getElementById('punch-member')?.value || undefined;
    }

    function requireLocation() {
      return new Promise((resolve, reject) => {
        if (!navigator.geolocation) {
          reject(new Error('Location is required, but this browser does not support geolocation.'));
          return;
        }
        navigator.geolocation.getCurrentPosition(
          (position) => resolve({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
            accuracyMeters: position.coords.accuracy,
          }),
          () => reject(new Error('Location permission is required to punch time.')),
          { enableHighAccuracy: true, timeout: 12000, maximumAge: 60000 },
        );
      });
    }

    async function refreshPunchStatus() {
      punchStatus = (await api('/v1/team/punch/status')).data;
      renderPunchClock();
      await loadData();
    }

    async function punchIn(forgot, options = {}) {
      if (isPunching) return;
      const jobId = document.getElementById('punch-job')?.value;
      try {
        isPunching = true;
        const location = await requireLocation();
        await api('/v1/team/punch/in', {
          method: 'POST',
          body: JSON.stringify({
            ...location,
            jobId: jobId || undefined,
            teamMemberId: getSelectedPunchMemberId(),
            forgotPunchIn: forgot,
            startedAt: forgot && options.startedAt ? new Date(options.startedAt).toISOString() : undefined,
            note: forgot
              ? options.note || 'Forgot to clock in; entered later from the app.'
              : jobId ? undefined : 'Crew clocked in without selecting a job.',
          }),
        });
        window.showToast?.(forgot || !jobId ? 'Clock-in created for review' : 'Clocked in', 'success');
        if (forgot) closeForgotClockInModal();
        await refreshPunchStatus();
      } catch (err) {
        window.showToast?.(err.message || 'Punch failed', 'error');
      } finally {
        isPunching = false;
      }
    }

    async function punchOut() {
      if (isPunching) return;
      try {
        isPunching = true;
        const location = await requireLocation();
        const forgotClockOut = Boolean(document.getElementById('forgot-clock-out-toggle')?.checked);
        const note = forgotClockOut ? document.getElementById('punch-out-note')?.value || '' : '';
        const endedAtValue = forgotClockOut ? document.getElementById('punch-out-time')?.value : '';
        if (forgotClockOut && !endedAtValue) {
          throw new Error('Enter the actual clock-out time for lead review.');
        }
        await api('/v1/team/punch/out', {
          method: 'POST',
          body: JSON.stringify({
            ...location,
            teamMemberId: getSelectedPunchMemberId(),
            endedAt: endedAtValue ? new Date(endedAtValue).toISOString() : undefined,
            note,
            overrideReason: note || undefined,
          }),
        });
        window.showToast?.('Clocked out', 'success');
        await refreshPunchStatus();
      } catch (err) {
        window.showToast?.(err.message || 'Punch failed', 'error');
      } finally {
        isPunching = false;
      }
    }

    async function reviewPunch(id, reviewStatus) {
      await api(`/v1/team/punch/review/${id}`, {
        method: 'PATCH',
        body: JSON.stringify({ reviewStatus }),
      });
      window.showToast?.(reviewStatus === 'approved' ? 'Punch approved' : 'Punch rejected', 'success');
      await refreshPunchStatus();
    }

    function getWeekEntries() {
      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 7);
      return allEntries.filter((entry) => {
        const entryDate = new Date(entry.date);
        return entryDate >= currentWeekStart && entryDate < weekEnd;
      });
    }

    function renderTimesheet() {
      document.getElementById('loading').classList.add('hidden');

      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 6);
      document.getElementById('week-range').textContent =
        `${currentWeekStart.toLocaleDateString()} - ${weekEnd.toLocaleDateString()}`;

      const weekEntries = getWeekEntries();
      renderSummary(weekEntries);
      renderViewModeControls();

      if (!weekEntries.length) {
        document.getElementById('empty').classList.remove('hidden');
        document.getElementById('timesheet').classList.add('hidden');
        return;
      }

      document.getElementById('timesheet').classList.remove('hidden');
      document.getElementById('timesheet').innerHTML = renderGroupedTimesheet(weekEntries);
    }

    function renderViewModeControls() {
      document.querySelectorAll('[data-view-mode]').forEach((button) => {
        const active = button.dataset.viewMode === viewMode;
        button.classList.toggle('view-mode-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function renderSummary(entries) {
      const totalHours = entries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = entries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      const crewCount = new Set(entries.map((entry) => entry.teamMemberId)).size;
      const reviewCount = entries.filter((entry) => entry.reviewStatus === 'flagged' || entry.reviewStatus === 'rejected').length;
      const overrideCount = entries.filter((entry) => entry.source === 'punch_clock' && entry.reviewReason).length;
      const summary = document.getElementById('week-summary');
      const cards = canManageTime ? [
        ['Hours', totalHours.toFixed(2), 'Logged this week'],
        ['Labor cost', currency(totalCost), 'Burdened job cost'],
        ['Crew', crewCount, 'People with entries'],
        ['Needs review', reviewCount, 'Flagged punches'],
        ['Overrides', overrideCount, 'Forgotten or adjusted punches'],
      ] : [
        ['Hours', totalHours.toFixed(2), 'Your logged time this week'],
        ['Entries', entries.length, 'Timecards on record'],
        ['Needs review', reviewCount, 'Flagged punches'],
        ['Overrides', overrideCount, 'Forgotten or adjusted punches'],
      ];
      summary.classList.toggle('lg:grid-cols-5', canManageTime);
      summary.classList.toggle('lg:grid-cols-4', !canManageTime);
      summary.innerHTML = cards.map(([label, value, help]) => `
        <div class="surface-panel p-4">
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">${label}</p>
          <p class="text-2xl font-bold mt-1">${value}</p>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `).join('');
    }

    function renderGroupedTimesheet(entries) {
      const grouping = {
        day: {
          key: (entry) => dateKey(entry.date),
          title: (key) => new Date(`${key}T12:00:00`).toLocaleDateString(undefined, { weekday: 'long', month: 'short', day: 'numeric' }),
          subtitle: (groupEntries) => entryCountLabel(groupEntries.length),
          sort: ([a], [b]) => b.localeCompare(a),
        },
        job: {
          key: (entry) => entry.jobId || 'unassigned-job',
          title: (_key, groupEntries) => groupEntries[0]?.jobName || 'Job',
          subtitle: (groupEntries) => `${new Set(groupEntries.map((entry) => entry.teamMemberId)).size} crew - ${entryCountLabel(groupEntries.length)}`,
          sort: ([, a], [, b]) => (b.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)) - (a.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)),
        },
        employee: {
          key: (entry) => entry.teamMemberId || 'unassigned-employee',
          title: (_key, groupEntries) => groupEntries[0]?.teamMemberName || 'Crew member',
          subtitle: (groupEntries) => `${new Set(groupEntries.map((entry) => entry.jobId)).size} jobs - ${entryCountLabel(groupEntries.length)}`,
          sort: ([, a], [, b]) => (b.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)) - (a.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)),
        },
      }[viewMode];

      const grouped = entries.reduce((groups, entry) => {
        const key = grouping.key(entry);
        if (!groups[key]) groups[key] = [];
        groups[key].push(entry);
        return groups;
      }, {});

      return Object.entries(grouped)
        .sort(grouping.sort)
        .map(([key, groupEntries]) => renderGroup(`${viewMode}:${key}`, grouping.title(key, groupEntries), grouping.subtitle(groupEntries), groupEntries, viewMode))
        .join('');
    }

    function entryCountLabel(count) {
      return `${count} ${count === 1 ? 'entry' : 'entries'}`;
    }

    function renderGroup(groupKey, title, subtitle, entries, mode) {
      const totalHours = entries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = entries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      const collapsed = collapsedGroups.has(groupKey);
      const columns = getColumns(mode);
      const gridClass = canManageTime
        ? 'lg:grid-cols-[minmax(12rem,1.2fr)_minmax(9rem,0.85fr)_5rem_7rem_5.5rem]'
        : 'lg:grid-cols-[minmax(12rem,1fr)_5rem]';

      return `
        <section class="surface-panel overflow-hidden">
          <button type="button" onclick="toggleGroup('${groupKey}')" class="w-full px-3 py-2 bg-gray-50 border-b flex items-center justify-between gap-3 text-left hover:bg-gray-100">
            <div class="flex items-center gap-3">
              <span class="btn-icon h-7 w-7" aria-hidden="true">${collapsed ? iconSvg('plus') : '<span class="text-lg leading-none">-</span>'}</span>
              <div>
                <h2 class="font-semibold text-sm sm:text-base">${escapeHtml(title)}</h2>
                <p class="text-xs text-gray-600">${escapeHtml(subtitle)}</p>
              </div>
            </div>
            <div class="text-right shrink-0">
              <p class="font-semibold text-sm">${totalHours.toFixed(2)} hrs</p>
              ${canManageTime ? `<p class="text-xs text-gray-600">${currency(totalCost)}</p>` : ''}
            </div>
          </button>
          ${collapsed ? '' : `
            <div class="hidden lg:grid ${gridClass} gap-3 px-3 py-1.5 bg-white text-[0.7rem] font-semibold uppercase tracking-wide text-gray-500 border-b border-[var(--pf-border)]">
              ${columns.map((column) => `<span class="${column.align === 'right' ? 'text-right' : ''}">${column.label}</span>`).join('')}
            </div>
            <div class="divide-y divide-[var(--pf-border)]">
              ${entries.map((entry) => renderEntry(entry, mode)).join('')}
            </div>
          `}
        </section>
      `;
    }

    function getColumns(mode) {
      const base = {
        date: { key: 'date', label: 'Date' },
        job: { key: 'job', label: 'Job' },
        employee: { key: 'employee', label: 'Employee' },
        hours: { key: 'hours', label: 'Hours', align: 'right' },
        cost: { key: 'cost', label: 'Cost', align: 'right' },
        actions: { key: 'actions', label: 'Actions', align: 'right' },
      };
      if (!canManageTime) {
        if (mode === 'job') return [base.date, base.hours];
        return [base.job, base.hours];
      }
      if (mode === 'day') return [base.job, base.employee, base.hours, base.cost, base.actions];
      if (mode === 'job') return [base.date, base.employee, base.hours, base.cost, base.actions];
      return [base.date, base.job, base.hours, base.cost, base.actions];
    }

    function reviewReasonText(value = '') {
      const labels = {
        forgot_clock_in: 'Forgot clock-in',
        late_clock_out: 'Late clock-out',
        long_shift: 'Long shift',
        missing_job_assignment: 'Missing job assignment',
      };
      return labels[value] || value.replace(/[_-]/g, ' ');
    }

    function renderEntry(entry, mode) {
      const hasDescription = Boolean(entry.description);
      const flagged = entry.reviewStatus === 'flagged' || entry.reviewStatus === 'rejected';
      const approvedOverride = entry.source === 'punch_clock' && entry.reviewReason && entry.reviewStatus === 'approved';
      const sourceLabel = entry.source === 'punch_clock' ? 'Punch clock' : null;
      const date = new Date(entry.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      const gridClass = canManageTime
        ? 'lg:grid-cols-[minmax(12rem,1.2fr)_minmax(9rem,0.85fr)_5rem_7rem_auto]'
        : 'lg:grid-cols-[minmax(12rem,1fr)_5rem]';
      const detailLine = [
        hasDescription ? entry.description : null,
        sourceLabel,
        flagged ? reviewReasonText(entry.reviewReason || 'Needs review') : null,
        approvedOverride ? `Approved override: ${reviewReasonText(entry.reviewReason)}` : null,
      ].filter(Boolean).join(' • ');
      const displayDetailLine = detailLine.replace(/[^\x00-\x7F]+/g, '-');
      const desktopCells = {
        date: `<p class="time-desktop-cell text-gray-700 truncate">${date}</p>`,
        job: `<div class="time-desktop-cell min-w-0"><p class="text-gray-700 truncate">${escapeHtml(entry.jobName || 'Job')} ${flagged ? '<span class="chip pf-status-danger ml-1">Review</span>' : ''}${approvedOverride ? '<span class="chip ml-1">Override approved</span>' : ''}</p>${displayDetailLine ? `<p class="text-xs text-gray-500 truncate">${escapeHtml(displayDetailLine)}</p>` : ''}</div>`,
        employee: `<p class="time-desktop-cell text-gray-700 truncate">${escapeHtml(entry.teamMemberName || 'Crew member')}</p>`,
        hours: `<p class="time-desktop-cell text-right font-medium">${Number(entry.hours).toFixed(2)}</p>`,
        cost: `<p class="time-desktop-cell text-right font-medium">${currency(entry.totalCost)}</p>`,
        actions: `
          <div class="time-entry-actions">
            <button type="button" onclick="editEntry('${entry.id}')" class="btn-icon btn-icon-tonal" aria-label="Edit time entry" title="Edit time entry">${iconSvg('edit')}</button>
            <button type="button" onclick="removeEntry('${entry.id}')" class="btn-icon btn-icon-outlined btn-icon-danger" aria-label="Remove time entry" title="Remove time entry">${iconSvg('trash')}</button>
          </div>
        `,
      };
      const mobileTitle = mode === 'job' ? entry.teamMemberName || 'Crew member' : entry.jobName || 'Job';
      const mobileParts = canManageTime ? {
        day: [entry.teamMemberName, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), displayDetailLine || null],
        job: [date, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), displayDetailLine || null],
        employee: [date, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), displayDetailLine || null],
      }[mode] : {
        day: [`${Number(entry.hours).toFixed(2)} hrs`, displayDetailLine || null],
        job: [date, `${Number(entry.hours).toFixed(2)} hrs`, displayDetailLine || null],
        employee: [date, `${Number(entry.hours).toFixed(2)} hrs`, displayDetailLine || null],
      }[mode];
      const mobileContext = mobileParts.filter(Boolean).join(' - ');

      return `
        <article class="mobile-card-row px-3 py-2 grid grid-cols-[minmax(0,1fr)_auto] ${gridClass} gap-2 lg:gap-3 lg:items-center text-sm hover:bg-gray-50">
          <div class="time-mobile-summary min-w-0">
            <p class="font-medium truncate">${escapeHtml(mobileTitle)}</p>
            <p class="lg:hidden text-xs text-gray-500 truncate">${escapeHtml(mobileContext)}</p>
          </div>
          ${getColumns(mode).map((column) => desktopCells[column.key]).join('')}
        </article>
      `;
    }

    function openModal(entry = null) {
      const form = document.getElementById('time-form');
      const fields = form.elements;
      form.reset();
      document.getElementById('modal-title').textContent = entry ? 'Edit Time Entry' : 'Log Time';
      fields.id.value = entry?.id || '';
      fields.teamMemberId.value = entry?.teamMemberId || '';
      fields.jobId.value = entry?.jobId || '';
      fields.date.value = entry ? dateKey(entry.date) : formatDate(new Date());
      fields.hours.value = entry?.hours || '';
      fields.description.value = entry?.description || '';
      document.getElementById('modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
    }

    window.editEntry = (id) => {
      const entry = allEntries.find((item) => item.id === id);
      if (entry) openModal(entry);
    };

    window.toggleGroup = (key) => {
      if (collapsedGroups.has(key)) {
        collapsedGroups.delete(key);
      } else {
        collapsedGroups.add(key);
      }
      renderTimesheet();
    };

    window.removeEntry = async (id) => {
      const entry = allEntries.find((item) => item.id === id);
      const label = entry ? `${entry.teamMemberName} on ${new Date(entry.date).toLocaleDateString()}` : 'this time entry';
      if (!confirm(`Remove ${label}? This will reverse its labor cost from the job.`)) return;
      await api(`/v1/team/time/${id}`, { method: 'DELETE' });
      window.showToast('Time entry removed', 'success');
      await loadData();
    };

    document.getElementById('cancel-btn').addEventListener('click', closeModal);
    document.getElementById('close-modal-btn').addEventListener('click', closeModal);
    document.getElementById('bulk-time-btn').addEventListener('click', openBulkModal);
    document.getElementById('cancel-bulk-btn').addEventListener('click', closeBulkModal);
    document.getElementById('close-bulk-modal-btn').addEventListener('click', closeBulkModal);
    document.getElementById('cancel-forgot-clock-in-btn').addEventListener('click', closeForgotClockInModal);
    document.getElementById('close-forgot-clock-in-btn').addEventListener('click', closeForgotClockInModal);
    document.getElementById('forgot-clock-in-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const submit = document.getElementById('submit-forgot-clock-in-btn');
      const startedAt = document.getElementById('forgot-in-time').value;
      const note = document.getElementById('forgot-in-reason').value.trim();
      if (!startedAt || !note) {
        window.showToast?.('Enter the clock-in time and reason', 'error');
        return;
      }
      submit.disabled = true;
      submit.textContent = 'Submitting...';
      try {
        await punchIn(true, { startedAt, note });
      } finally {
        submit.disabled = false;
        submit.textContent = 'Submit for review';
      }
    });
    document.getElementById('bulk-default-hours').addEventListener('input', () => {
      const defaultHours = getBulkDefaultHours();
      members.forEach((member) => bulkHours.set(member.id, defaultHours));
      document.querySelectorAll('[data-bulk-hours]').forEach((input) => {
        input.value = defaultHours;
      });
      updateBulkSummary();
    });
    document.getElementById('bulk-select-visible').addEventListener('click', () => {
      const visible = Array.from(document.querySelectorAll('[data-bulk-member]'));
      const shouldSelect = visible.some((checkbox) => !checkbox.checked);
      visible.forEach((checkbox) => {
        checkbox.checked = shouldSelect;
        bulkSelection.set(checkbox.dataset.bulkMember, shouldSelect);
      });
      updateBulkSelectionAction();
      updateBulkSummary();
    });

    document.getElementById('time-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSavingTime) return;
      const form = event.currentTarget;
      const saveButton = document.getElementById('save-time-btn');
      const data = Object.fromEntries(new FormData(form));
      const id = data.id;
      delete data.id;
      data.hours = Number(data.hours);
      data.date = new Date(`${data.date}T12:00:00`).toISOString();

      try {
        isSavingTime = true;
        saveButton.disabled = true;
        saveButton.textContent = id ? 'Updating...' : 'Saving...';
        await api(id ? `/v1/team/time/${id}` : '/v1/team/time', {
          method: id ? 'PATCH' : 'POST',
          body: JSON.stringify(data),
        });
        closeModal();
        window.showToast(id ? 'Time entry updated' : 'Time entry logged', 'success');
        await loadData();
      } catch (e) {
        alert(e.message || 'Failed to save time entry');
      } finally {
        isSavingTime = false;
        saveButton.disabled = false;
        saveButton.textContent = 'Save time';
      }
    });

    document.getElementById('bulk-time-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSavingBulkTime) return;
      const form = event.currentTarget;
      const submit = document.getElementById('submit-bulk-btn');
      const data = Object.fromEntries(new FormData(form));
      const selected = getBulkSelectedEntries().map(({ member, hours }) => ({
        teamMemberId: member.id,
        hours,
        description: data.description || 'Crew labor',
      }));

      if (!data.jobId) {
        window.showToast?.('Select a job first', 'error');
        return;
      }
      if (!selected.length) {
        window.showToast?.('Select at least one crew member with hours', 'error');
        return;
      }

      try {
        isSavingBulkTime = true;
        submit.disabled = true;
        submit.textContent = 'Logging...';
        await api('/v1/team/timecards', {
          method: 'POST',
          body: JSON.stringify({
            jobId: data.jobId,
            date: data.date,
            notes: data.description || undefined,
            entries: selected,
          }),
        });
        closeBulkModal();
        window.showToast(`Logged time for ${selected.length} crew members`, 'success');
        await loadData();
      } catch (err) {
        window.showToast?.(err.message || 'Failed to log crew time', 'error');
      } finally {
        isSavingBulkTime = false;
        submit.disabled = false;
        submit.textContent = 'Log crew time';
      }
    });

    document.getElementById('prev-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() - 7);
      renderTimesheet();
    });

    document.getElementById('next-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() + 7);
      renderTimesheet();
    });

    document.getElementById('prev-map-day').addEventListener('click', () => {
      currentMapDate.setDate(currentMapDate.getDate() - 1);
      loadMapData();
    });

    document.getElementById('next-map-day').addEventListener('click', () => {
      currentMapDate.setDate(currentMapDate.getDate() + 1);
      loadMapData();
    });

    document.getElementById('refresh-map-btn').addEventListener('click', loadMapData);

    document.querySelectorAll('[data-view-mode]').forEach((button) => {
      button.addEventListener('click', () => {
        viewMode = button.dataset.viewMode;
        localStorage.setItem('paintflow.time.viewMode', viewMode);
        renderTimesheet();
      });
    });

    loadData();
  </script>
</Base>
