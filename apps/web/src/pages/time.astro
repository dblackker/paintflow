---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Time Tracking - PaintFlow">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
      <div>
        <p class="text-sm font-semibold text-brand-700">Field Operations</p>
        <h1 class="text-2xl sm:text-3xl font-bold">Time Tracking</h1>
        <p class="text-gray-600 max-w-2xl">Review daily timecards, drill into individual entries, and correct job hours without touching pay rates.</p>
      </div>
      <button id="add-time" class="btn-primary w-full sm:w-auto">Log time</button>
    </div>

    <section class="surface-panel p-4 mb-6">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
        <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] gap-2 items-center w-full lg:w-auto lg:min-w-[22rem]">
          <button id="prev-week" class="btn-icon btn-icon-outlined" aria-label="Previous week"><Icon name="chevron-left" /></button>
          <span id="week-range" class="text-center font-semibold text-sm sm:text-base"></span>
          <button id="next-week" class="btn-icon btn-icon-outlined" aria-label="Next week"><Icon name="chevron-right" /></button>
        </div>
        <div class="pf-segmented-group justify-center lg:justify-end" aria-label="Time grouping">
          <button type="button" data-view-mode="day">Day</button>
          <button type="button" data-view-mode="job">Job</button>
          <button type="button" data-view-mode="employee">Employee</button>
        </div>
      </div>
    </section>

    <div id="week-summary" class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6"></div>

    <div id="loading" class="text-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
      <p class="mt-4 text-gray-600">Loading timesheet...</p>
    </div>

    <div id="timesheet" class="space-y-4 hidden"></div>

    <div id="empty" class="hidden surface-panel p-12 text-center">
      <p class="text-gray-500">No time entries this week</p>
      <button onclick="document.getElementById('add-time').click()" class="btn-primary btn-sm mt-4">Log your first entry</button>
    </div>
  </main>

  <div id="modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl max-w-lg w-full p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 id="modal-title" class="text-lg font-semibold">Log Time</h2>
          <p class="text-sm text-gray-600">Labor cost is calculated from the team member's burdened rate.</p>
        </div>
        <button type="button" id="close-modal-btn" class="btn-icon" aria-label="Close"><Icon name="close" /></button>
      </div>
      <form id="time-form" class="space-y-4">
        <input type="hidden" name="id">
        <label class="block">
          <span class="form-label">Crew member</span>
          <select name="teamMemberId" id="member-select" class="input" required>
            <option value="">Select crew member...</option>
          </select>
        </label>
        <label class="block">
          <span class="form-label">Job</span>
          <select name="jobId" id="job-select" class="input" required>
            <option value="">Select job...</option>
          </select>
        </label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="block">
            <span class="form-label">Work date</span>
            <input type="date" name="date" autocomplete="off" class="input" required>
          </label>
          <label class="block">
            <span class="form-label">Hours</span>
            <input type="number" name="hours" min="0" max="24" step="0.25" inputmode="decimal" autocomplete="off" placeholder="8" class="input" required>
          </label>
        </div>
        <label class="block">
          <span class="form-label">Work performed</span>
          <input type="text" name="description" autocomplete="off" enterkeyhint="done" placeholder="Prep, spray, trim, punch list" class="input">
        </label>
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <button type="button" id="cancel-btn" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" id="save-time-btn" class="btn-primary flex-1">Save time</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let currentWeekStart = getWeekStart(new Date());
    let allEntries = [];
    let members = [];
    let jobs = [];
    let isSavingTime = false;
    const supportedViewModes = new Set(['day', 'job', 'employee']);
    let viewMode = supportedViewModes.has(localStorage.getItem('paintflow.time.viewMode'))
      ? localStorage.getItem('paintflow.time.viewMode')
      : 'day';
    const collapsedGroups = new Set();

    const currency = (value) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));

    function escapeHtml(value = '') {
      return String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }

    function iconSvg(name) {
      const icons = {
        edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
        plus: '<path d="M12 5v14M5 12h14" />',
        trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
      };
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${icons[name] || ''}</svg>`;
    }

    function getWeekStart(date) {
      const d = new Date(date);
      const day = d.getDay();
      const diff = d.getDate() - day + (day === 0 ? -6 : 1);
      d.setHours(0, 0, 0, 0);
      return new Date(d.setDate(diff));
    }

    function formatDate(date) {
      return date.toISOString().split('T')[0];
    }

    function dateKey(value) {
      return formatDate(new Date(value));
    }

    async function api(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, {
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
        ...options,
      });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    async function loadData() {
      document.getElementById('loading').classList.remove('hidden');
      document.getElementById('timesheet').classList.add('hidden');
      document.getElementById('empty').classList.add('hidden');

      try {
        const [membersPayload, jobsPayload, timePayload] = await Promise.all([
          api('/v1/team/members'),
          api('/v1/jobs'),
          api('/v1/team/time'),
        ]);

        members = membersPayload.data || [];
        jobs = jobsPayload.data || [];
        allEntries = timePayload.data || [];
        populateSelects();
        renderTimesheet();
      } catch (e) {
        document.getElementById('loading').innerHTML = `<p class="text-red-600">${escapeHtml(e.message || 'Failed to load')}</p>`;
      }
    }

    function populateSelects() {
      document.getElementById('member-select').innerHTML = '<option value="">Select crew member...</option>' +
        members.map((member) => `<option value="${member.id}">${escapeHtml(member.name)}</option>`).join('');
      document.getElementById('job-select').innerHTML = '<option value="">Select job...</option>' +
        jobs.map((job) => `<option value="${job.id}">${escapeHtml(job.name)}</option>`).join('');
    }

    function getWeekEntries() {
      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 7);
      return allEntries.filter((entry) => {
        const entryDate = new Date(entry.date);
        return entryDate >= currentWeekStart && entryDate < weekEnd;
      });
    }

    function renderTimesheet() {
      document.getElementById('loading').classList.add('hidden');

      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 6);
      document.getElementById('week-range').textContent =
        `${currentWeekStart.toLocaleDateString()} - ${weekEnd.toLocaleDateString()}`;

      const weekEntries = getWeekEntries();
      renderSummary(weekEntries);
      renderViewModeControls();

      if (!weekEntries.length) {
        document.getElementById('empty').classList.remove('hidden');
        document.getElementById('timesheet').classList.add('hidden');
        return;
      }

      document.getElementById('timesheet').classList.remove('hidden');
      document.getElementById('timesheet').innerHTML = renderGroupedTimesheet(weekEntries);
    }

    function renderViewModeControls() {
      document.querySelectorAll('[data-view-mode]').forEach((button) => {
        const active = button.dataset.viewMode === viewMode;
        button.classList.toggle('view-mode-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function renderSummary(entries) {
      const totalHours = entries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = entries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      const crewCount = new Set(entries.map((entry) => entry.teamMemberId)).size;
      document.getElementById('week-summary').innerHTML = [
        ['Hours', totalHours.toFixed(2), 'Logged this week'],
        ['Labor cost', currency(totalCost), 'Burdened job cost'],
        ['Crew', crewCount, 'People with entries'],
      ].map(([label, value, help]) => `
        <div class="surface-panel p-4">
          <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">${label}</p>
          <p class="text-2xl font-bold mt-1">${value}</p>
          <p class="text-xs text-gray-500 mt-1">${help}</p>
        </div>
      `).join('');
    }

    function renderGroupedTimesheet(entries) {
      const grouping = {
        day: {
          key: (entry) => dateKey(entry.date),
          title: (key) => new Date(`${key}T12:00:00`).toLocaleDateString(undefined, { weekday: 'long', month: 'short', day: 'numeric' }),
          subtitle: (groupEntries) => entryCountLabel(groupEntries.length),
          sort: ([a], [b]) => b.localeCompare(a),
        },
        job: {
          key: (entry) => entry.jobId || 'unassigned-job',
          title: (_key, groupEntries) => groupEntries[0]?.jobName || 'Job',
          subtitle: (groupEntries) => `${new Set(groupEntries.map((entry) => entry.teamMemberId)).size} crew - ${entryCountLabel(groupEntries.length)}`,
          sort: ([, a], [, b]) => (b.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)) - (a.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)),
        },
        employee: {
          key: (entry) => entry.teamMemberId || 'unassigned-employee',
          title: (_key, groupEntries) => groupEntries[0]?.teamMemberName || 'Crew member',
          subtitle: (groupEntries) => `${new Set(groupEntries.map((entry) => entry.jobId)).size} jobs - ${entryCountLabel(groupEntries.length)}`,
          sort: ([, a], [, b]) => (b.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)) - (a.reduce((sum, entry) => sum + Number(entry.hours || 0), 0)),
        },
      }[viewMode];

      const grouped = entries.reduce((groups, entry) => {
        const key = grouping.key(entry);
        if (!groups[key]) groups[key] = [];
        groups[key].push(entry);
        return groups;
      }, {});

      return Object.entries(grouped)
        .sort(grouping.sort)
        .map(([key, groupEntries]) => renderGroup(`${viewMode}:${key}`, grouping.title(key, groupEntries), grouping.subtitle(groupEntries), groupEntries, viewMode))
        .join('');
    }

    function entryCountLabel(count) {
      return `${count} ${count === 1 ? 'entry' : 'entries'}`;
    }

    function renderGroup(groupKey, title, subtitle, entries, mode) {
      const totalHours = entries.reduce((sum, entry) => sum + Number(entry.hours || 0), 0);
      const totalCost = entries.reduce((sum, entry) => sum + Number(entry.totalCost || 0), 0);
      const collapsed = collapsedGroups.has(groupKey);
      const columns = getColumns(mode);
      const gridClass = mode === 'flat'
        ? 'lg:grid-cols-[minmax(8rem,0.7fr)_minmax(12rem,1.2fr)_minmax(9rem,0.85fr)_5rem_7rem_auto]'
        : 'lg:grid-cols-[minmax(12rem,1.2fr)_minmax(9rem,0.85fr)_5rem_7rem_auto]';

      return `
        <section class="surface-panel overflow-hidden">
          <button type="button" onclick="toggleGroup('${groupKey}')" class="w-full px-3 py-2.5 bg-gray-50 border-b flex items-center justify-between gap-3 text-left hover:bg-gray-100">
            <div class="flex items-center gap-3">
              <span class="btn-icon h-7 w-7" aria-hidden="true">${collapsed ? iconSvg('plus') : '<span class="text-lg leading-none">-</span>'}</span>
              <div>
                <h2 class="font-semibold text-sm sm:text-base">${escapeHtml(title)}</h2>
                <p class="text-xs text-gray-600">${escapeHtml(subtitle)}</p>
              </div>
            </div>
            <div class="text-right shrink-0">
              <p class="font-semibold text-sm">${totalHours.toFixed(2)} hrs</p>
              <p class="text-xs text-gray-600">${currency(totalCost)}</p>
            </div>
          </button>
          ${collapsed ? '' : `
            <div class="hidden lg:grid ${gridClass} gap-3 px-3 py-1.5 bg-white text-[0.7rem] font-semibold uppercase tracking-wide text-gray-500 border-b border-[var(--pf-border)]">
              ${columns.map((column) => `<span class="${column.align === 'right' ? 'text-right' : ''}">${column.label}</span>`).join('')}
            </div>
            <div class="divide-y divide-[var(--pf-border)]">
              ${entries.map((entry) => renderEntry(entry, mode)).join('')}
            </div>
          `}
        </section>
      `;
    }

    function getColumns(mode) {
      const base = {
        date: { key: 'date', label: 'Date' },
        job: { key: 'job', label: 'Job' },
        employee: { key: 'employee', label: 'Employee' },
        hours: { key: 'hours', label: 'Hours', align: 'right' },
        cost: { key: 'cost', label: 'Cost', align: 'right' },
        actions: { key: 'actions', label: 'Actions', align: 'right' },
      };
      if (mode === 'day') return [base.job, base.employee, base.hours, base.cost, base.actions];
      if (mode === 'job') return [base.date, base.employee, base.hours, base.cost, base.actions];
      return [base.date, base.job, base.hours, base.cost, base.actions];
    }

    function renderEntry(entry, mode) {
      const hasDescription = Boolean(entry.description);
      const date = new Date(entry.date).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      const gridClass = 'lg:grid-cols-[minmax(12rem,1.2fr)_minmax(9rem,0.85fr)_5rem_7rem_auto]';
      const desktopCells = {
        date: `<p class="hidden lg:block text-gray-700 truncate">${date}</p>`,
        job: `<div class="hidden lg:block min-w-0"><p class="text-gray-700 truncate">${escapeHtml(entry.jobName || 'Job')}</p>${hasDescription ? `<p class="text-xs text-gray-500 truncate">${escapeHtml(entry.description)}</p>` : ''}</div>`,
        employee: `<p class="hidden lg:block text-gray-700 truncate">${escapeHtml(entry.teamMemberName || 'Crew member')}</p>`,
        hours: `<p class="hidden lg:block text-right font-medium">${Number(entry.hours).toFixed(2)}</p>`,
        cost: `<p class="hidden lg:block text-right font-medium">${currency(entry.totalCost)}</p>`,
        actions: `
          <div class="flex justify-end gap-1.5">
            <button type="button" onclick="editEntry('${entry.id}')" class="btn-icon btn-icon-tonal" aria-label="Edit time entry">${iconSvg('edit')}</button>
            <button type="button" onclick="removeEntry('${entry.id}')" class="btn-icon btn-icon-outlined btn-icon-danger" aria-label="Remove time entry">${iconSvg('trash')}</button>
          </div>
        `,
      };
      const mobileTitle = mode === 'job' ? entry.teamMemberName || 'Crew member' : entry.jobName || 'Job';
      const mobileParts = {
        day: [entry.teamMemberName, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), hasDescription ? entry.description : null],
        job: [date, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), hasDescription ? entry.description : null],
        employee: [date, `${Number(entry.hours).toFixed(2)} hrs`, currency(entry.totalCost), hasDescription ? entry.description : null],
      }[mode];
      const mobileContext = mobileParts.filter(Boolean).join(' - ');

      return `
        <article class="px-3 py-2 grid grid-cols-[minmax(0,1fr)_auto] ${gridClass} gap-2 lg:gap-3 lg:items-center text-sm hover:bg-gray-50">
          <div class="min-w-0 lg:hidden">
            <p class="font-medium truncate">${escapeHtml(mobileTitle)}</p>
            <p class="lg:hidden text-xs text-gray-500 truncate">${escapeHtml(mobileContext)}</p>
          </div>
          ${getColumns(mode).map((column) => desktopCells[column.key]).join('')}
        </article>
      `;
    }

    function openModal(entry = null) {
      const form = document.getElementById('time-form');
      const fields = form.elements;
      form.reset();
      document.getElementById('modal-title').textContent = entry ? 'Edit Time Entry' : 'Log Time';
      fields.id.value = entry?.id || '';
      fields.teamMemberId.value = entry?.teamMemberId || '';
      fields.jobId.value = entry?.jobId || '';
      fields.date.value = entry ? dateKey(entry.date) : formatDate(new Date());
      fields.hours.value = entry?.hours || '';
      fields.description.value = entry?.description || '';
      document.getElementById('modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
    }

    window.editEntry = (id) => {
      const entry = allEntries.find((item) => item.id === id);
      if (entry) openModal(entry);
    };

    window.toggleGroup = (key) => {
      if (collapsedGroups.has(key)) {
        collapsedGroups.delete(key);
      } else {
        collapsedGroups.add(key);
      }
      renderTimesheet();
    };

    window.removeEntry = async (id) => {
      const entry = allEntries.find((item) => item.id === id);
      const label = entry ? `${entry.teamMemberName} on ${new Date(entry.date).toLocaleDateString()}` : 'this time entry';
      if (!confirm(`Remove ${label}? This will reverse its labor cost from the job.`)) return;
      await api(`/v1/team/time/${id}`, { method: 'DELETE' });
      window.showToast('Time entry removed', 'success');
      await loadData();
    };

    document.getElementById('add-time').addEventListener('click', () => openModal());
    document.getElementById('cancel-btn').addEventListener('click', closeModal);
    document.getElementById('close-modal-btn').addEventListener('click', closeModal);

    document.getElementById('time-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSavingTime) return;
      const form = event.currentTarget;
      const saveButton = document.getElementById('save-time-btn');
      const data = Object.fromEntries(new FormData(form));
      const id = data.id;
      delete data.id;
      data.hours = Number(data.hours);
      data.date = new Date(`${data.date}T12:00:00`).toISOString();

      try {
        isSavingTime = true;
        saveButton.disabled = true;
        saveButton.textContent = id ? 'Updating...' : 'Saving...';
        await api(id ? `/v1/team/time/${id}` : '/v1/team/time', {
          method: id ? 'PATCH' : 'POST',
          body: JSON.stringify(data),
        });
        closeModal();
        window.showToast(id ? 'Time entry updated' : 'Time entry logged', 'success');
        await loadData();
      } catch (e) {
        alert(e.message || 'Failed to save time entry');
      } finally {
        isSavingTime = false;
        saveButton.disabled = false;
        saveButton.textContent = 'Save time';
      }
    });

    document.getElementById('prev-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() - 7);
      renderTimesheet();
    });

    document.getElementById('next-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() + 7);
      renderTimesheet();
    });

    document.querySelectorAll('[data-view-mode]').forEach((button) => {
      button.addEventListener('click', () => {
        viewMode = button.dataset.viewMode;
        localStorage.setItem('paintflow.time.viewMode', viewMode);
        renderTimesheet();
      });
    });

    loadData();
  </script>
</Base>
