---
import Base from '../layouts/Base.astro';
---

<Base title="Time Tracking - PaintFlow">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold">Time Tracking</h2>
      <button id="add-time" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">+ Log Time</button>
    </div>

    <div class="bg-white rounded-lg shadow-sm border p-4 mb-6 flex gap-4 items-center">
      <button id="prev-week" class="px-3 py-1 border rounded hover:bg-gray-50">Previous</button>
      <span id="week-range" class="flex-1 text-center font-medium"></span>
      <button id="next-week" class="px-3 py-1 border rounded hover:bg-gray-50">Next</button>
    </div>

    <div id="loading" class="text-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
      <p class="mt-4 text-gray-600">Loading timesheet...</p>
    </div>

    <div id="timesheet" class="bg-white rounded-lg shadow-sm border divide-y hidden"></div>

    <div id="empty" class="hidden bg-white rounded-lg shadow-sm border p-12 text-center">
      <p class="text-gray-500">No time entries this week</p>
      <button onclick="document.getElementById('add-time').click()" class="mt-4 text-blue-600 text-sm">Log your first entry</button>
    </div>
  </div>

  <div id="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-md w-full p-6">
      <h2 class="text-lg font-semibold mb-4">Log Time</h2>
      <form id="time-form" class="space-y-4">
        <select name="teamMemberId" id="member-select" class="w-full px-3 py-2 border rounded-lg" required>
          <option value="">Select crew member...</option>
        </select>
        <select name="jobId" id="job-select" class="w-full px-3 py-2 border rounded-lg" required>
          <option value="">Select job...</option>
        </select>
        <input type="date" name="date" class="w-full px-3 py-2 border rounded-lg" required>
        <input type="number" name="hours" step="0.25" placeholder="Hours (e.g. 8)" class="w-full px-3 py-2 border rounded-lg" required>
        <input type="text" name="description" placeholder="What did you work on?" class="w-full px-3 py-2 border rounded-lg">
        <div class="flex gap-3">
          <button type="button" onclick="closeModal()" class="flex-1 py-2 border rounded-lg hover:bg-gray-50">Cancel</button>
          <button type="submit" class="flex-1 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    let currentWeekStart = getWeekStart(new Date());

    function getWeekStart(date) {
      const d = new Date(date);
      const day = d.getDay();
      const diff = d.getDate() - day + (day === 0 ? -6 : 1);
      return new Date(d.setDate(diff));
    }

    function formatDate(date) {
      return date.toISOString().split('T')[0];
    }

    async function apiJson(url) {
      const res = await fetch(url, { credentials: 'include' });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      if (!res.ok) throw new Error('Request failed');
      return res.json();
    }

    async function loadData() {
      document.getElementById('loading').classList.remove('hidden');
      document.getElementById('timesheet').classList.add('hidden');
      document.getElementById('empty').classList.add('hidden');

      try {
        const [members, jobs, time] = await Promise.all([
          apiJson(`${API_URL}/v1/team/members`),
          apiJson(`${API_URL}/v1/jobs`),
          apiJson(`${API_URL}/v1/team/time`),
        ]);

        const memberSelect = document.getElementById('member-select');
        memberSelect.innerHTML = '<option value="">Select crew member...</option>' + 
          members.data.map(m => `<option value="${m.id}">${m.name}</option>`).join('');

        const jobSelect = document.getElementById('job-select');
        jobSelect.innerHTML = '<option value="">Select job...</option>' + 
          jobs.data.map(j => `<option value="${j.id}">${j.name}</option>`).join('');

        renderTimesheet(time.data);
        document.querySelector('input[name="date"]').value = formatDate(new Date());
      } catch (e) {
        document.getElementById('loading').innerHTML = '<p class="text-red-600">Failed to load</p>';
      }
    }

    function renderTimesheet(entries) {
      document.getElementById('loading').classList.add('hidden');
      
      const weekEnd = new Date(currentWeekStart);
      weekEnd.setDate(weekEnd.getDate() + 6);
      
      document.getElementById('week-range').textContent = 
        `${currentWeekStart.toLocaleDateString()} - ${weekEnd.toLocaleDateString()}`;

      const weekEntries = entries.filter(e => {
        const date = new Date(e.date);
        return date >= currentWeekStart && date <= weekEnd;
      });

      if (!weekEntries.length) {
        document.getElementById('empty').classList.remove('hidden');
        return;
      }

      document.getElementById('timesheet').classList.remove('hidden');

      const grouped = {};
      weekEntries.forEach(e => {
        const key = e.jobId + '|' + e.teamMemberId;
        if (!grouped[key]) grouped[key] = { entries: [], total: 0 };
        grouped[key].entries.push(e);
        grouped[key].total += parseFloat(e.hours);
      });

      document.getElementById('timesheet').innerHTML = Object.values(grouped).map(g => {
        const first = g.entries[0];
        return `
          <div class="p-4 hover:bg-gray-50">
            <div class="flex justify-between">
              <div class="min-w-0 flex-1">
                <p class="font-medium text-sm truncate">${first.jobName}</p>
                <p class="text-xs text-gray-600">${first.teamMemberName} - ${g.entries.length} entries - ${new Date(first.date).toLocaleDateString()}</p>
                ${first.description ? `<p class="text-xs text-gray-500 mt-1 truncate">${first.description}</p>` : ''}
              </div>
              <div class="text-right ml-4">
                <p class="font-semibold text-sm">${g.total.toFixed(2)} hrs</p>
                <p class="text-xs text-gray-600">$${(g.total * parseFloat(first.hourlyRate)).toFixed(2)}</p>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    document.getElementById('add-time').addEventListener('click', () => {
      document.getElementById('modal').classList.remove('hidden');
    });

    window.closeModal = () => document.getElementById('modal').classList.add('hidden');

    document.getElementById('time-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = new FormData(e.target);
      const data = Object.fromEntries(form);
      data.hours = parseFloat(data.hours);
      data.date = new Date(data.date).toISOString();

      try {
        const res = await fetch(`${API_URL}/v1/team/time`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('Failed to save time entry');
        closeModal();
        e.target.reset();
        loadData();
      } catch (e) {
        alert('Failed to save time entry');
      }
    });

    document.getElementById('prev-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() - 7);
      loadData();
    });

    document.getElementById('next-week').addEventListener('click', () => {
      currentWeekStart.setDate(currentWeekStart.getDate() + 7);
      loadData();
    });

    loadData();
  </script>
</Base>
