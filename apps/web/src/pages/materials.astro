---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Paint Products - PaintFlow">
  <style>
    @media (max-width: 640px) {
      .materials-actions {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        width: 100%;
      }
      .materials-actions > * {
        justify-content: center;
        min-width: 0;
      }
      .material-price {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.5rem;
      }
      .material-price > div:first-child {
        text-align: left;
      }
    }
  </style>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="pf-kicker">Estimator setup</p>
        <h1 class="pf-page-title">Paint Products</h1>
        <p class="pf-page-copy mt-1">Track product cost, coverage, supplier, and markup for production estimates.</p>
      </div>
      <div class="materials-actions flex flex-wrap gap-2">
        <a href="/production-rates" class="btn-secondary btn-sm">Production rates</a>
        <a href="/settings" class="btn-secondary btn-sm">Settings</a>
        <button id="add-material" class="btn-primary btn-sm">
          <Icon name="plus" />
          Add Product
        </button>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border divide-y" id="materials-list">
      <div class="p-4 text-center text-gray-500">Loading...</div>
    </div>
  </section>

  <div id="modal" class="mobile-sheet hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-2xl w-full p-5 sm:p-6 max-h-[90vh] overflow-y-auto">
      <div class="mb-4 flex items-start justify-between gap-4">
        <div>
          <h2 id="material-modal-title" class="pf-section-title">Add Paint Product</h2>
          <p class="pf-copy">These costs feed estimate material pricing and production ordering.</p>
        </div>
        <button type="button" id="close-material" class="btn-icon" aria-label="Close paint product form"><Icon name="close" /></button>
      </div>
      <form id="material-form" class="space-y-4">
        <input type="hidden" name="id">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label>
            <span class="form-label">Product name</span>
            <input name="name" autocomplete="off" enterkeyhint="next" placeholder="Regal Select Interior Matte" class="input" required>
          </label>
          <label>
            <span class="form-label">Brand</span>
            <input name="brand" autocomplete="organization" enterkeyhint="next" placeholder="Benjamin Moore" class="input">
          </label>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <label>
            <span class="form-label">Category</span>
            <select name="category" class="input" required>
              <option value="">Choose category</option>
              <option value="paint">Paint</option>
              <option value="primer">Primer</option>
              <option value="supplies">Supplies</option>
            </select>
          </label>
          <label>
            <span class="form-label">Unit</span>
            <input name="unit" autocomplete="off" enterkeyhint="next" placeholder="gallon" class="input" required>
          </label>
          <label>
            <span class="form-label">Coverage per unit</span>
            <input name="coverageSqFt" type="number" min="0" step="1" inputmode="numeric" autocomplete="off" placeholder="350" class="input">
          </label>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label>
            <span class="form-label">Cost per unit</span>
            <input name="costPerUnit" type="number" min="0.01" step="0.01" inputmode="decimal" autocomplete="off" placeholder="48.00" class="input" required>
          </label>
          <label>
            <span class="form-label">Markup percent</span>
            <input name="markupPercent" type="number" min="0" max="200" step="0.1" inputmode="decimal" autocomplete="off" placeholder="30" class="input" required>
          </label>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label>
            <span class="form-label">Supplier</span>
            <input name="supplier" autocomplete="organization" enterkeyhint="next" placeholder="NorCal Paint Supply" class="input">
          </label>
          <label>
            <span class="form-label">SKU</span>
            <input name="sku" autocomplete="off" enterkeyhint="done" placeholder="Optional supplier SKU" class="input">
          </label>
        </div>
        <div class="mobile-sticky-actions flex flex-col sm:flex-row gap-3 pt-2 sm:static sm:m-0 sm:border-0 sm:bg-transparent sm:p-0">
          <button type="button" id="cancel-material" class="btn-secondary flex-1">Cancel</button>
          <button type="submit" id="save-material" class="btn-primary flex-1">Save product</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const modal = document.getElementById('modal');
    const money = (value) => window.PaintFlowFormat?.money(value) ?? `$${Number(value || 0).toFixed(2)}`;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    let materials = [];

    const iconSvg = (name) => {
      const icons = {
        edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
        trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
      };
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${icons[name] || ''}</svg>`;
    };

    function escapeHtml(value = '') {
      return String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }

    function closeModal() {
      modal?.classList.add('hidden');
    }

    function openMaterialModal(material = null) {
      const form = document.getElementById('material-form');
      form.reset();
      form.elements.id.value = material?.id || '';
      form.elements.name.value = material?.name || '';
      form.elements.brand.value = material?.brand || '';
      form.elements.category.value = material?.category || 'paint';
      form.elements.unit.value = material?.unit || 'gallon';
      form.elements.coverageSqFt.value = material?.coverageSqFt || '';
      form.elements.costPerUnit.value = material?.costPerUnit || '';
      form.elements.markupPercent.value = material?.markupPercent || '30';
      form.elements.supplier.value = material?.supplier || '';
      form.elements.sku.value = material?.sku || '';
      document.getElementById('material-modal-title').textContent = material ? 'Edit Paint Product' : 'Add Paint Product';
      document.getElementById('save-material').textContent = material ? 'Save changes' : 'Save product';
      modal?.classList.remove('hidden');
    }

    async function loadMaterials() {
      const res = await fetch(`${API_URL}/v1/materials`, { credentials: 'include' });
      if (res.status === 401) {
        window.location.href = '/login';
        return;
      }
      const { data } = await res.json();
      materials = data || [];
      renderMaterials(materials);
    }

    function renderMaterials(items) {
      const list = document.getElementById('materials-list');
      list.innerHTML = items.length
        ? items.map((material) => {
            const cost = Number(material.costPerUnit || 0);
            const markup = Number(material.markupPercent || 0);
            const price = cost * (1 + markup / 100);
            const title = [material.brand, material.name].filter(Boolean).join(' ');
            return `
              <div class="mobile-card-row p-4 grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-center hover:bg-gray-50">
                <div class="min-w-0">
                  <p class="font-medium truncate">${escapeHtml(title || material.name)}</p>
                  <p class="pf-copy">${escapeHtml(label(material.category))} &bull; ${escapeHtml(material.unit)}${material.coverageSqFt ? ` &bull; ${Number(material.coverageSqFt).toLocaleString('en-US')} sq ft/${escapeHtml(material.unit)}` : ''}</p>
                  <p class="text-xs text-gray-500 mt-1">${escapeHtml([material.supplier, material.sku].filter(Boolean).join(' - ') || 'No supplier details')}</p>
                </div>
                <div class="material-price flex items-center gap-3">
                  <div class="text-right">
                    <p class="pf-section-title">${money(price)}/${escapeHtml(material.unit)}</p>
                    <p class="pf-meta">Cost: ${money(material.costPerUnit)} &bull; ${Number(material.markupPercent || 0).toFixed(1)}% markup</p>
                  </div>
                  <div class="flex gap-1.5">
                    <button type="button" onclick="editMaterial('${material.id}')" class="btn-icon btn-icon-tonal" aria-label="Edit ${escapeHtml(title || material.name)}">${iconSvg('edit')}</button>
                    <button type="button" onclick="deleteMaterial('${material.id}')" class="btn-icon btn-icon-outlined btn-icon-danger" aria-label="Delete ${escapeHtml(title || material.name)}">${iconSvg('trash')}</button>
                  </div>
                </div>
              </div>
            `;
          }).join('')
        : '<div class="p-4 text-center text-gray-500">No paint products yet</div>';
    }

    window.editMaterial = (id) => {
      const material = materials.find((item) => item.id === id);
      if (material) openMaterialModal(material);
    };

    window.deleteMaterial = async (id) => {
      const material = materials.find((item) => item.id === id);
      const name = [material?.brand, material?.name].filter(Boolean).join(' ') || 'this product';
      if (!confirm(`Delete ${name}? Existing estimates keep saved product data, but new estimates will no longer use it.`)) return;
      const res = await fetch(`${API_URL}/v1/materials/${id}`, { method: 'DELETE', credentials: 'include' });
      if (!res.ok) {
        window.showToast?.('Could not delete paint product', 'error');
        return;
      }
      window.showToast?.('Paint product deleted', 'success');
      await loadMaterials();
    };

    document.getElementById('add-material')?.addEventListener('click', () => openMaterialModal());
    document.getElementById('cancel-material')?.addEventListener('click', closeModal);
    document.getElementById('close-material')?.addEventListener('click', closeModal);

    document.getElementById('material-form')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formEl = event.currentTarget;
      const payload = Object.fromEntries(new FormData(formEl));
      const id = payload.id;
      delete payload.id;
      payload.costPerUnit = Number(payload.costPerUnit);
      payload.markupPercent = Number(payload.markupPercent || 30);
      if (payload.coverageSqFt) {
        payload.coverageSqFt = Number(payload.coverageSqFt);
      } else {
        delete payload.coverageSqFt;
      }
      const saveButton = document.getElementById('save-material');
      saveButton.disabled = true;
      saveButton.textContent = id ? 'Saving...' : 'Adding...';
      const res = await fetch(`${API_URL}/v1/materials${id ? `/${id}` : ''}`, {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json', 'Idempotency-Key': crypto.randomUUID() },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
      saveButton.disabled = false;
      saveButton.textContent = id ? 'Save changes' : 'Save product';
      if (!res.ok) {
        window.showToast?.('Could not save paint product', 'error');
        return;
      }
      closeModal();
      window.showToast?.(id ? 'Paint product updated' : 'Paint product added', 'success');
      await loadMaterials();
    });

    loadMaterials().catch((error) => {
      document.getElementById('materials-list').innerHTML = `<div class="p-4 text-center text-red-600">${escapeHtml(error.message || 'Failed to load paint products')}</div>`;
    });
  </script>
</Base>
