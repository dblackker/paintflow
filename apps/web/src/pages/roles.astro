---
import Base from '../layouts/Base.astro';
---

<Base title="Roles & Permissions - PaintFlow">
<main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Roles & Permissions</h1>
        <p class="text-gray-600">Assign user permissions for the organization.</p>
      </div>
      <button id="seed-btn" class="btn-primary btn-sm">Seed Defaults</button>
    </div>
    <div class="bg-white rounded-lg shadow-sm border">
      <div class="p-4 border-b">
        <h2 class="font-semibold">User Roles</h2>
      </div>
      <div id="users-list" class="divide-y"></div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    async function loadData() {
      const [roles, users] = await Promise.all([
        fetch(`${API_URL}/v1/roles`, { credentials: 'include' }).then(r => r.json()),
        fetch(`${API_URL}/v1/roles/users`, { credentials: 'include' }).then(r => r.json()),
      ]);

      const rolesData = roles.data;
      const usersData = users.data;

      document.getElementById('users-list').innerHTML = usersData.map(u => `
        <div class="p-4 flex justify-between items-center">
          <div>
            <p class="font-medium">${u.name || u.email}</p>
            <p class="text-sm text-gray-600">${u.email}</p>
          </div>
          <select data-user="${u.userId}" class="px-3 py-1 border rounded">
            <option value="">No role</option>
            ${rolesData.map(r => `
              <option value="${r.id}" ${u.roleId === r.id ? 'selected' : ''}>${r.name}</option>
            `).join('')}
          </select>
        </div>
      `).join('');

      document.querySelectorAll('select[data-user]').forEach(sel => {
        sel.addEventListener('change', async (e) => {
          const userId = e.target.dataset.user;
          const roleId = e.target.value;
          if (roleId) {
            await fetch(`${API_URL}/v1/roles/assign`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ userId, roleId }),
            });
          }
        });
      });
    }

    document.getElementById('seed-btn').addEventListener('click', async () => {
      await fetch(`${API_URL}/v1/roles/seed`, { method: 'POST', credentials: 'include' });
      loadData();
    });

    loadData();
  </script>
</Base>
