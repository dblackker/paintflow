---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard - PaintFlow</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2563eb" />
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <h1 class="text-xl font-semibold">PaintFlow</h1>
          <button id="logout" class="text-sm text-gray-600 hover:text-gray-900">Sign out</button>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Welcome back!</h2>
        <p class="text-gray-600">Here's what's happening with your painting business</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-sm border">
          <p class="text-sm text-gray-600">Active Leads</p>
          <p class="text-3xl font-bold mt-2" id="active-leads">-</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm border">
          <p class="text-sm text-gray-600">Estimates Sent</p>
          <p class="text-3xl font-bold mt-2" id="estimates-sent">-</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm border">
          <p class="text-sm text-gray-600">Jobs This Month</p>
          <p class="text-3xl font-bold mt-2" id="jobs-month">-</p>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border p-6">
        <h3 class="text-lg font-semibold mb-4">Recent Activity</h3>
        <div id="recent-activity" class="text-gray-600">Loading...</div>
      </div>
    </main>

    <div id="install-prompt" class="hidden fixed bottom-4 right-4 bg-white p-4 rounded-lg shadow-lg border max-w-sm">
      <p class="font-medium mb-2">Install PaintFlow</p>
      <p class="text-sm text-gray-600 mb-3">Add to home screen for quick access</p>
      <div class="flex gap-2">
        <button id="install-btn" class="flex-1 px-3 py-2 bg-blue-600 text-white rounded text-sm">Install</button>
        <button id="dismiss-install" class="px-3 py-2 border rounded text-sm">Later</button>
      </div>
    </div>
    
    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

      // Check onboarding status and show progress widget
      (async () => {
        try {
          const res = await fetch(`${API_URL}/v1/settings/org`, { credentials: 'include' });
          if (res.ok) {
            const { data } = await res.json();
            const completed = data.onboardingCompletedAt;
            const hasCompany = !!data.companyName;
            
            if (!hasCompany && !completed) {
              window.location.href = '/onboarding';
              return;
            }
            
            if (!completed) {
              const progress = document.createElement('div');
              progress.className = 'bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6';
              progress.innerHTML = `
                <div class="flex items-start gap-3">
                  <div class="flex-1">
                    <p class="font-medium text-yellow-900">Complete your setup</p>
                    <p class="text-sm text-yellow-800 mt-1">Finish configuring PaintFlow so estimates, deposits, and job costing work from day one.</p>
                    <div class="flex flex-wrap gap-3 mt-3">
                      <a href="/onboarding" class="inline-block text-sm font-medium text-yellow-900 hover:underline">Continue setup</a>
                      <a href="/billing" class="inline-block text-sm font-medium text-yellow-900 hover:underline">Compare plans</a>
                    </div>
                  </div>
                </div>
              `;
              document.querySelector('main').prepend(progress);
            }
          }
        } catch (err) {
          console.error('Failed to check onboarding status', err);
        }
      })();

      // Load dashboard stats
      (async () => {
        try {
          const res = await fetch(`${API_URL}/v1/dashboard/stats`, { credentials: 'include' });
          if (res.ok) {
            const { data } = await res.json();
            document.getElementById('active-leads').textContent = data.activeLeads;
            document.getElementById('estimates-sent').textContent = data.estimatesSent;
            document.getElementById('jobs-month').textContent = data.jobsThisMonth;
            
            const activity = document.getElementById('recent-activity');
            if (data.recentActivity.length === 0) {
              activity.textContent = 'No recent activity. Start by adding your first lead!';
            } else {
              activity.innerHTML = data.recentActivity.map(e => `<div class="py-2 border-b last:border-0"><p class="font-medium">${e.clientName || 'Estimate'}</p><p class="text-sm text-gray-600">Status: ${e.status}</p></div>`).join('');
            }
          }
        } catch (err) {
          console.error('Failed to load stats', err);
        }
      })();

      let deferredPrompt;
      const prompt = document.getElementById('install-prompt');
      
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        prompt.classList.remove('hidden');
      });
      
      document.getElementById('install-btn')?.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        const { outcome } = await deferredPrompt.userChoice;
        console.log('Install outcome:', outcome);
        deferredPrompt = null;
        prompt.classList.add('hidden');
      });
      
      document.getElementById('dismiss-install')?.addEventListener('click', () => {
        prompt.classList.add('hidden');
      });

      document.getElementById('logout')?.addEventListener('click', async () => {
        await fetch(`${API_URL}/v1/auth/logout`, { method: 'POST', credentials: 'include' });
        window.location.href = '/login';
      });
    </script>

  </body>
</html>
