---
import Base from '../layouts/Base.astro';

const isDev = import.meta.env.DEV;
---

<Base title="Dashboard - PaintFlow">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between mb-6">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Dashboard</h2>
        <p class="text-sm sm:text-base text-gray-600 mt-1">Run today’s lead, estimate, and job workflow from one place.</p>
      </div>
      <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
        <a href="/leads?new=1" class="text-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-medium text-white hover:bg-blue-700">Add lead</a>
        <a href="/estimates/new" class="text-center rounded-lg border bg-white px-4 py-3 text-sm font-medium text-gray-800 hover:bg-gray-50">New estimate</a>
        <a href="/jobs" class="text-center rounded-lg border bg-white px-4 py-3 text-sm font-medium text-gray-800 hover:bg-gray-50">Jobs</a>
        <a href="/payments/stripe" class="text-center rounded-lg border bg-white px-4 py-3 text-sm font-medium text-gray-800 hover:bg-gray-50">Payments</a>
      </div>
    </div>

    <section id="setup-slot"></section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-6">
      <a href="/leads" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Active Leads</p>
        <p class="text-3xl font-bold mt-2" id="active-leads">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Open leads</p>
      </a>
      <a href="/estimates" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Estimates Sent</p>
        <p class="text-3xl font-bold mt-2" id="estimates-sent">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Review estimates</p>
      </a>
      <a href="/jobs" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Jobs This Month</p>
        <p class="text-3xl font-bold mt-2" id="jobs-month">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Open schedule</p>
      </a>
    </section>

    <section id="empty-start" class="hidden mb-6 rounded-lg border border-blue-200 bg-blue-50 p-5 sm:p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold text-blue-950">Start with your first lead</p>
          <p class="mt-1 text-sm text-blue-900">Capture the customer, then build an estimate from production rates when you are ready.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
          <a href="/leads?new=1" class="rounded-lg bg-blue-600 px-4 py-3 text-center text-sm font-medium text-white hover:bg-blue-700">Add first lead</a>
          <a href="/production-rates" class="rounded-lg border border-blue-200 bg-white px-4 py-3 text-center text-sm font-medium text-blue-800 hover:bg-blue-50">Tune rates</a>
          <a href="/materials" class="rounded-lg border border-blue-200 bg-white px-4 py-3 text-center text-sm font-medium text-blue-800 hover:bg-blue-50">Add paint products</a>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="bg-white rounded-lg shadow-sm border p-5 sm:p-6">
        <div class="flex items-center justify-between gap-3 mb-4">
          <h3 class="text-lg font-semibold">Recent Activity</h3>
          <a href="/activity" class="text-sm font-medium text-blue-700 hover:underline">View all activity</a>
        </div>
        <div id="recent-activity" class="text-gray-600">Loading...</div>
      </div>

      <aside class="space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <p class="font-semibold text-gray-900">Quick entry</p>
          <div class="mt-4 grid gap-2">
            <a href="/leads?new=1" class="rounded-lg border px-4 py-3 text-sm font-medium hover:bg-gray-50">Add a lead</a>
            <a href="/estimates/new" class="rounded-lg border px-4 py-3 text-sm font-medium hover:bg-gray-50">Create an estimate</a>
            <a href="/materials" class="rounded-lg border px-4 py-3 text-sm font-medium hover:bg-gray-50">Add paint products</a>
            <a href="/templates" class="rounded-lg border px-4 py-3 text-sm font-medium hover:bg-gray-50">Use an estimate template</a>
            <a href="/settings" class="rounded-lg border px-4 py-3 text-sm font-medium hover:bg-gray-50">Business settings</a>
          </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <p class="font-semibold text-gray-900">Owner tools</p>
          <div class="mt-4 grid gap-2 text-sm">
            <a href="/production-rates" class="text-blue-700 hover:underline">Production rates</a>
            <a href="/materials" class="text-blue-700 hover:underline">Paint products and material costs</a>
            <a href="/reporting/lead-sources" class="text-blue-700 hover:underline">Lead source reporting</a>
            <a href="/team" class="text-blue-700 hover:underline">Team and roles</a>
            <a href="/payments/stripe" class="text-blue-700 hover:underline">Stripe payment setup</a>
          </div>
        </div>
      </aside>
    </section>

    {isDev && (
      <footer class="mt-8 border-t pt-4 text-center sm:text-right">
        <a href="/dev/design-system" class="text-xs font-medium text-gray-500 hover:text-blue-700 hover:underline">
          Design system preview
        </a>
      </footer>
    )}
  </main>

  <div id="install-prompt" class="hidden fixed bottom-4 right-4 bg-white p-4 rounded-lg shadow-lg border max-w-sm">
    <p class="font-medium mb-2">Install PaintFlow</p>
    <p class="text-sm text-gray-600 mb-3">Add to home screen for quick access</p>
    <div class="flex gap-2">
      <button id="install-btn" class="flex-1 px-3 py-2 bg-blue-600 text-white rounded text-sm">Install</button>
      <button id="dismiss-install" class="px-3 py-2 border rounded text-sm">Later</button>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: options.cents === false ? 0 : 2, maximumFractionDigits: options.cents === false ? 0 : 2 })}`;
    const statusBadge = (value) => window.PaintFlowUI?.statusBadge({ value }) || `<span class="shrink-0 rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700">${escapeHtml(label(value))}</span>`;

    function customerProfileLink(item) {
      const name = item.clientName || 'Customer';
      if (!item.leadId) return `<p class="font-medium text-gray-950">${escapeHtml(name)}</p>`;
      const address = formatAddress(item);
      return window.PaintFlowUI?.contactSummary({
        leadId: item.leadId,
        name,
        address,
        phone: item.leadPhone,
        email: item.leadEmail,
      }) || `<p class="font-medium text-gray-950">${escapeHtml(name)}</p>`;
    }

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead') || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', '), record.leadPostalCode].filter(Boolean).join(' ');
    }

    function relativeDate(value) {
      if (!value) return '';
      const date = new Date(value);
      const diffMs = Date.now() - date.getTime();
      if (diffMs < 0) return 'Just now';
      const diffMinutes = Math.floor(diffMs / 60000);
      if (diffMinutes < 1) return 'Just now';
      if (diffMinutes < 60) return `${diffMinutes}m ago`;
      const diffHours = Math.floor(diffMinutes / 60);
      if (diffHours < 24) return `${diffHours}hr ago`;
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffDays === 1) return 'Yesterday';
      if (diffDays < 7) return `${diffDays} days ago`;
      return date.toLocaleDateString();
    }

    function activityText(event) {
      if (event.title) return event.title;
      const action = event.activityLabel || (event.status === 'sent' ? 'Estimate sent' : `Estimate ${label(event.status).toLowerCase()}`);
      const total = Number(event.total || 0);
      const amount = total > 0 ? ` - ${money(total, { cents: false })}` : '';
      const customer = event.clientName || 'customer';
      return `${action} for ${customer}${amount}`;
    }

    (async () => {
      try {
        const res = await fetch(`${API_URL}/v1/settings/org`, { credentials: 'include' });
        if (res.ok) {
          const { data } = await res.json();
          const completed = data.onboardingCompletedAt;
          const hasCompany = !!data.companyName;

          if (!hasCompany && !completed) {
            window.location.href = '/onboarding';
            return;
          }

          if (!completed) {
            document.getElementById('setup-slot').innerHTML = `
              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="font-medium text-yellow-900">Complete your setup</p>
                    <p class="text-sm text-yellow-800 mt-1">Finish settings, paint products, service areas, and payments before your first live estimate.</p>
                  </div>
                  <div class="flex flex-wrap gap-3">
                    <a href="/onboarding" class="text-sm font-medium text-yellow-900 hover:underline">Continue setup</a>
                    <a href="/materials" class="text-sm font-medium text-yellow-900 hover:underline">Add paint products</a>
                    <a href="/payments/stripe" class="text-sm font-medium text-yellow-900 hover:underline">Set up payments</a>
                  </div>
                </div>
              </div>
            `;
          }
        } else if (res.status === 401) {
          window.location.href = '/login';
        }
      } catch (err) {
        console.error('Failed to check onboarding status', err);
      }
    })();

    (async () => {
      try {
        const res = await fetch(`${API_URL}/v1/dashboard/stats`, { credentials: 'include' });
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        if (res.ok) {
          const { data } = await res.json();
          document.getElementById('active-leads').textContent = data.activeLeads;
          document.getElementById('estimates-sent').textContent = data.estimatesSent;
          document.getElementById('jobs-month').textContent = data.jobsThisMonth;

          if (!data.activeLeads && !data.estimatesSent && !data.jobsThisMonth) {
            document.getElementById('empty-start').classList.remove('hidden');
          }

          const activity = document.getElementById('recent-activity');
          const activityRes = await fetch(`${API_URL}/v1/activities/feed?limit=5`, { credentials: 'include' });
          const activityPayload = activityRes.ok ? await activityRes.json() : { data: [] };
          const recentActivity = activityPayload.data || data.recentActivity || [];
          if (recentActivity.length === 0) {
            activity.innerHTML = `
              <div class="rounded-lg border border-dashed p-6 text-center">
                <p class="font-medium text-gray-900">No activity yet</p>
                <p class="mt-1 text-sm text-gray-600">Add a lead to start tracking calls, estimates, and jobs.</p>
                <a href="/leads?new=1" class="mt-4 inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add lead</a>
              </div>
            `;
          } else {
            activity.innerHTML = `<div class="grid gap-3">${recentActivity.map(e => `
              <a href="${escapeHtml(e.href || `/estimates/${e.id}`)}" class="block rounded-lg border bg-white px-3 py-3 shadow-sm hover:border-blue-200 hover:bg-gray-50 hover:shadow-md">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div class="min-w-0">
                    <p class="font-medium text-gray-950">${escapeHtml(activityText(e))}</p>
                    <p class="mt-0.5 text-xs text-gray-500">${escapeHtml(relativeDate(e.occurredAt || e.activityAt || e.sentAt || e.createdAt))}</p>
                    <div class="mt-2">${customerProfileLink(e)}</div>
                  </div>
                  <span class="shrink-0">${statusBadge(e.status || e.source || 'activity')}</span>
                </div>
              </a>
            `).join('')}</div>`;
          }
        }
      } catch (err) {
        console.error('Failed to load stats', err);
      }
    })();

    let deferredPrompt;
    const prompt = document.getElementById('install-prompt');

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      prompt.classList.remove('hidden');
    });

    document.getElementById('install-btn')?.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      await deferredPrompt.userChoice;
      deferredPrompt = null;
      prompt.classList.add('hidden');
    });

    document.getElementById('dismiss-install')?.addEventListener('click', () => {
      prompt.classList.add('hidden');
    });
  </script>
</Base>
