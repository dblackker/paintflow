---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';

const isDev = import.meta.env.DEV;
---

<Base title="Dashboard - PaintFlow">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between mb-6">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Dashboard</h2>
        <p class="text-sm sm:text-base text-gray-600 mt-1">Run today’s lead, estimate, and job workflow from one place.</p>
      </div>
      <div id="dashboard-primary-actions" class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
        <a href="/leads?new=1" class="btn-primary btn-sm justify-center"><Icon name="plus" />Add lead</a>
        <a href="/estimates/production" class="btn-secondary btn-sm justify-center"><Icon name="file-text" />Estimate</a>
        <a href="/jobs" class="btn-secondary btn-sm justify-center"><Icon name="briefcase" />Jobs</a>
        <a href="/time" class="btn-secondary btn-sm justify-center"><Icon name="clock" />Time</a>
      </div>
    </div>

    <section id="setup-slot"></section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-6">
      <a href="/leads" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Active Leads</p>
        <p class="text-3xl font-bold mt-2" id="active-leads">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Open leads</p>
      </a>
      <a href="/estimates" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Estimates Sent</p>
        <p class="text-3xl font-bold mt-2" id="estimates-sent">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Review estimates</p>
      </a>
      <a href="/jobs" class="bg-white p-5 sm:p-6 rounded-lg shadow-sm border hover:border-blue-200 hover:shadow-md">
        <p class="text-sm text-gray-600">Jobs This Month</p>
        <p class="text-3xl font-bold mt-2" id="jobs-month">-</p>
        <p class="mt-3 text-sm font-medium text-blue-700">Open schedule</p>
      </a>
    </section>

    <section id="empty-start" class="hidden mb-6 rounded-lg border border-blue-200 bg-blue-50 p-5 sm:p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold text-blue-950">Start with your first lead</p>
          <p class="mt-1 text-sm text-blue-900">Capture the customer, then build an estimate from production rates when you are ready.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row">
          <a href="/leads?new=1" class="btn-primary btn-sm justify-center"><Icon name="plus" />Add first lead</a>
          <a href="/production-rates" class="btn-tonal btn-sm justify-center"><Icon name="settings" />Tune rates</a>
          <a href="/materials" class="btn-tonal btn-sm justify-center"><Icon name="paint-bucket" />Add paint products</a>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="bg-white rounded-lg shadow-sm border p-5 sm:p-6">
        <div class="flex items-center justify-between gap-3 mb-4">
          <h3 class="text-lg font-semibold">Recent Activity</h3>
          <a href="/activity" class="text-sm font-medium text-blue-700 hover:underline">View all activity</a>
        </div>
        <div id="recent-activity" class="text-gray-600">Loading...</div>
      </div>

      <aside class="space-y-4">
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="font-semibold text-gray-900">Quick actions</p>
              <p class="mt-0.5 text-xs text-gray-500">Configure the shortcuts your team uses daily.</p>
            </div>
            <button type="button" id="edit-quick-actions" class="btn-icon-tonal" aria-label="Customize quick actions" title="Customize quick actions">
              <Icon name="edit" />
            </button>
          </div>
          <div id="quick-actions-list" class="mt-4 grid gap-2">
            <a href="/leads?new=1" class="btn-primary btn-sm justify-start"><Icon name="plus" />Add lead</a>
            <a href="/estimates/production" class="btn-secondary btn-sm justify-start"><Icon name="file-text" />Create estimate</a>
            <a href="/time" class="btn-secondary btn-sm justify-start"><Icon name="clock" />Log time</a>
            <a href="/jobs" class="btn-secondary btn-sm justify-start"><Icon name="briefcase" />Open jobs</a>
          </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border p-5">
          <p class="font-semibold text-gray-900">Owner tools</p>
          <div class="mt-4 grid gap-2 text-sm">
            <a href="/production-rates" class="text-blue-700 hover:underline">Production rates</a>
            <a href="/materials" class="text-blue-700 hover:underline">Paint products and material costs</a>
            <a href="/reporting/lead-sources" class="text-blue-700 hover:underline">Lead source reporting</a>
            <a href="/team" class="text-blue-700 hover:underline">Team and roles</a>
            <a href="/payments/stripe" class="text-blue-700 hover:underline">Stripe payment setup</a>
          </div>
        </div>
      </aside>
    </section>

    {isDev && (
      <footer class="mt-8 border-t pt-4 text-center sm:text-right">
        <a href="/dev/design-system" class="text-xs font-medium text-gray-500 hover:text-blue-700 hover:underline">
          Design system preview
        </a>
      </footer>
    )}
  </main>

  <div id="quick-actions-modal" class="fixed inset-0 z-50 hidden items-end bg-gray-950/40 p-0 sm:items-center sm:justify-center sm:p-4" role="dialog" aria-modal="true" aria-labelledby="quick-actions-title">
    <div class="max-h-[92vh] w-full overflow-hidden rounded-t-2xl bg-white shadow-xl sm:max-w-2xl sm:rounded-2xl">
      <div class="flex items-start justify-between gap-4 border-b px-5 py-4">
        <div>
          <h3 id="quick-actions-title" class="text-lg font-semibold text-gray-950">Customize quick actions</h3>
          <p class="mt-1 text-sm text-gray-600">Choose the dashboard shortcuts, then move the most-used actions to the top.</p>
        </div>
        <button type="button" id="close-quick-actions" class="btn-icon" aria-label="Close quick actions editor">
          <Icon name="close" />
        </button>
      </div>
      <div class="max-h-[62vh] overflow-y-auto px-5 py-4">
        <div id="quick-actions-editor" class="grid gap-2"></div>
      </div>
      <div class="flex flex-col gap-2 border-t bg-gray-50 px-5 py-4 sm:flex-row sm:justify-end">
        <button type="button" id="reset-quick-actions" class="btn-text justify-center">Reset defaults</button>
        <button type="button" id="save-quick-actions" class="btn-primary justify-center">Save actions</button>
      </div>
    </div>
  </div>

  <div id="install-prompt" class="hidden fixed bottom-4 right-4 bg-white p-4 rounded-lg shadow-lg border max-w-sm">
    <p class="font-medium mb-2">Install PaintFlow</p>
    <p class="text-sm text-gray-600 mb-3">Add to home screen for quick access</p>
    <div class="flex gap-2">
      <button id="install-btn" class="flex-1 px-3 py-2 bg-blue-600 text-white rounded text-sm">Install</button>
      <button id="dismiss-install" class="px-3 py-2 border rounded text-sm">Later</button>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    const quickActionCatalog = [
      { id: 'add_lead', label: 'Add lead', href: '/leads?new=1', icon: 'plus', priority: true, defaultVisible: true },
      { id: 'create_estimate', label: 'Production estimate', href: '/estimates/production', icon: 'file-text', priority: true, defaultVisible: true },
      { id: 'quick_estimate', label: 'Quick estimate', href: '/estimates/new', icon: 'file-text', defaultVisible: false },
      { id: 'log_time', label: 'Log time', href: '/time', icon: 'clock', defaultVisible: true },
      { id: 'open_jobs', label: 'Open jobs', href: '/jobs', icon: 'briefcase', defaultVisible: true },
      { id: 'pipeline', label: 'Pipeline', href: '/pipeline', icon: 'bar-chart', defaultVisible: true },
      { id: 'messages', label: 'Messages', href: '/sms', icon: 'message', defaultVisible: true },
      { id: 'schedule', label: 'Schedule', href: '/calendar', icon: 'calendar', defaultVisible: false },
      { id: 'paint_products', label: 'Paint products', href: '/materials', icon: 'paint-bucket', defaultVisible: true },
      { id: 'production_rates', label: 'Production rates', href: '/production-rates', icon: 'settings', defaultVisible: false },
      { id: 'team', label: 'Team', href: '/team', icon: 'users', defaultVisible: false },
      { id: 'payments', label: 'Payments', href: '/payments/stripe', icon: 'credit-card', defaultVisible: false },
      { id: 'reports', label: 'Reports', href: '/reports', icon: 'bar-chart', defaultVisible: false },
      { id: 'templates', label: 'Templates', href: '/templates', icon: 'templates', defaultVisible: false },
      { id: 'settings', label: 'Business settings', href: '/settings', icon: 'settings', defaultVisible: false },
    ];

    const quickActionIcons = {
      'bar-chart': '<path d="M3 3v18h18" /><path d="M7 16v-5" /><path d="M12 16V7" /><path d="M17 16v-8" />',
      briefcase: '<path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1" /><path d="M3 7h18v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z" /><path d="M3 13h18" />',
      calendar: '<path d="M8 2v4M16 2v4" /><path d="M3 10h18" /><rect x="3" y="4" width="18" height="18" rx="2" />',
      clock: '<circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" />',
      'credit-card': '<rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 10h18" />',
      'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" /><path d="M14 2v6h6M8 13h8M8 17h6" />',
      message: '<path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4Z" />',
      'paint-bucket': '<path d="m19 11-8-8-8 8 8 8 8-8Z" /><path d="m5 9 6 6" /><path d="M19 13c1.3 1.4 2 2.6 2 3.5a2 2 0 0 1-4 0c0-.9.7-2.1 2-3.5Z" />',
      plus: '<path d="M12 5v14M5 12h14" />',
      settings: '<path d="M12 15.5A3.5 3.5 0 1 0 12 8a3.5 3.5 0 0 0 0 7.5Z" /><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 0 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6V21a2 2 0 0 1-4 0v-.1a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1A2 2 0 0 1 4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.6-1H3a2 2 0 0 1 0-4h.1a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.3 7A2 2 0 0 1 7.1 4.2l.1.1a1.7 1.7 0 0 0 1.9.3 1.7 1.7 0 0 0 1-1.6V3a2 2 0 0 1 4 0v.1a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1A2 2 0 0 1 19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.1a2 2 0 0 1 0 4H21a1.7 1.7 0 0 0-1.6 1Z" />',
      templates: '<path d="M4 4h7v7H4Z" /><path d="M13 4h7v7h-7Z" /><path d="M4 13h7v7H4Z" /><path d="M13 13h7v7h-7Z" />',
      users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.9" /><path d="M16 3.1a4 4 0 0 1 0 7.8" />',
    };

    const catalogById = new Map(quickActionCatalog.map((action) => [action.id, action]));
    let quickActionState = quickActionCatalog.map((action) => ({ id: action.id, visible: action.defaultVisible }));

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toLocaleString('en-US', { minimumFractionDigits: options.cents === false ? 0 : 2, maximumFractionDigits: options.cents === false ? 0 : 2 })}`;
    const statusBadge = (value) => window.PaintFlowUI?.statusBadge({ value }) || `<span class="shrink-0 rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700">${escapeHtml(label(value))}</span>`;

    function customerProfileLink(item) {
      const name = item.clientName || 'Customer';
      if (!item.leadId) return `<p class="font-medium text-gray-950">${escapeHtml(name)}</p>`;
      const address = formatAddress(item);
      return window.PaintFlowUI?.contactSummary({
        leadId: item.leadId,
        name,
        address,
        phone: item.leadPhone,
        email: item.leadEmail,
      }) || `<p class="font-medium text-gray-950">${escapeHtml(name)}</p>`;
    }

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead') || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', '), record.leadPostalCode].filter(Boolean).join(' ');
    }

    function relativeDate(value) {
      if (!value) return '';
      const date = new Date(value);
      const diffMs = Date.now() - date.getTime();
      if (diffMs < 0) return 'Just now';
      const diffMinutes = Math.floor(diffMs / 60000);
      if (diffMinutes < 1) return 'Just now';
      if (diffMinutes < 60) return `${diffMinutes}m ago`;
      const diffHours = Math.floor(diffMinutes / 60);
      if (diffHours < 24) return `${diffHours}hr ago`;
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffDays === 1) return 'Yesterday';
      if (diffDays < 7) return `${diffDays} days ago`;
      return date.toLocaleDateString();
    }

    function activityText(event) {
      if (event.title) return event.title;
      const action = event.activityLabel || (event.status === 'sent' ? 'Estimate sent' : `Estimate ${label(event.status).toLowerCase()}`);
      const total = Number(event.total || 0);
      const amount = total > 0 ? ` - ${money(total, { cents: false })}` : '';
      const customer = event.clientName || 'customer';
      return `${action} for ${customer}${amount}`;
    }

    function quickActionIcon(name) {
      const path = quickActionIcons[name] || quickActionIcons.plus;
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${path}</svg>`;
    }

    function mergeQuickActionPreferences(actions) {
      const seen = new Set();
      const saved = Array.isArray(actions) ? actions : [];
      const merged = [];

      for (const entry of saved) {
        const action = catalogById.get(entry?.id);
        if (!action || seen.has(action.id)) continue;
        seen.add(action.id);
        merged.push({ id: action.id, visible: Boolean(entry.visible) });
      }

      for (const action of quickActionCatalog) {
        if (seen.has(action.id)) continue;
        merged.push({ id: action.id, visible: action.defaultVisible });
      }

      return merged;
    }

    function visibleQuickActions() {
      return quickActionState.map((entry) => ({ ...entry, action: catalogById.get(entry.id) })).filter((entry) => entry.visible && entry.action);
    }

    function renderQuickActions() {
      const quickList = document.getElementById('quick-actions-list');
      const primaryList = document.getElementById('dashboard-primary-actions');
      const visibleActions = visibleQuickActions();

      if (quickList) {
        quickList.innerHTML = visibleActions.length ? visibleActions.map((entry, index) => {
          const action = entry.action;
          const buttonClass = index === 0 && action.priority ? 'btn-primary' : 'btn-secondary';
          return `<a href="${escapeHtml(action.href)}" class="${buttonClass} btn-sm w-full justify-start">${quickActionIcon(action.icon)}${escapeHtml(action.label)}</a>`;
        }).join('') : `
          <div class="rounded-lg border border-dashed p-4 text-center text-sm text-gray-600">
            No quick actions are visible.
            <button type="button" class="mt-3 btn-tonal btn-sm mx-auto" data-open-quick-actions>Choose actions</button>
          </div>
        `;
      }

      if (primaryList) {
        const primaryActions = (visibleActions.length ? visibleActions : quickActionCatalog.slice(0, 4).map((action) => ({ action }))).slice(0, 4);
        primaryList.innerHTML = primaryActions.map((entry, index) => {
          const action = entry.action;
          const buttonClass = index === 0 ? 'btn-primary' : 'btn-secondary';
          return `<a href="${escapeHtml(action.href)}" class="${buttonClass} btn-sm justify-center">${quickActionIcon(action.icon)}${escapeHtml(action.label)}</a>`;
        }).join('');
      }
    }

    function renderQuickActionEditor() {
      const editor = document.getElementById('quick-actions-editor');
      if (!editor) return;
      editor.innerHTML = quickActionState.map((entry, index) => {
        const action = catalogById.get(entry.id);
        if (!action) return '';
        return `
          <div class="flex items-center gap-3 rounded-xl border bg-white p-3">
            <label class="flex min-w-0 flex-1 items-center gap-3">
              <input type="checkbox" class="h-5 w-5 rounded border-gray-300" data-quick-visible="${escapeHtml(entry.id)}" ${entry.visible ? 'checked' : ''} />
              <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-700">${quickActionIcon(action.icon)}</span>
              <span class="min-w-0">
                <span class="block truncate text-sm font-medium text-gray-950">${escapeHtml(action.label)}</span>
                <span class="block truncate text-xs text-gray-500">${escapeHtml(action.href)}</span>
              </span>
            </label>
            <div class="flex shrink-0 gap-1">
              <button type="button" class="btn-text btn-sm px-2" data-move-action="${escapeHtml(entry.id)}" data-direction="-1" ${index === 0 ? 'disabled' : ''}>Up</button>
              <button type="button" class="btn-text btn-sm px-2" data-move-action="${escapeHtml(entry.id)}" data-direction="1" ${index === quickActionState.length - 1 ? 'disabled' : ''}>Down</button>
            </div>
          </div>
        `;
      }).join('');
    }

    function openQuickActionsModal() {
      renderQuickActionEditor();
      const modal = document.getElementById('quick-actions-modal');
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    }

    function closeQuickActionsModal() {
      const modal = document.getElementById('quick-actions-modal');
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    }

    async function loadQuickActionPreferences() {
      try {
        const res = await fetch(`${API_URL}/v1/settings/dashboard-actions`, { credentials: 'include' });
        if (res.ok) {
          const { data } = await res.json();
          quickActionState = mergeQuickActionPreferences(data.actions);
        }
      } catch (err) {
        console.error('Failed to load quick actions', err);
      } finally {
        renderQuickActions();
      }
    }

    async function saveQuickActionPreferences() {
      const button = document.getElementById('save-quick-actions');
      button?.setAttribute('disabled', 'true');
      try {
        const res = await fetch(`${API_URL}/v1/settings/dashboard-actions`, {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ actions: quickActionState.map(({ id, visible }) => ({ id, visible })) }),
        });
        if (!res.ok) throw new Error('Could not save quick actions');
        closeQuickActionsModal();
        renderQuickActions();
        window.showToast?.('Quick actions updated', 'success');
      } catch (err) {
        window.showToast?.(err.message || 'Failed to save quick actions', 'error');
      } finally {
        button?.removeAttribute('disabled');
      }
    }

    document.getElementById('edit-quick-actions')?.addEventListener('click', openQuickActionsModal);
    document.getElementById('close-quick-actions')?.addEventListener('click', closeQuickActionsModal);
    document.getElementById('quick-actions-modal')?.addEventListener('click', (event) => {
      if (event.target?.id === 'quick-actions-modal') closeQuickActionsModal();
    });
    document.addEventListener('click', (event) => {
      const openTarget = event.target.closest?.('[data-open-quick-actions]');
      if (openTarget) openQuickActionsModal();

      const moveTarget = event.target.closest?.('[data-move-action]');
      if (!moveTarget) return;
      const id = moveTarget.dataset.moveAction;
      const direction = Number(moveTarget.dataset.direction);
      const index = quickActionState.findIndex((entry) => entry.id === id);
      const nextIndex = index + direction;
      if (index < 0 || nextIndex < 0 || nextIndex >= quickActionState.length) return;
      const nextState = [...quickActionState];
      [nextState[index], nextState[nextIndex]] = [nextState[nextIndex], nextState[index]];
      quickActionState = nextState;
      renderQuickActionEditor();
    });
    document.addEventListener('change', (event) => {
      const checkbox = event.target.closest?.('[data-quick-visible]');
      if (!checkbox) return;
      quickActionState = quickActionState.map((entry) => entry.id === checkbox.dataset.quickVisible ? { ...entry, visible: checkbox.checked } : entry);
      renderQuickActions();
    });
    document.getElementById('reset-quick-actions')?.addEventListener('click', () => {
      quickActionState = quickActionCatalog.map((action) => ({ id: action.id, visible: action.defaultVisible }));
      renderQuickActionEditor();
      renderQuickActions();
    });
    document.getElementById('save-quick-actions')?.addEventListener('click', saveQuickActionPreferences);

    loadQuickActionPreferences();

    (async () => {
      try {
        const res = await fetch(`${API_URL}/v1/settings/org`, { credentials: 'include' });
        if (res.ok) {
          const { data } = await res.json();
          const completed = data.onboardingCompletedAt;
          const hasCompany = !!data.companyName;

          if (!hasCompany && !completed) {
            window.location.href = '/onboarding';
            return;
          }

          if (!completed) {
            document.getElementById('setup-slot').innerHTML = `
              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="font-medium text-yellow-900">Complete your setup</p>
                    <p class="text-sm text-yellow-800 mt-1">Finish settings, paint products, service areas, and payments before your first live estimate.</p>
                  </div>
                  <div class="flex flex-wrap gap-3">
                    <a href="/onboarding" class="text-sm font-medium text-yellow-900 hover:underline">Continue setup</a>
                    <a href="/materials" class="text-sm font-medium text-yellow-900 hover:underline">Add paint products</a>
                    <a href="/payments/stripe" class="text-sm font-medium text-yellow-900 hover:underline">Set up payments</a>
                  </div>
                </div>
              </div>
            `;
          }
        } else if (res.status === 401) {
          window.location.href = '/login';
        }
      } catch (err) {
        console.error('Failed to check onboarding status', err);
      }
    })();

    (async () => {
      try {
        const res = await fetch(`${API_URL}/v1/dashboard/stats`, { credentials: 'include' });
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        if (res.ok) {
          const { data } = await res.json();
          document.getElementById('active-leads').textContent = data.activeLeads;
          document.getElementById('estimates-sent').textContent = data.estimatesSent;
          document.getElementById('jobs-month').textContent = data.jobsThisMonth;

          if (!data.activeLeads && !data.estimatesSent && !data.jobsThisMonth) {
            document.getElementById('empty-start').classList.remove('hidden');
          }

          const activity = document.getElementById('recent-activity');
          const activityRes = await fetch(`${API_URL}/v1/activities/feed?limit=5`, { credentials: 'include' });
          const activityPayload = activityRes.ok ? await activityRes.json() : { data: [] };
          const recentActivity = activityPayload.data || data.recentActivity || [];
          if (recentActivity.length === 0) {
            activity.innerHTML = `
              <div class="rounded-lg border border-dashed p-6 text-center">
                <p class="font-medium text-gray-900">No activity yet</p>
                <p class="mt-1 text-sm text-gray-600">Add a lead to start tracking calls, estimates, and jobs.</p>
                <a href="/leads?new=1" class="mt-4 inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Add lead</a>
              </div>
            `;
          } else {
            activity.innerHTML = `<div class="grid gap-3">${recentActivity.map(e => `
              <a href="${escapeHtml(e.href || `/estimates/${e.id}`)}" class="block rounded-lg border bg-white px-3 py-3 shadow-sm hover:border-blue-200 hover:bg-gray-50 hover:shadow-md">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div class="min-w-0">
                    <p class="font-medium text-gray-950">${escapeHtml(activityText(e))}</p>
                    <p class="mt-0.5 text-xs text-gray-500">${escapeHtml(relativeDate(e.occurredAt || e.activityAt || e.sentAt || e.createdAt))}</p>
                    <div class="mt-2">${customerProfileLink(e)}</div>
                  </div>
                  <span class="shrink-0">${statusBadge(e.status || e.source || 'activity')}</span>
                </div>
              </a>
            `).join('')}</div>`;
          }
        }
      } catch (err) {
        console.error('Failed to load stats', err);
      }
    })();

    let deferredPrompt;
    const prompt = document.getElementById('install-prompt');

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      prompt.classList.remove('hidden');
    });

    document.getElementById('install-btn')?.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      await deferredPrompt.userChoice;
      deferredPrompt = null;
      prompt.classList.add('hidden');
    });

    document.getElementById('dismiss-install')?.addEventListener('click', () => {
      prompt.classList.add('hidden');
    });
  </script>
</Base>
