---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Production Rates - PaintFlow</title>
  <link rel="stylesheet" href="/styles/mobile.css">
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <h1 class="text-xl font-semibold">Production Rates</h1>
        <a href="/settings" class="text-sm text-gray-600">Back</a>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
    <p class="text-gray-600 mb-6">Set your production rates for accurate estimates. Rates are sq ft per hour.</p>

    <div class="bg-white rounded-lg shadow-sm border divide-y" id="rates-list">
      <div class="p-4 text-center text-gray-500">Loading...</div>
    </div>

    <button id="add-rate" class="w-full mt-4 py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-blue-500 hover:text-blue-600 touch-feedback">
      + Add Custom Rate
    </button>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    async function loadRates() {
      const res = await fetch(`${API_URL}/v1/production-rates`, { credentials: 'include' });
      const { data } = await res.json();
      renderRates(data);
    }

    function renderRates(rates) {
      const container = document.getElementById('rates-list');
      container.innerHTML = rates.map(r => `
        <div class="p-4 flex items-center justify-between" data-id="${r.id}">
          <div class="flex-1">
            <p class="font-medium">${r.category} • ${r.surfaceType}</p>
            <p class="text-sm text-gray-600">${r.ratePerHour} ${r.unit}/hr @ $${parseFloat(r.hourlyRate).toFixed(0)}/hr</p>
            ${r.description ? `<p class="text-xs text-gray-500 mt-1">${r.description}</p>` : ''}
          </div>
          <div class="flex gap-2">
            <button onclick="editRate('${r.id}')" class="text-sm text-blue-600">Edit</button>
            <button onclick="deleteRate('${r.id}')" class="text-sm text-red-600">Delete</button>
          </div>
        </div>
      `).join('');
    }

    async function deleteRate(id) {
      if (!confirm('Delete this rate?')) return;
      await fetch(`${API_URL}/v1/production-rates/${id}`, { method: 'DELETE', credentials: 'include' });
      loadRates();
    }

    function editRate(id) {
      alert('Edit functionality coming soon');
    }

    document.getElementById('add-rate').addEventListener('click', async () => {
      const category = prompt('Category (walls, ceilings, trim, cabinets):');
      if (!category) return;
      const ratePerHour = prompt('Rate per hour (sq ft):');
      if (!ratePerHour) return;
      
      await fetch(`${API_URL}/v1/production-rates`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          category,
          surfaceType: 'drywall',
          ratePerHour: parseFloat(ratePerHour),
          hourlyRate: 50,
        }),
      });
      loadRates();
    });

    loadRates();
  </script>
</body>
</html>
