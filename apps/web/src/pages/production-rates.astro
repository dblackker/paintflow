---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Production Rates - PaintFlow">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-24">
    <div class="mb-6 flex items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Settings</p>
        <h1 class="text-2xl font-semibold text-gray-950">Production Rates</h1>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/materials" class="rounded-lg border px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Paint products</a>
        <a href="/settings" class="rounded-lg border px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Back</a>
      </div>
    </div>
    <p class="text-gray-600 mb-6">Set your production rates for accurate estimates. Rates are sq ft per hour.</p>

    <div class="bg-white rounded-lg shadow-sm border divide-y" id="rates-list">
      <div class="p-4 text-center text-gray-500">Loading...</div>
    </div>

    <button id="add-rate" class="w-full mt-4 py-3 border-2 border-dashed border-gray-300 rounded-lg text-gray-600 hover:border-blue-500 hover:text-blue-600 touch-feedback inline-flex items-center justify-center gap-2">
      <Icon name="plus" />
      Add Custom Rate
    </button>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const money = (value, options = {}) => window.PaintFlowFormat?.money(value, options) ?? `$${Number(value || 0).toFixed(options.cents === false ? 0 : 2)}`;
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const iconSvg = (name) => {
      const icons = {
        edit: '<path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />',
        trash: '<path d="M3 6h18" /><path d="M8 6V4h8v2" /><path d="M19 6l-1 14H6L5 6" /><path d="M10 11v5M14 11v5" />',
      };
      return `<svg class="pf-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">${icons[name] || ''}</svg>`;
    };

    async function loadRates() {
      const res = await fetch(`${API_URL}/v1/production-rates`, { credentials: 'include' });
      const { data } = await res.json();
      renderRates(data);
    }

    function renderRates(rates) {
      const container = document.getElementById('rates-list');
      container.innerHTML = rates.map(r => `
        <div class="p-4 flex items-center justify-between" data-id="${r.id}">
          <div class="flex-1">
            <p class="font-medium">${label(r.category)} • ${label(r.surfaceType)}</p>
            <p class="text-sm text-gray-600">${Number(r.ratePerHour).toLocaleString('en-US')} ${label(r.unit)}/hr @ ${money(r.hourlyRate, { cents: false })}/hr</p>
            ${r.description ? `<p class="text-xs text-gray-500 mt-1">${r.description}</p>` : ''}
          </div>
          <div class="flex gap-1.5">
            <button type="button" onclick="editRate('${r.id}')" class="btn-icon btn-icon-tonal" aria-label="Edit ${label(r.category)} ${label(r.surfaceType)} rate">${iconSvg('edit')}</button>
            <button type="button" onclick="deleteRate('${r.id}')" class="btn-icon btn-icon-outlined btn-icon-danger" aria-label="Delete ${label(r.category)} ${label(r.surfaceType)} rate">${iconSvg('trash')}</button>
          </div>
        </div>
      `).join('');
    }

    async function deleteRate(id) {
      if (!confirm('Delete this rate?')) return;
      await fetch(`${API_URL}/v1/production-rates/${id}`, { method: 'DELETE', credentials: 'include' });
      loadRates();
    }

    function editRate(id) {
      alert('Edit functionality coming soon');
    }

    document.getElementById('add-rate').addEventListener('click', async () => {
      const category = prompt('Category (walls, ceilings, trim, cabinets):');
      if (!category) return;
      const ratePerHour = prompt('Rate per hour (sq ft):');
      if (!ratePerHour) return;
      
      await fetch(`${API_URL}/v1/production-rates`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          category,
          surfaceType: 'drywall',
          ratePerHour: parseFloat(ratePerHour),
          hourlyRate: 50,
        }),
      });
      loadRates();
    });

    loadRates();
  </script>
</Base>
