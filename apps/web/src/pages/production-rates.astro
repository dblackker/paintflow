---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Production Rates - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/production-rates" class="text-blue-600 font-medium">Production Rates</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Production Rates</h2>
        <p class="text-gray-600">Standard hours per unit for estimating</p>
      </div>

      <div class="bg-white rounded-lg shadow-sm border overflow-hidden">
        <table class="w-full">
          <thead class="bg-gray-50 border-b">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Task</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Unit</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Hours/Unit</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
            </tr>
          </thead>
          <tbody id="rates-table" class="divide-y">
            <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </main>

    <script>
      const rates = [
        { task: 'Interior Wall Painting', unit: 'sq ft', hours: 0.008, category: 'Interior' },
        { task: 'Interior Ceiling Painting', unit: 'sq ft', hours: 0.010, category: 'Interior' },
        { task: 'Interior Trim Painting', unit: 'lin ft', hours: 0.025, category: 'Interior' },
        { task: 'Exterior Siding Painting', unit: 'sq ft', hours: 0.012, category: 'Exterior' },
        { task: 'Exterior Trim Painting', unit: 'lin ft', hours: 0.030, category: 'Exterior' },
        { task: 'Deck Staining', unit: 'sq ft', hours: 0.015, category: 'Exterior' },
        { task: 'Cabinet Painting (per door)', unit: 'each', hours: 1.5, category: 'Cabinet' },
        { task: 'Cabinet Painting (per drawer)', unit: 'each', hours: 0.75, category: 'Cabinet' },
        { task: 'Wallpaper Removal', unit: 'sq ft', hours: 0.020, category: 'Prep' },
        { task: 'Drywall Repair (small)', unit: 'each', hours: 0.5, category: 'Prep' },
        { task: 'Drywall Repair (large)', unit: 'each', hours: 2.0, category: 'Prep' },
        { task: 'Power Washing', unit: 'sq ft', hours: 0.005, category: 'Prep' },
        { task: 'Caulking', unit: 'lin ft', hours: 0.010, category: 'Prep' },
      ];

      const tbody = document.getElementById('rates-table');
      tbody.innerHTML = rates.map(r => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium">${r.task}</td>
          <td class="px-6 py-4 text-sm text-gray-600">${r.unit}</td>
          <td class="px-6 py-4 text-sm">${r.hours}</td>
          <td class="px-6 py-4 text-sm"><span class="px-2 py-1 text-xs rounded-full bg-gray-100">${r.category}</span></td>
        </tr>
      `).join('');
    </script>
  </body>
</html>
