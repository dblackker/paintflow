---
import Base from '../layouts/Base.astro';
---

<Base title="Settings">
    <style>
      .settings-shell {
        max-width: 72rem;
      }

      .settings-hero {
        background: linear-gradient(135deg, color-mix(in srgb, var(--md-sys-color-primary-container) 54%, white), var(--md-sys-color-surface-container-lowest));
        border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 70%, transparent);
        border-radius: var(--pf-radius);
        box-shadow: 0 1px 2px rgb(25 28 32 / 0.05);
      }

      .settings-setup-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .settings-setup-card {
        background: var(--md-sys-color-surface-container-lowest);
        border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 78%, transparent);
        border-radius: var(--pf-radius);
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        min-height: 100%;
        padding: 1rem;
      }

      .settings-setup-card:hover {
        border-color: color-mix(in srgb, var(--md-sys-color-primary) 34%, var(--md-sys-color-outline-variant));
        box-shadow: 0 2px 8px rgb(25 28 32 / 0.07);
        text-decoration: none;
      }

      .settings-setup-card p {
        line-height: 1.35;
      }

      .settings-setup-card ul {
        color: var(--pf-text-muted);
        display: grid;
        font-size: 0.8rem;
        gap: 0.25rem;
        margin-top: auto;
      }

      .settings-setup-pill {
        align-self: flex-start;
        border-radius: 999px;
        background: var(--md-sys-color-secondary-container);
        color: var(--md-sys-color-on-secondary-container);
        font-size: 0.68rem;
        font-weight: 800;
        padding: 0.18rem 0.5rem;
        text-transform: uppercase;
      }

      .settings-anchor-card {
        scroll-margin-top: 5rem;
      }

      @media (max-width: 900px) {
        .settings-setup-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 640px) {
        .settings-stack {
          gap: 0.85rem;
        }
        .settings-card {
          padding: 1rem;
        }
        .settings-card h3 {
          margin-bottom: 0.75rem;
        }
        .settings-card button[type="submit"] {
          justify-content: center;
          width: 100%;
        }
        .settings-link-grid a {
          padding: 0.75rem;
        }
        .settings-link-grid span:last-child {
          display: none;
        }
        .settings-connectors > div {
          align-items: flex-start;
          flex-direction: column;
          gap: 0.25rem;
        }
        .settings-setup-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
    <main class="settings-shell mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-8">
      <section class="settings-hero mb-5 p-4 sm:p-6">
        <p class="text-sm font-semibold text-blue-700">Owner setup</p>
        <div class="mt-1 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h1 class="text-2xl font-bold text-gray-950 sm:text-3xl">Settings</h1>
            <p class="mt-2 max-w-3xl text-sm text-gray-700">
              Configure the business defaults that make PaintFlow usable in the field: pricing, production rates, materials, team roles, payments, and customer-facing branding.
            </p>
          </div>
          <a href="/onboarding" class="btn-secondary btn-sm justify-center">Review onboarding</a>
        </div>
      </section>

      <section class="mb-6">
        <div class="mb-3 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-gray-950">Setup checklist</h2>
            <p class="text-sm text-gray-600">Use these sections to get a contractor workspace ready before sending live estimates or scheduling crews.</p>
          </div>
        </div>
        <div class="settings-setup-grid">
          <a href="#business-settings" class="settings-setup-card">
            <span class="settings-setup-pill">Company</span>
            <div>
              <h3 class="font-semibold text-gray-950">Business profile</h3>
              <p class="mt-1 text-sm text-gray-600">Company name, phone, email, address, proposal branding, and review links.</p>
            </div>
            <ul>
              <li>Customer-facing identity</li>
              <li>Logo and proposal color</li>
            </ul>
          </a>
          <a href="#pricing-settings" class="settings-setup-card">
            <span class="settings-setup-pill">Estimating</span>
            <div>
              <h3 class="font-semibold text-gray-950">Pricing defaults</h3>
              <p class="mt-1 text-sm text-gray-600">Labor rate, material markup, tax, deposit, paint products, and production rates.</p>
            </div>
            <ul>
              <li>Required before live estimates</li>
              <li>Supports job costing accuracy</li>
            </ul>
          </a>
          <a href="#operations-settings" class="settings-setup-card">
            <span class="settings-setup-pill">Operations</span>
            <div>
              <h3 class="font-semibold text-gray-950">Team and field setup</h3>
              <p class="mt-1 text-sm text-gray-600">Crew roles, time clock policies, scheduling, notifications, and reusable templates.</p>
            </div>
            <ul>
              <li>Controls field workflows</li>
              <li>Keeps owner/admin tools together</li>
            </ul>
          </a>
          <a href="#integrations-settings" class="settings-setup-card">
            <span class="settings-setup-pill">Connectors</span>
            <div>
              <h3 class="font-semibold text-gray-950">Payments and integrations</h3>
              <p class="mt-1 text-sm text-gray-600">Stripe deposits, Google Calendar, QuickBooks status, billing, and browser notifications.</p>
            </div>
            <ul>
              <li>Connect as the business grows</li>
              <li>Central place for setup needs</li>
            </ul>
          </a>
          <a href="/reports" class="settings-setup-card">
            <span class="settings-setup-pill">Insights</span>
            <div>
              <h3 class="font-semibold text-gray-950">Reports</h3>
              <p class="mt-1 text-sm text-gray-600">Review sales, revenue, jobs, and operating metrics from one reporting surface.</p>
            </div>
            <ul>
              <li>Owner visibility</li>
              <li>Future reporting suite entry point</li>
            </ul>
          </a>
          <a href="/activity" class="settings-setup-card">
            <span class="settings-setup-pill">Audit</span>
            <div>
              <h3 class="font-semibold text-gray-950">Activity log</h3>
              <p class="mt-1 text-sm text-gray-600">See customer events and operational changes across leads, estimates, and jobs.</p>
            </div>
            <ul>
              <li>Estimate sent and accepted events</li>
              <li>Operational timeline</li>
            </ul>
          </a>
        </div>
      </section>

      <div class="settings-stack space-y-6">
        <!-- Business Info -->
        <div id="business-settings" class="settings-card settings-anchor-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Business Information</h3>
          <form id="business-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input name="companyName" autocomplete="organization" placeholder="Company Name" class="px-3 py-2 border rounded-lg">
              <input name="phone" type="tel" autocomplete="tel" inputmode="numeric" maxlength="14" pattern="[0-9() -]{10,14}" placeholder="(555) 123-4567" class="px-3 py-2 border rounded-lg">
            </div>
            <input name="email" placeholder="Email" type="email" autocomplete="email" inputmode="email" class="w-full px-3 py-2 border rounded-lg">
            <input name="address" placeholder="Address" autocomplete="street-address" class="w-full px-3 py-2 border rounded-lg">
            <button type="submit" class="btn-primary">Save</button>
          </form>
        </div>

        <div class="settings-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Branding & Proposals</h3>
          <form id="branding-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-[1fr_120px] gap-4">
              <input name="companyName" autocomplete="organization" placeholder="Proposal company name" class="px-3 py-2 border rounded-lg">
              <input name="primaryColor" type="color" value="#2563eb" class="h-11 w-full border rounded-lg">
            </div>
            <input name="logoUrl" type="url" inputmode="url" autocomplete="url" placeholder="Logo URL for customer estimates" class="w-full px-3 py-2 border rounded-lg">
            <div id="branding-preview" class="hidden rounded-lg border p-4">
              <img id="branding-logo-preview" class="h-12 max-w-48 object-contain" alt="Logo preview">
            </div>
            <button type="submit" class="btn-primary">Save Branding</button>
          </form>
        </div>

        <!-- Pricing -->
        <div id="pricing-settings" class="settings-card settings-anchor-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Pricing & Tax</h3>
          <form id="pricing-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="text-sm text-gray-600">Labor Rate ($/hr)</label>
                <input name="defaultLaborRate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" class="w-full px-3 py-2 border rounded-lg">
              </div>
              <div>
                <label class="text-sm text-gray-600">Material Markup (%)</label>
                <input name="materialMarkupPercent" type="number" min="0" step="0.1" inputmode="decimal" autocomplete="off" class="w-full px-3 py-2 border rounded-lg">
              </div>
              <div>
                <label class="text-sm text-gray-600">Sales Tax (%)</label>
                <input name="salesTaxRate" type="number" min="0" step="0.01" inputmode="decimal" autocomplete="off" class="w-full px-3 py-2 border rounded-lg">
              </div>
              <div>
                <label class="text-sm text-gray-600">Deposit (%)</label>
                <input name="depositPercent" type="number" min="0" max="100" step="0.1" inputmode="decimal" autocomplete="off" class="w-full px-3 py-2 border rounded-lg">
              </div>
            </div>
            <button type="submit" class="btn-primary">Save</button>
          </form>
        </div>

        <div class="settings-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-2">Estimator Setup</h3>
          <p class="text-sm text-gray-600">Keep labor production and paint product costs current before sending live estimates.</p>
          <div class="settings-link-grid mt-4 grid gap-3 sm:grid-cols-2">
            <a href="/materials" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Paint products and costs</span>
              <span class="mt-1 block text-sm text-gray-600">Enter cost per gallon/unit, coverage, supplier, SKU, and markup.</span>
            </a>
            <a href="/production-rates" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Production rates</span>
              <span class="mt-1 block text-sm text-gray-600">Tune sqft/hr, linear ft/hr, labor rate, coats, and prep defaults.</span>
            </a>
          </div>
        </div>

        <div id="operations-settings" class="settings-card settings-anchor-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-2">Operations Setup</h3>
          <p class="text-sm text-gray-600">Configure the workflows that crew leads and office admins use every day.</p>
          <div class="settings-link-grid mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/team" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Team and roles</span>
              <span class="mt-1 block text-sm text-gray-600">Manage active crew members, roles, rates, and time clock policies.</span>
            </a>
            <a href="/calendar" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Calendar scheduling</span>
              <span class="mt-1 block text-sm text-gray-600">Schedule jobs by day and connect Google Calendar when ready.</span>
            </a>
            <a href="/templates" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Templates</span>
              <span class="mt-1 block text-sm text-gray-600">Reusable estimate, message, and follow-up language.</span>
            </a>
            <a href="/notifications" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Notifications</span>
              <span class="mt-1 block text-sm text-gray-600">Review messages, accepted estimates, and browser alert readiness.</span>
            </a>
          </div>
        </div>

        <!-- Connectors -->
        <div id="integrations-settings" class="settings-card settings-anchor-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Connectors</h3>
          <div class="settings-connectors space-y-3" id="connectors">
            <div class="flex justify-between items-center p-3 border rounded-lg">
              <span>Stripe</span>
              <span class="text-sm text-gray-600" id="stripe-status">Checking...</span>
            </div>
            <div class="flex justify-between items-center p-3 border rounded-lg">
              <span>QuickBooks</span>
              <span class="text-sm text-gray-600" id="qb-status">Checking...</span>
            </div>
            <div class="flex justify-between items-center p-3 border rounded-lg">
              <span>Google Calendar</span>
              <span class="text-sm text-gray-600" id="calendar-status">Checking...</span>
            </div>
          </div>
          <div class="settings-link-grid mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/payments/stripe" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Stripe payments</span>
              <span class="mt-1 block text-sm text-gray-600">Collect deposits and customer payments.</span>
            </a>
            <a href="/billing" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Billing</span>
              <span class="mt-1 block text-sm text-gray-600">Manage the PaintFlow subscription and account status.</span>
            </a>
            <a href="/notifications" class="rounded-lg border px-4 py-3 hover:bg-gray-50">
              <span class="block font-medium text-gray-950">Browser notifications</span>
              <span class="mt-1 block text-sm text-gray-600">Enable alerts for new messages and accepted estimates.</span>
            </a>
          </div>
        </div>

        <!-- Review URLs -->
        <div class="settings-card bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Review Links</h3>
          <form id="reviews-form" class="space-y-4">
            <input name="googleReviewUrl" type="url" inputmode="url" autocomplete="url" placeholder="Google Business Review URL" class="w-full px-3 py-2 border rounded-lg">
            <input name="yelpReviewUrl" type="url" inputmode="url" autocomplete="url" placeholder="Yelp Review URL (optional)" class="w-full px-3 py-2 border rounded-lg">
            <button type="submit" class="btn-primary">Save</button>
          </form>
        </div>
      </div>
    </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    function phoneDigits(value) {
      return String(value || '').replace(/\D/g, '').slice(0, 10);
    }

    function formatPhone(value) {
      const digits = phoneDigits(value);
      if (digits.length <= 3) return digits;
      if (digits.length <= 6) return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
      return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
    }

    document.querySelector('input[name="phone"]')?.addEventListener('input', (event) => {
      event.target.value = formatPhone(event.target.value);
    });

    async function loadSettings() {
      const [settingsRes, brandingRes] = await Promise.all([
        fetch(`${API_URL}/v1/settings/org`, { credentials: 'include' }),
        fetch(`${API_URL}/v1/settings/branding`, { credentials: 'include' }),
      ]);
      const { data } = await settingsRes.json();
      const { data: branding } = await brandingRes.json();
      
      // Populate forms
      ['business-form', 'pricing-form', 'reviews-form'].forEach(formId => {
        const form = document.getElementById(formId);
        Array.from(form.elements).forEach(el => {
          if (el.name && data[el.name] !== undefined) {
            el.value = el.name === 'salesTaxRate' ? (Number(data[el.name]) * 100).toString() : data[el.name];
          }
        });
      });

      // Check connectors
      const calRes = await fetch(`${API_URL}/v1/calendar/status`, { credentials: 'include' });
      const { connected } = await calRes.json();
      document.getElementById('calendar-status').textContent = connected ? 'Connected' : 'Not connected';
      const stripeRes = await fetch(`${API_URL}/v1/stripe/status`, { credentials: 'include' });
      const { data: stripe } = await stripeRes.json();
      document.getElementById('stripe-status').innerHTML = stripe?.onboardingComplete
        ? '<span class="text-green-700">Ready for deposits</span>'
        : '<a href="/payments/stripe" class="text-blue-600 hover:underline">Set up payments</a>';
      document.getElementById('qb-status').textContent = 'Check QuickBooks settings';

      const brandingForm = document.getElementById('branding-form');
      Array.from(brandingForm.elements).forEach(el => {
        if (el.name && branding?.[el.name] !== undefined) el.value = branding[el.name] || '';
      });
      updateBrandingPreview();
    }

    function updateBrandingPreview() {
      const logoUrl = document.querySelector('#branding-form [name="logoUrl"]').value.trim();
      const preview = document.getElementById('branding-preview');
      const image = document.getElementById('branding-logo-preview');
      if (!logoUrl) {
        preview.classList.add('hidden');
        return;
      }
      image.src = logoUrl;
      preview.classList.remove('hidden');
    }

    document.querySelector('#branding-form [name="logoUrl"]').addEventListener('input', updateBrandingPreview);

    document.getElementById('business-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = Object.fromEntries(new FormData(e.target));
      if (formData.phone) {
        formData.phone = formatPhone(formData.phone);
        if (phoneDigits(formData.phone).length !== 10) {
          window.showToast('Enter a 10-digit phone number', 'error');
          return;
        }
      }
      await fetch(`${API_URL}/v1/settings/org`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(formData),
      });
      window.showToast('Business info saved', 'success');
    });

    document.getElementById('pricing-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = Object.fromEntries(new FormData(e.target));
      await fetch(`${API_URL}/v1/settings/org`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(formData),
      });
      window.showToast('Pricing saved', 'success');
    });

    document.getElementById('reviews-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = Object.fromEntries(new FormData(e.target));
      await fetch(`${API_URL}/v1/settings/org`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(formData),
      });
      window.showToast('Review links saved', 'success');
    });

    document.getElementById('branding-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = Object.fromEntries(new FormData(e.target));
      const res = await fetch(`${API_URL}/v1/settings/branding`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(formData),
      });
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        window.showToast(payload.error || 'Failed to save branding', 'error');
        return;
      }
      window.showToast('Branding saved', 'success');
      updateBrandingPreview();
    });

    loadSettings();
  </script>
</Base>
