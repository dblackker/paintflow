---
import Layout from '../../components/Layout.astro';
---

<Layout title="Stripe Payments">
  <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Payment setup</p>
        <h1 class="mt-2 text-3xl font-bold text-gray-900">Connect Stripe for customer deposits</h1>
        <p class="mt-2 max-w-2xl text-gray-600">
          Create or connect a Stripe account for your painting company so approved estimates can collect deposits and route payouts to your bank.
        </p>
      </div>
      <a href="/onboarding?welcome=1" class="rounded-lg border px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Back to setup</a>
    </div>

    <div id="notice" class="hidden mb-5 rounded-lg border p-4 text-sm"></div>

    <section class="grid gap-5 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border bg-white p-5 shadow-sm sm:p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-gray-900">Stripe Connect account</h2>
            <p id="status-copy" class="mt-2 text-gray-600">Checking Stripe setup...</p>
          </div>
          <span id="status-pill" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700">Checking</span>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border bg-gray-50 p-4">
            <p class="text-sm font-medium text-gray-700">Account details</p>
            <p id="details-status" class="mt-1 text-lg font-semibold text-gray-900">-</p>
          </div>
          <div class="rounded-lg border bg-gray-50 p-4">
            <p class="text-sm font-medium text-gray-700">Card charges</p>
            <p id="charges-status" class="mt-1 text-lg font-semibold text-gray-900">-</p>
          </div>
          <div class="rounded-lg border bg-gray-50 p-4">
            <p class="text-sm font-medium text-gray-700">Payouts</p>
            <p id="payouts-status" class="mt-1 text-lg font-semibold text-gray-900">-</p>
          </div>
        </div>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <button id="connect-btn" class="rounded-lg bg-blue-600 px-5 py-3 font-medium text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-60">
            Start Stripe setup
          </button>
          <button id="dashboard-btn" class="hidden rounded-lg border px-5 py-3 font-medium text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-60">
            Open Stripe dashboard
          </button>
        </div>
      </div>

      <aside class="space-y-4">
        <div class="rounded-lg border bg-white p-5 shadow-sm">
          <p class="font-semibold text-gray-900">What contractors need</p>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            <li>Legal business name and tax details</li>
            <li>Owner identity verification</li>
            <li>Bank account for payouts</li>
            <li>Customer-facing statement descriptor</li>
          </ul>
        </div>
        <div class="rounded-lg border border-blue-200 bg-blue-50 p-5">
          <p class="font-semibold text-blue-950">How payments will work</p>
          <p class="mt-2 text-sm text-blue-900">
            Customer deposits should be charged on the connected contractor account, with payouts and disputes managed by that account instead of PaintFlow subscription billing.
          </p>
        </div>
      </aside>
    </section>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const notice = document.getElementById('notice');
    const connectBtn = document.getElementById('connect-btn');
    const dashboardBtn = document.getElementById('dashboard-btn');

    function showNotice(message, type = 'info') {
      notice.textContent = message;
      notice.className = `mb-5 rounded-lg border p-4 text-sm ${type === 'error' ? 'border-red-200 bg-red-50 text-red-800' : 'border-blue-200 bg-blue-50 text-blue-900'}`;
    }

    async function apiJson(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, { credentials: 'include', ...options });
      if (res.status === 401) {
        window.location.href = '/login';
        throw new Error('Unauthorized');
      }
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(payload.error || 'Request failed');
      return payload;
    }

    function yesNo(value) {
      return value ? 'Ready' : 'Needs setup';
    }

    function renderStatus(status) {
      document.getElementById('details-status').textContent = yesNo(status.detailsSubmitted);
      document.getElementById('charges-status').textContent = yesNo(status.chargesEnabled);
      document.getElementById('payouts-status').textContent = yesNo(status.payoutsEnabled);

      const pill = document.getElementById('status-pill');
      const copy = document.getElementById('status-copy');
      if (status.onboardingComplete) {
        pill.textContent = 'Ready';
        pill.className = 'rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800';
        copy.textContent = 'Stripe is ready to collect customer deposits and send payouts.';
        connectBtn.textContent = 'Update Stripe setup';
        dashboardBtn.classList.remove('hidden');
      } else if (status.connected) {
        pill.textContent = 'Action needed';
        pill.className = 'rounded-full bg-yellow-100 px-3 py-1 text-xs font-semibold text-yellow-800';
        copy.textContent = 'Finish Stripe onboarding before customers can pay deposits online.';
        connectBtn.textContent = 'Continue Stripe setup';
        dashboardBtn.classList.add('hidden');
      } else {
        pill.textContent = 'Not connected';
        pill.className = 'rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700';
        copy.textContent = 'Start with Stripe hosted onboarding. If you do not have a Stripe account, Stripe will create one during setup.';
        connectBtn.textContent = 'Start Stripe setup';
        dashboardBtn.classList.add('hidden');
      }
    }

    async function loadStatus() {
      const params = new URLSearchParams(window.location.search);
      if (params.has('return')) showNotice('Stripe returned you to PaintFlow. Checking your account status now.');
      if (params.has('refresh')) showNotice('Stripe setup was restarted. Continue onboarding to finish payment setup.');
      const { data } = await apiJson('/v1/stripe/status');
      renderStatus(data);
    }

    connectBtn.addEventListener('click', async () => {
      connectBtn.disabled = true;
      try {
        const { url } = await apiJson('/v1/stripe/connect', { method: 'POST' });
        window.location.href = url;
      } catch (err) {
        showNotice(err.message || 'Failed to start Stripe setup', 'error');
        connectBtn.disabled = false;
      }
    });

    dashboardBtn.addEventListener('click', async () => {
      dashboardBtn.disabled = true;
      try {
        const { url } = await apiJson('/v1/stripe/dashboard', { method: 'POST' });
        window.location.href = url;
      } catch (err) {
        showNotice(err.message || 'Failed to open Stripe dashboard', 'error');
        dashboardBtn.disabled = false;
      }
    });

    loadStatus().catch((err) => showNotice(err.message || 'Failed to load Stripe setup', 'error'));
  </script>
</Layout>
