---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
---

<Base title="Calendar - PaintFlow">
  <style is:global>
    .schedule-shell {
      max-width: 78rem;
    }

    .schedule-panel {
      background: var(--md-sys-color-surface-container-lowest);
      border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 78%, transparent);
      border-radius: var(--pf-radius);
      box-shadow: 0 1px 2px rgb(25 28 32 / 0.05);
    }

    .schedule-day {
      min-height: 10rem;
      display: flex;
      flex-direction: column;
      border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 78%, transparent);
      border-radius: var(--pf-radius);
      background: var(--md-sys-color-surface-container-lowest);
    }

    .schedule-week-grid {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fit, minmax(11.5rem, 1fr));
    }

    .schedule-day.is-today {
      border-color: color-mix(in srgb, var(--pf-primary) 45%, var(--md-sys-color-outline-variant));
      background: color-mix(in srgb, var(--md-sys-color-primary-container) 18%, white);
    }

    .schedule-day.is-drop-target {
      border-color: color-mix(in srgb, var(--pf-primary) 58%, var(--md-sys-color-outline-variant));
      background: color-mix(in srgb, var(--md-sys-color-primary-container) 28%, white);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--pf-primary) 30%, transparent);
    }

    .schedule-day-add {
      min-height: 1.65rem;
      padding: 0 0.15rem;
      white-space: nowrap;
      color: var(--md-sys-color-primary);
      font-size: 0.72rem;
      font-weight: 600;
    }

    .schedule-day-add:hover {
      text-decoration: underline;
    }

    .schedule-day-footer {
      margin-top: auto;
      padding-top: 0.6rem;
      display: flex;
      justify-content: flex-end;
    }

    .schedule-quick-form {
      border-radius: 0.75rem;
      border: 1px solid color-mix(in srgb, var(--pf-primary) 22%, transparent);
      background: color-mix(in srgb, var(--md-sys-color-primary-container) 12%, white);
      padding: 0.65rem;
    }

    .schedule-job-card {
      display: block;
      border-radius: 0.75rem;
      border: 1px solid color-mix(in srgb, var(--pf-primary) 18%, transparent);
      background: color-mix(in srgb, var(--md-sys-color-primary-container) 18%, white);
      padding: 0.65rem;
      text-decoration: none;
      -webkit-touch-callout: none;
      touch-action: manipulation;
      user-select: none;
      transition: border-color 160ms ease, box-shadow 160ms ease, transform 120ms ease;
    }

    .schedule-job-card[draggable="true"] {
      cursor: grab;
    }

    .schedule-job-card:hover {
      border-color: color-mix(in srgb, var(--pf-primary) 42%, transparent);
      box-shadow: 0 1px 4px rgb(25 28 32 / 0.08);
      transform: translateY(-1px);
      text-decoration: none;
    }

    .schedule-job-card.is-dragging {
      cursor: grabbing;
      opacity: 0.68;
    }

    .schedule-job-card a,
    .schedule-job-card button,
    .schedule-backlog-card a,
    .schedule-backlog-card input,
    .schedule-backlog-card select,
    .schedule-backlog-card button,
    .schedule-backlog-card summary {
      -webkit-touch-callout: default;
      touch-action: manipulation;
      user-select: auto;
    }

    .schedule-google-card {
      border-radius: 0.75rem;
      background: var(--md-sys-color-secondary-container);
      color: var(--md-sys-color-on-secondary-container);
      padding: 0.55rem 0.65rem;
    }

    .schedule-backlog-card {
      border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 78%, transparent);
      border-radius: var(--pf-radius);
      padding: 0.8rem;
      background: var(--md-sys-color-surface-container-lowest);
      -webkit-touch-callout: none;
      touch-action: manipulation;
      user-select: none;
    }

    .schedule-backlog-card[draggable="true"] {
      cursor: grab;
    }

    .schedule-backlog-card.is-dragging {
      cursor: grabbing;
      opacity: 0.68;
    }

    .schedule-date-summary {
      width: fit-content;
    }

    .schedule-date-summary::marker,
    .schedule-date-summary::-webkit-details-marker {
      display: none;
      content: "";
    }

    .schedule-stat {
      border-radius: var(--pf-radius);
      background: var(--md-sys-color-surface-container-low);
      padding: 0.75rem;
    }

    .schedule-toolbar {
      align-self: flex-start;
      background: color-mix(in srgb, var(--md-sys-color-surface-container-lowest) 92%, transparent);
      border: 1px solid color-mix(in srgb, var(--md-sys-color-outline-variant) 55%, transparent);
      border-radius: 999px;
      box-shadow: 0 1px 3px rgb(25 28 32 / 0.08);
      padding: 0.25rem;
      position: sticky;
      top: 4.75rem;
      z-index: 8;
      backdrop-filter: blur(10px);
    }

    @media (max-width: 640px) {
      .schedule-shell {
        padding-top: 1rem;
      }

      .schedule-toolbar {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        border-radius: var(--pf-radius);
        top: 4.4rem;
        width: 100%;
      }

      .schedule-toolbar .connect-calendar {
        grid-column: 1 / -1;
      }

      .schedule-day {
        min-height: auto;
      }

      .schedule-week-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main class="schedule-shell mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <div class="mb-4">
      <div>
        <p class="pf-kicker">Operations calendar</p>
        <p class="pf-page-copy mt-1 max-w-2xl">
          Put accepted jobs on the production calendar, spot jobs missing dates, and keep Google Calendar as an optional external sync.
        </p>
      </div>
    </div>

    <div class="schedule-toolbar mb-5 flex flex-wrap gap-2 sm:ml-auto sm:w-fit">
      <button id="sync-btn" class="connect-calendar btn-tonal btn-sm justify-center" type="button"><Icon name="calendar" />Connect Google</button>
      <button id="prev-btn" class="btn-secondary btn-sm justify-center" type="button"><Icon name="chevron-left" />Prev</button>
      <button id="today-btn" class="btn-secondary btn-sm justify-center" type="button">Today</button>
      <button id="next-btn" class="btn-secondary btn-sm justify-center" type="button">Next<Icon name="chevron-right" /></button>
    </div>

    <section id="schedule-stats" class="mb-5 grid grid-cols-3 gap-2 sm:gap-3">
      <div class="schedule-stat">
        <p class="pf-metric-label">This week</p>
        <p id="stat-week" class="pf-metric-value mt-1">-</p>
      </div>
      <div class="schedule-stat">
        <p class="pf-metric-label">Needs date</p>
        <p id="stat-needs-date" class="pf-metric-value mt-1">-</p>
      </div>
      <div class="schedule-stat">
        <p class="pf-metric-label">In progress</p>
        <p id="stat-progress" class="pf-metric-value mt-1">-</p>
      </div>
    </section>

    <div class="grid grid-cols-1 gap-5 lg:grid-cols-12">
      <section class="schedule-panel lg:col-span-8">
        <div class="flex flex-col gap-2 border-b px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="pf-section-title" id="week-title">Week view</h2>
            <p class="pf-meta">Jobs render here only when they have scheduled dates.</p>
          </div>
          <a href="/jobs" class="btn-text btn-sm justify-center">Open jobs</a>
        </div>
        <div id="calendar-grid" class="p-3 sm:p-4">
          <div class="py-12 text-center text-gray-500">Loading calendar...</div>
        </div>
      </section>

      <aside class="schedule-panel lg:col-span-4">
        <div class="border-b px-4 py-3">
          <h2 class="pf-section-title">Needs scheduling</h2>
          <p class="pf-meta mt-1">These jobs are active, but do not have a calendar date yet.</p>
        </div>
        <div id="unscheduled-jobs" class="grid gap-3 p-3 sm:p-4">
          <div class="py-8 text-center text-gray-500">Loading jobs...</div>
        </div>
      </aside>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const DAY_MS = 86400000;
    const AVERAGE_CREW_SIZE = 3;
    const CREW_HOURS_PER_PERSON_DAY = 8;
    let currentWeekStart = getWeekStart(new Date());
    let allJobs = [];
    let allGoogleEvents = [];
    let activeQuickScheduleDay = null;
    let pointerScheduleDrag = null;
    let suppressScheduleClick = false;

    function escapeHtml(value = '') {
      return String(value ?? '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char]));
    }

    function label(value) {
      return window.PaintFlowFormat?.label(value) ?? String(value || '').replace(/[_-]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
    }

    function address(job) {
      return window.PaintFlowFormat?.address(job, 'lead', { includePostalCode: false }) || [
        job.leadStreetAddress,
        [job.leadCity, job.leadState].filter(Boolean).join(', '),
      ].filter(Boolean).join(' ');
    }

    function clearDropTargets() {
      document.querySelectorAll('.schedule-day.is-drop-target').forEach((day) => day.classList.remove('is-drop-target'));
    }

    function isInteractiveDragTarget(target) {
      return target instanceof Element && Boolean(target.closest('a, button, input, select, textarea, summary, details, label'));
    }

    function money(value) {
      return window.PaintFlowFormat?.money(value, { cents: false }) ?? new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0,
      }).format(Number(value || 0));
    }

    function getWeekStart(date) {
      const d = new Date(date);
      const day = d.getDay();
      const diff = d.getDate() - day + (day === 0 ? -6 : 1);
      d.setHours(0, 0, 0, 0);
      d.setDate(diff);
      return d;
    }

    function dateKey(date) {
      const d = new Date(date);
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    }

    function formatDate(date) {
      return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    }

    function formatTime(value) {
      if (!value) return '';
      return new Date(value).toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
    }

    function fromScheduleDate(value, endOfDay = false) {
      if (!value) return null;
      const [year, month, day] = String(value).split('-').map(Number);
      const date = new Date(year, month - 1, day);
      date.setHours(endOfDay ? 23 : 0, endOfDay ? 59 : 0, endOfDay ? 59 : 0, endOfDay ? 999 : 0);
      return date.toISOString();
    }

    function jobStart(job) {
      return job.scheduledStartAt ? new Date(job.scheduledStartAt) : null;
    }

    function jobEnd(job) {
      return job.scheduledEndAt ? new Date(job.scheduledEndAt) : null;
    }

    function activeJob(job) {
      return !['completed', 'cancelled'].includes(job.status);
    }

    function jobHasSchedule(job) {
      return Boolean(job.scheduledStartAt);
    }

    function jobIntersectsDay(job, day) {
      const start = jobStart(job);
      if (!start) return false;
      const end = jobEnd(job) || start;
      const dayStart = new Date(day);
      dayStart.setHours(0, 0, 0, 0);
      const dayEnd = new Date(dayStart.getTime() + DAY_MS);
      return start < dayEnd && end >= dayStart;
    }

    function jobIsInWeek(job) {
      return Array.from({ length: 7 }, (_, index) => new Date(currentWeekStart.getTime() + index * DAY_MS))
        .some((date) => jobIntersectsDay(job, date));
    }

    function formatScheduleRange(job) {
      const start = jobStart(job);
      if (!start) return 'Date scheduled';
      const end = jobEnd(job);
      const startText = start.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      if (!end || dateKey(start) === dateKey(end)) return startText;
      return `${startText} - ${end.toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}`;
    }

    function estimatedWorkDays(job) {
      const estimatedHours = Number(job.estimatedLaborHours || 0);
      if (!Number.isFinite(estimatedHours) || estimatedHours <= 0) return 1;
      return Math.max(1, Math.ceil(estimatedHours / (AVERAGE_CREW_SIZE * CREW_HOURS_PER_PERSON_DAY)));
    }

    function scheduledWorkDays(job) {
      const start = jobStart(job);
      const end = jobEnd(job) || start;
      if (!start || !end) return estimatedWorkDays(job);

      const cursor = new Date(start);
      cursor.setHours(0, 0, 0, 0);
      const last = new Date(end);
      last.setHours(0, 0, 0, 0);
      let days = 0;

      while (cursor <= last && days < 30) {
        const weekday = cursor.getDay();
        if (weekday !== 0 && weekday !== 6) days += 1;
        cursor.setDate(cursor.getDate() + 1);
      }

      return Math.max(1, days || estimatedWorkDays(job));
    }

    function addWorkDays(date, daysToAdd) {
      const result = new Date(date);
      let added = 0;
      while (added < daysToAdd) {
        result.setDate(result.getDate() + 1);
        const day = result.getDay();
        if (day !== 0 && day !== 6) added += 1;
      }
      return result;
    }

    function unscheduledJobs() {
      return allJobs
        .filter((job) => activeJob(job) && !jobHasSchedule(job))
        .sort((a, b) => String(a.updatedAt || a.createdAt).localeCompare(String(b.updatedAt || b.createdAt)));
    }

    function jobOptionLabel(job) {
      const jobAddress = address(job);
      return jobAddress ? `${job.name || 'Job'} - ${jobAddress}` : job.name || 'Job';
    }

    function scheduleDatesFromDuration(startDateValue, durationDays) {
      const [year, month, day] = String(startDateValue).split('-').map(Number);
      const safeDuration = Math.max(1, Math.min(30, Number.parseInt(durationDays, 10) || 1));
      const startDate = new Date(year, month - 1, day);
      const endDate = addWorkDays(startDate, safeDuration - 1);
      return {
        scheduledStartAt: fromScheduleDate(dateKey(startDate)),
        scheduledEndAt: fromScheduleDate(dateKey(endDate), true),
      };
    }

    async function scheduleJob(jobId, scheduledStartAt, scheduledEndAt, successMessage = 'Job scheduled.') {
      if (!jobId || !scheduledStartAt || !scheduledEndAt) return;
      if (new Date(scheduledEndAt) < new Date(scheduledStartAt)) {
        notify('Last work day must be on or after the first work day.', 'error');
        return;
      }

      await api(`/v1/jobs/${jobId}`, {
        method: 'PATCH',
        body: JSON.stringify({ scheduledStartAt, scheduledEndAt, status: 'scheduled' }),
      });
      activeQuickScheduleDay = null;
      notify(successMessage);
      await loadCalendar();
    }

    async function scheduleJobFromDuration(jobId, startDateValue, durationDays) {
      const { scheduledStartAt, scheduledEndAt } = scheduleDatesFromDuration(startDateValue, durationDays);
      const job = allJobs.find((item) => item.id === jobId);
      await scheduleJob(jobId, scheduledStartAt, scheduledEndAt, `${job?.name || 'Job'} added to the calendar.`);
    }

    async function scheduleDroppedJob(jobId, dayKey) {
      const job = allJobs.find((item) => item.id === jobId);
      if (!job || !dayKey) return;
      const duration = jobHasSchedule(job) ? scheduledWorkDays(job) : estimatedWorkDays(job);
      const message = jobHasSchedule(job) ? `${job.name || 'Job'} moved on the calendar.` : `${job.name || 'Job'} added to the calendar.`;
      const { scheduledStartAt, scheduledEndAt } = scheduleDatesFromDuration(dayKey, duration);
      await scheduleJob(job.id, scheduledStartAt, scheduledEndAt, message);
    }

    async function unscheduleJob(jobId) {
      const job = allJobs.find((item) => item.id === jobId);
      if (!job) return;
      const confirmed = window.confirm(`Remove ${job.name || 'this job'} from the calendar? It will move back to Needs scheduling.`);
      if (!confirmed) return;

      await api(`/v1/jobs/${job.id}`, {
        method: 'PATCH',
        body: JSON.stringify({ scheduledStartAt: null, scheduledEndAt: null }),
      });
      notify(`${job.name || 'Job'} moved back to Needs scheduling.`);
      await loadCalendar();
    }

    function autoPopulateEndDate(form) {
      const startInput = form.querySelector('input[name="scheduledStartDate"]');
      const endInput = form.querySelector('input[name="scheduledEndDate"]');
      if (!startInput?.value || !endInput || endInput.value) return;
      const job = allJobs.find((item) => item.id === form.dataset.jobId);
      const [year, month, day] = startInput.value.split('-').map(Number);
      const startDate = new Date(year, month - 1, day);
      endInput.value = dateKey(addWorkDays(startDate, estimatedWorkDays(job || {}) - 1));
    }

    function notify(message, type = 'success') {
      if (window.PaintFlowUI?.toast) {
        window.PaintFlowUI.toast({ message, type });
        return;
      }
      console.log(message);
    }

    async function api(path, options = {}) {
      const res = await fetch(`${API_URL}${path}`, {
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json',
          ...(options.headers || {}),
        },
        ...options,
      });
      if (res.status === 401) {
        window.location.href = '/login';
        return null;
      }
      if (!res.ok) throw new Error(`Request failed: ${res.status}`);
      return res.json();
    }

    async function loadCalendar() {
      const timeMin = currentWeekStart.toISOString();
      const timeMax = new Date(currentWeekStart.getTime() + 7 * DAY_MS).toISOString();

      try {
        const [eventsPayload, jobsPayload] = await Promise.all([
          api(`/v1/calendar/events?timeMin=${encodeURIComponent(timeMin)}&timeMax=${encodeURIComponent(timeMax)}`),
          api('/v1/jobs'),
        ]);

        allGoogleEvents = eventsPayload?.data?.google || [];
        allJobs = jobsPayload?.data || [];
        renderWeek();
      } catch (error) {
        console.error(error);
        document.getElementById('calendar-grid').innerHTML = '<div class="py-12 text-center text-red-600">Failed to load calendar</div>';
        document.getElementById('unscheduled-jobs').innerHTML = '<div class="py-8 text-center text-red-600">Failed to load jobs</div>';
      }
    }

    function renderStats() {
      const active = allJobs.filter(activeJob);
      document.getElementById('stat-week').textContent = allJobs.filter((job) => activeJob(job) && jobHasSchedule(job) && jobIsInWeek(job)).length;
      document.getElementById('stat-needs-date').textContent = active.filter((job) => !jobHasSchedule(job)).length;
      document.getElementById('stat-progress').textContent = active.filter((job) => job.status === 'in_progress').length;
    }

    function renderWeek() {
      renderStats();
      const grid = document.getElementById('calendar-grid');
      const weekEnd = new Date(currentWeekStart.getTime() + 6 * DAY_MS);
      document.getElementById('week-title').textContent = `${formatDate(currentWeekStart)} - ${formatDate(weekEnd)}`;

      const todayKey = dateKey(new Date());
      const days = Array.from({ length: 7 }, (_, index) => {
        const date = new Date(currentWeekStart.getTime() + index * DAY_MS);
        const key = dateKey(date);
        const dayEvents = allGoogleEvents.filter((event) => {
          const start = event.start?.dateTime || event.start?.date;
          return start && dateKey(start) === key;
        });
        const dayJobs = allJobs
          .filter((job) => activeJob(job) && jobIntersectsDay(job, date))
          .sort((a, b) => String(a.scheduledStartAt).localeCompare(String(b.scheduledStartAt)));

        const empty = !dayEvents.length && !dayJobs.length
          ? '<div class="rounded-lg border border-dashed border-gray-200 p-3 text-center text-xs text-gray-500">No scheduled work</div>'
          : '';

        return `
          <div class="schedule-day ${key === todayKey ? 'is-today' : ''} p-3" data-calendar-day="${key}">
            <div class="mb-3 flex items-start justify-between gap-2">
              <div>
                <p class="text-sm font-semibold text-gray-950">${date.toLocaleDateString(undefined, { weekday: 'short' })}</p>
                <p class="pf-meta">${date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}</p>
              </div>
              ${key === todayKey ? '<span class="shrink-0 rounded-full bg-blue-100 px-2 py-0.5 text-[0.68rem] font-semibold text-blue-800">Today</span>' : ''}
            </div>
            <div class="schedule-day-items grid gap-2">
              ${dayJobs.map(jobCard).join('')}
              ${dayEvents.map((event) => `
                <div class="schedule-google-card text-xs">
                  <p class="pf-section-title">${escapeHtml(event.summary || 'Google event')}</p>
                  <p class="mt-0.5 opacity-80">${escapeHtml(formatTime(event.start?.dateTime || event.start?.date))}</p>
                </div>
              `).join('')}
              ${empty}
            </div>
            ${quickSchedulePanel(key)}
            <div class="schedule-day-footer">
              <button type="button" class="schedule-day-add" data-quick-schedule-day="${key}">+ Add job</button>
            </div>
          </div>
        `;
      }).join('');

      grid.innerHTML = `<div class="schedule-week-grid">${days}</div>`;
      renderNeedsScheduling();
      wireCalendarInteractions();
    }

    function jobCard(job) {
      const jobAddress = address(job);
      const scheduleRange = formatScheduleRange(job);
      const canUnschedule = job.status === 'scheduled';
      return `
        <div class="schedule-job-card" draggable="true" data-schedule-draggable-job-id="${escapeHtml(job.id)}" aria-label="Drag to reschedule ${escapeHtml(job.name || 'job')}">
          <div class="flex items-start justify-between gap-2">
            <p class="min-w-0 truncate text-xs font-semibold text-gray-950">${escapeHtml(job.name || 'Job')}</p>
            ${window.PaintFlowUI?.statusBadge({ value: job.status }) || `<span class="rounded-full bg-blue-100 px-2 py-0.5 text-[0.68rem] font-semibold text-blue-800">${escapeHtml(label(job.status))}</span>`}
          </div>
          <p class="mt-1 text-[0.72rem] font-medium text-gray-700">${escapeHtml(scheduleRange)}</p>
          ${jobAddress ? `<p class="mt-1 line-clamp-2 text-[0.72rem] text-gray-600">${escapeHtml(jobAddress)}</p>` : ''}
          <div class="mt-2 flex flex-wrap items-center gap-2">
            <a href="/jobs/${escapeHtml(job.id)}" class="inline-flex text-[0.72rem] font-semibold text-blue-700 hover:underline">Open job</a>
            ${canUnschedule ? `<button type="button" class="btn-text btn-sm px-0 text-[0.72rem]" data-unschedule-job-id="${escapeHtml(job.id)}">Unschedule</button>` : ''}
          </div>
        </div>
      `;
    }

    function quickSchedulePanel(dayKey) {
      if (activeQuickScheduleDay !== dayKey) return '';
      const jobs = unscheduledJobs();
      const firstJob = jobs[0];
      const duration = firstJob ? estimatedWorkDays(firstJob) : 1;

      if (!jobs.length) {
        return `
          <div class="schedule-quick-form mb-3 grid gap-2 text-xs text-gray-600">
            <p class="font-medium text-gray-800">No unscheduled jobs right now.</p>
            <p>When an estimate becomes a job without work dates, it appears in Needs scheduling. Drag it onto a day or use this quick add panel.</p>
            <p>To try the flow with existing data, use Unschedule on a scheduled job card and it will move back into Needs scheduling.</p>
          </div>
        `;
      }

      return `
        <form class="schedule-quick-form mb-3 grid gap-2" data-quick-day="${escapeHtml(dayKey)}">
          <label class="grid gap-1 text-xs font-medium text-gray-700">
            Job
            <select name="quickJobId" class="form-input text-sm" required>
              ${jobs.map((job) => `<option value="${escapeHtml(job.id)}" data-days="${estimatedWorkDays(job)}">${escapeHtml(jobOptionLabel(job))}</option>`).join('')}
            </select>
          </label>
          <div class="grid grid-cols-[1fr_auto] items-end gap-2">
            <label class="grid gap-1 text-xs font-medium text-gray-700">
              Work days
              <input type="number" name="durationDays" class="form-input text-sm" min="1" max="30" step="1" value="${duration}" required>
            </label>
            <button type="submit" class="btn-primary btn-sm justify-center">Add</button>
          </div>
        </form>
      `;
    }

    function renderNeedsScheduling() {
      const container = document.getElementById('unscheduled-jobs');
      const needsDate = unscheduledJobs();

      container.innerHTML = needsDate.length
        ? needsDate.map(scheduleForm).join('')
        : '<div class="py-8 text-center text-gray-500"><p class="font-medium text-gray-700">Everything active has a date.</p><p class="mt-1 text-sm">New accepted jobs without dates will appear here.</p></div>';
    }

    function scheduleForm(job) {
      const jobAddress = address(job);
      const statusCopy = job.status === 'scheduled' ? 'Ready to schedule' : label(job.status);
      const estimateHours = Number(job.estimatedLaborHours || 0);
      const workDays = estimatedWorkDays(job);
      const durationCopy = estimateHours > 0
        ? `${estimateHours.toFixed(1).replace(/\.0$/, '')} estimated crew-hours. Defaults to ${workDays} work day${workDays === 1 ? '' : 's'} at a ${AVERAGE_CREW_SIZE}-person crew.`
        : 'No labor-hour estimate found. Defaults to 1 work day.';

      return `
        <div class="schedule-backlog-card" draggable="true" data-unscheduled-job-id="${escapeHtml(job.id)}" data-schedule-draggable-job-id="${escapeHtml(job.id)}">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="font-semibold text-gray-950">${escapeHtml(job.name || 'Job')}</p>
              <p class="mt-1 text-xs text-gray-600">${escapeHtml(statusCopy)}${job.budget ? ` - ${money(job.budget)}` : ''}</p>
              ${jobAddress ? `<p class="mt-1 text-xs text-gray-600">${escapeHtml(jobAddress)}</p>` : ''}
              <a href="/jobs/${escapeHtml(job.id)}" class="mt-2 inline-flex text-xs font-semibold text-blue-700 hover:underline">Open job</a>
            </div>
          </div>
          <details class="mt-3">
            <summary class="schedule-date-summary btn-tonal btn-sm justify-center cursor-pointer select-none">Set dates</summary>
            <form class="schedule-job-form mt-3 grid gap-2" data-job-id="${escapeHtml(job.id)}">
              <p class="rounded-lg bg-gray-50 px-3 py-2 text-xs text-gray-600">${escapeHtml(durationCopy)}</p>
              <label class="grid gap-1 text-xs font-medium text-gray-700">
                First work day
                <input type="date" name="scheduledStartDate" class="form-input text-sm" required>
              </label>
              <label class="grid gap-1 text-xs font-medium text-gray-700">
                Last work day <span class="font-normal text-gray-500">(optional)</span>
                <input type="date" name="scheduledEndDate" class="form-input text-sm">
              </label>
              <button type="submit" class="btn-primary btn-sm justify-center">Schedule job</button>
            </form>
          </details>
        </div>
      `;
    }

    function wireCalendarInteractions() {
      document.querySelectorAll('[data-quick-schedule-day]').forEach((button) => {
        button.addEventListener('click', () => {
          const day = button.dataset.quickScheduleDay;
          activeQuickScheduleDay = activeQuickScheduleDay === day ? null : day;
          renderWeek();
        });
      });

      document.querySelectorAll('[data-schedule-draggable-job-id]').forEach((card) => {
        card.addEventListener('dragstart', (event) => {
          const jobId = card.dataset.scheduleDraggableJobId || '';
          event.dataTransfer?.setData('text/plain', jobId);
          event.dataTransfer?.setData('application/x-paintflow-job-id', jobId);
          if (event.dataTransfer) event.dataTransfer.effectAllowed = 'move';
          card.classList.add('is-dragging');
        });
        card.addEventListener('dragend', () => {
          card.classList.remove('is-dragging');
          clearDropTargets();
        });
      });

      document.querySelectorAll('[data-unschedule-job-id]').forEach((button) => {
        button.addEventListener('click', async () => {
          button.disabled = true;
          try {
            await unscheduleJob(button.dataset.unscheduleJobId);
          } catch (error) {
            console.error(error);
            notify('Failed to unschedule job.', 'error');
          } finally {
            if (button.isConnected) button.disabled = false;
          }
        });
      });

      document.querySelectorAll('[data-calendar-day]').forEach((day) => {
        day.addEventListener('dragover', (event) => {
          if (!Array.from(event.dataTransfer?.types || []).includes('text/plain')) return;
          event.preventDefault();
          day.classList.add('is-drop-target');
        });
        day.addEventListener('dragleave', () => {
          day.classList.remove('is-drop-target');
        });
        day.addEventListener('drop', async (event) => {
          event.preventDefault();
          day.classList.remove('is-drop-target');
          const jobId = event.dataTransfer?.getData('application/x-paintflow-job-id') || event.dataTransfer?.getData('text/plain');
          if (!jobId || !day.dataset.calendarDay) return;

          try {
            await scheduleDroppedJob(jobId, day.dataset.calendarDay);
          } catch (error) {
            console.error(error);
            notify('Failed to schedule job.', 'error');
          }
        });
      });

      wirePointerScheduleDrag();
    }

    function wirePointerScheduleDrag() {
      document.querySelectorAll('[data-schedule-draggable-job-id]').forEach((card) => {
        card.addEventListener('pointerdown', (event) => {
          if (event.pointerType === 'mouse' || event.button !== 0 || isInteractiveDragTarget(event.target)) return;
          pointerScheduleDrag = {
            card,
            jobId: card.dataset.scheduleDraggableJobId || '',
            pointerId: event.pointerId,
            startX: event.clientX,
            startY: event.clientY,
            active: false,
            targetDay: null,
          };
          card.setPointerCapture?.(event.pointerId);
        });

        card.addEventListener('pointermove', (event) => {
          if (!pointerScheduleDrag || pointerScheduleDrag.card !== card || pointerScheduleDrag.pointerId !== event.pointerId) return;
          const distance = Math.hypot(event.clientX - pointerScheduleDrag.startX, event.clientY - pointerScheduleDrag.startY);
          if (!pointerScheduleDrag.active && distance < 10) return;

          event.preventDefault();
          pointerScheduleDrag.active = true;
          card.classList.add('is-dragging');
          clearDropTargets();

          const element = document.elementFromPoint(event.clientX, event.clientY);
          const targetDay = element instanceof Element ? element.closest('[data-calendar-day]') : null;
          if (targetDay) {
            targetDay.classList.add('is-drop-target');
            pointerScheduleDrag.targetDay = targetDay;
          } else {
            pointerScheduleDrag.targetDay = null;
          }
        });

        card.addEventListener('pointerup', async (event) => {
          if (!pointerScheduleDrag || pointerScheduleDrag.card !== card || pointerScheduleDrag.pointerId !== event.pointerId) return;
          const drag = pointerScheduleDrag;
          pointerScheduleDrag = null;
          card.releasePointerCapture?.(event.pointerId);
          card.classList.remove('is-dragging');
          clearDropTargets();

          if (!drag.active) return;
          suppressScheduleClick = true;
          window.setTimeout(() => {
            suppressScheduleClick = false;
          }, 0);

          const dayKey = drag.targetDay?.dataset.calendarDay;
          if (!drag.jobId || !dayKey) return;

          try {
            await scheduleDroppedJob(drag.jobId, dayKey);
          } catch (error) {
            console.error(error);
            notify('Failed to schedule job.', 'error');
          }
        });

        card.addEventListener('pointercancel', (event) => {
          if (!pointerScheduleDrag || pointerScheduleDrag.card !== card || pointerScheduleDrag.pointerId !== event.pointerId) return;
          pointerScheduleDrag = null;
          card.releasePointerCapture?.(event.pointerId);
          card.classList.remove('is-dragging');
          clearDropTargets();
        });
      });
    }

    document.addEventListener('click', (event) => {
      if (!suppressScheduleClick || !(event.target instanceof Element) || !event.target.closest('[data-schedule-draggable-job-id]')) return;
      event.preventDefault();
      event.stopPropagation();
      suppressScheduleClick = false;
    }, true);

    document.getElementById('sync-btn')?.addEventListener('click', () => {
      window.location.href = `${API_URL}/v1/calendar/connect`;
    });

    document.getElementById('prev-btn')?.addEventListener('click', () => {
      currentWeekStart = new Date(currentWeekStart.getTime() - 7 * DAY_MS);
      loadCalendar();
    });

    document.getElementById('today-btn')?.addEventListener('click', () => {
      currentWeekStart = getWeekStart(new Date());
      loadCalendar();
    });

    document.getElementById('next-btn')?.addEventListener('click', () => {
      currentWeekStart = new Date(currentWeekStart.getTime() + 7 * DAY_MS);
      loadCalendar();
    });

    document.addEventListener('change', (event) => {
      const input = event.target;
      if (input instanceof HTMLInputElement && input.name === 'scheduledStartDate') {
        const form = input.closest('.schedule-job-form');
        if (form) autoPopulateEndDate(form);
      }

      if (input instanceof HTMLSelectElement && input.name === 'quickJobId') {
        const durationInput = input.closest('.schedule-quick-form')?.querySelector('input[name="durationDays"]');
        const selected = input.selectedOptions[0];
        if (durationInput && selected?.dataset.days) durationInput.value = selected.dataset.days;
      }
    });

    document.addEventListener('submit', async (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement)) return;
      if (form.classList.contains('schedule-quick-form')) {
        event.preventDefault();
        const button = form.querySelector('button[type="submit"]');
        const data = new FormData(form);
        const jobId = data.get('quickJobId');
        const durationDays = data.get('durationDays') || 1;
        const day = form.dataset.quickDay;

        if (!jobId || !day) return;
        button.disabled = true;
        button.textContent = 'Adding...';
        try {
          await scheduleJobFromDuration(String(jobId), day, durationDays);
        } catch (error) {
          console.error(error);
          notify('Failed to schedule job.', 'error');
          button.disabled = false;
          button.textContent = 'Add';
        }
        return;
      }

      if (!form.classList.contains('schedule-job-form')) return;
      event.preventDefault();
      autoPopulateEndDate(form);

      const button = form.querySelector('button[type="submit"]');
      const data = new FormData(form);
      const startDate = data.get('scheduledStartDate');
      const endDate = data.get('scheduledEndDate') || startDate;
      const scheduledStartAt = fromScheduleDate(startDate);
      const scheduledEndAt = fromScheduleDate(endDate, true);
      const jobId = form.dataset.jobId;

      if (!jobId || !scheduledStartAt || !scheduledEndAt) return;
      if (new Date(scheduledEndAt) < new Date(scheduledStartAt)) {
        notify('Last work day must be on or after the first work day.', 'error');
        return;
      }

      button.disabled = true;
      button.textContent = 'Scheduling...';
      try {
        await scheduleJob(jobId, scheduledStartAt, scheduledEndAt);
      } catch (error) {
        console.error(error);
        notify('Failed to schedule job.', 'error');
        button.disabled = false;
        button.textContent = 'Schedule job';
      }
    });

    loadCalendar();
  </script>
</Base>
