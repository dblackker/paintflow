---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Calendar - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/jobs" class="text-gray-600 hover:text-gray-900">Jobs</a>
              <a href="/calendar" class="text-blue-600 font-medium">Calendar</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-6 flex justify-between items-center">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Schedule</h2>
          <p class="text-gray-600">Manage job scheduling</p>
        </div>
        <button id="sync-btn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          Sync with Google
        </button>
      </div>

      <div class="grid grid-cols-12 gap-6">
        <!-- Week view -->
        <div class="col-span-8 bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <h3 class="font-semibold">Week View</h3>
            <div class="flex gap-2">
        <!-- Calendar view -->
        <div class="col-span-8 bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b flex justify-between items-center">
            <div class="flex items-center gap-4">
              <h3 class="font-semibold" id="view-title">Week View</h3>
              <div class="flex border rounded overflow-hidden">
                <button id="week-view-btn" class="px-3 py-1 text-sm bg-blue-600 text-white">Week</button>
                <button id="month-view-btn" class="px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200">Month</button>
              </div>
            </div>
            <div class="flex gap-2">
              <button id="prev-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">←</button>
              <button id="today-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">Today</button>
              <button id="next-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">→</button>
            </div>
          </div>
          <div id="calendar-grid" class="p-4">
            <div class="text-center text-gray-500 py-12">Loading calendar...</div>
          </div>
        </div>
        <div class="col-span-4 bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h3 class="font-semibold">Unscheduled Jobs</h3>
          </div>
          <div id="unscheduled-jobs" class="p-4 space-y-3">
            <div class="text-center text-gray-500 py-8">Loading jobs...</div>
          </div>
        </div>
      </div>
    </main>

    <script>
      const API_URL = 'http://localhost:8787';
      let currentWeekStart = getWeekStart(new Date());
      
      function getWeekStart(date) {
        const d = new Date(date);
    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
      let currentWeekStart = getWeekStart(new Date());
      
      function getWeekStart(date) {
        const d = new Date(date);
        const day = d.getDay();
        const diff = d.getDate() - day + (day === 0 ? -6 : 1);
        return new Date(d.setDate(diff));
      }
      
      async function loadCalendar() {
        try {
          const timeMin = currentWeekStart.toISOString();
          const timeMax = new Date(currentWeekStart.getTime() + 7 * 86400000).toISOString();
          
          const res = await fetch(`${API_URL}/v1/calendar/events?timeMin=${timeMin}&timeMax=${timeMax}`, { credentials: 'include' });
          if (res.status === 401) {
            window.location.href = '/login';
            return;
          }
          const { data } = await res.json();
          
          const grid = document.getElementById('calendar-grid');
          const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
          const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
          
          grid.innerHTML = `
            <div class="grid grid-cols-7 gap-2 mb-4">
              ${days.map((day, i) => {
                const date = new Date(currentWeekStart.getTime() + i * 86400000);
                return `<div class="text-center"><div class="text-sm font-medium text-gray-600">${day}</div><div class="text-xs text-gray-500">${date.getMonth()+1}/${date.getDate()}</div></div>`;
              }).join('')}
            </div>
            <div class="grid grid-cols-7 gap-2">
              ${Array(7).fill(0).map((_, i) => {
                const date = new Date(currentWeekStart.getTime() + i * 86400000);
                const dayEvents = data.google.filter(e => {
                  const eventDate = new Date(e.start.dateTime || e.start.date);
                  return eventDate.toDateString() === date.toDateString();
                });
                const dayJobs = data.jobs.filter(j => {
                  // Jobs don't have dates yet, so show all
                  return true;
                });
                
                return `
                <div class="min-h-[150px] border rounded p-2 bg-gray-50">
                  <div class="space-y-1">
                    ${dayEvents.map(e => `<div class="text-xs p-1 bg-blue-100 text-blue-800 rounded truncate">${e.summary}</div>`).join('')}
                    ${i === 0 ? dayJobs.slice(0, 3).map(j => `<div class="text-xs p-1 bg-green-100 text-green-800 rounded truncate">${j.name}</div>`).join('') : ''}
                  </div>
                </div>
              `;
              }).join('')}
            </div>
          `;
        } catch (err) {
          console.error('Failed to load calendar', err);
          document.getElementById('calendar-grid').innerHTML = '<div class="text-center text-gray-500 py-12">Failed to load calendar</div>';
        }
      }
      
      async function loadJobs() {
        try {
          const res = await fetch(`${API_URL}/v1/jobs`, { credentials: 'include' });
          const { data } = await res.json();
          const container = document.getElementById('unscheduled-jobs');
          
          const unscheduled = data.filter(j => j.status === 'scheduled');
          
          if (unscheduled.length === 0) {
            container.innerHTML = '<div class="text-center text-gray-500 py-8">No unscheduled jobs</div>';
            return;
          }
          
          container.innerHTML = unscheduled.map(job => `
            <div class="p-3 border rounded hover:bg-gray-50 cursor-pointer" draggable="true" data-job-id="${job.id}">
              <p class="font-medium text-sm">${job.name}</p>
              <p class="text-xs text-gray-600">Budget: $${Number(job.budget || 0).toFixed(2)}</p>
              <button onclick="scheduleJob('${job.id}')" class="mt-2 text-xs text-blue-600 hover:underline">Schedule →</button>
            </div>
          `).join('');
        } catch (err) {
          console.error('Failed to load jobs', err);
        }
      }
      
      window.scheduleJob = async (jobId) => {
        const date = prompt('Enter date (YYYY-MM-DD):');
        const start = prompt('Start time (HH:MM):', '09:00');
        const end = prompt('End time (HH:MM):', '17:00');
        
        if (!date || !start || !end) return;
        
        try {
          await fetch(`${API_URL}/v1/calendar/sync-job`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              jobId,
              startTime: `${date}T${start}:00`,
              endTime: `${date}T${end}:00`,
            }),
          });
          window.showToast('Job scheduled!', 'success');
          loadCalendar();
        } catch (err) {
          window.showToast('Failed to schedule job', 'error');
        }
      };
      
      document.getElementById('prev-week')?.addEventListener('click', () => {
        currentWeekStart.setDate(currentWeekStart.getDate() - 7);
        loadCalendar();
      });
      
      document.getElementById('next-week')?.addEventListener('click', () => {
        currentWeekStart.setDate(currentWeekStart.getDate() + 7);
        loadCalendar();
      });
      
      document.getElementById('sync-btn')?.addEventListener('click', () => {
        window.location.href = `${API_URL}/v1/calendar/connect`;
      });
      
      loadCalendar();
      loadJobs();
    </script>

    // Month view support
    let currentView = 'week';
    let currentDate = new Date();

    function getMonthStart(date) {
      return new Date(date.getFullYear(), date.getMonth(), 1);
    }

    function renderMonthView(events) {
      const grid = document.getElementById('calendar-grid');
      const start = getMonthStart(currentDate);
      const end = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 0);
      const startDay = start.getDay();
      const daysInMonth = end.getDate();
      
      const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      
      let html = `<div class="grid grid-cols-7 gap-1 mb-2">`;
      html += days.map(d => `<div class="text-center text-xs font-medium text-gray-600 py-1">${d}</div>`).join('');
      html += `</div><div class="grid grid-cols-7 gap-1">`;
      
      // Empty cells before month start
      for (let i = 0; i < startDay; i++) {
        html += `<div class="min-h-[80px] border rounded bg-gray-50"></div>`;
      }
      
      // Days of month
      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(currentDate.getFullYear(), currentDate.getMonth(), day);
        const dayEvents = events.google.filter(e => {
          const eventDate = new Date(e.start.dateTime || e.start.date);
          return eventDate.toDateString() === date.toDateString();
        });
        
        html += `<div class="min-h-[80px] border rounded p-1 bg-white" data-date="${date.toISOString().split('T')[0]}">
          <div class="text-xs font-medium">${day}</div>
          <div class="space-y-0.5 mt-1">
            ${dayEvents.slice(0, 2).map(e => `<div class="text-[10px] p-0.5 bg-blue-100 text-blue-800 rounded truncate">${e.summary}</div>`).join('')}
            ${dayEvents.length > 2 ? `<div class="text-[10px] text-gray-500">+${dayEvents.length - 2}</div>` : ''}
          </div>
        </div>`;
      }
      
      html += `</div>`;
      grid.innerHTML = html;
      
      document.getElementById('view-title').textContent = `${currentDate.toLocaleString('default', { month: 'long', year: 'numeric' })}`;
    }

    // View toggle
    document.getElementById('week-view-btn')?.addEventListener('click', () => {
      currentView = 'week';
      document.getElementById('week-view-btn').classList.add('bg-blue-600', 'text-white');
      document.getElementById('week-view-btn').classList.remove('bg-gray-100');
      document.getElementById('month-view-btn').classList.remove('bg-blue-600', 'text-white');
      document.getElementById('month-view-btn').classList.add('bg-gray-100');
      loadCalendar();
    });

    document.getElementById('month-view-btn')?.addEventListener('click', () => {
      currentView = 'month';
      document.getElementById('month-view-btn').classList.add('bg-blue-600', 'text-white');
      document.getElementById('month-view-btn').classList.remove('bg-gray-100');
      document.getElementById('week-view-btn').classList.remove('bg-blue-600', 'text-white');
      document.getElementById('week-view-btn').classList.add('bg-gray-100');
      loadCalendar();
    });

      // Make job cards draggable
      setTimeout(() => {
        document.querySelectorAll('#unscheduled-jobs [draggable="true"]').forEach(el => {
          el.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', el.dataset.jobId);
            e.dataTransfer.effectAllowed = 'move';
          });
        });

        // Add drop handlers to calendar cells
        document.querySelectorAll('#calendar-grid [data-date]').forEach(cell => {
          cell.addEventListener('dragover', (e) => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            cell.classList.add('bg-blue-100', 'border-blue-400');
          });
          
          cell.addEventListener('dragleave', () => {
            cell.classList.remove('bg-blue-100', 'border-blue-400');
          });
          
          cell.addEventListener('drop', async (e) => {
            e.preventDefault();
            cell.classList.remove('bg-blue-100', 'border-blue-400');
            
            const jobId = e.dataTransfer.getData('text/plain');
            const date = cell.dataset.date;
            
            if (!jobId || !date) return;
            
            const startTime = `${date}T09:00:00`;
            const endTime = `${date}T17:00:00`;
            
            try {
              const res = await fetch(`${API_URL}/v1/calendar/sync-job`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ jobId, startTime, endTime }),
              });
              
              if (res.ok) {
                window.showToast('Job scheduled!', 'success');
                loadCalendar();
                loadJobs();
              } else {
                window.showToast('Failed to schedule job', 'error');
              }
            } catch (err) {
              window.showToast('Failed to schedule job', 'error');
            }
          });
        });
      }, 100);
