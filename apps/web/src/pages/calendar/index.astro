---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Calendar - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <nav class="bg-white shadow-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-8">
            <h1 class="text-xl font-semibold">PaintFlow</h1>
            <nav class="flex space-x-4">
              <a href="/dashboard" class="text-gray-600 hover:text-gray-900">Dashboard</a>
              <a href="/jobs" class="text-gray-600 hover:text-gray-900">Jobs</a>
              <a href="/calendar" class="text-blue-600 font-medium">Calendar</a>
            </nav>
          </div>
          <button id="sync-btn" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            Connect Google Calendar
          </button>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-6 flex justify-between items-center">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Schedule</h2>
          <p class="text-gray-600">Manage job scheduling</p>
        </div>
        <div class="flex gap-2">
          <button id="prev-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">Prev</button>
          <button id="today-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">Today</button>
          <button id="next-btn" class="px-3 py-1 text-sm border rounded hover:bg-gray-50">Next</button>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <section class="lg:col-span-8 bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h3 class="font-semibold" id="week-title">Week View</h3>
          </div>
          <div id="calendar-grid" class="p-4">
            <div class="text-center text-gray-500 py-12">Loading calendar...</div>
          </div>
        </section>

        <aside class="lg:col-span-4 bg-white rounded-lg shadow-sm border">
          <div class="p-4 border-b">
            <h3 class="font-semibold">Unscheduled Jobs</h3>
          </div>
          <div id="unscheduled-jobs" class="p-4 space-y-3">
            <div class="text-center text-gray-500 py-8">Loading jobs...</div>
          </div>
        </aside>
      </div>
    </main>

    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
      let currentWeekStart = getWeekStart(new Date());

      function getWeekStart(date) {
        const d = new Date(date);
        const day = d.getDay();
        const diff = d.getDate() - day + (day === 0 ? -6 : 1);
        d.setHours(0, 0, 0, 0);
        return new Date(d.setDate(diff));
      }

      function formatDate(date) {
        return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
      }

      async function loadCalendar() {
        const timeMin = currentWeekStart.toISOString();
        const timeMax = new Date(currentWeekStart.getTime() + 7 * 86400000).toISOString();

        const [eventsRes, jobsRes] = await Promise.all([
          fetch(`${API_URL}/v1/calendar/events?timeMin=${timeMin}&timeMax=${timeMax}`, { credentials: 'include' }),
          fetch(`${API_URL}/v1/jobs`, { credentials: 'include' }),
        ]);

        if (eventsRes.status === 401 || jobsRes.status === 401) {
          window.location.href = '/login';
          return;
        }

        const { data: events } = await eventsRes.json();
        const { data: jobs } = await jobsRes.json();
        renderWeek(events?.google || [], jobs || []);
      }

      function renderWeek(googleEvents, jobs) {
        const grid = document.getElementById('calendar-grid');
        const weekEnd = new Date(currentWeekStart.getTime() + 6 * 86400000);
        document.getElementById('week-title').textContent = `${formatDate(currentWeekStart)} - ${formatDate(weekEnd)}`;

        const days = Array.from({ length: 7 }, (_, index) => {
          const date = new Date(currentWeekStart.getTime() + index * 86400000);
          const dayEvents = googleEvents.filter((event) => {
            const start = event.start?.dateTime || event.start?.date;
            return start && new Date(start).toDateString() === date.toDateString();
          });

          return `
            <div class="border rounded p-3 min-h-[140px]">
              <div class="text-sm font-medium mb-2">${date.toLocaleDateString(undefined, { weekday: 'short', day: 'numeric' })}</div>
              <div class="space-y-2">
                ${dayEvents.map((event) => `<div class="text-xs p-2 rounded bg-blue-50 text-blue-800">${event.summary || 'Scheduled event'}</div>`).join('')}
              </div>
            </div>
          `;
        }).join('');

        grid.innerHTML = `<div class="grid grid-cols-1 md:grid-cols-7 gap-2">${days}</div>`;

        const unscheduled = jobs.filter((job) => job.status !== 'completed');
        document.getElementById('unscheduled-jobs').innerHTML = unscheduled.length
          ? unscheduled.map((job) => `
              <div class="border rounded p-3">
                <div class="font-medium">${job.name}</div>
                <div class="text-sm text-gray-600">${job.status}</div>
              </div>
            `).join('')
          : '<div class="text-center text-gray-500 py-8">No unscheduled jobs</div>';
      }

      document.getElementById('sync-btn')?.addEventListener('click', () => {
        window.location.href = `${API_URL}/v1/calendar/connect`;
      });

      document.getElementById('prev-btn')?.addEventListener('click', () => {
        currentWeekStart = new Date(currentWeekStart.getTime() - 7 * 86400000);
        loadCalendar();
      });

      document.getElementById('today-btn')?.addEventListener('click', () => {
        currentWeekStart = getWeekStart(new Date());
        loadCalendar();
      });

      document.getElementById('next-btn')?.addEventListener('click', () => {
        currentWeekStart = new Date(currentWeekStart.getTime() + 7 * 86400000);
        loadCalendar();
      });

      loadCalendar().catch((error) => {
        console.error(error);
        document.getElementById('calendar-grid').innerHTML = '<div class="text-center text-red-600 py-12">Failed to load calendar</div>';
      });
    </script>
  </body>
</html>
