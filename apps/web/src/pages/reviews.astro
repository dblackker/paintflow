---
import Base from '../layouts/Base.astro';
---

<Base title="Review Analytics - PaintFlow">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="pf-kicker">Reputation marketing</p>
        <h1 class="pf-page-title mt-1">Review analytics</h1>
        <p class="pf-page-copy mt-2 max-w-2xl">
          Track review requests, customer feedback, and the closeout flow that can later feed testimonials, before/after posts, and referral campaigns.
        </p>
      </div>
      <a href="/reports" class="btn-secondary btn-sm justify-center">Back to reports</a>
    </div>

    <section class="mb-6 rounded-lg border bg-blue-50 p-4 text-sm text-blue-950">
      <p class="pf-section-title text-blue-950">Why this lives under Reports</p>
      <p class="mt-1 text-blue-900">
        Reviews are not a daily dispatch workflow. They are a reputation and marketing metric tied to completed jobs, so this page should remain a focused reporting drill-in until the marketing suite grows.
      </p>
    </section>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-4 sm:gap-4 mb-6" id="review-stats">
      <div class="bg-white rounded-lg shadow-sm border p-4">
        <p class="pf-metric-label">Total requests</p>
        <p class="pf-metric-value mt-1" id="total-requests">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border p-4">
        <p class="pf-metric-label">Response rate</p>
        <p class="pf-metric-value mt-1" id="response-rate">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border p-4">
        <p class="pf-metric-label">Avg rating</p>
        <p class="pf-metric-value mt-1" id="avg-rating">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border p-4">
        <p class="pf-metric-label">5-star reviews</p>
        <p class="pf-metric-value mt-1" id="five-star">-</p>
      </div>
    </div>

    <section class="bg-white rounded-lg shadow-sm border overflow-hidden">
      <div class="p-4 border-b flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="pf-section-title">Recent review requests</h2>
          <p class="pf-copy">Customer feedback and Google/Yelp handoff status.</p>
        </div>
        <a href="/settings#business-settings" class="btn-text btn-sm justify-center">Review links</a>
      </div>
      <div id="requests-list" class="divide-y">
        <div class="p-8 text-center text-gray-500">Loading review requests...</div>
      </div>
    </section>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    function escapeHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }
    const label = (value) => window.PaintFlowFormat?.label(value) ?? value;
    const statusBadge = (value) => window.PaintFlowUI?.statusBadge({ value }) || `<span class="px-2 py-1 text-xs rounded bg-gray-100">${escapeHtml(label(value))}</span>`;
    const dateLabel = (value) => value ? new Date(value).toLocaleDateString() : 'Not sent';

    function formatAddress(record) {
      return window.PaintFlowFormat?.address(record, 'lead', { includePostalCode: false }) || [record.leadStreetAddress, [record.leadCity, record.leadState].filter(Boolean).join(', ')].filter(Boolean).join(' ');
    }

    function customerProfileLink(req) {
      const name = req.leadName || 'Customer';
      if (!req.leadId) return `<p class="font-medium text-sm">${escapeHtml(name)}</p>`;
      const address = formatAddress(req);
      return `
        <div class="min-w-0 rounded-lg pr-2">
          <a href="/leads/${req.leadId}" class="block truncate text-sm font-medium text-gray-950 hover:text-blue-700">${escapeHtml(name)}</a>
          ${window.PaintFlowFormat?.addressLink(address) || `<span class="block truncate text-sm text-gray-700">${escapeHtml(address || 'No jobsite address')}</span>`}
        </div>
      `;
    }

    async function loadAnalytics() {
      try {
        const res = await fetch(`${API_URL}/v1/reviews/stats`, { credentials: 'include' });
        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }
        const payload = await res.json();
        if (!res.ok) throw new Error(payload.error || 'Failed to load reviews');
        const { data } = payload;

        document.getElementById('total-requests').textContent = data.total;
        document.getElementById('response-rate').textContent = `${data.responseRate}%`;
        document.getElementById('avg-rating').textContent = Number(data.avgRating || 0).toFixed(1);
        document.getElementById('five-star').textContent = data.fiveStar;

        const container = document.getElementById('requests-list');
        if (!data.requests.length) {
          container.innerHTML = `
            <div class="p-8 text-center text-gray-500">
              <p class="font-medium text-gray-700">No review requests yet</p>
              <p class="mt-1 text-sm">Completed jobs can send review requests from the Jobs workflow.</p>
            </div>
          `;
          return;
        }

        container.innerHTML = data.requests.map(req => `
          <div class="p-4 grid grid-cols-1 gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-center">
            <div class="min-w-0">
              ${customerProfileLink(req)}
              <p class="mt-1 text-sm text-gray-600">${escapeHtml(req.jobName || 'Job')}</p>
              <p class="pf-meta">Requested ${dateLabel(req.sentAt || req.createdAt)}${req.respondedAt ? ` &middot; Responded ${dateLabel(req.respondedAt)}` : ''}</p>
            </div>
            <div class="flex items-center justify-between gap-3 sm:justify-end">
              ${req.rating ? `<div class="text-sm font-semibold text-yellow-700" aria-label="${escapeHtml(req.rating)} star rating">${Array.from({ length: Number(req.rating) }, () => '&#9733;').join('')}</div>` : '<span class="text-sm text-gray-500">No rating</span>'}
              ${statusBadge(req.status)}
            </div>
          </div>
        `).join('');
      } catch (err) {
        console.error(err);
        document.getElementById('requests-list').innerHTML = `
          <div class="p-8 text-center text-red-700">
            <p class="font-medium">Review analytics could not be loaded</p>
            <p class="mt-1 text-sm">${escapeHtml(err.message || 'Try again later.')}</p>
          </div>
        `;
      }
    }

    loadAnalytics();
  </script>
</Base>
