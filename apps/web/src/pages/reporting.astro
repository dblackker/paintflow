---
import Base from '../layouts/Base.astro';
---

<Base title="Reporting - PaintFlow">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Reporting Dashboard</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <p class="text-sm text-gray-600 mb-1">Total Revenue</p>
          <p class="text-3xl font-bold">$124,580</p>
          <p class="text-sm text-green-600 mt-2">↑ 12% vs last month</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <p class="text-sm text-gray-600 mb-1">Win Rate</p>
          <p class="text-3xl font-bold">68%</p>
          <p class="text-sm text-gray-600 mt-2">47 won / 69 sent</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <p class="text-sm text-gray-600 mb-1">Avg Job Margin</p>
          <p class="text-3xl font-bold">32.4%</p>
          <p class="text-sm text-green-600 mt-2">↑ 3.2% vs target</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Revenue by Month</h3>
          <div class="h-64 flex items-end justify-between gap-2">
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 60%"></div>
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 75%"></div>
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 45%"></div>
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 80%"></div>
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 90%"></div>
            <div class="flex-1 bg-blue-600 rounded-t" style="height: 100%"></div>
          </div>
          <div class="flex justify-between mt-2 text-xs text-gray-600">
            <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="text-lg font-semibold mb-4">Top Services</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm">Interior Painting</span>
              <span class="text-sm font-medium">$42,300</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 85%"></div>
            </div>
            
            <div class="flex justify-between items-center mt-4">
              <span class="text-sm">Exterior Painting</span>
              <span class="text-sm font-medium">$38,900</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 78%"></div>
            </div>
            
            <div class="flex justify-between items-center mt-4">
              <span class="text-sm">Cabinet Painting</span>
              <span class="text-sm font-medium">$28,100</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 56%"></div>
            </div>
          </div>
        </div>
      </div>
    </main>
</Base>
