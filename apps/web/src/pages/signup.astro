---
import '../styles/design-system.css';

const requestedPlan = Astro.url.searchParams.get('plan') || 'pro';

const plans = {
  starter: {
    name: 'Starter',
    price: '$49/mo',
    fit: 'Solo operators and lean teams',
    limit: '3 team members',
  },
  pro: {
    name: 'Pro',
    price: '$149/mo',
    fit: 'Small to mid-sized painting companies',
    limit: 'Unlimited team',
  },
  enterprise: {
    name: 'Enterprise',
    price: '$399/mo',
    fit: 'Multi-crew operations',
    limit: 'Advanced controls',
  },
};

const plan = plans[requestedPlan] ? requestedPlan : 'pro';
const selectedPlan = plans[plan];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Start a PaintFlow trial for your painting company. Configure leads, production-rate estimates, scheduling, job costing, and payments."
    />
    <title>Start {selectedPlan.name} Trial - PaintFlow</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-950">
    <header class="border-b bg-white">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-2 pf-row-title" aria-label="PaintFlow home">
          <span class="flex h-8 w-8 items-center justify-center rounded bg-blue-600 pf-row-title text-white">P</span>
          <span>PaintFlow</span>
        </a>
        <nav class="flex items-center gap-3 text-sm">
          <a href="/login" class="hidden pf-copy hover:text-slate-950 sm:inline">Sign in</a>
          <a href="/#pricing" class="btn-secondary btn-sm">Plans</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto grid max-w-6xl gap-6 px-4 py-6 sm:px-6 sm:py-10 lg:grid-cols-[minmax(0,1fr)_420px] lg:px-8">
      <section class="rounded-lg border bg-white p-5 shadow-sm sm:p-8">
        <p class="pf-kicker">Owner setup</p>
        <h1 class="pf-page-title mt-3 max-w-2xl">
          Start with the settings painting contractors actually tune.
        </h1>
        <p class="pf-page-copy mt-4 max-w-2xl">
          Build your workspace around service areas, production rates, labor burden, material markup,
          deposits, approvals, and job costing from day one.
        </p>

        <div class="mt-7 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border bg-slate-50 p-4">
            <p class="pf-row-title">Lead intake</p>
            <p class="pf-copy mt-1">Capture web, call, referral, and repeat-customer sources.</p>
          </div>
          <div class="rounded-lg border bg-slate-50 p-4">
            <p class="pf-row-title">Estimating</p>
            <p class="pf-copy mt-1">Use production rates and proposal options.</p>
          </div>
          <div class="rounded-lg border bg-slate-50 p-4">
            <p class="pf-row-title">Job costing</p>
            <p class="pf-copy mt-1">Track labor, materials, expenses, change orders, and margins.</p>
          </div>
        </div>

        <div class="mt-7 rounded-lg border border-blue-200 bg-blue-50 p-4">
          <p class="pf-row-title text-blue-950">What happens next</p>
          <ol class="mt-3 space-y-2 text-sm text-blue-950">
            <li class="flex gap-2"><span class="pf-row-title text-blue-950">1.</span><span>We send a secure sign-in link.</span></li>
            <li class="flex gap-2"><span class="pf-row-title text-blue-950">2.</span><span>You set company defaults and service areas.</span></li>
            <li class="flex gap-2"><span class="pf-row-title text-blue-950">3.</span><span>Your team can start adding leads and estimates.</span></li>
          </ol>
        </div>
      </section>

      <aside class="lg:sticky lg:top-6">
        <section class="rounded-lg border bg-white p-5 shadow-sm sm:p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="pf-kicker">14-day trial</p>
              <h2 class="pf-section-title mt-2">Create your workspace</h2>
            </div>
            <div class="rounded-lg bg-slate-100 px-3 py-2 text-right">
              <p class="pf-row-title">{selectedPlan.name}</p>
              <p class="pf-meta">{selectedPlan.price}</p>
            </div>
          </div>
          <p class="pf-copy mt-3">{selectedPlan.fit}. {selectedPlan.limit}.</p>

          <form id="signup-form" class="mt-6 space-y-4">
            <input type="hidden" name="plan" value={plan} />

            <div>
              <label for="companyName" class="form-label">Company name</label>
              <input
                id="companyName"
                name="companyName"
                type="text"
                autocomplete="organization"
                enterkeyhint="next"
                required
                class="w-full rounded-lg border px-3 py-3 text-base focus:border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Acme Painting Co."
              />
            </div>

            <div>
              <label for="name" class="form-label">Your name</label>
              <input
                id="name"
                name="name"
                type="text"
                autocomplete="name"
                enterkeyhint="next"
                class="w-full rounded-lg border px-3 py-3 text-base focus:border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Daniel"
              />
            </div>

            <div>
              <label for="email" class="form-label">Work email</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                enterkeyhint="send"
                required
                class="w-full rounded-lg border px-3 py-3 text-base focus:border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="owner@example.com"
              />
            </div>

            <button
              id="submit"
              type="submit"
              class="btn-primary w-full justify-center"
            >
              Send secure sign-in link
            </button>
          </form>

          <div id="message" class="pf-copy hidden mt-4 rounded-lg border p-3"></div>

          <div class="pf-meta mt-5 flex items-center justify-between gap-3">
            <span>No credit card required</span>
            <a href="/#pricing" class="pf-row-title hover:text-slate-950">Change plan</a>
          </div>
        </section>
      </aside>
    </main>

    <script>
      const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
      const form = document.getElementById('signup-form');
      const message = document.getElementById('message');
      const submit = document.getElementById('submit');
      const storageKey = 'paintflow.signup';

      function restoreDraft() {
        try {
          const draft = JSON.parse(localStorage.getItem(storageKey) || '{}');
          ['companyName', 'name', 'email'].forEach((field) => {
            if (draft[field] && form.elements[field]) {
              form.elements[field].value = draft[field];
            }
          });
        } catch {
          localStorage.removeItem(storageKey);
        }
      }

      function saveDraft() {
        const formData = new FormData(form);
        localStorage.setItem(storageKey, JSON.stringify({
          companyName: formData.get('companyName'),
          name: formData.get('name'),
          email: formData.get('email'),
        }));
      }

      function showMessage(text, type = 'success') {
        message.textContent = text;
        message.className = `mt-4 rounded-lg border p-3 text-sm ${type === 'success' ? 'bg-green-50 border-green-200 text-green-800' : 'bg-red-50 border-red-200 text-red-800'}`;
      }

      function addDevLink(token) {
        if (!token) return;
        const devLink = document.createElement('a');
        devLink.href = `${API_URL}/v1/auth/verify?token=${token}`;
        devLink.textContent = 'Dev: open workspace';
        devLink.className = 'mt-2 block font-medium underline';
        message.appendChild(devLink);
      }

      restoreDraft();
      form.addEventListener('input', saveDraft);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        submit.disabled = true;
        submit.textContent = 'Sending...';

        try {
          const formData = new FormData(form);
          const res = await fetch(`${API_URL}/v1/auth/magic-link`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              companyName: formData.get('companyName'),
              name: formData.get('name'),
              email: formData.get('email'),
              plan: formData.get('plan'),
            }),
          });
          const payload = await res.json();
          if (!res.ok) throw new Error(payload.error || 'Failed to send magic link');

          localStorage.removeItem(storageKey);
          showMessage('Check your email for the sign-in link. It expires in 15 minutes.');
          addDevLink(payload.devToken);
        } catch (err) {
          showMessage(err.message || 'Failed to start trial', 'error');
        } finally {
          submit.disabled = false;
          submit.textContent = 'Send secure sign-in link';
        }
      });
    </script>
  </body>
</html>
