---
import '../../styles/design-system.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Portal - PaintFlow</title>
  <script src="https://js.stripe.com/v3/"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <h1 class="text-xl font-semibold">Customer Portal</h1>
        <div class="text-sm text-gray-600" id="customer-info"></div>
      </div>
    </div>
  </nav>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div id="portal-content">
      <div class="text-center py-12 text-gray-500">Loading...</div>
    </div>
  </main>
  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;
    const token = window.location.pathname.split('/').pop();
    let stripe = null;
    const money = (value) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Number(value || 0));
    const label = (value) => String(value || '').replace(/[_-]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
    const escapeHtml = (value = '') => String(value).replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    
    async function loadPortal() {
      const res = await fetch(`${API_URL}/v1/portal/${token}`, { credentials: 'include' });
      if (!res.ok) {
        document.getElementById('portal-content').innerHTML = '<div class="text-center py-12 text-red-600">Invalid or expired link</div>';
        return;
      }
      const { data } = await res.json();
      renderPortal(data);
    }
    
    function renderPortal(data) {
      const { customer, estimate, job, changeOrders = [] } = data;
      document.getElementById('customer-info').textContent = customer.name;
      
      if (estimate && !estimate.signedAt) {
        renderEstimate(estimate);
      } else if (job) {
        renderJob(job, changeOrders);
      } else {
        document.getElementById('portal-content').innerHTML = '<div class="text-center py-12 text-gray-500">No active items</div>';
      }
    }
    
    function renderEstimate(estimate) {
      document.getElementById('portal-content').innerHTML = `
        <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
          <h2 class="text-2xl font-bold mb-2">${estimate.title}</h2>
          <p class="text-3xl font-bold">${money(estimate.total)}</p>
          <div class="mt-6 flex gap-3">
            <button onclick="approve()" class="btn-primary flex-1 justify-center">Approve Estimate</button>
          </div>
        </div>
      `;
    }
    
    function renderJob(job, changeOrders = []) {
      const balance = parseFloat(job.balance || 0);
      const activeChangeOrders = changeOrders.filter((order) => ['pending', 'approved'].includes(order.status) || order.paymentStatus === 'pending');
      document.getElementById('portal-content').innerHTML = `
        <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
          <h2 class="text-2xl font-bold mb-2">${escapeHtml(job.name || job.title || 'Painting project')}</h2>
          <span class="inline-flex px-3 py-1 rounded-full text-sm bg-blue-100 text-blue-800">${label(job.status)}</span>
        </div>
        ${activeChangeOrders.length ? `
        <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
          <h3 class="font-semibold mb-4">Change Orders</h3>
          <div class="space-y-4">
            ${activeChangeOrders.map((order) => renderChangeOrder(order)).join('')}
          </div>
        </div>
        ` : ''}
        ${balance > 0 ? `
        <div class="bg-white rounded-lg shadow-sm border p-6">
          <h3 class="font-semibold mb-4">Outstanding Balance</h3>
          <p class="text-3xl font-bold mb-4">${money(balance)}</p>
          <div id="payment-element"></div>
          <button id="pay-btn" onclick="pay(${balance})" class="btn-primary w-full justify-center mt-4">Pay Now</button>
        </div>
        ` : '<div class="bg-white rounded-lg shadow-sm border p-6 text-center text-gray-600">No balance due</div>'}
      `;
    }

    function renderChangeOrder(order) {
      const paymentRequired = Boolean(order.paymentRequired);
      const paymentDue = Number(order.paymentDueAmount || 0);
      const isApproved = order.status === 'approved' || order.status === 'completed';
      const isPaid = order.paymentStatus === 'paid';
      const needsPayment = paymentRequired && !isPaid;
      return `
        <article class="rounded-lg border p-4">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
            <div>
              <p class="font-medium">${escapeHtml(order.description)}</p>
              <p class="mt-1 text-sm text-gray-600">Change order amount: ${money(order.amount)}</p>
              ${paymentRequired ? `<p class="text-sm text-gray-600">Payment due now: ${money(paymentDue || order.amount)}</p>` : '<p class="text-sm text-gray-600">No online payment is required for this change order.</p>'}
            </div>
            <div class="flex flex-wrap gap-2 text-xs">
              <span class="rounded-full bg-blue-50 px-2 py-1 text-blue-800">${label(order.status)}</span>
              ${paymentRequired ? `<span class="rounded-full bg-gray-100 px-2 py-1 text-gray-700">${label(order.paymentStatus)}</span>` : ''}
            </div>
          </div>
          <div class="mt-4 flex flex-col sm:flex-row gap-3">
            ${!isApproved ? `<button onclick="approveChangeOrder('${order.id}')" class="btn-primary flex-1 justify-center">Approve Change Order</button>` : ''}
            ${isApproved && needsPayment ? `<button onclick="payChangeOrder('${order.id}')" class="btn-primary flex-1 justify-center">Pay ${money(paymentDue || order.amount)}</button>` : ''}
            ${isPaid ? '<p class="text-sm font-medium text-green-700">Payment received. Thank you.</p>' : ''}
          </div>
        </article>
      `;
    }
    
    window.approve = async () => {
      await fetch(`${API_URL}/v1/portal/${token}/approve`, { method: 'POST', credentials: 'include' });
      alert('Approved! We will contact you to schedule.');
      location.reload();
    };
    
    window.pay = async (amount) => {
      const res = await fetch(`${API_URL}/v1/portal/${token}/pay`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ amount })
      });
      const { data } = await res.json();
      
      if (!stripe) stripe = Stripe('pk_test_...');
      const { error } = await stripe.confirmCardPayment(data.clientSecret);
      if (!error) {
        alert('Payment successful!');
        location.reload();
      }
    };

    window.approveChangeOrder = async (id) => {
      const approvedBy = document.getElementById('customer-info').textContent || 'customer';
      const res = await fetch(`${API_URL}/v1/portal/${token}/change-orders/${id}/approve`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ approvedBy }),
      });
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        alert(payload.error || 'Unable to approve this change order.');
        return;
      }
      location.reload();
    };

    window.payChangeOrder = async (id) => {
      const res = await fetch(`${API_URL}/v1/portal/${token}/change-orders/${id}/checkout`, {
        method: 'POST',
        credentials: 'include',
      });
      const payload = await res.json().catch(() => ({}));
      const checkoutUrl = payload.data?.checkoutUrl;
      if (!res.ok || !checkoutUrl) {
        alert(payload.error || 'Unable to start payment.');
        return;
      }
      window.location.href = checkoutUrl;
    };
    
    loadPortal();
  </script>
</body>
</html>
