---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoices - PaintFlow</title>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <h1 class="text-xl font-semibold">Material Invoices</h1>
        <button id="upload-btn" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">Upload Invoice</button>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <p class="text-sm text-blue-800">Upload supplier invoices (CSV) to track material costs and update pricing automatically.</p>
    </div>

    <div id="purchases-list" class="space-y-3">
      <div class="text-center py-12 text-gray-500">Loading...</div>
    </div>
  </main>

  <div id="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg max-w-lg w-full p-6">
      <h2 class="text-lg font-semibold mb-4">Upload Invoice CSV</h2>
      <form id="invoice-form" class="space-y-4">
        <select name="supplier" class="w-full px-3 py-2 border rounded-lg" required>
          <option value="">Select supplier...</option>
          <option value="Sherwin-Williams">Sherwin-Williams</option>
          <option value="Benjamin Moore">Benjamin Moore</option>
          <option value="Home Depot">Home Depot</option>
          <option value="Lowes">Lowes</option>
          <option value="Other">Other</option>
        </select>
        <input name="invoiceNumber" placeholder="Invoice #" class="w-full px-3 py-2 border rounded-lg">
        <textarea name="csvData" placeholder="Paste CSV data here..." rows="8" class="w-full px-3 py-2 border rounded-lg font-mono text-sm" required></textarea>
        <p class="text-xs text-gray-600">CSV columns: Description, SKU, Quantity, Unit Cost, Total</p>
        <div class="flex gap-3">
          <button type="button" onclick="closeModal()" class="flex-1 py-2 border rounded-lg">Cancel</button>
          <button type="submit" class="flex-1 py-2 bg-blue-600 text-white rounded-lg">Upload</button>
        </div>
      </form>
      <details class="mt-4">
        <summary class="text-sm text-gray-600 cursor-pointer">Example CSV format</summary>
        <pre class="mt-2 text-xs bg-gray-100 p-2 rounded overflow-x-auto">Description,SKU,Quantity,Unit Cost,Total
SuperPaint Interior,SW-123,5,65.00,325.00
Primer,SW-456,2,25.00,50.00</pre>
      </details>
    </div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || `${window.location.protocol}//${window.location.hostname}:8787`;

    async function loadPurchases() {
      const res = await fetch(`${API_URL}/v1/invoices/purchases`, { credentials: 'include' });
      const { data } = await res.json();
      renderPurchases(data);
    }

    function renderPurchases(purchases) {
      const list = document.getElementById('purchases-list');
      if (purchases.length === 0) {
        list.innerHTML = '<div class="text-center py-12 text-gray-500">No invoices uploaded yet</div>';
        return;
      }
      list.innerHTML = purchases.map(p => `
        <div class="bg-white rounded-lg shadow-sm border p-4">
          <div class="flex justify-between items-start">
            <div>
              <p class="font-medium">${p.supplier}</p>
              <p class="text-sm text-gray-600">${p.invoiceNumber || 'No invoice #'} • ${new Date(p.createdAt).toLocaleDateString()}</p>
            </div>
            <div class="text-right">
              <p class="font-semibold">$${parseFloat(p.totalAmount).toFixed(2)}</p>
              <p class="text-xs text-gray-500">${p.parsedData?.length || 0} items</p>
            </div>
          </div>
        </div>
      `).join('');
    }

    document.getElementById('upload-btn').addEventListener('click', () => {
      document.getElementById('modal').classList.remove('hidden');
    });

    window.closeModal = () => document.getElementById('modal').classList.add('hidden');

    document.getElementById('invoice-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = new FormData(e.target);
      const res = await fetch(`${API_URL}/v1/invoices/upload`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(Object.fromEntries(form)),
      });
      const result = await res.json();
      if (res.ok) {
        alert(`Processed ${result.data.itemsProcessed} items. Total: $${result.data.totalAmount.toFixed(2)}`);
        closeModal();
        loadPurchases();
      } else {
        alert(result.error || 'Upload failed');
      }
    });

    loadPurchases();
  </script>
</body>
</html>
