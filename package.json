{
  "name": "paintflow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "deploy:api": "cd apps/api && wrangler deploy",
    "deploy:web": "cd apps/web && astro build && wrangler pages deploy dist",
    "db:push": "cd packages/db && drizzle-kit push",
    "db:studio": "cd packages/db && drizzle-kit studio"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
