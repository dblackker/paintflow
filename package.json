{
  "name": "paintflow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "deploy:api": "cd apps/api && wrangler deploy",
    "deploy:web": "pnpm --filter @paintflow/web build && wrangler pages deploy apps/web/dist",
    "db:push": "cd packages/db && drizzle-kit push",
    "db:migrate": "cd packages/db && drizzle-kit migrate",
    "db:studio": "cd packages/db && drizzle-kit studio",
    "db:seed:golden": "corepack pnpm --filter @paintflow/db seed:golden",
    "lint:buttons": "node scripts/lint-buttons.mjs --baseline=29 --print-limit=40",
    "lint:typography": "node scripts/lint-typography.mjs --baseline=495 --print-limit=40",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260514.0",
    "@playwright/test": "^1.44.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.2"
  },
  "packageManager": "pnpm@9.0.0"
}
