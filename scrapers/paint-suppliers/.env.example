# Database
DATABASE_PATH=./data/suppliers.db

# Scraping
RATE_LIMIT_MS=1000
MAX_RETRIES=3
HEADLESS=true
USER_AGENT_ROTATION=true

# Playwright
PLAYWRIGHT_BROWSERS_PATH=./.playwright

# Proxies (optional)
# PROXY_URL=http://proxy.example.com:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Notifications (optional)
# SLACK_WEBHOOK_URL=
# EMAIL_ON_ERROR=admin@example.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/scraper.log

# Cron
CRON_SCHEDULE=0 2 * * 0
