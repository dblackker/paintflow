NEON_API_KEY=
NEON_PROJECT_ID=

# Optional: use exactly one of these. Leave both blank for Neon Local default behavior.
PARENT_BRANCH_ID=
BRANCH_ID=

# Set true if you want ephemeral Neon Local branches deleted when the container stops.
DELETE_BRANCH=false

# Optional local integration secrets.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional web autocomplete. This is a browser-exposed key; restrict it to your domains
# and to Maps JavaScript API + Places API in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=

# Optional local email delivery. Use a verified sender domain.
EMAIL_PROVIDER=mailchannels
EMAIL_FROM=estimates@example.com
EMAIL_FROM_NAME=Crewmodo
MAILCHANNELS_API_KEY=

# Optional supplier invoice OCR. Required for PDF/image invoice uploads.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini
INVOICE_AUTOMATION_ENABLED=true
INBOUND_INVOICE_EMAIL_SECRET=
