NEON_API_KEY=
NEON_PROJECT_ID=

# Optional: use exactly one of these. Leave both blank for Neon Local default behavior.
PARENT_BRANCH_ID=
BRANCH_ID=

# Set true if you want ephemeral Neon Local branches deleted when the container stops.
DELETE_BRANCH=false

# Optional local integration secrets.
